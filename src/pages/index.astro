---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTAForm from '../components/CTAForm.astro';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'הוצאהלפועל.info',
  url: 'https://hotzaa-lapoal.info',
  description: 'מידע על הוצאה לפועל וחדלות פירעון בישראל — כלים חינמיים, מדריכים בעברית פשוטה',
  inLanguage: 'he',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://hotzaa-lapoal.info/?s={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'הוצאהלפועל.info',
  url: 'https://hotzaa-lapoal.info',
  logo: 'https://hotzaa-lapoal.info/favicon.svg',
  description: 'מידע חינמי על הוצאה לפועל וחדלות פירעון לחייבים בישראל',
  inLanguage: 'he',
  areaServed: 'IL',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    availableLanguage: 'Hebrew',
    url: 'https://hotzaa-lapoal.info/contact/',
  },
};

const homeFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'כמה זמן יש לי להגיב אחרי קבלת מכתב הוצאה לפועל?',
      acceptedAnswer: { '@type': 'Answer', text: '20 יום מיום קבלת האזהרה. לאחר 20 יום הנושה יכול לבקש עיקולים והגבלות. כדאי לפעול מוקדם ככל האפשר.' },
    },
    {
      '@type': 'Question',
      name: 'האם ניתן לפרוס חוב לתשלומים?',
      acceptedAnswer: { '@type': 'Answer', text: 'כן. ניתן להגיש בקשה לצו תשלומים לרשם ההוצאה לפועל. הרשם קובע סכום חודשי לפי יכולתך, וכשיש צו פעיל — אין עיקולים חדשים.' },
    },
    {
      '@type': 'Question',
      name: 'אילו כספים לא ניתן לעקל?',
      acceptedAnswer: { '@type': 'Answer', text: 'קצבאות ביטוח לאומי (ילדים, נכות, זקנה, שאירים) מוגנות לחלוטין. גם שכר מינימום (6,247 ₪) לא ניתן לעיקול מלא.' },
    },
    {
      '@type': 'Question',
      name: 'מה זה תיקון 9 ואיך הוא משפיע עליי?',
      acceptedAnswer: { '@type': 'Answer', text: 'תיקון 9 (ינואר 2025) שינה את חישוב ריבית הפיגורים. כיום: ריבית בנק ישראל (4.5%) + 3.5% + 1% שנתי דמי פיגורים. חוב שלא משלמים גדל בכ-9% בשנה.' },
    },
    {
      '@type': 'Question',
      name: 'מתי כדאי לשקול חדלות פירעון?',
      acceptedAnswer: { '@type': 'Answer', text: 'כשסך החובות גדול משמעותית מהיכולת לשלמם, ואין נכסים לממש. בהליך חדלות פירעון ניתן לקבל הפטר (מחיקת חובות) לאחר ~3 שנים.' },
    },
    {
      '@type': 'Question',
      name: 'האם יש התיישנות על חובות בהוצאה לפועל?',
      acceptedAnswer: { '@type': 'Answer', text: 'חוב אזרחי מתיישן לאחר 7 שנים אם הנושה לא פעל. חוב שנקבע בפסק דין — 25 שנה. חשוב: תשלום חלקי או הודאה בחוב מאפסים את שעון ההתיישנות.' },
    },
    {
      '@type': 'Question',
      name: 'קיבלתי תביעה כערב — מה עושים?',
      acceptedAnswer: { '@type': 'Answer', text: 'אם ערבת לחוב אישי עד 100,000 ₪ — ייתכן שאתה ערב מוגן. הנושה חייב לנסות לגבות מהחייב קודם. יש לך 20 יום להגיש התנגדות מרגע קבלת האזהרה.' },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר לבדוק אם יש נגדי תיק הוצאה לפועל?',
      acceptedAnswer: { '@type': 'Answer', text: 'כן. ניתן לבדוק דרך מערכת הוצל"פ נט באתר gov.il או לפנות ישירות ללשכת הוצאה לפועל עם תעודת זהות. ראה מדריך בדיקת תיק.' },
    },
    {
      '@type': 'Question',
      name: 'כמה זמן נמשך הליך הוצאה לפועל?',
      acceptedAnswer: { '@type': 'Answer', text: 'תלוי בהסדר: צו תשלומים — לפי יכולתך (1-10 שנים). איחוד תיקים — בדרך כלל 3-7 שנים. חדלות פירעון — 3 שנים. תשלום מלא — מיידי.' },
    },
    {
      '@type': 'Question',
      name: 'האם הוצאה לפועל משפיעה על דירוג האשראי?',
      acceptedAnswer: { '@type': 'Answer', text: 'כן. תיק פעיל בהוצאה לפועל מופיע בדוח BDI ומשפיע לרעה על קבלת הלוואות, משכנתא וחוזים עסקיים. סגירת התיק משפרת את הדירוג בהדרגה.' },
    },
  ],
};
---

<BaseLayout
  title="הוצאה לפועל — מידע, זכויות וכלים חינמיים לחייבים בישראל"
  description="570,000 ישראלים עם תיק הוצאה לפועל פעיל. קבל מידע ברור על זכויותיך, מחשבון ריבית תיקון 9, ועזרה להסדיר את החוב. חינם, בעברית פשוטה."
  schema={[websiteSchema, organizationSchema, homeFaqSchema]}
>
  <Header />

  <main>

    <!-- HERO -->
    <section class="bg-gradient-to-bl from-blue-50 to-amber-50 border-b border-neutral-border">
      <div class="max-w-4xl mx-auto px-4 py-16 text-center">
        <div class="inline-block bg-white border border-brand-light text-brand-dark text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
          מידע חינמי לחייבים בישראל
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-5">
          קיבלת מכתב מהוצאה לפועל?<br>
          <span class="text-brand">אל תבהל. יש לך זכויות.</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-xl mx-auto mb-10 leading-relaxed">
          570,000 ישראלים עם תיק פעיל — רובם לא יודעים שיש להם אפשרויות. אנחנו כאן לעזור.
        </p>
        <div class="flex flex-wrap gap-6 justify-center">
          {[
            { num: '570K', label: 'ישראלים במצבך' },
            { num: '77%', label: 'ללא ייצוג — לא לבד' },
            { num: '1.2%', label: 'מגישים בקשות — אפשר לשנות' },
          ].map(s => (
            <div class="text-center">
              <div class="text-3xl font-bold text-brand-dark">{s.num}</div>
              <div class="text-sm text-neutral-muted mt-1">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 2025 UPDATE BANNER -->
    <section class="bg-amber-50 border-y border-amber-200 py-4">
      <div class="max-w-4xl mx-auto px-4 flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <span class="text-amber-600 text-xl">📢</span>
          <div>
            <span class="font-bold text-amber-800">עדכון ינואר 2025 — תיקון 9:</span>
            <span class="text-amber-700 text-sm mr-1">שיטת חישוב ריבית הפיגורים השתנתה. בדוק כמה אתה חייב עכשיו.</span>
          </div>
        </div>
        <a href="/guides/tikunim-2025/" class="text-sm font-semibold text-amber-800 bg-amber-100 hover:bg-amber-200 px-4 py-2 rounded-full transition-colors whitespace-nowrap">
          קרא על תיקון 9 ←
        </a>
      </div>
    </section>

    <!-- SITUATION SELECTOR -->
    <section class="max-w-4xl mx-auto px-4 py-14">
      <div class="text-center mb-8">
        <p class="text-brand text-sm font-bold uppercase tracking-wide mb-2">התחל כאן</p>
        <h2 class="text-3xl font-bold text-gray-900 mb-2">מה קרה לך?</h2>
        <p class="text-gray-500">בחר את המצב שלך — נפנה אותך בדיוק למה שאתה צריך</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-4 gap-3" id="situation-grid">
        {[
          { id: 'account',  icon: '🏦', title: 'עיקלו לי את החשבון',   desc: 'הבנק חסם את הכסף שלי',      href: '/guides/ikul-heshbon/' },
          { id: 'salary',   icon: '💼', title: 'עיקלו את המשכורת',      desc: 'מנכים לי כסף מהמשכורת',    href: '/guides/ikul-maskoret/' },
          { id: 'letter',   icon: '✉️', title: 'קיבלתי מכתב מהוצל"פ', desc: 'לא יודע מה לעשות',          href: '/guides/michtav-hotzaa/' },
          { id: 'mazamot',  icon: '👨‍👧', title: 'חוב מזונות',           desc: 'הוצאה לפועל על מזונות',     href: '/guides/mazamot/' },
          { id: 'property', icon: '🏠', title: 'מאיימים לעקל נכס',     desc: 'דירה, רכב או ציוד',         href: '/guides/ikul-nechassim/' },
          { id: 'bankrupt', icon: '📋', title: 'שוקל פשיטת רגל',        desc: 'חדלות פירעון ומחיקת חובות', href: '/guides/pshitat-regel/' },
          { id: 'close',    icon: '✅', title: 'רוצה לסגור את התיק',    desc: 'איך מסגרים תיק הוצאה לפועל',href: '/guides/sgor-tik/' },
          { id: 'unknown',  icon: '❓', title: 'לא יודע מאיפה להתחיל', desc: 'אני מבולבל לגמרי',          href: '/guides/' },
        ].map(s => (
          <a
            href={s.href}
            class="group flex flex-col items-center text-center p-5 bg-white border-2 border-neutral-border rounded-2xl hover:border-brand hover:bg-brand-pale transition-all"
          >
            <span class="text-3xl mb-3">{s.icon}</span>
            <span class="text-sm font-semibold text-gray-800 mb-1 leading-tight">{s.title}</span>
            <span class="text-xs text-neutral-muted">{s.desc}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- TOOLS -->
    <section class="bg-gray-50 border-y border-neutral-border py-14">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-8">
          <p class="text-brand text-sm font-bold uppercase tracking-wide mb-2">כלים חינמיים</p>
          <h2 class="text-3xl font-bold text-gray-900 mb-2">כלים שעובדים בשבילך</h2>
          <p class="text-gray-500">ייחודיים בשוק — פותחנו אותם כי הם לא היו קיימים</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {[
            {
              icon: '🧮',
              bg: 'bg-blue-50',
              name: 'מחשבון ריבית — תיקון 9',
              desc: 'חשב כמה אתה באמת חייב לפי החוק החדש מינואר 2025',
              tag: 'חדש! תיקון 9',
              tagColor: 'bg-orange-100 text-orange-700',
              href: '/tools/calculator/',
            },
            {
              icon: '💬',
              bg: 'bg-green-50',
              name: "צ'אטבוט מידע",
              desc: 'שאל שאלה ותקבל תשובה מבוססת חוק — לא ניחושים',
              tag: 'AI + מאגר מאומת',
              tagColor: 'bg-green-100 text-green-700',
              href: '/tools/chatbot/',
            },
            {
              icon: '✅',
              bg: 'bg-purple-50',
              name: 'בדיקת זכאות',
              desc: 'האם אתה זכאי לצו תשלומים, איחוד תיקים, או חדלות פירעון?',
              tag: '4 שאלות בלבד',
              tagColor: 'bg-purple-100 text-purple-700',
              href: '/tools/eligibility/',
            },
          ].map(tool => (
            <a href={tool.href} class="group bg-white border border-neutral-border rounded-2xl p-6 hover:border-brand hover:shadow-sm transition-all block">
              <div class={`w-11 h-11 ${tool.bg} rounded-xl flex items-center justify-center text-xl mb-4`}>{tool.icon}</div>
              <h3 class="font-bold text-gray-800 mb-2">{tool.name}</h3>
              <p class="text-sm text-gray-500 mb-3 leading-relaxed">{tool.desc}</p>
              <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${tool.tagColor}`}>{tool.tag}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- GUIDES -->
    <section class="max-w-4xl mx-auto px-4 py-14">
      <div class="text-center mb-8">
        <p class="text-brand text-sm font-bold uppercase tracking-wide mb-2">מדריכים</p>
        <h2 class="text-3xl font-bold text-gray-900 mb-2">המדריכים הכי נקראים</h2>
        <p class="text-gray-500">כתובים בשפה פשוטה — בלי ז'רגון משפטי מיותר</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { cat: 'עיקולים',         title: 'איך מבטלים עיקול על חשבון בנק?',            desc: 'מה הצעדים המדויקים, אילו טפסים צריך, ואיפה מגישים',  href: '/guides/ikul-heshbon/',    kw: '9,500 חיפושים/חודש' },
          { cat: 'זכויות',          title: '10 זכויות שכל חייב חייב להכיר',            desc: 'רשימה שאנשים לא יודעים — ויש להם מה להפסיד',         href: '/rights/',                kw: '7,600 חיפושים/חודש' },
          { cat: 'עיקולים',         title: 'ביטול עיקול — כל הסוגים, כל הטפסים',       desc: 'מדריך שלב-אחר-שלב לביטול עיקול על כל נכס',           href: '/guides/bitul-ikul/',      kw: '8,200 חיפושים/חודש' },
          { cat: 'מזונות',          title: 'מזונות בהוצאה לפועל — עיקולים וגבייה',     desc: 'כל מה שצריך לדעת על הוצאה לפועל בתיקי מזונות',       href: '/guides/mazamot/',        kw: '6,500 חיפושים/חודש' },
          { cat: 'הסדרים',          title: 'צו תשלומים — איך מגישים ומה הסיכויים',     desc: 'הדרך הנפוצה ביותר להסדיר תשלומים בצורה מסודרת',     href: '/guides/tzav-tashlumim/', kw: '5,100 חיפושים/חודש' },
          { cat: 'חדלות פירעון',    title: 'פשיטת רגל — מה השתנה ואיך מגישים 2026',   desc: 'המדריך המעודכן לחדלות פירעון — זכאות, עלויות, תהליך', href: '/guides/pshitat-regel/',  kw: '5,900 חיפושים/חודש' },
        ].map(g => (
          <a href={g.href} class="group flex gap-4 items-start p-5 bg-white border border-neutral-border rounded-xl hover:border-brand hover:bg-brand-pale transition-all">
            <div class="flex-1">
              <span class="text-xs font-bold text-neutral-muted uppercase tracking-wide">{g.cat}</span>
              <h3 class="font-bold text-gray-800 mt-1 mb-1 text-base leading-snug group-hover:text-brand-dark transition-colors">{g.title}</h3>
              <p class="text-sm text-gray-500">{g.desc}</p>
            </div>
            <span class="text-brand-dark text-xl mt-1 group-hover:translate-x-[-4px] transition-transform">←</span>
          </a>
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/guides/" class="inline-flex items-center gap-2 text-brand font-semibold hover:text-brand-dark transition-colors">
          לכל המדריכים ←
        </a>
      </div>
    </section>

    <!-- PROCESS STEPS -->
    <section class="bg-gray-50 border-y border-neutral-border py-14">
      <div class="max-w-4xl mx-auto px-4">
        <div class="text-center mb-10">
          <p class="text-brand text-sm font-bold uppercase tracking-wide mb-2">איך זה עובד</p>
          <h2 class="text-3xl font-bold text-gray-900 mb-2">שלבי הליך הוצאה לפועל</h2>
          <p class="text-gray-500">מה קורה מרגע פתיחת התיק ועד סגירתו</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { num: '1', icon: '📂', title: 'פתיחת תיק', desc: 'הנושה פותח תיק בהוצאה לפועל ומצרף פסק דין או שטר חוב.' },
            { num: '2', icon: '✉️', title: 'אזהרה לחייב', desc: 'החייב מקבל מכתב רשמי ויש לו 20 יום להגיב או לשלם.' },
            { num: '3', icon: '🔒', title: 'הגבלות', desc: 'אם אין תגובה — עיקולים, עיכוב יציאה מהארץ והגבלות נוספות.' },
            { num: '4', icon: '💸', title: 'גבייה', desc: 'עיקול חשבון בנק, ניכוי ממשכורת, ועיקול נכסים.' },
            { num: '5', icon: '🤝', title: 'הסדר', desc: 'ניתן להגיע להסדר תשלומים בכל שלב ולהקפיא את הגבייה.' },
            { num: '6', icon: '✅', title: 'סגירת תיק', desc: 'החוב שולם במלואו — התיק נסגר וכל ההגבלות מוסרות.' },
          ].map(step => (
            <div class="bg-white border border-neutral-border rounded-2xl p-5 flex flex-col gap-3">
              <div class="flex items-center gap-3">
                <span class="w-8 h-8 rounded-full bg-brand text-white text-sm font-bold flex items-center justify-center flex-shrink-0">{step.num}</span>
                <span class="text-2xl">{step.icon}</span>
              </div>
              <div>
                <p class="font-bold text-gray-800 mb-1">{step.title}</p>
                <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ALL GUIDE CATEGORIES -->
    <section class="max-w-4xl mx-auto px-4 py-14">
      <div class="text-center mb-10">
        <p class="text-brand text-sm font-bold uppercase tracking-wide mb-2">כל המדריכים</p>
        <h2 class="text-3xl font-bold text-gray-900 mb-2">מדריכים לפי נושא</h2>
        <p class="text-gray-500">31 מדריכים מפורטים — בחר את הנושא הרלוונטי אליך</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          {
            title: 'עיקולים',
            icon: '🔒',
            color: 'bg-blue-50 border-blue-200',
            titleColor: 'text-blue-800',
            guides: [
              { label: 'ביטול עיקול חשבון בנק', href: '/guides/ikul-heshbon/' },
              { label: 'עיקול משכורת — מה מותר ומה אסור', href: '/guides/ikul-maskoret/' },
              { label: 'עיקול נכסים — דירה ורכב', href: '/guides/ikul-nechassim/' },
              { label: 'עיקול פנסיה וקרן השתלמות', href: '/guides/ikul-pensiya/' },
              { label: 'עיקול דירת מגורים', href: '/guides/ikul-dira/' },
              { label: 'ביטול הגבלות — כרטיס אשראי ורישיון', href: '/guides/bitul-hagbalot/' },
            ],
          },
          {
            title: 'הסדרת חוב',
