---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'כיצד להגיש בקשה לחדלות פירעון בישראל',
  description: 'מדריך שלב אחר שלב לפתיחת הליך חדלות פירעון בישראל — בדיקת זכאות, הגשת בקשה, ועד לקבלת הפטר',
  totalTime: 'P4Y',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'בדוק זכאות', text: 'חוב מינימלי 57,445 ₪ (2026). יחידים בלבד — לא חברות. תושב ישראל.' },
    { '@type': 'HowToStep', position: 2, name: 'בחר מסלול', text: 'חוב 57,445–176,923 ₪: רשם חדלות פירעון. חוב מעל 176,923 ₪: בית משפט השלום עם נאמן.' },
    { '@type': 'HowToStep', position: 3, name: 'הכן מסמכים', text: 'רשימת נושים וחובות, דוח הכנסות/הוצאות, רשימת נכסים, מסמכי זיהוי.' },
    { '@type': 'HowToStep', position: 4, name: 'הגש בקשה ועמוד בתנאים', text: 'הגש לבית המשפט או לרשם. לאחר הגשה — שתף פעולה עם הנאמן, עמוד בתשלומים ובדיווחים.' },
    { '@type': 'HowToStep', position: 5, name: 'קבל הפטר', text: 'לאחר כ-4 שנים של עמידה בתנאים — בית המשפט מבטל את יתרת החובות.' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'מה ההבדל בין חדלות פירעון לפשיטת רגל?', acceptedAnswer: { '@type': 'Answer', text: 'אין הבדל — "פשיטת רגל" הוא השם הישן. מאז 2019, החוק החדש קרוי "חדלות פירעון ושיקום כלכלי" (חוק תשע"ח-2018). ההליך שודרג והפך ידידותי יותר לחייבים.' } },
    { '@type': 'Question', name: 'מה הסכום המינימלי לפתיחת הליך חדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'נכון ל-2026: 57,445 ₪. חוב מתחת לסכום זה אינו מאפשר פתיחת הליך אישי.' } },
    { '@type': 'Question', name: 'כמה זמן נמשך הליך חדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'בממוצע כ-4 שנים: שנת ביניים + 3 שנות שיקום. בשיתוף פעולה מלא ניתן לקצר. בהפרות — ניתן להאריך.' } },
    { '@type': 'Question', name: 'האם אפשר לפתוח עסק בזמן הליך חדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'בעקרון כן, אבל בכפוף לאישור הנאמן. ההכנסות מהעסק מחויבות לדיווח ועשויות להשפיע על התשלום החודשי.' } },
    { '@type': 'Question', name: 'מה קורה לדירה שלי בהליך חדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'אם יש לך דירת מגורים בבעלותך — הנאמן יבחן אותה. בנסיבות מסוימות ניתן לשמור על הדירה, בתנאים מסוימים. כל מקרה נבחן לגופו ומומלץ ייעוץ עורך דין.' } },
    { '@type': 'Question', name: 'האם חדלות פירעון מוחקת את כל החובות?', acceptedAnswer: { '@type': 'Answer', text: 'לא הכל. חובות מזונות, קנסות פליליים, עיצומים מנהליים, וחובות שנוצרו במרמה — לא נמחקים. רוב החובות הרגילים (הלוואות, אשראי, שיקים) — כן נמחקים בהפטר.' } },
  ],
};
---

<BaseLayout
  title="חדלות פירעון בישראל — כל מה שצריך לדעת 2026"
  description="חדלות פירעון היא לא קץ העולם — היא דרך לצאת ממעגל החובות. מי זכאי, כמה עולה, מה קורה לדירה, ומה נמחק בסוף. מדריך מעודכן 2026."
  schema={[faqSchema, howToSchema]}
>
  <Header />
  <main class="max-w-4xl mx-auto px-4 py-10">

    <nav class="text-sm text-neutral-muted mb-6">
      <a href="/">בית</a> › <span class="text-gray-700">חדלות פירעון</span>
    </nav>

    <h1 class="text-3xl font-bold text-brand-dark mb-3">חדלות פירעון בישראל</h1>
    <p class="text-lg text-gray-600 mb-10 max-w-2xl">
      כשהחובות גדולים מדי מלסגור — יש מסלול חוקי שנועד לתת לך התחלה חדשה.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-12">
      {[
        {
          icon: '❓',
          title: 'מהי חדלות פירעון?',
          desc: 'ההסבר הפשוט — מה השתנה מ"פשיטת רגל" ולמה זה שונה',
          href: '/insolvency/what-is/',
          kw: '6,800 חיפושים/חודש',
          highlight: true,
        },
        {
          icon: '✅',
          title: 'מי זכאי להגיש?',
          desc: 'סכומי הסף, התנאים, ומי לא יכול להגיש',
          href: '/insolvency/eligibility/',
          kw: '3,900 חיפושים/חודש',
          highlight: false,
        },
        {
          icon: '🗓️',
          title: 'שלבי ההליך — מה קורה בכל שלב',
          desc: 'מהגשת הבקשה עד ההפטר — 4 שנים בממוצע, שלב אחרי שלב',
          href: '/insolvency/process/',
          kw: '',
          highlight: false,
        },
        {
          icon: '💰',
          title: 'כמה עולה הליך חדלות פירעון?',
          desc: 'אגרות, שכר טרחה עורך דין, ועלויות נסתרות — הכל על השולחן',
          href: '/insolvency/costs/',
          kw: '',
          highlight: false,
        },
        {
          icon: '🏁',
          title: 'ההפטר — מה זה ומתי מקבלים?',
          desc: 'ביטול החובות בסוף ההליך — מה מוחק, מה נשאר, ומה התנאים',
          href: '/insolvency/haftar/',
          kw: '',
          highlight: false,
        },
      ].map(item => (
        <a
          href={item.href}
          class={`flex gap-4 items-start p-5 rounded-xl border-2 transition-all group ${
            item.highlight
              ? 'border-brand bg-brand-pale hover:bg-blue-100'
              : 'border-neutral-border bg-white hover:border-brand hover:bg-brand-pale'
          }`}
        >
          <span class="text-3xl mt-0.5">{item.icon}</span>
          <div class="flex-1">
            {item.highlight && (
              <span class="text-xs font-bold text-brand bg-blue-100 px-2 py-0.5 rounded-full mb-2 inline-block">התחל כאן</span>
            )}
            <h2 class="font-bold text-gray-800 mb-1 group-hover:text-brand-dark transition-colors leading-snug">{item.title}</h2>
            <p class="text-sm text-gray-500 mb-2">{item.desc}</p>
            {item.kw && <span class="text-xs text-neutral-muted">🔍 {item.kw}</span>}
          </div>
          <span class="text-brand-dark text-lg group-hover:translate-x-[-4px] transition-transform mt-1">←</span>
        </a>
      ))}
    </div>

    <!-- בדיקה מהירה -->
    <div class="bg-brand-pale border border-brand-light rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-brand-dark mb-4">האם חדלות פירעון מתאימה לי?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
        {[
          { q: 'גובה החוב המינימלי', a: 'מ-57,445 ₪ (2026)' },
          { q: 'משך ההליך הממוצע', a: 'כ-4 שנים' },
          { q: 'עלות משוערת', a: '8,000–25,000 ₪' },
          { q: 'מה קורה בסוף', a: 'הפטר — ביטול החובות' },
          { q: 'מי מנהל', a: 'בית משפט / רשם חדלות פירעון' },
          { q: 'האם חובה עורך דין', a: 'מומלץ מאוד, לא חובה' },
        ].map(item => (
          <div class="flex justify-between items-center py-2 border-b border-brand-light last:border-0">
            <span class="text-gray-600">{item.q}</span>
            <span class="font-semibold text-brand-dark text-xs">{item.a}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 text-sm text-gray-700 mb-10">
      ⚠️ המידע כאן הוא כללי בלבד ואינו מהווה ייעוץ משפטי. חדלות פירעון היא הליך מורכב — מומלץ להתייעץ עם עורך דין לפני הגשה.
    </div>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-brand-dark mb-6">שאלות נפוצות על חדלות פירעון</h2>
      <div class="space-y-3">
        {[
          { q: 'מה ההבדל בין חדלות פירעון לפשיטת רגל?', a: 'אין הבדל — "פשיטת רגל" הוא השם הישן. מאז 2019, החוק החדש קרוי "חדלות פירעון ושיקום כלכלי". ההליך שודרג, ומוקד הגישה השתנה מענישת החייב לשיקומו הכלכלי.' },
          { q: 'מה הסכום המינימלי לפתיחת הליך?', a: 'נכון ל-2026: 57,445 ₪. חוב מתחת לסכום זה אינו מאפשר פתיחת הליך אישי. חוב גבוה יותר עדיין דורש עמידה בתנאים נוספים.' },
          { q: 'האם חדלות פירעון מוחקת את כל החובות?', a: 'רוב החובות הרגילים (הלוואות, אשראי, שיקים) — כן. חובות מזונות, קנסות פליליים, וחובות שנוצרו במרמה — לא נמחקים.' },
          { q: 'מה קורה לדירה שלי?', a: 'הנאמן יבחן את הנכסים. בנסיבות מסוימות ניתן לשמור על הדירה, לרוב בתנאים. כל מקרה נבחן לגופו — ייעוץ עורך דין חיוני.' },
          { q: 'האם אפשר לפתוח עסק בזמן ההליך?', a: 'בעקרון כן, בכפוף לאישור הנאמן. ההכנסות מהעסק מחויבות דיווח ועשויות להשפיע על התשלום החודשי.' },
          { q: 'כמה זמן נמשך ההליך?', a: 'בממוצע כ-4 שנים: שנת ביניים + 3 שנות שיקום. ניתן לקצר בשיתוף פעולה יוצא דופן, להאריך בהפרות.' },
        ].map(faq => (
          <details class="border border-neutral-border rounded-xl group">
            <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
              {faq.q}
              <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="px-4 pb-4 text-gray-600 text-sm">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
