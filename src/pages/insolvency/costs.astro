---
import GuideLayout from '../../layouts/GuideLayout.astro';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'איך לתכנן את עלויות הליך חדלות פירעון',
  description: 'שלבים לתכנון נכון של עלויות הגשת בקשה לחדלות פירעון בישראל — אגרות, עורך דין, ונאמן',
  totalTime: 'PT1H',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'בדוק זכאות לפטור מאגרה', text: 'אגרת הגשה היא 1,564 ₪. אם אין לך יכולת לשלם — ניתן לבקש פטור מלא או חלקי. הבקשה מוגשת יחד עם הבקשה הראשית לחדלות פירעון.' },
    { '@type': 'HowToStep', position: 2, name: 'בדוק זכאות לסיוע משפטי חינמי', text: 'הלשכה לסיוע משפטי מציעה ייצוג חינמי לזכאים לפי רמת הכנסה. קליניקות משפטיות באוניברסיטאות מציעות ייעוץ חינמי. בדוק זאת לפני שכירת עורך דין פרטי.' },
    { '@type': 'HowToStep', position: 3, name: 'השווה שכר טרחת עורכי דין', text: 'שכר טרחה נע בין 6,000 ל-20,000 ₪. פנה לפחות ל-3 עורכי דין לקבלת הצעות מחיר. בדוק ניסיון ספציפי בחדלות פירעון.' },
    { '@type': 'HowToStep', position: 4, name: 'שקול שמאות נכסים', text: 'אם יש לך נכסים (דירה, רכב) — ייתכן צורך בשמאות. עלות שמאות: 1,500–3,000 ₪. הנאמן עשוי לדרוש זאת.' },
    { '@type': 'HowToStep', position: 5, name: 'חשב את כדאיות ההליך', text: 'חשב: עלות ההליך (~15,000 ₪) + תשלומים חודשיים (4 שנים) מול סך החוב שיימחק. על חוב של 350,000 ₪ — החיסכון הנטו עומד על כ-287,000 ₪.' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'כמה עולה הגשת בקשה לחדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'אגרת בית המשפט עומדת על 1,564 ₪. שכר טרחת עורך דין נע בין 6,000 ל-20,000 ₪ לפי מורכבות התיק. סה"כ עלות משוערת: 8,000-25,000 ₪.' } },
    { '@type': 'Question', name: 'האם ניתן לקבל פטור מאגרת בית המשפט?', acceptedAnswer: { '@type': 'Answer', text: 'כן. אנשים שאין ביכולתם לשלם יכולים לבקש פטור מלא או חלקי. הבקשה מוגשת יחד עם הבקשה הראשית לחדלות פירעון.' } },
    { '@type': 'Question', name: 'האם חובה לשכור עורך דין לחדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'לא חובה, אבל מומלץ מאוד. ניתן להגיש בעצמך, אך ההליך מורכב ומלא דקויות בירוקרטיות. טעויות יכולות לעכב בחודשים. לזכאים — הלשכה לסיוע משפטי מציעה ייצוג חינמי.' } },
    { '@type': 'Question', name: 'מי משלם לנאמן?', acceptedAnswer: { '@type': 'Answer', text: 'שכר הנאמן נקבע על ידי בית המשפט ומשולם מתוך הכספים שנגבים לטובת הנושים — לא ישירות מכיסך.' } },
    { '@type': 'Question', name: 'האם ההשקעה משתלמת?', acceptedAnswer: { '@type': 'Answer', text: 'לרוב כן. על חוב של 350,000 ₪ — עלות ההליך ~15,000 ₪, תשלומים ~48,000 ₪ לאורך 4 שנים, ובסוף נמחקים ~287,000 ₪. החיסכון הנטו משמעותי.' } },
  ],
};
---

<GuideLayout
  title="כמה עולה הליך חדלות פירעון? — פירוט עלויות 2026"
  description="העלות הכוללת של הליך חדלות פירעון נעה בין 8,000 ל-25,000 ₪. פירוט אגרות, שכר טרחה עורך דין, ועלויות נסתרות — לפני שמחליטים."
  breadcrumb={[{ label: 'חדלות פירעון', href: '/insolvency/' }, { label: 'עלויות', href: '/insolvency/costs/' }]}
  publishDate="2025-03-01"
  updateDate="2026-03-28"
  readTime="5 דקות"
  schema={[faqSchema, howToSchema]}
>

  <p>
    אחת השאלות הראשונות שאנשים שואלים היא כמה זה עולה. התשובה הכנה: לא מעט —
    אבל ביחס לחובות שנמחקים בסוף, רוב האנשים שעברו את ההליך אומרים שהיה שווה.
  </p>

  <h2>סיכום עלויות — 2026</h2>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">פריט</th>
          <th class="text-right p-3 border border-gray-200">עלות משוערת</th>
          <th class="text-right p-3 border border-gray-200">הערות</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['אגרת בית משפט', '1,564 ₪', 'ניתן לבקש פטור במצוקה כלכלית'],
          ['שכר טרחה עורך דין', '6,000 – 20,000 ₪', 'לפי מורכבות התיק ונכסים'],
          ['שכר נאמן', 'נקבע על ידי בית המשפט', 'מתוך כספי הנושים בדרך כלל'],
          ['שמאות נכסים (אם נדרש)', '1,500 – 3,000 ₪', 'רק אם יש נכסים לשום'],
          ['סה"כ משוער', '8,000 – 25,000 ₪', 'ממוצע: כ-12,000-15,000 ₪'],
        ].map(([item, cost, note], i) => (
          <tr class={i === 4 ? 'bg-blue-50 font-bold' : i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200">{item}</td>
            <td class="p-3 border border-gray-200 text-brand-dark font-semibold">{cost}</td>
            <td class="p-3 border border-gray-200 text-gray-500 text-xs">{note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>אגרת בית המשפט — ואפשרות לפטור</h2>
  <p>
    אגרת הגשת בקשה לחדלות פירעון עומדת על <strong>1,564 ₪</strong> (נכון ל-2026).
    אנשים שאין ביכולתם לשלם את האגרה יכולים לבקש פטור מלא או חלקי ממנה.
    הבקשה לפטור מוגשת יחד עם הבקשה הראשית.
  </p>

  <h2>שכר טרחה עורך דין — האם חובה?</h2>
  <p>
    עורך דין אינו חובה — אפשר להגיש בעצמך. אבל:
  </p>
  <ul>
    <li>ההליך מורכב ומלא מלכודות בירוקרטיות</li>
    <li>טעויות בהגשה יכולות לעכב את ההליך בחודשים</li>
    <li>עורך דין טוב יכול לשפר את תנאי תוכנית השיקום</li>
    <li>בתיקים עם נכסים (דירה, רכב) — ייצוג חשוב מאוד</li>
  </ul>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">כיצד לחסוך בשכר טרחה:</p>
    <ul>
      <li><strong>הלשכה לסיוע משפטי</strong> — ייצוג חינמי לזכאים לפי הכנסה</li>
      <li><strong>קליניקות משפטיות</strong> — אוניברסיטאות מציעות ייעוץ בחינם</li>
      <li><strong>השוואת מחירים</strong> — שכר הטרחה שונה מאוד בין עורכי דין. שאל לפחות 2-3</li>
    </ul>
  </div>

  <h2>שכר נאמן — מי משלם?</h2>
  <p>
    הנאמן שממונה על ידי בית המשפט מקבל שכר מהכספים שנגבים מהחייב לטובת הנושים.
    כלומר — שכר הנאמן לא יוצא ישירות מכיסך, אלא מהתשלומים שממילא אתה משלם.
  </p>

  <h2>האם ההשקעה משתלמת?</h2>

  <div class="not-prose bg-green-50 border border-green-200 rounded-xl p-5 my-6">
    <p class="font-semibold text-green-800 mb-3">דוגמה מספרית:</p>
    <div class="text-sm text-gray-700 space-y-1">
      <p>סכום חוב כולל: <strong>350,000 ₪</strong></p>
      <p>עלות ההליך: <strong>~15,000 ₪</strong></p>
      <p>תשלומים במהלך 4 שנים: <strong>~48,000 ₪</strong> (1,000 ₪/חודש)</p>
      <p>חוב שנמחק בהפטר: <strong>~287,000 ₪</strong></p>
      <div class="mt-3 pt-3 border-t border-green-200">
        <p class="font-bold text-green-800">חיסכון נטו: כ-287,000 ₪ 💚</p>
      </div>
    </div>
  </div>

  <h2>שאלות נפוצות</h2>
  <div class="space-y-4 my-6">
    {[
      { q: 'כמה עולה הגשת בקשה לחדלות פירעון?', a: 'אגרת בית המשפט: 1,564 ₪. שכר עורך דין: 6,000-20,000 ₪. סה"כ: 8,000-25,000 ₪ בהתאם למורכבות.' },
      { q: 'האם ניתן לקבל פטור מאגרת בית המשפט?', a: 'כן. מי שאין ביכולתו לשלם יכול לבקש פטור מלא או חלקי יחד עם הגשת הבקשה.' },
      { q: 'האם חובה לשכור עורך דין?', a: 'לא חובה, אבל מומלץ מאוד. לזכאים — הלשכה לסיוע משפטי מציעה ייצוג חינמי.' },
      { q: 'מי משלם לנאמן?', a: 'שכר הנאמן נקבע בבית המשפט ומשולם מהכספים שנגבים לנושים — לא ישירות מהחייב.' },
    ].map(faq => (
      <details class="border border-neutral-border rounded-xl group">
        <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
          {faq.q}
          <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
        </summary>
        <p class="px-4 pb-4 text-gray-600">{faq.a}</p>
      </details>
    ))}
  </div>

  <div slot="next-steps" class="not-prose mt-10 p-6 bg-brand-pale border border-brand-light rounded-xl">
    <h3 class="text-lg font-bold text-brand-dark mb-3">מה עכשיו?</h3>
    <ul class="space-y-2 text-sm">
      <li>← <a href="/insolvency/process/" class="text-brand hover:underline">שלבי ההליך — מה קורה בכל שלב</a></li>
      <li>← <a href="/insolvency/haftar/" class="text-brand hover:underline">ההפטר — מה בדיוק נמחק</a></li>
      <li>← <a href="/contact/" class="text-brand hover:underline">רוצה ייעוץ? צור קשר עם עורך דין</a></li>
    </ul>
  </div>

</GuideLayout>
