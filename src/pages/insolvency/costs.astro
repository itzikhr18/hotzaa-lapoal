---
import GuideLayout from '../../layouts/GuideLayout.astro';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'איך לתכנן את עלויות הליך חדלות פירעון',
  description: 'שלבים לתכנון נכון של עלויות הגשת בקשה לחדלות פירעון בישראל — אגרות, עורך דין, ונאמן',
  totalTime: 'PT1H',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'בדוק זכאות לפטור מאגרה', text: 'אגרת הגשה היא 1,564 ₪. אם אין לך יכולת לשלם — ניתן לבקש פטור מלא או חלקי. הבקשה מוגשת יחד עם הבקשה הראשית לחדלות פירעון.' },
    { '@type': 'HowToStep', position: 2, name: 'בדוק זכאות לסיוע משפטי חינמי', text: 'הלשכה לסיוע משפטי מציעה ייצוג חינמי לזכאים לפי רמת הכנסה. קליניקות משפטיות באוניברסיטאות מציעות ייעוץ חינמי. בדוק זאת לפני שכירת עורך דין פרטי.' },
    { '@type': 'HowToStep', position: 3, name: 'השווה שכר טרחת עורכי דין', text: 'שכר טרחה נע בין 5,000 ל-20,000 ₪. פנה לפחות ל-3 עורכי דין לקבלת הצעות מחיר. בדוק ניסיון ספציפי בחדלות פירעון.' },
    { '@type': 'HowToStep', position: 4, name: 'שקול שמאות נכסים', text: 'אם יש לך נכסים (דירה, רכב) — ייתכן צורך בשמאות. עלות שמאות: 1,500–3,000 ₪. הנאמן עשוי לדרוש זאת.' },
    { '@type': 'HowToStep', position: 5, name: 'חשב את כדאיות ההליך', text: 'חשב: עלות ההליך (~15,000 ₪) + תשלומים חודשיים (3-4 שנים) מול סך החוב שיימחק. על חוב של 350,000 ₪ — החיסכון הנטו עומד על כ-287,000 ₪.' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'כמה עולה הגשת בקשה לחדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'אגרת בית המשפט: 1,564 ₪. שכר נאמן: 2,500–5,000 ₪ (נקבע בבית המשפט). שכר עורך דין: 5,000–20,000 ₪. סה"כ משוער: 8,000–25,000 ₪.' } },
    { '@type': 'Question', name: 'האם ניתן לקבל פטור מאגרת בית המשפט?', acceptedAnswer: { '@type': 'Answer', text: 'כן. אנשים שאין ביכולתם לשלם יכולים לבקש פטור מלא או חלקי. הבקשה מוגשת יחד עם הבקשה הראשית לחדלות פירעון.' } },
    { '@type': 'Question', name: 'האם חובה לשכור עורך דין לחדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'לא חובה, אבל מומלץ מאוד. ניתן להגיש בעצמך, אך ההליך מורכב ומלא דקויות בירוקרטיות. טעויות יכולות לעכב בחודשים. לזכאים — הלשכה לסיוע משפטי מציעה ייצוג חינמי.' } },
    { '@type': 'Question', name: 'מי משלם לנאמן?', acceptedAnswer: { '@type': 'Answer', text: 'שכר הנאמן נקבע על ידי בית המשפט ומשולם מתוך הכספים שנגבים לטובת הנושים — לא ישירות מכיסך.' } },
    { '@type': 'Question', name: 'מה קורה אם אי אפשר לשלם אפילו את האגרה?', acceptedAnswer: { '@type': 'Answer', text: 'ניתן לבקש פטור מלא מהאגרה במסגרת הבקשה לחדלות פירעון. אם אין לך ייצוג משפטי — הלשכה לסיוע משפטי יכולה לייצג אותך חינמית. בית המשפט אינו דוחה בקשות על בסיס חוסר יכולת כלכלית בלבד.' } },
    { '@type': 'Question', name: 'האם ההשקעה משתלמת?', acceptedAnswer: { '@type': 'Answer', text: 'לרוב כן. על חוב של 350,000 ₪ — עלות ההליך ~15,000 ₪, תשלומים ~48,000 ₪ לאורך 4 שנים, ובסוף נמחקים ~287,000 ₪. החיסכון הנטו משמעותי.' } },
  ],
};
---

<GuideLayout
  title="כמה עולה הליך חדלות פירעון? — פירוט עלויות 2026"
  description="העלות הכוללת של הליך חדלות פירעון נעה בין 8,000 ל-25,000 ₪. פירוט אגרות, שכר טרחה עורך דין, שכר נאמן, ועלויות נסתרות — לפני שמחליטים."
  breadcrumb={[{ label: 'חדלות פירעון', href: '/insolvency/' }, { label: 'עלויות', href: '/insolvency/costs/' }]}
  publishDate="2025-03-01"
  updateDate="2026-04-24"
  readTime="9 דקות"
  schema={[faqSchema, howToSchema]}
>

  <p>
    אחת השאלות הראשונות שאנשים שואלים היא כמה זה עולה. התשובה הכנה: לא מעט —
    אבל ביחס לחובות שנמחקים בסוף, רוב האנשים שעברו את ההליך אומרים שהיה שווה.
    הנה פירוט מלא של כל עלות, אפשרויות לפטור, ומה קורה אם אין לך כסף בכלל.
  </p>

  <h2>סיכום עלויות — 2026</h2>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">פריט</th>
          <th class="text-right p-3 border border-gray-200">עלות משוערת</th>
          <th class="text-right p-3 border border-gray-200">אפשרות לפטור?</th>
          <th class="text-right p-3 border border-gray-200">הערות</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['אגרת הגשה לבית משפט', '1,564 ₪', 'כן — ניתן לבקש פטור מלא', 'מוגשת עם הבקשה הראשית'],
          ['אגרות בית משפט נוספות', '200–600 ₪', 'כן — לפי מצב כלכלי', 'דיונים, ערעורים, בקשות'],
          ['שכר טרחת עורך דין', '5,000 – 20,000 ₪', 'כן — סיוע משפטי חינמי', 'לפי מורכבות התיק ונכסים'],
          ['שכר נאמן', '2,500 – 5,000 ₪', 'לא — נקבע בבית המשפט', 'מתוך כספי הנושים בדרך כלל'],
          ['שמאות נכסים (אם נדרש)', '1,500 – 3,000 ₪', 'לא', 'רק אם יש נכסים לשום'],
          ['תרגום מסמכים (אם נדרש)', '500 – 1,500 ₪', 'לא', 'למי שמסמכים בשפה זרה'],
          ['סה"כ משוער', '8,000 – 25,000 ₪', 'חלקי', 'ממוצע: כ-12,000-15,000 ₪'],
        ].map(([item, cost, exempt, note], i) => (
          <tr class={i === 6 ? 'bg-blue-50 font-bold' : i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200">{item}</td>
            <td class="p-3 border border-gray-200 text-brand-dark font-semibold">{cost}</td>
            <td class="p-3 border border-gray-200 text-xs">{exempt}</td>
            <td class="p-3 border border-gray-200 text-gray-500 text-xs">{note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>אגרת בית המשפט — פירוט ואפשרויות פטור</h2>
  <p>
    אגרת הגשת בקשה לחדלות פירעון עומדת על <strong>1,564 ₪</strong> (נכון ל-2026, צמודה למדד).
    זו האגרה הראשונית — יתכנו אגרות נוספות על דיונים, ערעורים ובקשות ספציפיות, אך הן קטנות יחסית.
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">מי זכאי לפטור מאגרה?</p>
    <ul class="space-y-1">
      <li><strong>הכנסה מתחת לסף קיום</strong> — מי שהכנסתו מתחת לקו העוני מקבל פטור מלא בדרך כלל</li>
      <li><strong>מקבלי קצבאות סוציאליות</strong> — נכות כללית, הבטחת הכנסה — פטור אוטומטי כמעט</li>
      <li><strong>מי שאין לו נכסים</strong> — נכסים אפסיים תומכים בבקשת הפטור</li>
      <li><strong>כיצד מגישים</strong> — בקשת פטור מאגרה מוגשת יחד עם הבקשה הראשית, ללא עלות נוספת</li>
    </ul>
  </div>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">שימו לב — אגרה חלקית</p>
    <p>בית המשפט עשוי לאשר פטור חלקי — למשל, לשלם 500 ₪ במקום 1,564 ₪. גם פטור חלקי הוא עזרה משמעותית. המסמך המרכזי לצירוף לבקשת פטור הוא תלוש שכר, אישור גמלה, או תצהיר הכנסות.</p>
  </div>

  <h2>שכר נאמן — 2,500 עד 5,000 ₪</h2>
  <p>
    בתיקים עם חוב מעל 176,923 ₪, בית המשפט ממנה נאמן לניהול ההליך.
    שכר הנאמן נקבע על ידי בית המשפט — לא על ידי הנאמן עצמו — ונע בדרך כלל בין <strong>2,500 ₪ ל-5,000 ₪</strong>,
    בתוספת מע"מ. בתיקים מורכבים עם נכסים רבים, שכר הנאמן עשוי להיות גבוה יותר.
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">מי משלם לנאמן בפועל?</p>
    <p>שכר הנאמן מגיע בראש ובראשונה מהכספים שנגבים מהחייב ומועברים לנושים. כלומר — מבחינה מעשית, הנושים "מממנים" חלק מהנאמן. אם אין כספים מספיקים, ייתכן שהנאמן יקבל שכרו מהמדינה (קרן נאמן). בכל מקרה — לא מוסיפים את שכר הנאמן על גבי התשלומים החודשיים שלך.</p>
  </div>

  <h2>שכר טרחת עורך דין — 5,000 עד 20,000 ₪</h2>
  <p>
    שכר הטרחה תלוי בגורמים רבים:
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">סוג התיק</th>
          <th class="text-right p-3 border border-gray-200">שכר טרחה משוער</th>
          <th class="text-right p-3 border border-gray-200">מה כלול</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['תיק פשוט — אין נכסים, שכיר', '5,000 – 8,000 ₪', 'הגשה, ייצוג בדיונים, תוכנית שיקום'],
          ['תיק בינוני — נכסים מועטים', '8,000 – 14,000 ₪', 'הנ"ל + טיפול בנכסים, ערעורים'],
          ['תיק מורכב — דירה, עסק', '14,000 – 20,000 ₪', 'הנ"ל + משא ומתן עם נושים, שומות'],
          ['עצמאי — ייצוג בלבד בחלקים', '3,000 – 5,000 ₪', 'ייעוץ בלבד, הגשה עצמאית עם ליווי'],
        ].map(([type, fee, includes], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-semibold">{type}</td>
            <td class="p-3 border border-gray-200 text-brand-dark font-semibold">{fee}</td>
            <td class="p-3 border border-gray-200 text-gray-600 text-xs">{includes}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>ייצוג עצמי — האם אפשרי?</h2>
  <p>
    כן — החוק אינו מחייב ייצוג משפטי. אפשר להגיש בקשה לחדלות פירעון בעצמך.
    אבל כדאי לדעת מה מחכה לך:
  </p>

  <ol class="step-list">
    <li><span class="step-num">1</span><span><strong>מסמכים מורכבים</strong> — הבקשה כוללת טפסים ארוכים, תצהירים, רשימות נושים מפורטות ודוחות כספיים. טעות אחת עלולה לגרום לדחיית הבקשה.</span></li>
    <li><span class="step-num">2</span><span><strong>דיוני בית משפט</strong> — תצטרך להופיע בדיונים, להתמודד עם שאלות מהנאמן ומהנושים, ולהציג את מצבך הכלכלי בצורה מסודרת.</span></li>
    <li><span class="step-num">3</span><span><strong>תוכנית שיקום</strong> — הנאמן קובע מה תשלם. ללא ייצוג, קשה יותר להתמקח על תנאי התוכנית ולהוכיח שהסכום שנדרש ממך גבוה מדי.</span></li>
    <li><span class="step-num">4</span><span><strong>נושים פעילים</strong> — אם יש לך נושים שמתנגדים להפטר או לתנאי ההליך, ייצוג משפטי חיוני.</span></li>
  </ol>

  <div class="tip-box">
    <p class="font-semibold text-green-800 mb-2">מתי ייצוג עצמי הגיוני?</p>
    <ul class="space-y-1">
      <li>כשאין לך נכסים כלל (שוכר, אין רכב, אין חסכונות)</li>
      <li>כשכל הנושים הם גופים פיננסיים (בנקים, כרטיסי אשראי) ואין חובות אישיים</li>
      <li>כשיש לך זמן ויכולת ללמוד את ההליך לעומק</li>
      <li>כשאתה מגיש דרך הלשכה לסיוע משפטי שעוזרת לך</li>
    </ul>
  </div>

  <h2>הלשכה לסיוע משפטי — ייצוג חינמי לזכאים</h2>
  <p>
    הלשכה לסיוע משפטי היא זרוע של משרד המשפטים המספקת ייצוג משפטי חינמי לאנשים שאינם יכולים להרשות לעצמם עורך דין.
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">קריטריון</th>
          <th class="text-right p-3 border border-gray-200">פרטים</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['הכנסה חודשית מירבית (יחיד)', 'כ-7,500 ₪ נטו (משתנה לפי גודל משפחה)'],
          ['הכנסה חודשית מירבית (זוג + 2 ילדים)', 'כ-13,000 ₪ נטו'],
          ['נכסים', 'אין נכסים בעלי ערך ניכר (דירה, חסכונות גדולים)'],
          ['מה הלשכה מכסה?', 'ייצוג בכל שלבי ההליך — הגשה, דיונים, ערעורים'],
          ['מה הלשכה לא מכסה?', 'אגרות בית משפט (אפשר לבקש פטור בנפרד)'],
          ['כיצד פונים?', 'לסניף הלשכה לסיוע משפטי הקרוב — יש לקבוע תור'],
        ].map(([crit, detail], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-semibold text-gray-700">{crit}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{detail}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">אפשרויות נוספות לסיוע חינמי:</p>
    <ul class="space-y-1">
      <li><strong>קליניקות משפטיות באוניברסיטאות</strong> — אוניברסיטת תל אביב, בר-אילן, חיפה, ירושלים — מציעות ייעוץ ולעיתים ייצוג חינמי</li>
      <li><strong>עמותת "פרוטקשן"</strong> — מלווה חייבים בהליכי חדלות פירעון בחינם</li>
      <li><strong>ייעוץ ראשוני חינמי</strong> — חלק גדול מעורכי הדין מציעים שיחה ראשונה ללא עלות</li>
    </ul>
  </div>

  <h2>תוכנית תשלום לעלויות ההליך עצמו</h2>
  <p>
    מה קורה כשאין לך כסף לשלם לעורך דין? יש מספר פתרונות:
  </p>

  <ol class="step-list">
    <li><span class="step-num">א</span><span><strong>תשלום בתשלומים לעורך הדין</strong> — רוב עורכי הדין המתמחים בחדלות פירעון מציעים תשלום מפורס. נהוג לשלם חלק מראש ואת היתרה לאורך ההליך.</span></li>
    <li><span class="step-num">ב</span><span><strong>שכר טרחה דחוי</strong> — חלק מהעורכים מסכימים שהחלק הגדול ישולם רק בסוף ההליך — ממקורות שישתחררו.</span></li>
    <li><span class="step-num">ג</span><span><strong>הלשכה לסיוע משפטי</strong> — ייצוג חינמי לזכאים.</span></li>
    <li><span class="step-num">ד</span><span><strong>קרן קהילתית</strong> — בחלק מהמקרים, ארגוני צדקה וגמ"חים מסייעים בעלויות הליכים משפטיים.</span></li>
  </ol>

  <h2>מה קורה אם אי אפשר לשלם אפילו את האגרה?</h2>

  <div class="alert-box">
    <p class="font-semibold text-red-800 mb-2">חשוב לדעת — אל תוותר על ההליך בגלל חוסר כסף</p>
    <p>בית המשפט בישראל <strong>לא דוחה</strong> בקשות לחדלות פירעון אך ורק מסיבת חוסר יכולת לשלם אגרה. ישנן מספר שכבות הגנה:</p>
  </div>

  <ul class="mt-4 space-y-2">
    <li><strong>פטור מלא מאגרה</strong> — בקשה מנומקת עם מסמכי הכנסה. אם מתקבלת, הגשת הבקשה היא ללא עלות.</li>
    <li><strong>דחיית תשלום האגרה</strong> — בית המשפט יכול לאשר דחיית תשלום עד לשלב מאוחר יותר בהליך.</li>
    <li><strong>הלשכה לסיוע משפטי</strong> — מייצגת גם אנשים ללא כל יכולת כלכלית.</li>
    <li><strong>ייצוג עצמי ללא עורך דין</strong> — חוקי לחלוטין, וכשאין ברירה — אפשרי.</li>
  </ul>

