---
import GuideLayout from '../../layouts/GuideLayout.astro';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'איך להתחיל הליך חדלות פירעון בישראל',
  description: 'מדריך שלב אחר שלב — מהחלטה לפתיחת הליך חדלות פירעון ועד לקבלת הפטר',
  totalTime: 'P4Y',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'הבן את ההבדל בין המסלולים', text: 'חוב 58,794–176,923 ₪ מטופל ברשם חדלות פירעון. חוב מעל 176,923 ₪ מטופל בבית משפט השלום עם מינוי נאמן. ודא שאתה בסכום המינימלי לפני הגשה.' },
    { '@type': 'HowToStep', position: 2, name: 'התייעץ עם עורך דין', text: 'הליך חדלות פירעון הוא מורכב. ייעוץ ראשוני לרוב זול. הלשכה לסיוע משפטי מציעה ייצוג חינמי לזכאים. קבל תמונה מלאה לפני הגשה.' },
    { '@type': 'HowToStep', position: 3, name: 'הגש בקשה לצו פתיחת הליכים', text: 'הגש את הבקשה עם: רשימת נושים וחובות, דוח הכנסות והוצאות, רשימת נכסים. לאחר הגשה — ההליכים נגדך מוקפאים.' },
    { '@type': 'HowToStep', position: 4, name: 'שתף פעולה מלא עם הנאמן', text: 'ספק כל מסמך נדרש, הגש דיווחים תקופתיים, עמוד בתשלומים החודשיים. אל תסתיר הכנסות או נכסים — זה עלול לבטל את ההפטר.' },
    { '@type': 'HowToStep', position: 5, name: 'קבל הפטר לאחר תקופת השיקום', text: 'לאחר כ-4 שנים של עמידה בתנאים — בית המשפט מעניק הפטר: ביטול יתרת החובות. ניתן לחזור לחיים כלכליים רגילים.' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'מה ההבדל בין חדלות פירעון לפשיטת רגל?',
      acceptedAnswer: { '@type': 'Answer', text: 'אין הבדל — הם אותו הדבר. חוק חדלות פירעון ושיקום כלכלי (2019) החליף את חוק פשיטת הרגל הישן. השם החדש מדגיש את מטרת השיקום ולא את הכישלון.' },
    },
    {
      '@type': 'Question',
      name: 'האם חדלות פירעון מוחקת את כל החובות?',
      acceptedAnswer: { '@type': 'Answer', text: 'לא את כולם. מזונות, קנסות פליליים, וחובות שנוצרו במרמה — לא ניתנים להפטר. רוב החובות הרגילים (הלוואות, אשראי, שיקים) — כן.' },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר לעבוד בזמן הליך חדלות פירעון?',
      acceptedAnswer: { '@type': 'Answer', text: 'כן. מותר לעבוד, ואפילו נדרש. החייב מחויב להפריש חלק מהכנסותיו לנושים במהלך תקופת השיקום.' },
    },
    {
      '@type': 'Question',
      name: 'כמה זמן נשאר הרישום בדוח האשראי?',
      acceptedAnswer: { '@type': 'Answer', text: 'רישום חדלות פירעון נשמר בנתוני האשראי של בנק ישראל למשך 7 שנים מיום ההפטר. במהלך תקופה זו ייתכן שתתקשו לקבל אשראי, אך אפשר להמשיך לעבוד ולנהל חיים רגילים.' },
    },
    {
      '@type': 'Question',
      name: 'האם בן או בת הזוג מושפעים מהליך חדלות הפירעון שלי?',
      acceptedAnswer: { '@type': 'Answer', text: 'ההליך חל על החייב בלבד. בן/בת הזוג אינם אחראים לחובותיך אלא אם כן חתמו כערבים. עם זאת, נכסים משותפים (כגון דירה משותפת) עשויים להיכלל בנכסי הקופה.' },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר להחזיק רכב בזמן ההליך?',
      acceptedAnswer: { '@type': 'Answer', text: 'תלוי בשווי הרכב ובצורך. רכב בעל ערך נמוך שמשמש לעבודה לרוב נשמר. רכב יוקרה בעל ערך גבוה עשוי להימכר לטובת הנושים. הנאמן מחליט בכל מקרה לגופו.' },
    },
    {
      '@type': 'Question',
      name: 'מה קורה לדירה שלי אם אנחנו בהליך חדלות פירעון?',
      acceptedAnswer: { '@type': 'Answer', text: 'אם יש לך דירה בבעלות, היא נכנסת לקופת הנשייה. הנאמן יבחן את שווייה, המשכנתה שעליה, וזכויות בני המשפחה. לא תמיד מוכרים את הדירה — לעיתים מגיעים להסדר שמאפשר לחייב להישאר בה תוך תשלום שווי חלקו.' },
    },
  ],
};
---

<GuideLayout
  title="מהי חדלות פירעון בישראל? — ההסבר הפשוט"
  description="חדלות פירעון היא הדרך החוקית לצאת ממעגל חובות שאין מוצא ממנו. מה השתנה מ'פשיטת רגל', מי יכול להגיש, ומה קורה בסוף — בעברית פשוטה."
  breadcrumb={[{ label: 'חדלות פירעון', href: '/insolvency/' }, { label: 'מהי חדלות פירעון?', href: '/insolvency/what-is/' }]}
  publishDate="2025-03-01"
  updateDate="2026-03-28"
  readTime="10 דקות"
  schema={[faqSchema, howToSchema]}
>

  <p>
    אם החובות שלך גדלו מעבר לנקודה שאין ממנה דרך חזרה — חדלות פירעון היא המסלול החוקי שנועד
    בדיוק לזה. זה לא "להפקיר" את החובות — זה הליך מפוקח שבסופו ניתן לקבל התחלה חדשה.
  </p>

  <h2>מה זה בעצם?</h2>
  <p>
    חדלות פירעון היא הליך משפטי שבו אדם שאינו מסוגל לשלם את חובותיו פונה לבית המשפט
    ומבקש לאגד את כל החובות תחת פיקוח שיפוטי. בתמורה לשיתוף פעולה מלא ועמידה בתנאים
    לאורך כ-4 שנים — הוא עשוי לקבל <strong>הפטר</strong>: ביטול משפטי של יתרת החובות.
  </p>

  <h2>מה ההבדל בין "חדלות פירעון" ל"פשיטת רגל"?</h2>
  <p>
    אין הבדל — הם אותו הדבר. חוק חדלות פירעון ושיקום כלכלי שנכנס לתוקף בספטמבר 2019
    החליף את חוק פשיטת הרגל הישן מ-1980.
  </p>
  <p>
    השם החדש לא מקרי — הוא משקף שינוי תפיסתי. החוק הישן ראה בחייב "כושל". החוק החדש
    מתייחס אליו כאדם שצריך <strong>שיקום כלכלי</strong> ולא ענישה.
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">3 המטרות של החוק החדש:</p>
    <ul>
      <li>שיקום כלכלי של החייב — לאפשר לו להתחיל מחדש</li>
      <li>מקסום הפירעון לנושים — לגבות כמה שאפשר</li>
      <li>שילוב מחדש במרקם הכלכלי — לחזור להיות אזרח פעיל</li>
    </ul>
  </div>

  <h2>מי יכול להגיש?</h2>
  <p>
    כל יחיד (לא חברה) שחובותיו עולים על <strong>58,794 ₪</strong> (נכון ל-2026) ואינו מסוגל
    לשלם אותם. גם נושה או היועץ המשפטי לממשלה יכולים להגיש בקשה נגד חייב.
  </p>

  <h2>שני מסלולים — לפי גובה החוב</h2>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">קריטריון</th>
          <th class="text-right p-3 border border-gray-200">מסלול א' — חוב נמוך</th>
          <th class="text-right p-3 border border-gray-200">מסלול ב' — חוב גבוה</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['סכום החוב', '58,794 – 176,923 ₪', 'מעל 176,923 ₪'],
          ['גורם מטפל', 'רשם חדלות פירעון', 'בית משפט השלום'],
          ['מינוי נאמן', 'לא תמיד', 'כן, חובה'],
          ['מורכבות', 'פחות מורכב', 'מורכב יותר'],
          ['משך הליך', 'קצר יותר', 'כ-4 שנים'],
        ].map(([k, a, b], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-semibold text-gray-700">{k}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{a}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{b}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="text-xs text-neutral-muted mt-2">* הסכומים מתעדכנים מדי שנה לפי מדד המחירים לצרכן. עודכנו לינואר 2026.</p>
  </div>

  <h2>חדלות פירעון לעומת אפשרויות אחרות</h2>
  <p>
    חדלות פירעון היא לא תמיד הפתרון הנכון. לפני שמגישים, כדאי להכיר את כל האפשרויות ולהבין
    מה ההבדל בין כל אחת מהן.
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">אפשרות</th>
          <th class="text-right p-3 border border-gray-200">מתי מתאים</th>
          <th class="text-right p-3 border border-gray-200">יתרונות</th>
          <th class="text-right p-3 border border-gray-200">חסרונות</th>
        </tr>
      </thead>
      <tbody>
        {[
          [
            'צו תשלומים',
            'חוב ניתן לניהול, הכנסה קיימת',
            'פשוט, לא מחייב הליך מלא',
            'לא מגן מפני עיקולים, אינו מוחק חוב',
          ],
          [
            'איחוד תיקים',
            'ריבוי תיקים בהוצאה לפועל',
            'מאחד את כל התיקים לתשלום אחד',
            'לא מוחק חוב, מצריך עמידה בתשלום',
          ],
          [
            'חדלות פירעון',
            'חוב גדול שאין יכולת אמיתית לפרוע',
            'מגן מיידי, הפטר בסוף ההליך',
            'הליך ארוך (~4 שנים), מגבלות על החייב',
          ],
          [
            'הסדר ישיר עם נושה',
            'נושה בודד, חוב ספציפי',
            'מהיר, גמיש, ללא בית משפט',
            'תלוי ברצון הנושה, לא מחייב אחרים',
          ],
        ].map(([opt, when, pros, cons], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-semibold text-gray-700">{opt}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{when}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{pros}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{cons}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="tip-box">
    <p>
      <strong>טיפ:</strong> אם יש לך נושה גדול אחד (כגון בנק אחד שרוב החוב אצלו), לעיתים הסדר ישיר
      יכול להיות מהיר ופחות מכביד. עורך דין שמתמחה בדיני חדלות פירעון יכול לעזור לך להשוות
      בין המסלולים לפני שמגישים.
    </p>
  </div>

  <h2>מה קורה ביום שמגישים את הבקשה?</h2>
  <p>
    רגע הגשת הבקשה הוא נקודת מפנה. עצם הגשת הבקשה לרשם חדלות פירעון או לבית המשפט
    מפעילה מנגנון הגנה אוטומטי — עוד לפני שניתן צו רשמי.
  </p>

  <ol class="step-list">
    <li>
      <span class="step-num">1</span>
      <div>
        <strong>עצירת הליכי גבייה</strong> — ברגע שהבקשה מוגשת ורשומה במערכת, נושים אינם יכולים
        לפתוח הליכי הוצאה לפועל חדשים. הליכים קיימים מוקפאים עם מתן הצו הרשמי.
      </div>
    </li>
    <li>
      <span class="step-num">2</span>
      <div>
        <strong>קביעת מועד דיון</strong> — בית המשפט או הרשם קובע מועד לדיון ראשוני שבו בוחנים
        את הבקשה ואת הנסיבות.
      </div>
    </li>
    <li>
      <span class="step-num">3</span>
      <div>
        <strong>הגשת מסמכים ראשונית</strong> — החייב נדרש להגיש רשימה מלאה של כל נושיו, פירוט
        כל הנכסים וההכנסות, ותצהיר על מצבו הכלכלי.
      </div>
    </li>
    <li>
      <span class="step-num">4</span>
      <div>
        <strong>מינוי נאמן (במסלול הגבוה)</strong> — הרשם ממנה נאמן שיפקח על ההליך מטעם בית
        המשפט. הנאמן הוא לא "האויב" — הוא גורם ניטרלי שמחויב גם לנושים וגם לחייב.
      </div>
    </li>
    <li>
      <span class="step-num">5</span>
      <div>
        <strong>הודעה לנושים</strong> — כל הנושים מקבלים הודעה רשמית על פתיחת ההליך ומוזמנים
        להגיש תביעות חוב. מרגע זה — כל תקשורת עם נושים עוברת דרך הנאמן או הרשם.
      </div>
    </li>
  </ol>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-2">שימו לב ביום הגשה:</p>
    <p>
      אל תסיימו לשלם לנושה בודד ממש לפני ההגשה. תשלומים שנעשו בתקופה שלפני הגשת הבקשה
      (עד 3 חודשים לאחור) עלולים להיחשב "העדפת נושים" ולהיות מבוטלים על ידי הנאמן.
    </p>
  </div>

  <h2>מה קורה במהלך ההליך?</h2>
  <p>
    לאחר שניתן צו פתיחת הליכים, מתחילה תקופת שיקום — בדרך כלל כ-3 עד 4 שנים. זו תקופה
    אקטיבית שבה גם החייב וגם הנאמן פועלים לפי מתווה מוגדר.
  </p>

  <h3>מה הנאמן עושה?</h3>
  <p>
    הנאמן הוא הדמות המרכזית בהליך מסלול ב'. הוא עורך דין שמינה אותו בית המשפט, ותפקידו
    הוא לפקח על כל ההליך בשם כלל הנושים ובית המשפט.
  </p>
  <ul>
    <li><strong>ריכוז נכסי הקופה</strong> — הנאמן לוקח שליטה על הנכסים של החייב שניתנים לממוש: חשבונות בנק, נכסי נדל"ן, כלי רכב, ירושות שהתקבלו במהלך ההליך.</li>
    <li><strong>בחינת תביעות חוב</strong> — הנאמן בוחן את כל הדרישות שהגישו הנושים ומאשר אילו מהן חוקיות ובאיזה גובה.</li>
    <li><strong>פיקוח על הכנסות החייב</strong> — מדי חודש מעביר החייב לנאמן דוח על הכנסותיו. הנאמן מחשב כמה מהן יועבר לנושים (לרוב עד 1/3 מההכנסה הפנויה).</li>
    <li><strong>דיווח לבית המשפט</strong> — הנאמן מגיש דוחות תקופתיים לבית המשפט ומודיע על כל חריגה מצד החייב.</li>
    <li><strong>ממוש נכסים</strong> — אם יש נכסים למכירה, הנאמן מפרסם מכרז ומוכר אותם לפי הוראות בית המשפט.</li>
  </ul>

  <h3>מה מצופה מהחייב?</h3>
  <ul>
    <li>להפריש חלק קבוע מהכנסותיו מדי חודש לנושים</li>
    <li>לדווח לנאמן על כל שינוי בהכנסות, בנכסים, או בנסיבות החיים (נישואין, ירושה, שינוי עבודה)</li>
    <li>לא לקחת הלוואות חדשות או אשראי מעל סכום שנקבע (לרוב כ-5,000 ₪) ללא אישור</li>
    <li>לא לצאת מהארץ ללא אישור מיוחד מבית המשפט</li>
    <li>להשתתף בהכשרה פיננסית שנקבעה על ידי הרשם</li>
    <li>לשתף פעולה עם הנאמן ולמסור כל מסמך שנדרש</li>
  </ul>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">מה קורה אם לא עומדים בתנאים?</p>
    <p>
      אי-עמידה בתנאי ההליך (הסתרת נכסים, אי-דיווח על הכנסות, קבלת אשראי ללא אישור) עלולה
      לגרום לביטול ההפטר בסוף — כלומר, החובות לא יימחקו. בית המשפט יכול גם להאריך את תקופת
      השיקום.
    </p>
  </div>

