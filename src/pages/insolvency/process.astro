---
import GuideLayout from '../../layouts/GuideLayout.astro';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'שלבי הליך חדלות פירעון — מדריך שלב אחר שלב',
  description: 'הסבר מפורט על 4 שלבי הליך חדלות פירעון בישראל — מהגשת הבקשה ועד ההפטר',
  totalTime: 'P4Y',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'הגשת הבקשה לצו פתיחת הליכים', text: 'הגש בקשה לבית משפט השלום (חוב מעל 176,923 ₪) או לרשם חדלות פירעון. כלול: רשימת נושים, דוחות הכנסה/הוצאות, רשימת נכסים ומסמכי זיהוי. לאחר אישור — כל ההליכים נגדך מוקפאים.' },
    { '@type': 'HowToStep', position: 2, name: 'תקופת ביניים — שיתוף פעולה עם הנאמן', text: 'בתקופת הביניים (כשנה) הנאמן חוקר את מצבך הכלכלי. שתף פעולה מלא: ספק מסמכים מבוקשים, הגש דיווחים, והשתתף בחקירת היכולת.' },
    { '@type': 'HowToStep', position: 3, name: 'אישור תוכנית שיקום', text: 'הנאמן מגבש תוכנית שיקום — כמה תשלם כל חודש ולכמה זמן. בית המשפט מאשר את התוכנית. סכום התשלום נקבע לפי יכולתך הכלכלית.' },
    { '@type': 'HowToStep', position: 4, name: 'תקופת שיקום — עמידה בתנאים', text: 'שלם את התשלום החודשי בזמן. הגש דיווחים דו-חודשיים. קבל אישור לפני יציאה לחו"ל ולפני רכישות גדולות. השתתף בהכשרה פיננסית.' },
    { '@type': 'HowToStep', position: 5, name: 'קבלת ההפטר', text: 'בסיום תקופת השיקום (כ-3 שנים) — בית המשפט מעניק הפטר. יתרת החובות נמחקת. ניתן לחזור לחיים נורמליים ללא הגבלות.' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'כמה זמן נמשך הליך חדלות פירעון?',
      acceptedAnswer: { '@type': 'Answer', text: 'הליך חדלות פירעון נמשך בממוצע כ-4 שנים: כ-שנה לתקופת הביניים (בחינה וגיבוש תוכנית שיקום) ועוד כ-3 שנים לתקופת השיקום עצמה. בסוף התקופה, בית המשפט מעניק הפטר — ביטול יתרת החובות.' },
    },
    {
      '@type': 'Question',
      name: 'מה זה נאמן חדלות פירעון?',
      acceptedAnswer: { '@type': 'Answer', text: 'נאמן חדלות פירעון הוא גורם מקצועי (עו"ד או רו"ח) שבית המשפט ממנה לנהל את ענייניו הכלכליים של החייב במהלך ההליך. הנאמן בוחן את נכסי החייב, מגבש תוכנית שיקום, מפקח על תשלומים, ומדווח לבית המשפט. הנאמן ממונה בתיקים עם חוב מעל 176,923 ₪.' },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר לצאת לחו"ל בזמן ההליך?',
      acceptedAnswer: { '@type': 'Answer', text: 'לא ללא אישור. במהלך הליך חדלות פירעון נדרש אישור מהנאמן או מבית המשפט לפני כל יציאה לחו"ל. ניתן לקבל אישור לנסיעות עבודה, רפואיות או אחרות, אך אין לצאת ללא קבלת אישור מראש.' },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם לא עומדים בתשלומים?',
      acceptedAnswer: { '@type': 'Answer', text: 'אי-עמידה בתשלומים החודשיים עלולה לגרום לעיכוב מתן ההפטר או אף לביטולו. בית המשפט רשאי להאריך את תקופת השיקום, להגדיל את סכום התשלום החודשי, או במקרים קיצוניים — לבטל את ההליך לחלוטין.' },
    },
    {
      '@type': 'Question',
      name: 'מה ההבדל בין תקופת הביניים לתקופת השיקום?',
      acceptedAnswer: { '@type': 'Answer', text: 'תקופת הביניים (כשנה) היא שלב הבחינה: הנאמן חוקר את מצב החייב, הנושים מגישים תביעות חוב, ומגובשת תוכנית שיקום. תקופת השיקום (כ-3 שנים) היא שלב הביצוע: החייב מבצע תשלומים חודשיים קבועים, מדווח לנאמן ועומד בכל תנאי ההליך עד לקבלת הפטר.' },
    },
  ],
};
---

<GuideLayout
  title="שלבי הליך חדלות פירעון — מה קורה בכל שלב"
  description="הליך חדלות פירעון נמשך כ-4 שנים ומורכב מ-3 שלבים עיקריים. מה קורה בכל שלב, מה נדרש ממך, ומתי מקבלים הפטר — מדריך שלב אחר שלב."
  breadcrumb={[{ label: 'חדלות פירעון', href: '/insolvency/' }, { label: 'שלבי ההליך', href: '/insolvency/process/' }]}
  publishDate="2025-03-01"
  updateDate="2026-03-28"
  readTime="7 דקות"
  schema={[faqSchema, howToSchema]}
>

  <p>
    אחת הסיבות שאנשים מתרחקים מחדלות פירעון היא שהם לא מבינים מה מצפה להם.
    הנה התמונה המלאה — שלב אחרי שלב, בלי סיבוכים מיותרים.
  </p>

  <div class="not-prose bg-brand-pale border border-brand-light rounded-xl p-5 mb-8">
    <p class="font-semibold text-brand-dark mb-1">סיכום תמציתי:</p>
    <p class="text-sm text-gray-600">הגשה → פתיחת הליכים → תקופת ביניים (שנה) → תקופת שיקום (3 שנים) → <strong>הפטר</strong></p>
  </div>

  <h2>שלב 1 — הגשת הבקשה ופתיחת ההליכים</h2>
  <p>
    מגישים בקשה לצו לפתיחת הליכים. ניתן להגיש בעצמך או דרך עורך דין.
    הבקשה מוגשת לבית משפט השלום (חוב מעל 176,923 ₪) או לרשם חדלות פירעון (חוב נמוך יותר).
  </p>
  <p>
    <strong>מה מגישים:</strong> טפסי הבקשה, רשימת נושים ופירוט חובות, דוחות הכנסה והוצאות,
    רשימת נכסים, ומסמכי זיהוי.
  </p>
  <p>
    <strong>מה קורה אחרי הגשה:</strong> בית המשפט בוחן את הבקשה. אם היא עומדת בתנאים — מוצא
    "צו לפתיחת הליכים". מרגע הצו — כל ההליכים נגדך מוקפאים.
  </p>

  <h2>שלב 2 — תקופת הביניים (כשנה)</h2>
  <p>
    זו התקופה הכי אינטנסיבית. ממונה נאמן (בתיקים גדולים) שבוחן את מצבך הכלכלי לעומק.
  </p>

  <ol class="step-list">
    <li><span class="step-num">א</span><span><strong>חקירת יכולת</strong> — הנאמן או הרשם בוחן את כל נכסיך, הכנסותיך, והוצאותיך</span></li>
    <li><span class="step-num">ב</span><span><strong>הגשת תביעות חוב</strong> — הנושים מגישים תביעות; הנאמן בוחן אותן</span></li>
    <li><span class="step-num">ג</span><span><strong>גיבוש תוכנית שיקום</strong> — כמה תשלם כל חודש, לכמה זמן</span></li>
    <li><span class="step-num">ד</span><span><strong>אישור התוכנית</strong> — בית המשפט מאשר את תוכנית השיקום</span></li>
  </ol>

  <h2>שלב 3 — תקופת השיקום (כ-3 שנים)</h2>
  <p>
    זו התקופה הארוכה ביותר. אתה ממשיך לחיות את חייך, אבל עם מגבלות ומחויבויות.
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">מה נדרש ממך בתקופת השיקום:</p>
    <ul class="space-y-1">
      <li>✓ תשלום חודשי קבוע לנאמן לפי התוכנית שנקבעה</li>
      <li>✓ דיווח דו-חודשי על הכנסות ושינויים כלכליים</li>
      <li>✓ השתתפות בהכשרה פיננסית (קורס ניהול כספים)</li>
      <li>✓ אישור מהנאמן לפני רכישות גדולות</li>
      <li>✓ אישור ליציאה מהארץ</li>
    </ul>
  </div>

  <h2>שלב 4 — ההפטר</h2>
  <p>
    אחרי שעמדת בכל תנאי תקופת השיקום — בית המשפט מעניק לך <strong>הפטר</strong>.
    זה ביטול משפטי של יתרת החובות שלא שולמה.
  </p>
  <p>
    מרגע ההפטר — אתה נקי. אין יותר חובות, אין יותר עיקולים, אין יותר הגבלות.
    אתה יכול להתחיל מחדש.
  </p>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-2">⚠️ מה יכול לעכב או לבטל את ההפטר</p>
    <ul>
      <li>אי-עמידה בתשלומים החודשיים</li>
      <li>הסתרת הכנסות או נכסים</li>
      <li>אי-הגשת דיווחים תקופתיים</li>
      <li>לקיחת אשראי חדש ללא אישור</li>
    </ul>
    <p class="mt-2">שיתוף פעולה מלא עם הנאמן ובית המשפט הוא המפתח להגיע להפטר.</p>
  </div>

  <h2>ציר הזמן הממוצע</h2>

  <div class="not-prose my-6 space-y-2">
    {[
      { time: 'חודש 1-2',    label: 'הגשת בקשה ופתיחת הליכים',         color: 'bg-blue-100 border-blue-300' },
      { time: 'חודש 3-12',   label: 'תקופת ביניים — בחינה וגיבוש תוכנית', color: 'bg-purple-100 border-purple-300' },
      { time: 'שנה 2-4',     label: 'תקופת שיקום — תשלומים ודיווחים',    color: 'bg-amber-100 border-amber-300' },
      { time: 'סוף שנה 4',   label: 'הפטר — התחלה חדשה',               color: 'bg-green-100 border-green-300' },
    ].map(item => (
      <div class={`flex items-center gap-4 p-4 rounded-xl border ${item.color}`}>
        <span class="text-sm font-bold text-gray-600 w-24 shrink-0">{item.time}</span>
        <span class="text-sm text-gray-700">{item.label}</span>
      </div>
    ))}
  </div>

  <h2>שאלות נפוצות</h2>
  <div class="space-y-4 my-6">
    <details class="border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        כמה זמן נמשך הליך חדלות פירעון?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">בממוצע כ-4 שנים: שנה לתקופת הביניים (בחינה וגיבוש תוכנית) ועוד כ-3 שנים לתקופת השיקום. בסיום — בית המשפט מעניק הפטר ומבטל את יתרת החובות.</p>
    </details>

    <details class="border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        מה זה נאמן חדלות פירעון?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">גורם מקצועי (עו"ד או רו"ח) שבית המשפט ממנה לנהל את ענייניו הכלכליים של החייב. הנאמן בוחן נכסים, מגבש תוכנית שיקום, מפקח על תשלומים ומדווח לבית המשפט. ממונה בתיקים עם חוב מעל 176,923 ₪.</p>
    </details>

    <details class="border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        מה ההבדל בין תקופת הביניים לתקופת השיקום?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">תקופת הביניים (כשנה) היא שלב הבחינה — הנאמן חוקר את מצב החייב ומגבש תוכנית שיקום. תקופת השיקום (כ-3 שנים) היא שלב הביצוע — תשלומים חודשיים קבועים, דיווחים ועמידה בתנאים עד לקבלת הפטר.</p>
    </details>
  </div>

  <div slot="next-steps" class="not-prose mt-10 p-6 bg-brand-pale border border-brand-light rounded-xl">
    <h3 class="text-lg font-bold text-brand-dark mb-3">מה עכשיו?</h3>
    <ul class="space-y-2 text-sm">
      <li>← <a href="/insolvency/costs/" class="text-brand hover:underline">כמה עולה ההליך? פירוט עלויות</a></li>
      <li>← <a href="/insolvency/haftar/" class="text-brand hover:underline">ההפטר — מה בדיוק מוחק</a></li>
      <li>← <a href="/insolvency/eligibility/" class="text-brand hover:underline">האם אני זכאי להגיש?</a></li>
    </ul>
  </div>

</GuideLayout>
