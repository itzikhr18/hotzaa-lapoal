        <ul class="text-xs space-y-1 text-gray-600">
          {col.conditions.map(c => <li>• {c}</li>)}
        </ul>
      </div>
    ))}
  </div>

  <h3>מה נמחק בהפטר?</h3>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">סוג חוב</th>
          <th class="text-right p-3 border border-gray-200">נמחק?</th>
          <th class="text-right p-3 border border-gray-200">הערה</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['הלוואות בנקאיות', 'כן', ''],
          ['חובות כרטיסי אשראי', 'כן', ''],
          ['חובות למס הכנסה / ביטוח לאומי', 'כן (ברוב המקרים)', 'תלוי בנסיבות'],
          ['חובות ספקים (עסקיים)', 'כן', ''],
          ['שטרות חוב', 'כן', ''],
          ['חובות מזונות (לבן/בת זוג, ילדים)', 'לא', 'לעולם לא נמחקים'],
          ['קנסות פליליים', 'לא', 'פסקי דין של בית משפט פלילי'],
          ['חובות שנוצרו במרמה', 'לא', 'אם הוכחה מרמה'],
          ['חובות עוולה מכוונת', 'לא', 'נזק גוף מכוון, לשון הרע'],
          ['חובות שלא הוגשה לגביהם תביעת חוב', 'לא', 'הנושה לא הגיש בזמן'],
        ].map(([type, erased, note], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 text-gray-700">{type}</td>
            <td class={`p-3 border border-gray-200 font-semibold ${erased === 'כן' ? 'text-green-600' : erased === 'לא' ? 'text-red-600' : 'text-amber-600'}`}>{erased}</td>
            <td class="p-3 border border-gray-200 text-gray-500 text-xs">{note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="alert-box">
    <p class="font-semibold text-red-800 mb-2">מה יכול לבטל את ההפטר?</p>
    <ul class="space-y-1">
      <li>אי-עמידה מתמשכת בתשלומים ללא הסבר</li>
      <li>הסתרת הכנסות או נכסים מהנאמן ובית המשפט</li>
      <li>אי-הגשת דיווחים תקופתיים</li>
      <li>לקיחת אשראי חדש ללא אישור</li>
      <li>הברחת נכסים לצד שלישי (אפשרות לביטול העסקה)</li>
    </ul>
    <p class="mt-2">שיתוף פעולה מלא עם הנאמן ובית המשפט הוא המפתח להגיע להפטר.</p>
  </div>

  <h2>שאלות נפוצות</h2>
  <div class="space-y-4 my-6">
    <details class="faq-item border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        כמה זמן נמשך הליך חדלות פירעון?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">בממוצע כ-4 שנים: שנה לתקופת הביניים (הגשה, מינוי נאמן, ישיבת נושים, אישור תוכנית) ועוד כ-3 שנים לתקופת ההבראה. בסיום — הפטר ומחיקת יתרת החובות.</p>
    </details>

    <details class="faq-item border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        מה זה נאמן חדלות פירעון ומה הוא עושה?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">גורם מקצועי (עו"ד או רו"ח) שבית המשפט ממנה לנהל את ענייניך הכלכליים. הנאמן בוחן נכסים, מגבש תוכנית שיקום, מפקח על תשלומים, ומדווח לבית המשפט. הנאמן אינו האויב שלך — הוא מנהל את ההליך בצורה מאוזנת.</p>
    </details>

    <details class="faq-item border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        מה קורה בישיבת הנושים?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">הנושים מגישים תביעות חוב, הנאמן מציג את ממצאיו ומלצותיו, ובית המשפט מאשר את תוכנית השיקום. ברוב המקרים הישיבה פרוצדורלית — הנושים הגדולים (בנקים) לרוב לא שולחים נציגים לדיונים קטנים.</p>
    </details>

    <details class="faq-item border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        האם אפשר לצאת לחו"ל בזמן ההליך?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">לא ללא אישור. נדרש אישור הנאמן לכל נסיעה. לרוב מקבלים אישור לנסיעות עבודה, רפואיות ומשפחתיות — אבל חייבים לבקש מראש. יציאה ללא אישור היא הפרת תנאי ההליך.</p>
    </details>

    <details class="faq-item border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        מה קורה אם לא עומד בתשלומים?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">אי-עמידה בתשלומים עלולה לעכב או לבטל את ההפטר. אבל — אם הכנסה ירדה, יש לפנות לנאמן מיד ולבקש הפחתת תשלום. בית המשפט מאפשר התאמות לנסיבות. הבעיה היא שתיקה — לא קושי אמיתי.</p>
    </details>

    <details class="faq-item border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        אילו חובות לא נמחקים בהפטר?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">חובות מזונות, קנסות פליליים, חובות שנוצרו במרמה, חובות עוולה מכוונת, וחובות שנושה לא הגיש לגביהם תביעת חוב בהליך. רוב חובות הבנקים, כרטיסי האשראי, הספקים וחובות עסקיים — נמחקים.</p>
    </details>
  </div>

