    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'אשר תוכנית שיקום',
      text: 'לאחר שנת הביניים, הנאמן מגיש לבית המשפט המלצה לתוכנית שיקום — סכום תשלום חודשי לתקופה של כ-3 שנים. בית המשפט מאשר את התוכנית בצו.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'עמוד בכל תנאי תוכנית השיקום',
      text: 'שלם את התשלום החודשי בדיוק ובזמן. הגש דיווחים דו-חודשיים על הכנסות. קבל אישור מהנאמן לפני יציאה לחו"ל ולפני רכישות גדולות. אל תיקח אשראי חדש ללא אישור.',
    },
    {
      '@type': 'HowToStep',
      position: 5,
      name: 'קבל הפטר בסיום השיקום',
      text: 'בסיום תקופת השיקום, הנאמן מגיש המלצה לבית המשפט. בית המשפט בוחן שעמדת בכל התנאים ומעניק צו הפטר. מרגע זה — יתרת החובות מבוטלת לצמיתות.',
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'מה זה הפטר בחדלות פירעון?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'הפטר הוא החלטה שיפוטית שמבטלת את יתרת החובות שלא שולמה לאחר סיום הליך חדלות פירעון. מרגע ההפטר — הנושים לא יכולים לתבוע אותך יותר על אותם חובות — לא היום ולא בעוד עשר שנים. מדובר בביטול משפטי מוחלט של החוב, לא בדחיית תשלום.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם ההפטר מוחק את כל החובות?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לא הכל. רוב החובות הרגילים (הלוואות, אשראי, שיקים, חובות לספקים) נמחקים. אך חובות מסוימים שורדים את ההפטר: מזונות לילדים ובן/בת זוג לשעבר, קנסות פליליים, עיצומים מנהליים, חובות שנוצרו במרמה שהוכחה בבית משפט, ונזקי גוף מכוונים.',
      },
    },
    {
      '@type': 'Question',
      name: 'כמה זמן עד לקבלת הפטר?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לרוב כ-4 שנים מהגשת הבקשה: שנה אחת של שנת ביניים ועוד כ-3 שנות שיקום. בית המשפט רשאי לקצר את התקופה אם הייתה שיתוף פעולה יוצא דופן ותשלום מעבר לנדרש, או להאריך את התקופה אם היו הפרות.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם לא עמדתי בתשלום חודשי אחד?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'פיגור חד-פעמי בתשלום לא בהכרח מבטל את ההליך. הנאמן ובית המשפט לוקחים בחשבון נסיבות. עם זאת, פיגורים חוזרים או אי-עמידה ממושכת בתנאים עלולים לגרום לדחיית ההפטר, הארכת תקופת השיקום, או במקרים קיצוניים — ביטול ההליך.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה הפטר מותנה?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'הפטר מותנה הוא הפטר שמחייב עמידה בתנאים נוספים לתקופה קצרה לאחר סיום ההליך הרשמי. לדוגמה, המשך דיווח על הכנסות לתקופה נוספת. לאחר עמידה בתנאים — ההפטר הופך לבלתי מוגבל ומוחלט.',
      },
    },
    {
