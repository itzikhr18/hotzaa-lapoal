---
import GuideLayout from '../../layouts/GuideLayout.astro';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'איך להגיע להפטר בהליך חדלות פירעון',
  description: 'שלבים לקבלת הפטר — ביטול יתרת החובות — בסיום הליך חדלות פירעון בישראל',
  totalTime: 'P4Y',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'עמוד בתשלומים החודשיים', text: 'שלם את התשלום החודשי שנקבע בתוכנית השיקום בדיוק ובזמן. אי-עמידה בתשלומים עלולה לגרום לדחיית ההפטר או ביטולו.' },
    { '@type': 'HowToStep', position: 2, name: 'הגש דיווחים תקופתיים', text: 'הגש דיווח דו-חודשי על הכנסותיך ושינויים כלכליים. שמור על שקיפות מלאה — הסתרת הכנסות עלולה לגרום לביטול ההפטר.' },
    { '@type': 'HowToStep', position: 3, name: 'עמוד בכל תנאי ההליך', text: 'קבל אישור מהנאמן לפני יציאה לחו"ל ולפני רכישות גדולות. אל תיקח אשראי חדש ללא אישור. השתתף בהכשרה פיננסית.' },
    { '@type': 'HowToStep', position: 4, name: 'בקש את ההפטר בסיום השיקום', text: 'בסיום תקופת השיקום, הנאמן מגיש המלצה לבית המשפט. בית המשפט בוחן שעמדת בכל התנאים ומעניק הפטר.' },
    { '@type': 'HowToStep', position: 5, name: 'התחל מחדש לאחר ההפטר', text: 'לאחר ההפטר ניתן לפתוח חשבון בנק, לרכוש נכסים, לצאת לחו"ל ולחזור לחיים רגילים. חובות שנמחקו — הנושים לא יכולים לתבוע אותך עליהם לעולם.' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'מה זה הפטר בחדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'הפטר הוא החלטה שיפוטית שמבטלת את יתרת החובות שלא שולמה. מרגע ההפטר — הנושים לא יכולים לתבוע אותך יותר על אותם חובות.' } },
    { '@type': 'Question', name: 'האם ההפטר מוחק את כל החובות?', acceptedAnswer: { '@type': 'Answer', text: 'לא הכל. מזונות, קנסות פליליים, עיצומים מנהליים, וחובות שנוצרו במרמה — לא נמחקים. רוב החובות הרגילים (הלוואות, אשראי, שיקים) — כן.' } },
    { '@type': 'Question', name: 'כמה זמן עד לקבלת הפטר?', acceptedAnswer: { '@type': 'Answer', text: 'לרוב כ-4 שנים מהגשת הבקשה: שנת ביניים + כ-3 שנות שיקום. ניתן לקיצור אם הייתה שיתוף פעולה יוצא דופן.' } },
    { '@type': 'Question', name: 'מה ניתן לעשות אחרי קבלת הפטר?', acceptedAnswer: { '@type': 'Answer', text: 'מרגע ההפטר — ניתן לפתוח חשבון בנק, לרכוש נכסים, לצאת לחו"ל, לפתוח עסק, ולחזור לחיים רגילים ללא הגבלות.' } },
    { '@type': 'Question', name: 'מה הפטר מותנה?', acceptedAnswer: { '@type': 'Answer', text: 'הפטר שמחייב עמידה בתנאים נוספים לתקופה קצרה לאחר סיום ההליך הרשמי. לאחר עמידה בתנאים — הופך לבלתי מוגבל.' } },
  ],
};
---

<GuideLayout
  title="ההפטר בחדלות פירעון — מה נמחק ומה לא"
  description="ההפטר הוא הפרס בסוף הליך חדלות פירעון — ביטול משפטי של יתרת החובות. מה בדיוק נמחק, מה לא, ומה קורה אחרי — מדריך מלא."
  breadcrumb={[{ label: 'חדלות פירעון', href: '/insolvency/' }, { label: 'ההפטר', href: '/insolvency/haftar/' }]}
  publishDate="2025-03-01"
  updateDate="2026-03-28"
  readTime="5 דקות"
  schema={[faqSchema, howToSchema]}
>

  <p>
    ההפטר הוא המטרה של כל ההליך. אחרי שנים של שיתוף פעולה, תשלומים ומגבלות —
    בית המשפט מעניק לך ניקיון מחובות ומאפשר לך להתחיל מחדש.
  </p>

  <h2>מה זה הפטר?</h2>
  <p>
    הפטר הוא החלטה שיפוטית שמבטלת את יתרת החובות שלך שלא שולמה במהלך ההליך.
    מרגע ההפטר — הנושים לא יכולים לתבוע אותך יותר על אותם חובות. לא היום, לא בעוד 10 שנים.
  </p>

  <h2>מה ההפטר מוחק?</h2>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">✅ ניתנים להפטר (נמחקים):</p>
    <ul class="space-y-1">
      <li>הלוואות בנקאיות</li>
      <li>חובות לכרטיסי אשראי</li>
      <li>שיקים שחזרו</li>
      <li>חובות לספקים ועסקים</li>
      <li>חובות ארנונה ועירייה (בדרך כלל)</li>
      <li>חובות משכנתה שנותרו אחרי מכירת נכס</li>
    </ul>
  </div>

  <div class="warn-box mt-4">
    <p class="font-semibold text-amber-800 mb-2">❌ לא ניתנים להפטר (נשארים):</p>
    <ul class="space-y-1">
      <li><strong>מזונות</strong> — לבן/בת זוג לשעבר וילדים</li>
      <li><strong>קנסות פליליים</strong> — מבית משפט פלילי</li>
      <li><strong>עיצומים מנהליים</strong> — מרשויות המדינה</li>
      <li><strong>חובות שנוצרו במרמה</strong> — אם הוכח בבית משפט</li>
      <li><strong>נזקי גוף מכוונים</strong> — שגרמת לאדם אחר</li>
      <li><strong>חובות שנוצרו אחרי פתיחת ההליך</strong></li>
    </ul>
  </div>

  <h2>מתי מקבלים הפטר?</h2>
  <p>
    ההפטר ניתן בסיום תקופת השיקום — לרוב כ-3 שנים אחרי אישור תוכנית השיקום,
    כלומר כ-4 שנים מהגשת הבקשה הראשונית.
  </p>
  <p>
    בית המשפט רשאי לקצר את תקופת השיקום אם החייב הפגין שיתוף פעולה יוצא דופן,
    או להאריך אותה אם היו הפרות.
  </p>

  <h2>מה קורה אחרי ההפטר?</h2>

  <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-4 my-6">
    {[
      { icon: '✅', title: 'מה מותר מחר בבוקר', items: ['לפתוח חשבון בנק רגיל', 'לקחת אשראי (תלוי בבנק)', 'לצאת מהארץ ללא הגבלה', 'לרכוש נכסים ורכב', 'לפתוח עסק'] },
      { icon: '⚠️', title: 'מה כדאי לדעת', items: ['הרישום בנתוני האשראי נשאר זמן מה', 'בנקים עשויים לנהוג בזהירות בתחילה', 'חובות שלא בהפטר — ממשיכים', 'כדאי לבנות היסטוריית אשראי בהדרגה'] },
    ].map(col => (
      <div class="border border-neutral-border rounded-xl p-5 bg-white">
        <h3 class="font-bold text-gray-800 mb-3">{col.icon} {col.title}</h3>
        <ul class="text-sm space-y-1 text-gray-600">
          {col.items.map(item => <li>• {item}</li>)}
        </ul>
      </div>
    ))}
  </div>

  <h2>הפטר מותנה לעומת הפטר מוחלט</h2>
  <p>
    לפעמים בית המשפט נותן <strong>הפטר מותנה</strong> — שמחייב עמידה בתנאים נוספים לתקופה
    קצרה לאחר סיום ההליך הרשמי. לאחר עמידה בתנאים — הופך לבלתי מוגבל.
  </p>

  <h2>שאלות נפוצות</h2>
  <div class="space-y-4 my-6">
    {[
      { q: 'מה זה הפטר בחדלות פירעון?', a: 'ביטול משפטי של יתרת החובות שלא שולמה. מרגע ההפטר — הנושים לא יכולים לתבוע אותך יותר על אותם חובות — לא היום ולא בעוד שנים.' },
      { q: 'האם ההפטר מוחק את כל החובות?', a: 'לא הכל. מזונות, קנסות פליליים, וחובות שנוצרו במרמה — לא נמחקים. רוב החובות הרגילים כן.' },
      { q: 'כמה זמן עד לקבלת הפטר?', a: 'לרוב כ-4 שנים: שנת ביניים + 3 שנות שיקום. ניתן לקיצור בשיתוף פעולה יוצא דופן.' },
      { q: 'מה ניתן לעשות אחרי הפטר?', a: 'לפתוח חשבון בנק, לרכוש נכסים, לצאת לחו"ל חופשי, לפתוח עסק — חיים רגילים ללא הגבלות.' },
    ].map(faq => (
      <details class="border border-neutral-border rounded-xl group">
        <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
          {faq.q}
          <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
        </summary>
        <p class="px-4 pb-4 text-gray-600">{faq.a}</p>
      </details>
    ))}
  </div>

  <div slot="next-steps" class="not-prose mt-10 p-6 bg-brand-pale border border-brand-light rounded-xl">
    <h3 class="text-lg font-bold text-brand-dark mb-3">מה עכשיו?</h3>
    <ul class="space-y-2 text-sm">
      <li>← <a href="/insolvency/what-is/" class="text-brand hover:underline">התחל מהתחלה — מהי חדלות פירעון?</a></li>
      <li>← <a href="/insolvency/eligibility/" class="text-brand hover:underline">האם אני זכאי?</a></li>
      <li>← <a href="/contact/" class="text-brand hover:underline">רוצה ייעוץ אישי? צור קשר</a></li>
    </ul>
  </div>

</GuideLayout>
