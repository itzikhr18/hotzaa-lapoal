const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'ההפטר בחדלות פירעון — מה נמחק, מה לא, ומה קורה אחרי',
  description: 'מדריך מלא על הפטר — ביטול משפטי של יתרת חובות בסיום הליך חדלות פירעון. מה נמחק, מה שורד, לוח הזמנים, וחיים אחרי ההפטר.',
