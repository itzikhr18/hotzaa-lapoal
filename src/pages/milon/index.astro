---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const publishDate = '2026-03-31';

// כל מונחי המילון — מקור אמת אחד לעמוד ולסכמת DefinedTermSet
const sections = [
  { id: "alef", letter: "א", terms: [
    { name: "אגרה", desc: "תשלום חובה הנגבה על ידי לשכת ההוצאה לפועל בעת פתיחת תיק או הגשת בקשה מסוימת. גובה האגרה נקבע לפי שווי החוב הנתבע ומתעדכן מעת לעת. האגרה מתווספת לחוב המקורי ומוטלת על החייב." },
    { name: "אזהרה", desc: "המסמך הרשמי הראשון שמקבל החייב לאחר פתיחת תיק הוצאה לפועל נגדו. האזהרה מפרטת את סכום החוב ומזהירה שאם לא יפרע תוך 20 יום, ינקטו כנגדו הליכי גבייה. חשוב מאוד לפעול מיידית עם קבלת האזהרה — אל תתעלמו ממנה." },
    { name: "איחוד תיקים", desc: "הליך שמאחד מספר תיקי הוצאה לפועל פתוחים של אותו חייב לתיק אחד מרכזי. כתוצאה מכך משלם החייב סכום חודשי אחד בלבד, המחולק בין כל הנושים לפי הסדר עדיפויות. מאפשר ניהול סדור ומניעת ריבוי הגבלות מקבילות.", guide: "/guides/ichud-tikim/" },
    { name: "אכיפה", desc: "פעולות שנוקטת לשכת ההוצאה לפועל כדי לגבות את החוב בפועל — עיקולים, מכירת נכסים, הגבלות ועוד. הזוכה רשאי לבקש אכיפה לאחר שחלפו 20 יום מהמצאת האזהרה לחייב ולא שולם. האכיפה כוללת מגוון כלים חוקיים להפעלת לחץ על החייב." },
    { name: "ארנונה — חוב", desc: "חוב ארנונה לרשות המקומית הוא חוב מוכר שניתן לגבותו בהוצאה לפועל. הרשות המקומית רשאית לפתוח תיק גבייה ישיר ואף לנקוט בהליכי עיקול על נכסי החייב. חוב ארנונה מתיישן בדרך כלל לאחר 7 שנים אם לא ננקטה פעולת גבייה (ולפי פסיקה מסוימת — פחות)." },
  ] },
  { id: "bet", letter: "ב", terms: [
    { name: "בית משפט שלום", desc: "הערכאה הנמוכה ביותר בהיררכיה השיפוטית בישראל, דנה בתביעות כספיות עד 2.5 מיליון ש\"ח. רוב תיקי ההוצאה לפועל מבוססים על פסקי דין של בית משפט שלום. ניתן לערער על פסיקתו לבית משפט מחוזי." },
    { name: "בית משפט מחוזי", desc: "ערכאת ביניים הדנה בתביעות מעל 2.5 מיליון ש\"ח ובערעורים על פסיקת בית משפט שלום. עניינים מסוימים של חדלות פירעון ופשיטת רגל נדונים ישירות בבית המשפט המחוזי. פסיקתו ניתנת לערעור לבית המשפט העליון." },
    { name: "בית משפט לענייני משפחה", desc: "ערכאה מיוחדת הדנה בנושאי גירושין, מזונות, משמורת ורכוש הנוגעים לבני זוג וילדים. פסקי דין של בית המשפט לענייני משפחה בנושא מזונות ניתנים לאכיפה דרך הוצאה לפועל. לחוב מזונות ניתנת עדיפות מיוחדת בדיני האכיפה." },
    { name: "ביטול עיקול", desc: "הליך שבו מבקש החייב לבטל עיקול שהוטל על נכסיו או חשבונו. ניתן לבקש ביטול עיקול בשל פגמים בהטלתו, חוסר יכולת כלכלית, או הגעה להסדר עם הנושה. הבקשה מוגשת לרשם ההוצאה לפועל, שיחליט לאחר שמיעת שני הצדדים.", guide: "/guides/bitul-ikul/" },
    { name: "ביטוח לאומי — פטור מעיקול", desc: "קצבאות המשולמות על ידי המוסד לביטוח לאומי כגון קצבת נכות, קצבת זקנה ודמי אבטלה מוגנות מפני עיקול. מדובר בהכנסה הנחשבת כ\"בסיס קיום\" ולכן אינה ניתנת לעיקול על ידי נושה רגיל. חריג קיים לחובות מזונות, שכן ניתן לעקל חלק מהקצבה גם במקרה זה." },
    { name: "בקשה לרשם", desc: "פנייה רשמית לרשם ההוצאה לפועל לצורך קבלת החלטה בעניין מסוים — ביטול עיקול, קביעת תשלומים, הסרת הגבלה וכדומה. הבקשה מוגשת בכתב בצירוף תצהיר ואסמכתאות רלוונטיות. יש לשלם אגרה עבור הגשת בקשות מסוימות." },
  ] },
  { id: "gimel", letter: "ג", terms: [
    { name: "גביית חוב", desc: "כלל הפעולות המשפטיות והמעשיות שנוקט נושה כדי לקבל את כספו מהחייב. כוללת שליחת דרישות תשלום, פתיחת תיק הוצאה לפועל, הטלת עיקולים ומכירת נכסים. ישנם גבולות חוקיים ברורים לגביית חוב — אין מדובר בשרות עצמי." },
    { name: "גמלה", desc: "תשלום תקופתי המשולם לאדם הזכאי לו — לרוב מהביטוח הלאומי או ממקום עבודה לשעבר. גמלאות רבות מוגנות מפני עיקול מאחר שהן מהוות מקור פרנסה בסיסי. יש לבדוק בכל מקרה לגופו אם הגמלה הספציפית ניתנת לעיקול ובאיזה שיעור." },
    { name: "גרעון", desc: "הפרש שלילי בין הכנסות לבין הוצאות ו/או התחייבויות. בהקשר של הוצאה לפועל — כאשר חייב אינו מסוגל לכסות את חובותיו מהכנסותיו השוטפות. גרעון מתמשך עשוי להוביל לחדלות פירעון ולהליך שיקום כלכלי." },
    { name: "גישור", desc: "הליך חוץ-משפטי שבו צד שלישי ניטרלי (המגשר) מסייע לחייב ולנושה להגיע להסכמה מרצון. גישור מוצלח בנושא חוב יכול למנוע את ההגעה לבית משפט ולחסוך עלויות לשני הצדדים. ניתן לנסות גישור גם לאחר פתיחת תיק הוצאה לפועל — הסכם שמושג יגרור סגירת התיק." },
  ] },
  { id: "dalet", letter: "ד", terms: [
    { name: "דמי פיגורים", desc: "תוספת לחוב המקורי הנגבית עקב איחור בתשלום — מעבר לריבית הרגילה. בתיקי הוצאה לפועל, דמי הפיגורים מצטברים על גבי הקרן ועלולים לנפח משמעותית את יתרת החוב. חשוב לפעול מהר כדי לעצור את צבירת דמי הפיגורים." },
    { name: "דירוג אשראי", desc: "ציון המבטא את רמת האמינות הפיננסית של אדם, המחושב על בסיס היסטוריית תשלומים ומצב חובות. תיק הוצאה לפועל פתוח פוגע קשות בדירוג האשראי ומקשה על קבלת הלוואות, משכנתאות ושירותים בנקאיים. סגירת התיק ופירעון החוב תורמים להתאוששות הדירוג לאורך זמן." },
    { name: "דרכון — הגבלה", desc: "רשם ההוצאה לפועל רשאי להורות על עיכוב יציאה מהארץ, אך אינו יכול לבטל את הדרכון עצמו. ה\"הגבלת הדרכון\" שנשמעת לפעמים מתייחסת בפועל לצו עיכוב יציאה מהארץ. ניתן לבקש הסרת הגבלה זו עם הסרת הגבלות אחרות מעמד חייב מוגבל." },
  ] },
  { id: "he", letter: "ה", terms: [
    { name: "הגבלות — רשימה", desc: "על חייב משתמט (חייב בעל יכולת שאינו משלם, סעיף 66א) ניתן להטיל הגבלות: עיכוב יציאה מהארץ (בחוב מעל 50,000 ₪), הגבלת כרטיסי אשראי ושיקים, ואיסור ייסוד תאגיד. הגבלת רישיון נהיגה בוטלה בתיקון 69 (פברואר 2022). ההגבלות מוסרות עם פירעון החוב, הסדר מאושר, או בקשה מוצדקת לרשם.", guide: "/guides/hayav-mugbal/" },
    { name: "הגנה על דירת מגורים", desc: "החוק קובע שדירת מגורים יחידה של חייב מוגנת בפני מכירה כפויה אם ערכה אינו עולה על תקרה מסוימת. עם זאת, ניתן לרשום עיקול על הדירה ולמנוע את מכירתה על ידי החייב עצמו. בתנאים מסוימים בית המשפט רשאי לאשר מכירה גם של דירה יחידה, בפרט בחובות גדולים.", guide: "/guides/ikul-dira/" },
    { name: "הוצאה לפועל — הגדרה", desc: "המנגנון המשפטי שמאפשר לנושה לממש פסק דין או שטר חוב ולגבות את כספו מהחייב בסיוע המדינה. מנוהלת על ידי רשות האכיפה והגבייה שפועלת מטעם משרד המשפטים. הליך ההוצאה לפועל כולל עיקולים, הגבלות, מכירת נכסים ועוד." },
    { name: "הוצל\"פ נט", desc: "מערכת מקוונת של רשות האכיפה והגבייה המאפשרת לחייבים ולזוכים לבצע פעולות דרך האינטרנט. דרכה ניתן לבדוק יתרת חוב, לשלם, לעיין בתיק ולהגיש בקשות מסוימות. כתובת: eca.gov.il" },
    { name: "הממונה על הליכי חדלות פירעון", desc: "הרשות הממשלתית במשרד המשפטים המפקחת על הליכי חדלות פירעון ושיקום כלכלי לפי החוק משנת 2019. הממונה מקבל בקשות לפתיחת הליכים בחובות גבוהים (מעל 176,923 ₪ נכון ל-2026), ממנה נאמנים ומפקח עליהם, ומנהל מרשם ציבורי של ההליכים. תפקיד זה החליף את \"כונס הנכסים הרשמי\" (הכנ\"ר) מפקודת פשיטת הרגל הישנה.", guide: "/guides/pshitat-regel/" },
    { name: "המצאה", desc: "מסירה רשמית של מסמך משפטי לנמען — כגון אזהרה, צו עיקול, או הזמנה לדיון. ההמצאה יוצרת את \"שעון הזמן\" לתגובת החייב — ממנה מתחיל מניין הימים לפעולה. ניתן לבצע המצאה ידנית, בדואר רשום, או בדרכים אלקטרוניות שאושרו בחוק." },
    { name: "הפטר", desc: "שחרור סופי וחוקי מכל החובות שנכללו בהליך חדלות פירעון או פשיטת רגל. לאחר קבלת הפטר, הנושים אינם יכולים לתבוע את החייב בגין אותם חובות. ניתן לאחר שהחייב עמד בכל תנאי תוכנית הפירעון (צו השיקום הכלכלי) שקבע בית המשפט או הרשם.", guide: "/guides/pshitat-regel/" },
    { name: "הצהרת נכסים", desc: "מסמך שחייב נדרש להגיש בו פירוט מלא של כל נכסיו, הכנסותיו, הוצאותיו וחובותיו. מוגשת לרשם ההוצאה לפועל לצורך קביעת יכולת הפירעון ותנאי התשלום. מסירת פרטים כוזבים בהצהרת נכסים עלולה להוות עבירה פלילית." },
    { name: "התיישנות", desc: "חסימה משפטית של תביעה לאחר שחלפה תקופה קבועה בחוק (בדרך כלל 7 שנים לחובות כספיים). חוב שהתיישן אינו ניתן לאכיפה בבית משפט, אך על החייב לטעון את הטענה מפורשות. פעולות גבייה מסוימות מפסיקות את מרוץ ההתיישנות ומחזירות אותו לאפס.", guide: "/guides/hitiyashnoot-chov/" },
  ] },
  { id: "vav", letter: "ו", terms: [
    { name: "ועדת ערר", desc: "גוף מינהלי שאפשר לערור בפניו על החלטות רשויות מסוימות (כגון הרשות המקומית בענין ארנונה). בהקשר הוצאה לפועל — הערר מוגש לרשם ההוצאה לפועל ולאחריו לבית המשפט. יש לשים לב למועדי הגשה קצרים שנקבעים בחוק." },
    { name: "ויתור על חוב", desc: "הסכמה של הנושה לוותר על חלק מהחוב או על כולו — לרוב כחלק מהסדר פשרה. ויתור רשמי מחייב תיעוד כתוב ואישור סגירת תיק ההוצאה לפועל. מוותר על חוב? בדוק עם רואה חשבון — במקרים מסוימים מדובר בהכנסה חייבת במס." },
  ] },
  { id: "zayin", letter: "ז", terms: [
    { name: "זוכה", desc: "הצד שפתח תיק הוצאה לפועל — הנושה שזכה בפסק דין ורוצה לגבות את חובו. הזוכה הוא הצד הפעיל בתיק: הוא מגיש בקשות לנקיטת הליכים ובוחר את אמצעי הגבייה. בשיח היומיומי משתמשים לפעמים גם במושג \"הנושה\" לאותו גורם." },
    { name: "זכות עיון", desc: "הזכות של חייב לעיין בכל מסמכי תיק ההוצאה לפועל הנוגעים לו — כולל הבקשות, הצווים וההחלטות. ניתן לממש זכות זו בלשכת ההוצאה לפועל הרלוונטית. עיון בתיק חיוני לבניית טענות הגנה מדויקות." },
    { name: "זכות קיום — בסיס קיום", desc: "עיקרון חוקי לפיו לחייב מובטחת הכנסה מינימלית בסיסית שאינה ניתנת לעיקול. הסכום מחושב לפי שכר המינימום (בערך) ומותאם לגודל המשפחה. המדינה מכירה בכך שאין להותיר חייב ומשפחתו ללא אמצעי מחיה." },
  ] },
  { id: "chet", letter: "ח", terms: [
    { name: "חדלות פירעון", desc: "מצב משפטי ופיננסי שבו חייב אינו מסוגל לפרוע את חובותיו במועדם. מאז 2019 הוחלף הליך \"פשיטת הרגל\" הישן בהליך חדלות פירעון ושיקום כלכלי, שמקנה מסלול שיקום קצר ומהיר יותר. ניתן ליזום את ההליך גם לבקשת הנושה וגם ביוזמת החייב עצמו.", guide: "/guides/pshitat-regel/" },
    { name: "חוב — הגדרה", desc: "התחייבות כספית שאדם חייב לאדם אחר, לגוף פיננסי, לרשות ממשלתית או לחברה. בהוצאה לפועל מדובר בחוב שקיבל תוקף משפטי — בפסק דין, שטר חוב, המחאה שחזרה ועוד. החוב כולל לרוב קרן, ריבית, הצמדה ואגרות שנצברו." },
    { name: "חוב מוכר", desc: "חוב שהחייב הסכים לו רשמית או לא חלק עליו בהזדמנות הראשונה. \"הכרה בחוב\" עלולה להפסיק את מרוץ ההתיישנות ולחדש את תוקפו המשפטי. לפני הכרה בכל חוב — בעל פה או בכתב — מומלץ להיוועץ עם גורם מקצועי." },
    { name: "חוב מזונות", desc: "חוב הנובע מפסק דין מזונות לילדים או לבן/בת זוג. לחוב מזונות מעמד מועדף בדיני האכיפה — הוא קודם לחובות אחרים ואינו ניתן לכלול בהליך חדלות פירעון. ניתן לגבות חוב מזונות גם מגמלאות ביטוח לאומי שאחרת פטורות מעיקול." },
    { name: "חייב", desc: "הצד שנגדו נפתח תיק ההוצאה לפועל — מי שחייב כסף לזוכה ואינו שילם. החייב הוא הצד \"הסביל\" בתיק: הוא מגיב לבקשות הזוכה ויכול להגיש התנגדויות ובקשות. זכויות החייב מוגנות בחוק — אין לנהוג בו בשרירות." },
    { name: "חייב מוגבל באמצעים", desc: "מעמד היסטורי שהוכרז לחייבים שלא יכלו לפרוע את חובם בפרקי הזמן שבחוק. מאז 15.9.2019 לא מכריזים על חייבים מוגבלים חדשים — המסלול הוחלף בהליכי חדלות פירעון; מי שהוכרז לפני כן נשאר במעמד. על החייב לעדכן את הרשם בשינויים במצבו הכלכלי.", guide: "/guides/hayav-mugbal/" },
    { name: "חקירת יכולת", desc: "דיון שבו נחקר החייב בפני רשם ההוצאה לפועל על מצבו הכלכלי — הכנסות, הוצאות, נכסים וחובות. הרשם משתמש במידע שנאסף לצורך קביעת צו תשלומים ו/או מתן מעמד חייב מוגבל. הגעה לחקירת יכולת היא חובה חוקית — אי-הופעה עלולה לגרור הוצאת צו מאסר." },
  ] },
  { id: "tet", letter: "ט", terms: [
    { name: "טאבו — רישום מקרקעין", desc: "לשכת רישום המקרקעין (\"טאבו\") שומרת את רישומי הבעלות על קרקעות ובתים בישראל. כאשר מוטל עיקול על נכס מקרקעין, הוא נרשם בטאבו ומונע מכירה עתידית ללא אישור. כל אדם יכול לבדוק רישומי טאבו באופן מקוון לגבי כל נכס." },
    { name: "טופס 7", desc: "טופס רשמי של רשות האכיפה והגבייה — \"בקשת חייב לאיחוד תיקים\". באמצעותו חייב שיש נגדו כמה תיקים מבקש לאחד אותם לתיק אחד עם תשלום חודשי אחד. ניתן להוריד מאתר gov.il. טפסים מרכזיים נוספים: טופס 214 (ביטול/עיכוב הליכים), טופס 233 (בקשה לצו חיוב בתשלומים) וטופס 529 (שאלון וכתב ויתור על סודיות)." },
    { name: "טפסי הוצאה לפועל", desc: "מגוון רחב של טפסים רשמיים המשמשים לפעולות שונות בתיק — פתיחת תיק, בקשות, תגובות, תצהירים וכדומה. ניתן להוריד את הטפסים מאתר רשות האכיפה והגבייה או לקבלם בלשכה. מילוי נכון ומדויק של הטפסים הוא קריטי — טעויות עלולות לגרום לדחיית הבקשה." },
  ] },
  { id: "yod", letter: "י", terms: [
    { name: "יכולת פירעון", desc: "הערכה של מידת יכולתו של חייב לשלם את חובותיו, בהתבסס על הכנסותיו, נכסיו והוצאותיו הבסיסיות. הרשם מעריך יכולת פירעון בחקירת יכולת ולאחר עיון בהצהרת הנכסים. ממצאי ההערכה קובעים את גובה התשלום החודשי ואת הזכאות למעמד חייב מוגבל." },
    { name: "יורש וחוב", desc: "יורש עזבון שנפטר אינו חייב בחובות המנוח מכיסו הפרטי — הוא אחראי רק עד לגובה ירושתו. כלומר, נושים של המנוח יוכלו לגבות רק מהעיזבון ולא מהרכוש הפרטי של היורש. אם לא נותר דבר בעיזבון, הנושים לא יוכלו לתבוע את היורשים." },
  ] },
  { id: "kaf", letter: "כ", terms: [
    { name: "כינוס נכסים", desc: "הליך שבו בית המשפט ממנה כונס נכסים — בדרך כלל עורך דין — לנהל ולממש נכסי חייב לשם פירעון חובותיו. כינוס נכסים מתבצע לרוב על נכס ספציפי (כמו דירה) ולא על כלל נכסי החייב. הוא פולשני יותר מאמצעי גבייה רגילים ומשמש ביחס לחובות גדולים.", guide: "/guides/kinnus-nechasim/" },
    { name: "כלי עבודה — פטור", desc: "כלים וציוד המשמשים חייב לפרנסתו מוגנים מפני עיקול עד לשווי מסוים הקבוע בחוק. ההגיון הוא שאם ייעקל הכלי מפרנסתו, לא יוכל החייב לכסות את חובו בעתיד. הפטור חל על כלי עבודה בסיסיים ולא על ציוד יקר ערך הניתן להחלפה." },
    { name: "כל-זכות", desc: "אתר ממשלתי (kol-zchut.gov.il) המרכז מידע על זכויות הציבור בישראל, כולל בנושא הוצאה לפועל. מקור מידע אמין ומוסמך הכתוב בשפה נגישה, מומלץ לצד המידע שתמצאו כאן. כולל מידע על הגבלות, הטבות, ועוד." },
    { name: "כרטיס אשראי — עיקול", desc: "חייב מוגבל באמצעים עלול לאבד את זכותו לכרטיסי אשראי כחלק מהגבלות החוק. חברות כרטיסי האשראי רשאיות לבטל את הכרטיס עם הטלת ההגבלה. ישנם כרטיסים חיוביים (דביט) שאינם מושפעים מהליכי הוצאה לפועל." },
  ] },
  { id: "lamed", letter: "ל", terms: [
    { name: "לשכת הוצאה לפועל", desc: "הגוף המקומי שמנהל את תיקי ההוצאה לפועל, בפיקוח רשות האכיפה והגבייה. ישנן לשכות רבות ברחבי הארץ — החייב פונה לפי מקום המגורים או מיקום הנכס. בלשכה ניתן להגיש בקשות, לשלם חוב, לעיין בתיק ולהיפגש עם רשם." },
    { name: "לשכת רישום מקרקעין", desc: "הגוף הממשלתי האחראי לרישום בעלות ועסקאות מקרקעין (הידוע בכינוי \"טאבו\"). בעת עיקול נכס נדל\"ן, ההוצאה לפועל מורה ללשכה לרשום הערה על הנכס. ניתן לבדוק רישומים בלשכה ולגלות אם יש עיקול על נכס מסוים." },
  ] },
  { id: "mem", letter: "מ", terms: [
    { name: "מזונות", desc: "תשלום חודשי שחייב אדם לשלם לבן/בת זוגו לשעבר ו/או לילדיו הקטינים בהתאם לפסק דין. חובות מזונות הם בעלי עדיפות גבוהה במיוחד בדיני האכיפה — לא ניתן לפשוט רגל מחובות מזונות. ניתן לגבות פיגורי מזונות בהוצאה לפועל ולהטיל עיקול על משכורת, חשבון בנק ועוד." },
    { name: "מנהל מיוחד", desc: "מונח מפקודת פשיטת הרגל הישנה — גורם שמינה בית המשפט לנהל את נכסי החייב ולחלקם לנושים, בפיקוח כונס הנכסים הרשמי (הכנ\"ר). מאז חוק חדלות פירעון ושיקום כלכלי (בתוקף ספטמבר 2019) התפקיד מכונה \"נאמן\", והוא פועל בפיקוח \"הממונה על הליכי חדלות פירעון ושיקום כלכלי\" שהחליף את הכנ\"ר. המונח עדיין עשוי להופיע בתיקים ישנים." },
    { name: "מסמכי אכיפה", desc: "מסמכים המהווים בסיס לפתיחת תיק הוצאה לפועל — פסק דין, שטר חוב, המחאה חוזרת, חוזה שאינו נפרע ועוד. בלא מסמך אכיפה תקף, לא ניתן לפתוח תיק. סוג המסמך משפיע על הליך ההוצאה לפועל ועל זכויות החייב." },
    { name: "מעקל", desc: "השם לנכס או לכסף שהוטל עליו עיקול — \"נכס מעוקל\" הוא נכס שעליו הוטל עיקול. מעקל גם מתייחס לגורם המחזיק בנכס המעוקל (כמו בנק המחזיק בכספי החייב). ניתן גם לכנות \"מעקל\" את הגורם שמוטל עליו חובה להעביר כספים לתיק." },
    { name: "מעקל — צד שלישי", desc: "גורם שבידיו מוחזקים כספים או נכסים של החייב, כמו בנק, מעביד, לקוח עסקי. כאשר מוטל עיקול אצל צד שלישי, הוא מחויב בחוק להעביר את הכספים לתיק ההוצאה לפועל. אי-ציות לצו עיקול מצד שלישי עלול לחייב אותו לשלם את הסכום מכיסו." },
    { name: "מקרקעין — עיקול", desc: "עיקול על נכס נדל\"ן — דירה, קרקע, מחסן, חנות וכדומה — הנרשם בלשכת רישום המקרקעין. העיקול מונע מהחייב למכור את הנכס מבלי להסדיר את החוב תחילה. בנסיבות מסוימות ניתן למכור את הנכס בכפייה לאחר קבלת אישור בית המשפט.", guide: "/guides/ikul-dira/" },
    { name: "משכורת — עיקול", desc: "עיקול המוטל על שכר העבודה של החייב, כאשר המעביד מנכה חלק ממשכורתו ומעביר לתיק ההוצאה לפועל. לחייב מובטח \"שכר מינימום נקי\" שאינו ניתן לעיקול בשום מצב. שיעור העיקול נקבע לפי היחס בין ההכנסה לבין בסיס הקיום.", guide: "/guides/ikul-maskoret/" },
    { name: "משכנתא", desc: "הלוואה לרכישת נדל\"ן שבה הנכס עצמו משמש ערבות (שעבוד) להלוואה. אי-עמידה בתשלומי משכנתא עלולה להוביל לכינוס נכסים ומכירת הנכס על ידי הבנק. הבנק הממשכן נחשב לנושה מובטח ויש לו עדיפות על פני נושים אחרים." },
  ] },
  { id: "nun", letter: "נ", terms: [
    { name: "נאמן", desc: "בעל התפקיד שממנה בית המשפט או הממונה בהליך חדלות פירעון של יחיד לפי החוק החדש (2019). הנאמן בוחן את מצבו הכלכלי של החייב, מנהל את נכסי קופת הנשייה, גובה את התשלום החודשי מהחייב ומחלק אותו לנושים, ומגיש לבית המשפט המלצה לצו שיקום ולהפטר. הנאמן החליף את \"המנהל המיוחד\" מהמשטר הישן.", guide: "/guides/pshitat-regel/" },
    { name: "נושה", desc: "האדם או הגוף שלזכותו קיים החוב — מי שמגיע לו הכסף מהחייב. נושה יכול להיות בנק, ספק, בן משפחה, רשות ממשלתית, חברת אשראי וכדומה. נושה מובטח (כמו בנק עם משכנתא) נחשב בעל עדיפות על פני נושה רגיל." },
    { name: "נכס — הגדרה", desc: "כל דבר בעל ערך כספי שהחייב הוא הבעלים שלו — כסף, דירה, רכב, ניירות ערך, חסכונות, זכויות וכדומה. נכסים מהווים את הבסיס לגביית החוב: הנושה מנסה לאתר נכסים ולממשם. ישנם נכסים מוגנים מפני עיקול, ואחרים שניתן לעקל ולמכור." },
    { name: "נכסים מוגנים", desc: "נכסים שהחוק קובע שאינם ניתנים לעיקול, כגון: כלי עבודה בסיסיים, ריהוט בית ביתי, בגדים, ספרי לימוד, ועוד. ההגנה נועדה לאפשר לחייב להמשיך לתפקד ולפרנס את משפחתו. הרשימה המדויקת קבועה בתקנות ההוצאה לפועל ומתעדכנת מדי פעם." },
  ] },
  { id: "samech", letter: "ס", terms: [
    { name: "סגירת תיק", desc: "סיום תיק ההוצאה לפועל עם פירעון מלא של החוב, הסדר מוסכם, או התיישנות. עם סגירת התיק מוסרות כל ההגבלות וההערות הרשומות על שם החייב. חשוב לבקש מהזוכה אישור בכתב על סגירת התיק ולוודא שהלשכה עדכנה את הרישומים." },
    { name: "סיוע משפטי", desc: "שירות ממשלתי המספק ייעוץ וייצוג משפטי חינמי לאנשים שאינם יכולים לממן עורך דין. ניתן לפנות ללשכות הסיוע המשפטי בכל הארץ בענייני הוצאה לפועל ואכיפה. הזכאות נבדקת לפי מצב כלכלי — לא כולם זכאים, אך חייבים רבים עומדים בתנאים." },
  ] },
  { id: "ayin", letter: "ע", terms: [
    { name: "עיכוב הליכים", desc: "צו שיורה בית המשפט להפסיק באופן זמני את פעולות ההוצאה לפועל כנגד חייב. ניתן לבקש עיכוב הליכים בעת פתיחת הליך חדלות פירעון או בעת ערעור על פסק הדין הבסיסי. עיכוב הליכים מספק \"הקפאה\" שמאפשרת לחייב להסדיר את ענייניו בלי לחץ מיידי." },
    { name: "עיכוב יציאה מהארץ", desc: "הגבלה המוטלת על חייב מוגבל באמצעים, המונעת ממנו לצאת מישראל. מונפקת על ידי רשם ההוצאה לפועל ומועברת לרשויות הגבול. ניתן לבקש הסרת ההגבלה זמנית לצורך נסיעה דחופה, בהוכחת נסיבות מיוחדות." },
    { name: "עיקול", desc: "צו משפטי המקפיא נכס של החייב ומונע ממנו להשתמש בו או למכרו עד לפירעון החוב. עיקול יכול לחול על חשבון בנק, משכורת, רכב, דירה, פנסיה וכל נכס אחר. הטלת עיקול אינה אוטומטית — הזוכה צריך לבקש אותה, והרשם אמור לאשרה." },
    { name: "עיקול זמני", desc: "עיקול המוטל לפני מתן פסק דין, כדי למנוע מהחייב להבריח נכסים עד לסיום ההליך המשפטי. עיקול זמני מחייב צד המבקשו להפקיד ערבות ולהוכיח ראייה לכאורית לחובו. אם זוכה התובע בדין — העיקול הזמני הופך לסופי. אם הפסיד — העיקול מוסר." },
    { name: "עיקול חשבון בנק", desc: "עיקול על כספים בחשבון עו\"ש, חסכון או כל חשבון בנק אחר של החייב. הבנק מקבל הוראה מלשכת ההוצאה לפועל להקפיא את הכספים ולהעבירם. החשבון יקפא עד לגובה החוב הנקוב בצו — לא מעבר לכך.", guide: "/guides/ikul-heshbon/" },
    { name: "עיקול משכורת", desc: "עיקול המוטל על שכר עבודתו של החייב — המעביד מחויב להעביר חלק מהמשכורת ישירות לתיק. שיעור העיקול מחושב לפי נוסחה הלוקחת בחשבון את מצב המשפחה ואת ההכנסה. לא ניתן לפטר עובד בשל עיקול משכורת — זוהי עילת פיטורין אסורה.", guide: "/guides/ikul-maskoret/" },
    { name: "עיקול נכסים", desc: "עיקול המוטל על נכסים מוחשיים שבבעלות החייב — ריהוט, ציוד, מלאי עסקי, כלי רכב ועוד. נכסים מעוקלים ניתנים בסופו של דבר למכירה בהוצאה לפועל אם החוב אינו משולם. ישנם חפצים פטורים מעיקול בשל חשיבותם הבסיסית לחייב ולמשפחתו." },
    { name: "עיקול פנסיה", desc: "קרן פנסיה וקרן השתלמות מוגנות מפני עיקול בשלב הצבירה, אך כאשר החייב מושך את הכספים הם עשויים להיות חשופים. קצבת פנסיה (תשלום חודשי לגמלאי) ניתנת לעיקול חלקי בדומה לשכר עבודה. הכללים שונים לגבי ביטוח מנהלים, קרן פנסיה מקיפה ופנסיה תקציבית.", guide: "/guides/ikul-pensiya/" },
    { name: "עיקול רכב", desc: "עיקול על כלי רכב של החייב — נרשם ברשות הרישוי ומונע העברת הבעלות. אם הרכב דרוש לחייב לצורך פרנסתו (כגון מונית, משאית), ניתן לבקש להסיר את העיקול. ניתן גם לעקל רכב פיזית — לגרור אותו ולמכרו — בנסיבות מסוימות." },
    { name: "עיקול שלילי", desc: "תוצאה שבה עיקול חשבון הבנק הביא ליתרת חשבון שלילית בשל נכיית כספים שהיו בחשבון. מצב זה עלול לגרום לקשיים בניהול השוטף — שיקים שחוזרים, תשלומים קבועים שאינם מכובדים. יש לפעול מיידית להסדרת המצב — פנו ללשכה ולבנק בהקדם.", guide: "/guides/ikul-heshbon/" },
    { name: "ערב", desc: "אדם שחתם על ערבות להלוואה או לחוב של אדם אחר — אם החייב לא ישלם, הנושה יפנה לערב. ערב יכול להיות חשוף לאותם הליכי הוצאה לפועל כמו החייב עצמו. קיימת הגנה מיוחדת ל\"ערב מוגן\" בחוק הערבות.", guide: "/guides/arev/" },
    { name: "ערב מוגן", desc: "קטגוריה מיוחדת של ערב שחוק הערבות מעניק לו הגנות נוספות — לרוב מדובר בערב שאינו בעל עניין בהלוואה. הנושה חייב להזהיר ערב מוגן על הסיכונים ולהודיע לו על אי-תשלום לפני פנייה לערב. הערב המוגן רשאי לבטל את ערבותו בתנאים מסוימים.", guide: "/guides/arev/" },
    { name: "ערעור", desc: "פנייה לערכאה גבוהה יותר כדי לשנות החלטה של ערכאה נמוכה יותר. על החלטות רשם ההוצאה לפועל ניתן לערער לבית משפט שלום תוך 20 יום. על פסק דין של בית משפט שלום ניתן לערער לבית משפט מחוזי. מועדי הגשה קצרים — אל תפספסו." },
  ] },
  { id: "pe", letter: "פ", terms: [
