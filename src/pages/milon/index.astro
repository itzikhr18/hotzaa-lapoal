    { name: "פסק דין בהיעדר", desc: "פסק דין שניתן כאשר הנתבע לא התייצב לדיון ולא הגיש כתב הגנה. ניתן לבקש ביטול פסק דין בהיעדר אם יש הצדקה לאי-ההתייצבות וסיכוי להגנה. יש לפעול מהר — הגשת הבקשה חייבת להיות תוך 30 יום מיום שנודע לנתבע על פסק הדין." },
    { name: "פשיטת רגל", desc: "ההליך המשפטי הישן (טרם 2019) שאִפשר לחייב שאינו יכול לפרוע חובותיו לקבל הפטר בתום תהליך. מאז 2019 הוחלף ב\"הליך חדלות פירעון ושיקום כלכלי\" המהיר יותר ויעיל יותר. המושג \"פשיטת רגל\" עדיין נפוץ בשיח היומיומי ומתייחס בפועל להליך החדש.", guide: "/guides/pshitat-regel/" },
    { name: "פתיחת תיק", desc: "הצעד הראשון שנוקט הנושה (הזוכה) — הגשת בקשה רשמית ללשכת ההוצאה לפועל לפתיחת תיק גבייה. כוללת תשלום אגרת פתיחה, הגשת מסמך האכיפה (פסק דין וכדומה) וטופס הבקשה. לאחר אישור הפתיחה, נשלחת אזהרה לחייב." },
  ] },
  { id: "tsadi", letter: "צ", terms: [
    { name: "צו הריסה", desc: "צו שיפוטי המורה על הריסת מבנה שנבנה ללא היתר או בניגוד לתנאי ההיתר. ניתן לאכוף צו הריסה דרך הוצאה לפועל אם בעל הנכס מסרב לציית. חוב הנובע מאי-ציות לצו הריסה עשוי לצמוח לסכומים גבוהים מאוד." },
    { name: "צו תשלומים", desc: "החלטת רשם ההוצאה לפועל הקובעת לוח תשלומים חודשי לפירעון החוב. הצו מבסס תשלום חודשי ריאלי לפי יכולת החייב, ומפסיק הטלת הגבלות נוספות. אי-עמידה בצו תשלומים עלולה לחדש את ההליכים — חשוב לעמוד בתשלומים במועד.", guide: "/guides/tzav-tashlumim/" },
    { name: "צו עיקול", desc: "הצו הרשמי שמנפיקה לשכת ההוצאה לפועל להטלת עיקול על נכס ספציפי. הצו נשלח לגורם המחזיק בנכס (בנק, מעביד, רשם מקרקעין) עם הוראה לפעול. מרגע קבלת הצו, הגורם המחזיק חייב לציית תוך זמן קצוב." },
  ] },
  { id: "kuf", letter: "ק", terms: [
    { name: "קופת גמל", desc: "חיסכון פנסיוני לטווח ארוך שכספי החיסכון בו אינם ניתנים לעיקול בשלב הצבירה. עם פדיון הקרן (משיכה בגיל פרישה) הכספים עשויים להיות חשופים לעיקול. בנסיבות מסוימות ניתן לבקש פדיון מוקדם — אך שים לב לעיקול שעשוי לחול." },
    { name: "קרן השתלמות", desc: "חיסכון לטווח קצר-בינוני (לרוב 6 שנים) עם הטבות מס — ניתן לפדיון לאחר תקופת ותק. מוגנת מפני עיקול בשלב הצבירה ולפני הבשלת הזכאות לפדיון. לאחר שניתן לפדות את הקרן, כספים שנמשכו עשויים להיות חשופים לעיקול." },
    { name: "קרן פנסיה", desc: "חיסכון חובה לגיל פרישה המשולם לעובד כקצבה חודשית (ולא כסכום חד-פעמי). כספי קרן פנסיה מוגנים מעיקול בשלב הצבירה, אך הקצבה החודשית ניתנת לעיקול חלקי. שיעור העיקול על קצבת פנסיה מחושב בדומה לעיקול משכורת.", guide: "/guides/ikul-pensiya/" },
  ] },
  { id: "resh", letter: "ר", terms: [
