---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const publishDate = '2026-03-31';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'מילון מושגים — הוצאה לפועל בעברית פשוטה',
  description: '100+ מושגי הוצאה לפועל מוסברים בעברית פשוטה. מאגר המונחים המקיף ביותר לחייבים בישראל.',
  inLanguage: 'he',
  url: 'https://hotzaa-lapoal.info/milon/',
  datePublished: publishDate,
  hasDefinedTerm: [
    {
      '@type': 'DefinedTerm',
      name: 'עיקול',
      description: 'צו משפטי המונע מהחייב להשתמש בנכס מסוים או בכספים עד לפירעון החוב.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
    {
      '@type': 'DefinedTerm',
      name: 'צו תשלומים',
      description: 'החלטת רשם ההוצאה לפועל הקובעת לוח זמנים לפירעון החוב בתשלומים חודשיים.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
    {
      '@type': 'DefinedTerm',
      name: 'חייב מוגבל באמצעים',
      description: 'מעמד רשמי שמוענק לחייב שאינו יכול לשלם את חובותיו, המקנה לו הגנות מסוימות.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
    {
      '@type': 'DefinedTerm',
      name: 'כינוס נכסים',
      description: 'הליך שבו ממנים כונס נכסים שמוכר את נכסי החייב לשם פירעון חובותיו.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
    {
      '@type': 'DefinedTerm',
      name: 'חדלות פירעון',
      description: 'מצב שבו אדם אינו מסוגל לפרוע את חובותיו, ועשוי לעבור הליך שיקום כלכלי.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
    {
      '@type': 'DefinedTerm',
      name: 'הפטר',
      description: 'שחרור סופי מחובות בסיום הליך חדלות פירעון או פשיטת רגל.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
    {
      '@type': 'DefinedTerm',
      name: 'עיכוב יציאה מהארץ',
      description: 'הגבלה המונעת מחייב לצאת מישראל עד לפירעון חובו.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
    {
      '@type': 'DefinedTerm',
      name: 'זוכה',
      description: 'הנושה — הצד שזכה בפסק הדין ופתח תיק הוצאה לפועל לגביית חובו.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
    {
      '@type': 'DefinedTerm',
      name: 'ריבית פיגורים',
      description: 'ריבית גבוהה המצטברת על חוב שלא שולם במועד, לפי חוק פסיקת ריבית והצמדה.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
    {
      '@type': 'DefinedTerm',
      name: 'איחוד תיקים',
      description: 'הליך המאגד מספר תיקי הוצאה לפועל לתיק אחד, עם תשלום חודשי אחד מפוצל בין הנושים.',
      inDefinedTermSet: 'https://hotzaa-lapoal.info/milon/',
    },
  ],
};
---

<BaseLayout
  title="מילון מושגים — הוצאה לפועל בעברית פשוטה"
  description="100+ מושגי הוצאה לפועל מוסברים בעברית פשוטה. מאגר המונחים המקיף ביותר לחייבים בישראל."
  canonicalUrl="https://hotzaa-lapoal.info/milon/"
  ogType="website"
  schema={schema}
>
  <Header />

  <main id="main-content">

    <!-- Hero -->
    <section class="bg-gradient-to-l from-blue-700 to-blue-900 text-white py-12 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-blue-200 text-sm font-medium mb-2">מאגר מונחים | עודכן מרץ 2026</p>
        <h1 class="text-3xl md:text-4xl font-bold mb-4">מילון מושגים — הוצאה לפועל בעברית פשוטה</h1>
        <p class="text-lg text-blue-100 max-w-2xl mx-auto">
          100+ מושגי הוצאה לפועל, עיקולים וחדלות פירעון — מוסברים בשפה ברורה, ללא עורכי דין.
          מאגר המונחים המקיף ביותר לחייבים בישראל.
        </p>
      </div>
    </section>

    <!-- Sticky alpha nav -->
    <nav aria-label="ניווט לפי אות" class="sticky top-0 z-30 bg-white border-b border-gray-200 shadow-sm overflow-x-auto">
      <div class="max-w-4xl mx-auto px-2 py-2 flex gap-1 flex-nowrap text-sm font-medium">
        <a href="#alef"   class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">א</a>
        <a href="#bet"    class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ב</a>
        <a href="#gimel"  class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ג</a>
        <a href="#dalet"  class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ד</a>
        <a href="#he"     class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ה</a>
        <a href="#vav"    class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ו</a>
        <a href="#zayin"  class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ז</a>
        <a href="#chet"   class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ח</a>
        <a href="#tet"    class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ט</a>
        <a href="#yod"    class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">י</a>
        <a href="#kaf"    class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">כ</a>
        <a href="#lamed"  class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ל</a>
        <a href="#mem"    class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">מ</a>
        <a href="#nun"    class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">נ</a>
        <a href="#samech" class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ס</a>
        <a href="#ayin"   class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ע</a>
        <a href="#pe"     class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">פ</a>
        <a href="#tsadi"  class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">צ</a>
        <a href="#kuf"    class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ק</a>
        <a href="#resh"   class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ר</a>
        <a href="#shin"   class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ש</a>
        <a href="#tav"    class="px-2 py-1 rounded hover:bg-blue-50 text-blue-700 whitespace-nowrap">ת</a>
      </div>
    </nav>

    <div class="max-w-4xl mx-auto px-4 py-10">

      <!-- א -->
      <section id="alef" class="mb-10 scroll-mt-16">
        <h2 class="text-2xl font-bold text-blue-800 border-b-2 border-blue-200 pb-2 mb-5">א</h2>
        <dl>

          <dt class="font-bold text-gray-800 text-base mt-4">אגרה</dt>
          <dd class="text-gray-600 text-sm mb-3">
            תשלום חובה הנגבה על ידי לשכת ההוצאה לפועל בעת פתיחת תיק או הגשת בקשה מסוימת.
            גובה האגרה נקבע לפי שווי החוב הנתבע ומתעדכן מעת לעת. האגרה מתווספת לחוב המקורי ומוטלת על החייב.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">אזהרה</dt>
          <dd class="text-gray-600 text-sm mb-3">
            המסמך הרשמי הראשון שמקבל החייב לאחר פתיחת תיק הוצאה לפועל נגדו.
            האזהרה מפרטת את סכום החוב ומזהירה שאם לא יפרע תוך 20 יום, ינקטו כנגדו הליכי גבייה.
            חשוב מאוד לפעול מיידית עם קבלת האזהרה — אל תתעלמו ממנה.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">איחוד תיקים</dt>
          <dd class="text-gray-600 text-sm mb-3">
            הליך שמאחד מספר תיקי הוצאה לפועל פתוחים של אותו חייב לתיק אחד מרכזי.
            כתוצאה מכך משלם החייב סכום חודשי אחד בלבד, המחולק בין כל הנושים לפי הסדר עדיפויות.
            מאפשר ניהול סדור ומניעת ריבוי הגבלות מקבילות.
            <a href="/guides/ichud-tikim/" class="text-blue-600 hover:underline text-xs mr-1">← קרא מדריך מלא</a>
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">אכיפה</dt>
          <dd class="text-gray-600 text-sm mb-3">
            פעולות שנוקטת לשכת ההוצאה לפועל כדי לגבות את החוב בפועל — עיקולים, מכירת נכסים, הגבלות ועוד.
            הזוכה רשאי לבקש אכיפה לאחר שחלפו 20 יום מהמצאת האזהרה לחייב ולא שולם.
            האכיפה כוללת מגוון כלים חוקיים להפעלת לחץ על החייב.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">ארנונה — חוב</dt>
          <dd class="text-gray-600 text-sm mb-3">
            חוב ארנונה לרשות המקומית הוא חוב מוכר שניתן לגבותו בהוצאה לפועל.
            הרשות המקומית רשאית לפתוח תיק גבייה ישיר ואף לנקוט בהליכי עיקול על נכסי החייב.
            חוב ארנונה מתיישן לאחר 7 שנים אם לא ננקטה פעולת גבייה.
          </dd>

        </dl>
      </section>

      <!-- ב -->
      <section id="bet" class="mb-10 scroll-mt-16">
        <h2 class="text-2xl font-bold text-blue-800 border-b-2 border-blue-200 pb-2 mb-5">ב</h2>
        <dl>

          <dt class="font-bold text-gray-800 text-base mt-4">בית משפט שלום</dt>
          <dd class="text-gray-600 text-sm mb-3">
            הערכאה הנמוכה ביותר בהיררכיה השיפוטית בישראל, דנה בתביעות כספיות עד 2.5 מיליון ש"ח.
            רוב תיקי ההוצאה לפועל מבוססים על פסקי דין של בית משפט שלום.
            ניתן לערער על פסיקתו לבית משפט מחוזי.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">בית משפט מחוזי</dt>
          <dd class="text-gray-600 text-sm mb-3">
            ערכאת ביניים הדנה בתביעות מעל 2.5 מיליון ש"ח ובערעורים על פסיקת בית משפט שלום.
            עניינים מסוימים של חדלות פירעון ופשיטת רגל נדונים ישירות בבית המשפט המחוזי.
            פסיקתו ניתנת לערעור לבית המשפט העליון.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">בית משפט לענייני משפחה</dt>
          <dd class="text-gray-600 text-sm mb-3">
            ערכאה מיוחדת הדנה בנושאי גירושין, מזונות, משמורת ורכוש הנוגעים לבני זוג וילדים.
            פסקי דין של בית המשפט לענייני משפחה בנושא מזונות ניתנים לאכיפה דרך הוצאה לפועל.
            לחוב מזונות ניתנת עדיפות מיוחדת בדיני האכיפה.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">ביטול עיקול</dt>
          <dd class="text-gray-600 text-sm mb-3">
            הליך שבו מבקש החייב לבטל עיקול שהוטל על נכסיו או חשבונו.
            ניתן לבקש ביטול עיקול בשל פגמים בהטלתו, חוסר יכולת כלכלית, או הגעה להסדר עם הנושה.
            הבקשה מוגשת לרשם ההוצאה לפועל, שיחליט לאחר שמיעת שני הצדדים.
            <a href="/guides/bitul-ikul/" class="text-blue-600 hover:underline text-xs mr-1">← קרא מדריך מלא</a>
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">ביטוח לאומי — פטור מעיקול</dt>
          <dd class="text-gray-600 text-sm mb-3">
            קצבאות המשולמות על ידי המוסד לביטוח לאומי כגון קצבת נכות, קצבת זקנה ודמי אבטלה מוגנות מפני עיקול.
            מדובר בהכנסה הנחשבת כ"בסיס קיום" ולכן אינה ניתנת לעיקול על ידי נושה רגיל.
            חריג קיים לחובות מזונות, שכן ניתן לעקל חלק מהקצבה גם במקרה זה.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">בקשה לרשם</dt>
          <dd class="text-gray-600 text-sm mb-3">
            פנייה רשמית לרשם ההוצאה לפועל לצורך קבלת החלטה בעניין מסוים — ביטול עיקול, קביעת תשלומים, הסרת הגבלה וכדומה.
            הבקשה מוגשת בכתב בצירוף תצהיר ואסמכתאות רלוונטיות.
            יש לשלם אגרה עבור הגשת בקשות מסוימות.
          </dd>

        </dl>
      </section>

      <!-- ג -->
      <section id="gimel" class="mb-10 scroll-mt-16">
        <h2 class="text-2xl font-bold text-blue-800 border-b-2 border-blue-200 pb-2 mb-5">ג</h2>
        <dl>

          <dt class="font-bold text-gray-800 text-base mt-4">גביית חוב</dt>
          <dd class="text-gray-600 text-sm mb-3">
            כלל הפעולות המשפטיות והמעשיות שנוקט נושה כדי לקבל את כספו מהחייב.
            כוללת שליחת דרישות תשלום, פתיחת תיק הוצאה לפועל, הטלת עיקולים ומכירת נכסים.
            ישנם גבולות חוקיים ברורים לגביית חוב — אין מדובר בשרות עצמי.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">גמלה</dt>
          <dd class="text-gray-600 text-sm mb-3">
            תשלום תקופתי המשולם לאדם הזכאי לו — לרוב מהביטוח הלאומי או ממקום עבודה לשעבר.
            גמלאות רבות מוגנות מפני עיקול מאחר שהן מהוות מקור פרנסה בסיסי.
            יש לבדוק בכל מקרה לגופו אם הגמלה הספציפית ניתנת לעיקול ובאיזה שיעור.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">גרעון</dt>
          <dd class="text-gray-600 text-sm mb-3">
            הפרש שלילי בין הכנסות לבין הוצאות ו/או התחייבויות.
            בהקשר של הוצאה לפועל — כאשר חייב אינו מסוגל לכסות את חובותיו מהכנסותיו השוטפות.
            גרעון מתמשך עשוי להוביל לחדלות פירעון ולהליך שיקום כלכלי.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">גישור</dt>
          <dd class="text-gray-600 text-sm mb-3">
            הליך חוץ-משפטי שבו צד שלישי ניטרלי (המגשר) מסייע לחייב ולנושה להגיע להסכמה מרצון.
            גישור מוצלח בנושא חוב יכול למנוע את ההגעה לבית משפט ולחסוך עלויות לשני הצדדים.
            ניתן לנסות גישור גם לאחר פתיחת תיק הוצאה לפועל — הסכם שמושג יגרור סגירת התיק.
          </dd>

        </dl>
      </section>

      <!-- ד -->
      <section id="dalet" class="mb-10 scroll-mt-16">
        <h2 class="text-2xl font-bold text-blue-800 border-b-2 border-blue-200 pb-2 mb-5">ד</h2>
        <dl>

          <dt class="font-bold text-gray-800 text-base mt-4">דמי פיגורים</dt>
          <dd class="text-gray-600 text-sm mb-3">
            תוספת לחוב המקורי הנגבית עקב איחור בתשלום — מעבר לריבית הרגילה.
            בתיקי הוצאה לפועל, דמי הפיגורים מצטברים על גבי הקרן ועלולים לנפח משמעותית את יתרת החוב.
            חשוב לפעול מהר כדי לעצור את צבירת דמי הפיגורים.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">דירוג אשראי</dt>
          <dd class="text-gray-600 text-sm mb-3">
            ציון המבטא את רמת האמינות הפיננסית של אדם, המחושב על בסיס היסטוריית תשלומים ומצב חובות.
            תיק הוצאה לפועל פתוח פוגע קשות בדירוג האשראי ומקשה על קבלת הלוואות, משכנתאות ושירותים בנקאיים.
            סגירת התיק ופירעון החוב תורמים להתאוששות הדירוג לאורך זמן.
          </dd>

          <dt class="font-bold text-gray-800 text-base mt-4">דרכון — הגבלה</dt>
          <dd class="text-gray-600 text-sm mb-3">
            רשם ההוצאה לפועל רשאי להורות על עיכוב יציאה מהארץ, אך אינו יכול לבטל את הדרכון עצמו.
            ה"הגבלת הדרכון" שנשמעת לפעמים מתייחסת בפועל לצו עיכוב יציאה מהארץ.
            ניתן לבקש הסרת הגבלה זו עם הסרת הגבלות אחרות מעמד חייב מוגבל.
          </dd>

        </dl>
      </section>

      <!-- ה -->
      <section id="he" class="mb-10 scroll-mt-16">
        <h2 class="text-2xl font-bold text-blue-800 border-b-2 border-blue-200 pb-2 mb-5">ה</h2>
        <dl>

          <dt class="font-bold text-gray-800 text-base mt-4">הגבלות — רשימה</dt>
          <dd class="text-gray-600 text-sm mb-3">
