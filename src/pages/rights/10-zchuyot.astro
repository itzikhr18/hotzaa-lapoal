  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'האם חייב יכול לבקש דחיית תשלום?',
      acceptedAnswer: { '@type': 'Answer', text: 'כן. חייב רשאי לפנות לרשם ההוצאה לפועל בבקשה לצו תשלומים שקובע פריסה חודשית לפי יכולתו.' },
    },
    {
