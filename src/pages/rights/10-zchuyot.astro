      { q: 'האם נושה יכול לפנות ישירות למעסיק שלי?', a: 'לא ישירות. עיקול משכורת חייב לעבור דרך רשות האכיפה בצו רשמי. פנייה ישירה למעסיק ללא צו היא הפרת חוק.' },
      { q: 'מה עושים אם עיקלו סכום גבוה מהמותר?', a: 'פנה מיד לרשם ההוצאה לפועל עם הוכחות ובקש תיקון. ניתן גם לפנות לעורך דין לייעוץ.' },
    ].map(faq => (
