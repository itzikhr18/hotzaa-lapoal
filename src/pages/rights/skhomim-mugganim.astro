---
import GuideLayout from '../../layouts/GuideLayout.astro';
import { wageList, wageSentence, fmtILS } from '../../data/protected-amounts';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'האם קצבת ביטוח לאומי ניתנת לעיקול?', acceptedAnswer: { '@type': 'Answer', text: 'ברוב המקרים קצבאות ביטוח לאומי (ילדים, נכות, זקנה, שאירים, דמי אבטלה, גמלת סיעוד) נהנות מהגנה מיוחדת מפני עיקול לפי סעיף 303 לחוק הביטוח הלאומי. ההגנה תלויה בסוג הקצבה ובאופן ההפקדה — חשוב לשמור על הפרדה בחשבון. אם עיקלו, ניתן לפנות לרשם בבקשת ביטול בצירוף הוכחות מקור.' } },
    { '@type': 'Question', name: 'כמה ממשכורת ניתן לעקל?', acceptedAnswer: { '@type': 'Answer', text: 'לפי סעיף 8 לחוק הגנת השכר, נשאר בידי החייב סכום מוגן לפי הרכב המשפחה: ' + wageSentence + '. שכר נמוך מהסכום המוגן — מוגן במלואו; מעליו — היתרה ניתנת לעיקול, ואם הסכום המוגן גבוה מ-80% מהנטו מעקלים לכל היותר 20% מהנטו. בתיקי מזונות ההגנה אינה חלה.' } },
    { '@type': 'Question', name: 'האם כלי עבודה מוגנים מעיקול?', acceptedAnswer: { '@type': 'Answer', text: 'כן. כלי עבודה הנחוצים לפרנסה מוגנים — מחשב לעצמאי, כלי חשמל, ציוד מקצועי. גם ציוד רפואי חיוני, בגדים, ורהיטים בסיסיים — מוגנים מעיקול לפי סעיף 22 לחוק ההוצאה לפועל.' } },
    { '@type': 'Question', name: 'מה עושים אם עיקלו כסף מוגן?', acceptedAnswer: { '@type': 'Answer', text: 'פנה לרשם ההוצאה לפועל עם הוכחות (תלושי שכר, אישור ביטוח לאומי) ובקש ביטול העיקול. הרשם מחויב לבטל עיקול על כספים מוגנים — אין לו שיקול דעת. ניתן לבקש גם ביניים — עיכוב ביצוע — בזמן הטיפול בבקשה.' } },
    { '@type': 'Question', name: 'האם ניתן לעקל כסף בחשבון בנק שמקורו בקצבאות?', acceptedAnswer: { '@type': 'Answer', text: 'ברוב המקרים, כסף שמקורו בקצבאות ביטוח לאומי נהנה מהגנה גם בחשבון הבנק — אך ההגנה תלויה ביכולת להוכיח שזהו אכן מקור הכספים. לכן חשוב לשמור על חשבון נפרד לקצבאות; ערבוב עם הכנסות אחרות מקשה על הוכחת המקור.' } },
    { '@type': 'Question', name: 'האם מעסיק יכול לנכות מהמשכורת יותר מהמותר?', acceptedAnswer: { '@type': 'Answer', text: 'לא. המעסיק מחויב להותיר בידי העובד את הסכום המוגן לפי הרכב המשפחה (או 80% מהנטו כשהסכום המוגן גבוה ממנו). אם נוכה יותר — זו חריגה מהחוק, וניתן לפנות לרשם ההוצאה לפועל בבקשת השבה (בתיקי מזונות ההגנה אינה חלה).' } },
    { '@type': 'Question', name: 'מה ההגנה על חשבון בנק — האם יש סכום מינימלי שחייב להישאר?', acceptedAnswer: { '@type': 'Answer', text: 'אין בחוק סכום מינימלי קשיח שחייב להישאר בחשבון, אבל הרשם יכול לקבוע סכום מינימלי בצו תשלומים. בנוסף, כספי קצבאות מוגנים מעיקול גם בחשבון. מומלץ לבקש מהרשם לקבוע סכום מינימלי שנשאר פנוי לצרכים בסיסיים.' } },
    { '@type': 'Question', name: 'האם רכב מוגן מעיקול?', acceptedAnswer: { '@type': 'Answer', text: 'עיקול רישומי (שמונע מכירה) אפשרי. אבל אם הרכב נחוץ לפרנסה — ניתן לבקש מהרשם הגנה מעיקול ממשי (לקיחה פיזית של הרכב). הרשם מתחשב ברכב שמשמש לעבודה. כדאי להוכיח שהרכב הכרחי לייצר פרנסה.' } },
  ],
};
---

<GuideLayout
  title="כספים מוגנים מעיקול בהוצאה לפועל — קצבאות, שכר ונכסים (2026)"
  description="מה לא ניתן לעקל בהוצאה לפועל? רשימה מלאה לפי החוק: קצבאות ביטוח לאומי, שכר הגנה לפי הרכב המשפחה, כלי עבודה וציוד רפואי — ואיך מבטלים עיקול על כסף מוגן."
  breadcrumb={[{ label: 'זכויות חייבים', href: '/rights/' }, { label: 'סכומים מוגנים', href: '/rights/skhomim-mugganim/' }]}
  publishDate="2025-03-01"
  updateDate="2026-06-24"
  readTime="8 דקות"
  schema={[faqSchema, {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'איך לבטל עיקול על כספים מוגנים',
    description: 'שלבים לביטול עיקול שהוטל על כספים שמוגנים בחוק',
    totalTime: 'P7D',
    step: [
      { '@type': 'HowToStep', position: 1, name: 'זהה את הכסף המוגן', text: 'בדוק אם הכסף שעוקל מגיע מקצבאות ביטוח לאומי, משכר מינימום, מפיצוי נזקי גוף, או ממקור אחר המוגן בחוק.' },
      { '@type': 'HowToStep', position: 2, name: 'אסוף הוכחות', text: 'הדפס תדפיסי בנק שמראים הפקדות מביטוח לאומי, תלושי שכר, או כל מסמך אחר שמוכיח את מקור הכסף המוגן.' },
      { '@type': 'HowToStep', position: 3, name: 'הגש בקשה לרשם', text: 'פנה ללשכת ההוצאה לפועל עם הוכחות ובקש ביטול העיקול על הסכומים המוגנים. ציין במפורש את הסעיף המשפטי: סעיף 22 לחוק ההוצאה לפועל / חוק הביטוח הלאומי.' },
      { '@type': 'HowToStep', position: 4, name: 'בקש ביניים', text: 'בו-זמנית, בקש מהרשם "עיכוב ביצוע" — עצירת העיקול בינתיים עד להחלטה. הבנק יקבל הודעה שלא לממש את העיקול.' },
      { '@type': 'HowToStep', position: 5, name: 'קבל אישור', text: 'לאחר שהרשם מאשר — הבנק מסיר את העיקול. שמור את אישור הביטול. במידה שהבנק לא פועל — פנה לו ישירות עם אישור הרשם.' },
    ],
  }]}
>

  <p>
    אחת הטעויות הנפוצות ביותר שחייבים עושים — הם מניחים שהנושה יכול לקחת הכל.
    זה לא נכון. החוק הישראלי מעניק הגנה מיוחדת לקטגוריות שלמות של כסף ונכסים.
    הכרת ההגנות האלה יכולה לשנות מהותית את המצב שלך.
  </p>

  <div class="not-prose bg-amber-50 border-r-4 border-amber-400 rounded-lg p-4 my-5 text-sm text-gray-700">
    <strong class="text-amber-900">חשוב לדעת:</strong>
    היקף ההגנה תלוי בסוג ההכנסה, באופן ההפקדה (חשבון נפרד / מעורב), ובהוראות
    הדין הספציפיות. הדוגמאות והסכומים בעמוד זה הם הכלל הרגיל — בכל מקרה ספציפי
    מומלץ להתייעץ עם עורך דין.
  </div>

  <nav aria-label="תוכן עניינים" class="not-prose bg-gray-50 border border-gray-200 rounded-xl p-4 my-6">
    <p class="font-semibold text-gray-800 mb-2 text-sm">תוכן עניינים</p>
    <ol class="list-decimal list-inside space-y-1 text-sm text-brand">
      <li><a href="#kzbaot" class="hover:underline">קצבאות ביטוח לאומי מוגנות</a></li>
      <li><a href="#maskoret" class="hover:underline">הגנה על משכורת — תקרות וחישוב</a></li>
      <li><a href="#nechasim" class="hover:underline">נכסים פיזיים שלא ניתן לעקל</a></li>
      <li><a href="#bank" class="hover:underline">הגנה על חשבון בנק</a></li>
      <li><a href="#rechev" class="hover:underline">מה קורה עם הרכב</a></li>
      <li><a href="#action" class="hover:underline">מה לעשות אם עיקלו כסף מוגן</a></li>
      <li><a href="#faq" class="hover:underline">שאלות נפוצות</a></li>
    </ol>
  </nav>

  <h2 id="kzbaot">קצבאות ביטוח לאומי — הגנה מיוחדת</h2>

  <p>
    לפי <strong>סעיף 303 לחוק הביטוח הלאומי [נוסח משולב] תשנ"ה-1995</strong>,
    כל הקצבאות שמשלם המוסד לביטוח לאומי מוגנות מעיקול, שיעבוד ועיכוב — בכפוף
    לכללים בחוק ולאופן ההפקדה. ברוב המקרים זוהי הגנה רחבה מאוד, אך הוכחת המקור
    (ובמיוחד הפרדת חשבון) חיונית.
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">קצבה / גמלה</th>
          <th class="text-right p-3 border border-gray-200">הגנה</th>
          <th class="text-right p-3 border border-gray-200">הערה</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['קצבת ילדים', 'מוגנת לחלוטין', 'כולל תוספות'],
          ['קצבת נכות כללית', 'מוגנת לחלוטין', 'כל רמות הנכות'],
          ['קצבת זקנה', 'מוגנת לחלוטין', 'כולל תוספת תלויים'],
          ['קצבת שאירים', 'מוגנת לחלוטין', 'לאלמן/ה וילדים'],
          ['דמי אבטלה', 'מוגנים לחלוטין', 'מהביטוח הלאומי'],
          ['דמי לידה', 'מוגנים לחלוטין', ''],
          ['גמלת סיעוד', 'מוגנת לחלוטין', 'כולל "ויזה לאוכל"'],
          ['גמלת שמירת הריון', 'מוגנת לחלוטין', ''],
          ['קצבת תלויים בנפגעי עבודה', 'מוגנת לחלוטין', ''],
          ['מזונות שנפסקו לילדים', 'מוגנים לחלוטין', 'לפי פסק דין'],
          ['פיצויי נזקי גוף', 'מוגנים לחלוטין', 'פגיעה גופנית בלבד'],
        ].map(([src, prot, note], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-medium">{src}</td>
            <td class="p-3 border border-gray-200 text-green-700 font-semibold">{prot}</td>
            <td class="p-3 border border-gray-200 text-gray-500 text-xs">{note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">⚠️ שמור קצבאות בחשבון נפרד</p>
    <p>
      אם תערבב כסף מקצבאות עם הכנסות אחרות באותו חשבון, יהיה קשה יותר להוכיח שהכסף המעוקל
      מגיע מקצבה. הפתרון הפשוט: פתח חשבון בנק נפרד ייעודי לקצבאות ביטוח לאומי.
    </p>
  </div>

  <h2 id="maskoret">הגנה על משכורת — חישוב מדויק</h2>

  <p>
    לפי <strong>סעיף 8 לחוק הגנת השכר, תשי"ח-1958</strong>, ההגנה על משכורת מעיקול
    פועלת כך:
  </p>

  <ul>
    <li><strong>סכום מוגן לפי משפחה:</strong> סכום נטו לקיום בסיסי שמשתנה לפי הרכב המשפחה (ראו טבלה). שכר שנמוך ממנו — <strong>מוגן במלואו</strong>.</li>
    <li><strong>מעל הסכום המוגן:</strong> היתרה שמעל הסכום המוגן ניתנת לעיקול. אם הסכום המוגן גבוה מ-80% מהנטו — נשארים בידי החייב 80% מהנטו (כלומר מעקלים לכל היותר 20%).</li>
  </ul>

  <p>
    בפועל: גובה העיקול נקבע בצו של רשם ההוצאה לפועל, וניתן לבקש הפחתה משמעותית
    מתחת למקסימום החוקי לפי הוצאות המחיה. בתיקי <strong>מזונות</strong> הכללים שונים —
    ההגנה אינה חלה, והרשם רשאי להורות על ניכוי גבוה משמעותית.
  </p>

  <h3>שכר מוגן מעיקול — שכר הגנה לפי הרכב משפחה (2026)</h3>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">הרכב המשפחה</th>
          <th class="text-right p-3 border border-gray-200">שכר הגנה (נטו לחודש)</th>
        </tr>
      </thead>
      <tbody>
        {[
          ...wageList.map(w => [w.label, `~${fmtILS(w.amount)}`]),
        ].map(([fam, prot], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-medium">{fam}</td>
            <td class="p-3 border border-gray-200 text-brand-dark font-semibold">{prot}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="text-xs text-gray-500 mt-2">* סכומים מתעדכנים מעת לעת. לבדיקה עדכנית — <a href="https://www.kolzchut.org.il/he/%D7%A9%D7%9B%D7%A8_%D7%A2%D7%91%D7%95%D7%93%D7%94_%D7%A9%D7%9C%D7%90_%D7%A0%D7%99%D7%AA%D7%9F_%D7%9C%D7%A2%D7%A7%D7%9C_%D7%90%D7%95_%D7%9C%D7%A9%D7%A2%D7%91%D7%93" target="_blank" rel="noopener noreferrer">כל-זכות — שכר עבודה שלא ניתן לעקל</a>.</p>
  </div>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">💡 מזונות — חריג חשוב</p>
    <p>
      בתיקי <strong>מזונות ילדים ובן/בת זוג</strong>, אין תקרת הגנה אוטומטית. הרשם
      או בית המשפט רשאים להורות על ניכוי גבוה יותר, מעבר לסכומי הקיום הבסיסיים,
      בהתאם לסכום המזונות שנפסק וליכולת ההכנסה של החייב. זהו חריג מכוון שנועד להגן
      על ילדים.
    </p>
  </div>

  <h2 id="nechasim">נכסים פיזיים שלא ניתן לעקל</h2>

  <p>
    לפי <strong>סעיף 22 לחוק ההוצאה לפועל</strong>, קיימת רשימה של מיטלטלין (חפצים) שאינם ניתנים
    לעיקול כלל — ללא קשר לגובה החוב:
  </p>

  <div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-4 my-6">
    {[
      { icon: '🛏️', title: 'מיטה ומצעים', desc: 'לחייב ולכל בני ביתו — מיטה בסיסית ומצעים' },
      { icon: '🪑', title: 'ריהוט בסיסי', desc: 'שולחן אוכל, כיסאות — לשימוש יומיומי הכרחי' },
      { icon: '🍳', title: 'ציוד מטבח', desc: 'מקרר, כיריים, מכונת כביסה — ציוד בית בסיסי' },
      { icon: '👕', title: 'בגדים ולבוש', desc: 'בגדי חייב ומשפחתו — לא ניתנים לעיקול' },
      { icon: '🔧', title: 'כלי עבודה', desc: 'ציוד מקצועי הכרחי לפרנסה, עד תקרה קבועה' },
      { icon: '♿', title: 'ציוד רפואי', desc: 'כיסא גלגלים, מכשיר שמיעה, ציוד חיוני' },
      { icon: '📚', title: 'ספרי לימוד ילדים', desc: 'ספרי לימוד וחינוך לילדים בית הספר' },
      { icon: '🐕', title: 'בעל חיים', desc: 'חיית מחמד — בית המשפט נוטה שלא לאפשר עיקול' },
    ].map(item => (
      <div class="bg-green-50 border border-green-200 rounded-lg p-3 flex gap-3 items-start">
        <span class="text-2xl">{item.icon}</span>
        <div>
          <p class="font-semibold text-green-800 text-sm">{item.title}</p>
          <p class="text-xs text-gray-600 mt-0.5">{item.desc}</p>
        </div>
      </div>
    ))}
  </div>

  <h2 id="bank">הגנה על חשבון בנק — מה מוגן?</h2>

  <p>
    אין בחוק "סכום מינימום מוגן" קבוע בחשבון בנק, אבל ישנן הגנות חשובות:
  </p>

  <ul>
    <li>
      <strong>כסף שמקורו בקצבאות ביטוח לאומי</strong> — מוגן לחלוטין, גם כשהוא בחשבון בנק.
      אחריות ההוכחה על החייב.
    </li>
    <li>
      <strong>קביעת סכום מינימום על ידי רשם</strong> — ניתן לבקש מהרשם לקבוע שיש להשאיר
      סכום מינימום בחשבון לצרכי קיום בסיסיים (שכר דירה, מזון).
    </li>
    <li>
      <strong>כסף שהגיע 48 שעות לפני העיקול ולאחריו</strong> — ניתן לבקש ביניים על כסף
      שהגיע ממקורות מוגנים סמוך לרגע העיקול.
    </li>
  </ul>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">⚠️ פתרון מעשי לחשבון בנק</p>
    <p>
      פתח חשבון בנק נפרד <strong>ייעודי לקצבאות ביטוח לאומי</strong>.
      הגדר אצל ביטוח לאומי שיפקידו לחשבון הזה בלבד.
      כשכל הכסף בחשבון זה מגיע מקצבאות — ההגנה ברורה ואין ויכוח.
    </p>
  </div>

  <h2 id="rechev">מה קורה עם הרכב?</h2>

  <p>
    רכב אינו מוגן אוטומטית — אבל יש הגנות חשובות שכדאי להכיר:
  </p>

  <ul>
    <li>
      <strong>עיקול רישומי</strong> — הנושה יכול לרשום עיקול רישומי (מונע מכירה), אבל
      <em>אינו מונע שימוש ברכב ונסיעה</em>.
    </li>
    <li>
      <strong>עיקול ממשי (לקיחת הרכב)</strong> — דורש אישור מיוחד. אם הרכב נחוץ לפרנסה —
      ניתן לבקש מהרשם הגנה.
    </li>
    <li>
      <strong>ערך הרכב</strong> — לרכבים עם ערך נמוך יחסית, הרשם שוקל אם שווה לעקל בכלל.
    </li>
    <li>
      <strong>רכב ממומן/ליסינג</strong> — בנק או חברת ליסינג עם שיעבוד ראשון — החוב לבנק
      קודם לעיקול. לרשם יש סמכות מוגבלת.
    </li>
  </ul>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">💡 כיצד להגן על הרכב</p>
    <p>
      הגש לרשם ההוצאה לפועל בקשה בכתב שבה אתה מסביר שהרכב הכרחי לעבודה — ציין מקום עבודה,
      מרחק, העדר תחבורה ציבורית, או אופי עצמאי של העבודה.
      צרף מכתב ממעסיק / אישור רשם עסקים. הרשם מוסמך להגן על הרכב.
    </p>
  </div>

  <h2 id="action">מה לעשות אם עיקלו כסף מוגן?</h2>

  <p>עיקול על כספים מוגנים הוא לא חוקי. הנה הצעדים המדויקים:</p>

  <ol>
    <li>
      <strong>קבל תדפיסי בנק</strong> — הורד 3-6 חודשים אחרונים שמראים הפקדות מביטוח לאומי.
    </li>
    <li>
      <strong>קבל אישור מביטוח לאומי</strong> — פנה לביטוח לאומי ובקש אישור בכתב שאתה מקבל
      קצבה ומאיזה תאריך.
    </li>
    <li>
      <strong>הגש בקשה לרשם</strong> — הגש ללשכת ההוצאה לפועל בקשה לביטול עיקול, עם כל
      המסמכים. ציין: "הכסף מגיע מקצבת ביטוח לאומי — מוגן לפי סעיף 303 לחוק ביטוח לאומי".
    </li>
    <li>
      <strong>בקש עיכוב ביניים</strong> — בו-זמנית בקש "עיכוב ביצוע" כדי שהבנק לא יעביר
      את הכסף המעוקל לנושה עד שהרשם יחליט.
    </li>
    <li>
      <strong>המתן להחלטה</strong> — הרשם מחויב לקבל החלטה. אם אושר — הבנק מקבל הודעה
      ומשחרר את הכסף המוגן.
    </li>
  </ol>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">🆘 סיוע משפטי חינמי</p>
    <p>
      אם אין לך כסף לעורך דין, פנה <a href="https://www.gov.il/he/departments/ministry_of_justice_legal_aid/govil-landing-page" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">ללשכה לסיוע משפטי</a> של משרד המשפטים.
      עבור חייבים במצב כלכלי קשה, הייצוג הוא חינמי לחלוטין.
    </p>
  </div>

  <h2 id="faq">שאלות נפוצות</h2>
  <div class="space-y-4 my-6">
    {[
      { q: 'האם קצבת ביטוח לאומי ניתנת לעיקול?', a: 'ברוב המקרים קצבאות ביטוח לאומי (ילדים, נכות, זקנה, שאירים, דמי אבטלה, גמלת סיעוד) נהנות מהגנה מיוחדת מפני עיקול לפי סעיף 303 לחוק הביטוח הלאומי. ההגנה תלויה באופן ההפקדה — חשוב לשמור על חשבון נפרד. אם עיקלו, ניתן לפנות לרשם בבקשת ביטול בצירוף הוכחות מקור.' },
      { q: 'כמה ממשכורת ניתן לעקל?', a: `נשאר בידי החייב סכום מוגן לפי הרכב המשפחה: ${wageSentence}. שכר נמוך מהסכום המוגן — מוגן במלואו; מעליו — היתרה ניתנת לעיקול (ולכל היותר כך שיישארו 80% מהנטו כשהסכום המוגן גבוה מ-80% מהשכר). בתיקי מזונות ההגנה אינה חלה.` },
      { q: 'האם כלי עבודה מוגנים מעיקול?', a: 'כן. כלי עבודה הנחוצים לפרנסה מוגנים לפי סעיף 22 — מחשב לעצמאי, כלי חשמל, ציוד מקצועי. גם ציוד רפואי חיוני ורהיטים בסיסיים.' },
      { q: 'מה עושים אם עיקלו כסף מוגן?', a: 'פנה לרשם עם תדפיסי בנק ואישור ביטוח לאומי. בקש ביטול עיקול ועיכוב ביצוע בינתיים. הרשם מחויב לבטל — אין לו שיקול דעת על כספים מוגנים בחוק.' },
      { q: 'האם כסף מקצבה בחשבון בנק מוגן?', a: 'כן, אבל מומלץ לשמור בחשבון נפרד. לאחר ערבוב עם הכנסות אחרות — קשה יותר להוכיח את המקור. חשבון נפרד = הוכחה קלה.' },
      { q: 'האם ניתן לעקל מחשב שקניתי לעבודה?', a: 'לא אם הוא כלי עבודה הכרחי. מחשב לעצמאי שמפרנס ממנו — מוגן. מחשב נוסף לצד מחשב אחר, או מחשב "יוקרה" — עשוי להיות ניתן לעיקול.' },
      { q: 'האם מעסיק יכול לנכות 50% ממשכורת?', a: 'בחוב אזרחי רגיל — רק אם אחרי הניכוי נשאר בידי העובד הסכום המוגן לפי הרכב משפחתו (בשכר גבוה זה אפשרי). בכל מקרה, כשהסכום המוגן גבוה מ-80% מהנטו, הניכוי מוגבל ל-20% מהנטו. בתיקי מזונות ההגנה אינה חלה כלל.' },
    ].map(faq => (
      <details class="border border-neutral-border rounded-xl group">
        <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
          {faq.q}
          <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
        </summary>
        <p class="px-4 pb-4 text-gray-600">{faq.a}</p>
      </details>
    ))}
  </div>

