---
import GuideLayout from '../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'האם יכולים לעקל את הדירה שאני גר בה?', acceptedAnswer: { '@type': 'Answer', text: 'עיקול רישומי (רישום בטאבו) — כן, אפשרי. אבל עיקול רישומי לא גורם לך לעזוב את הבית. הוא מונע ממך למכור את הדירה בלי לסלק קודם את החוב. ממוש בפועל (מכירה כפויה) — הרבה קשה יותר, ומצריך הליך משפטי ארוך.' } },
    { '@type': 'Question', name: 'האם יכולים לממש (למכור) את ביתי בכפייה?', acceptedAnswer: { '@type': 'Answer', text: 'בתיאוריה — כן. בפועל — הליך ממוש דירת מגורים ראשית, בפרט כשגרים בה ילדים קטינים, הוא ארוך, יקר ומורכב לנושה. בתי המשפט ורשמי ההוצאה לפועל מהססים מאוד, ורוב הנושים מעדיפים הסדר תשלומים.' } },
    { '@type': 'Question', name: 'אם יש לי ילדים קטינים, האם הבית מוגן?', acceptedAnswer: { '@type': 'Answer', text: 'נוכחות ילדים קטינים בדירה היא שיקול כבד מאוד בהחלטה על ממוש. בתי המשפט מהססים מאוד לאשר מכירה כפויה כשיש ילדים שגרים בבית. אין הגנה מוחלטת, אבל זהו טיעון משמעותי.' } },
    { '@type': 'Question', name: 'מה ההבדל בין עיקול רישומי לממוש דירה?', acceptedAnswer: { '@type': 'Answer', text: 'עיקול רישומי = רישום הערה בטאבו שמונעת מכירה ללא סילוק החוב. אתה ממשיך לגור בדירה. ממוש = מכירה כפויה בפועל — הליך שדורש אישור בית משפט, שמאות, מכרז ופרסום.' } },
    { '@type': 'Question', name: 'מה עושים כשעיקלו את הדירה?', acceptedAnswer: { '@type': 'Answer', text: 'אל תתעלם — פנה לרשם ההוצאה לפועל מיד. הגש בקשה לצו תשלומים שיכולה לעצור הליכי ממוש. הגש התנגדות לממוש אם יש טעמים (ילדים, דירה יחידה, חוב קטן ביחס לשווי). שקול ייעוץ עורך דין — בנושא דירה, ייצוג משפטי שווה את הכסף.' } },
    { '@type': 'Question', name: 'כמה זמן לוקח להוציא אדם מביתו?', acceptedAnswer: { '@type': 'Answer', text: 'מהרישום בטאבו ועד פינוי בפועל — מדובר לרוב בשנים. כל שלב (בקשת ממוש, שמיעה, שמאות, מכרז, אישור בית משפט) לוקח חודשים. לנושה כדאי לנסות הסדר ישיר מאשר לעבור את כל ההליך.' } },
  ],
};
---

<GuideLayout
  title="האם אפשר לעקל את הבית שלי? — הגנה על דירת מגורים"
  description="מתי ניתן לעקל דירת מגורים ראשית ומתי לא? מה ההבדל בין עיקול רישומי לממוש, מה מגן עליך כשיש ילדים, ואיך עוצרים את ההליך — מעודכן 2026."
  breadcrumb={[{ label: 'זכויות חייבים', href: '/rights/' }, { label: 'הבית שלי', href: '/rights/bayit-muggan/' }]}
  publishDate="2025-03-01"
  updateDate="2026-03-28"
  readTime="6 דקות"
  schema={[faqSchema, {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'מה לעשות אם עיקלו את הדירה שלך',
    description: 'הצעדים הנכונים כשעיקול רישומי הוטל על דירת המגורים שלך',
    totalTime: 'P14D',
    step: [
      { '@type': 'HowToStep', position: 1, name: 'בדוק את סוג העיקול', text: 'האם זה עיקול רישומי (הערה בטאבו) או בקשת ממוש? עיקול רישומי — אתה ממשיך לגור. ממוש — דורש פעולה מיידית.' },
      { '@type': 'HowToStep', position: 2, name: 'הגש בקשה לצו תשלומים', text: 'הגש מיד ללשכת ההוצאה לפועל בקשה לצו תשלומים. ברגע שיש צו פעיל ואתה עומד בו — הנושה לא יכול לנקוט הליכי ממוש.' },
      { '@type': 'HowToStep', position: 3, name: 'הגש התנגדות לממוש', text: 'אם הוגשה בקשה לממוש — הגש התנגדות מיד. ציין: ילדים קטינים, דירה יחידה, חוב לא פרופורציונלי לשווי הדירה.' },
      { '@type': 'HowToStep', position: 4, name: 'פנה לנושה ישירות', text: 'רוב הנושים מעדיפים הסדר תשלומים על ממוש ארוך ויקר. פנה ישירות — לעיתים ניתן להגיע להסכם טוב יותר מחוץ לכותלי בית המשפט.' },
      { '@type': 'HowToStep', position: 5, name: 'התייעץ עם עורך דין', text: 'בנושא דירה — ייצוג משפטי שווה את עלותו. פנה ללשכה לסיוע משפטי אם אין לך אמצעים. הליך ממוש ניתן לעצור בשלבים מוקדמים.' },
    ],
  }]}
>

  <p>
    הפחד מאיבוד הבית הוא אחד הגדולים ביותר כשנכנסים להוצאה לפועל. האמת היא שעיקול
    וממוש של דירת מגורים ראשית הוא הליך קשה ומורכב לנושה — ויש לך הגנות חשובות בחוק.
  </p>

  <h2>עיקול רישומי לעומת ממוש — ההבדל הקריטי</h2>

  <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-4 my-6">
    {[
      {
        title: 'עיקול רישומי (הערה בטאבו)',
        items: [
          'רישום הערה בלשכת רישום המקרקעין',
          'אתה ממשיך לגור בדירה כרגיל',
          'לא תוכל למכור ללא סילוק החוב',
          'לא תוכל לשעבד את הדירה',
          'קל יחסית לרשם להטיל',
        ],
        color: 'border-blue-200 bg-blue-50',
        titleColor: 'text-blue-800',
        icon: '📋',
      },
      {
        title: 'ממוש דירה (מכירה כפויה)',
        items: [
          'מכירת הדירה בפועל נגד רצונך',
          'מצריך אישור בית משפט',
          'שמאות, מכרז ופרסום',
          'שנים של הליכים משפטיים',
          'נדיר ביחס לדירה ראשית',
        ],
        color: 'border-amber-200 bg-amber-50',
        titleColor: 'text-amber-800',
        icon: '⚠️',
      },
    ].map(col => (
      <div class={`border-2 ${col.color} rounded-xl p-5`}>
        <h3 class={`font-bold ${col.titleColor} mb-3`}>{col.icon} {col.title}</h3>
        <ul class="text-sm space-y-1.5 text-gray-700">
          {col.items.map(item => <li>• {item}</li>)}
        </ul>
      </div>
    ))}
  </div>

  <h2>מה מגן עליך מפני ממוש?</h2>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-3">גורמים שמקשים מאוד על ממוש הדירה:</p>
    <ul class="space-y-1.5">
      <li><strong>זו הדירה היחידה שלך</strong> — בית יחיד נהנה מהגנה משמעותית יותר בחוק</li>
      <li><strong>ילדים קטינים מתגוררים בה</strong> — שיקול כבד מאוד בכל החלטה שיפוטית</li>
      <li><strong>שווי הדירה גבוה בהרבה מהחוב</strong> — ממוש לא יכסה אפילו את עלויות ההליך</li>
      <li><strong>בן/בת זוג שלא חייב/ת</strong> — חלקו/ה בדירה מוגן; צריך הסכמה</li>
      <li><strong>החוב קטן ביחס לשווי הדירה</strong> — הרשם עשוי לדחות בקשת ממוש כלא פרופורציונלית</li>
      <li><strong>משכנתה גדולה על הדירה</strong> — אחרי פירעון המשכנתה יתכן שלא ישאר מה לחלק</li>
    </ul>
  </div>

  <h2>שלבי הממוש — למה זה לוקח שנים</h2>
  <p>
    כדי שנושה ימש דירה, הוא צריך לעבור תהליך ארוך, יקר ומסורבל:
  </p>

  <ol class="step-list">
    <li><span class="step-num">1</span><span>רישום עיקול בלשכת רישום המקרקעין (טאבו)</span></li>
    <li><span class="step-num">2</span><span>הגשת בקשה לממוש לרשם ההוצאה לפועל</span></li>
    <li><span class="step-num">3</span><span>שמיעת עמדת החייב ובני ביתו — בית משפט</span></li>
    <li><span class="step-num">4</span><span>שמאות לקביעת שווי הנכס (1,500–3,000 ₪)</span></li>
    <li><span class="step-num">5</span><span>פרסום מכרז ומכירה פומבית</span></li>
    <li><span class="step-num">6</span><span>תשלום לנושים לפי סדר עדיפויות (בנק משכנתה ראשון)</span></li>
  </ol>

  <p>
    תהליך זה יכול לקחת <strong>2-5 שנים</strong> ועולה לנושה עשרות אלפי שקלים.
    לכן — רוב הנושים מעדיפים הסדר תשלומים מחוץ לכותלי בית המשפט.
  </p>

  <h2>מה כדאי לעשות אם עיקלו את הדירה?</h2>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">⚠️ אל תתעלם</p>
    <p>עיקול רישומי על הדירה הוא אות אזהרה. עדיף לפעול מוקדם — לפני שמגיעים לשלב הממוש.</p>
  </div>

  <ol class="step-list mt-4">
    <li>
      <span class="step-num">1</span>
      <span><strong>פנה לרשם מיד</strong> — הגש בקשה לצו תשלומים. ברגע שיש צו תשלומים פעיל ואתה עומד בו — לרוב לא ניתן לנקוט הליכי ממוש.</span>
    </li>
    <li>
      <span class="step-num">2</span>
      <span><strong>הגש התנגדות לממוש</strong> אם הוגשה בקשה — ציין ילדים קטינים, מצב כלכלי, דירה יחידה, חוב לא פרופורציונלי.</span>
    </li>
    <li>
      <span class="step-num">3</span>
      <span><strong>פנה ישירות לנושה</strong> — לרוב עדיף לנושה הסדר תשלומים מאשר הליך ממוש ארוך ויקר.</span>
    </li>
    <li>
      <span class="step-num">4</span>
      <span><strong>התייעץ עם עורך דין</strong> — בעניין דירה, ייצוג משפטי מחזיר את עצמו. קיים גם סיוע משפטי חינמי לזכאים.</span>
    </li>
  </ol>

  <div class="info-box mt-4">
    <p class="font-semibold text-blue-800 mb-2">סיוע משפטי חינמי לנושא הדירה:</p>
    <ul>
      <li><strong>הלשכה לסיוע משפטי</strong> — של משרד המשפטים, לפי קריטריוני הכנסה</li>
      <li><strong>קליניקות משפטיות</strong> — אוניברסיטאות תל אביב, בר אילן, חיפה</li>
      <li><strong>עמותת "אדווה"</strong> — דיור ושוק הדיור בישראל</li>
    </ul>
  </div>

  <h2>שאלות נפוצות</h2>
  <div class="space-y-4 my-6">
    {[
      { q: 'האם יכולים לעקל את הדירה שאני גר בה?', a: 'עיקול רישומי — כן, אפשרי. הוא מונע ממך למכור בלי לסלק החוב, אבל אתה ממשיך לגור. ממוש בפועל — הרבה קשה יותר, מצריך הליך ארוך ואישור בית משפט.' },
      { q: 'האם יכולים לממש את ביתי בכפייה?', a: 'בתיאוריה כן, בפועל — הליך ממוש דירת מגורים ראשית, בפרט עם ילדים קטינים, ארוך, יקר ומורכב. רוב הנושים מעדיפים הסדר ישיר.' },
      { q: 'מה מגן עלי אם יש לי ילדים?', a: 'נוכחות ילדים קטינים היא שיקול כבד מאוד. בתי המשפט מהססים מאוד לאשר ממוש כשיש ילדים. אין הגנה מוחלטת, אבל זהו טיעון משמעותי בהתנגדות.' },
      { q: 'מה עושים מיד כשעיקלו את הדירה?', a: 'פנה לרשם מיד והגש בקשה לצו תשלומים — זה יכול לעצור הליכי ממוש. גם שקול פנייה ישירה לנושה להסדר. התייעץ עם עורך דין.' },
    ].map(faq => (
      <details class="border border-neutral-border rounded-xl group">
        <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
          {faq.q}
          <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
        </summary>
        <p class="px-4 pb-4 text-gray-600">{faq.a}</p>
      </details>
    ))}
  </div>

  <div slot="next-steps" class="not-prose mt-10 p-6 bg-brand-pale border border-brand-light rounded-xl">
    <h3 class="text-lg font-bold text-brand-dark mb-3">מה עכשיו?</h3>
    <ul class="space-y-2 text-sm">
      <li>← <a href="/guides/tzav-tashlumim/" class="text-brand hover:underline">איך מגישים צו תשלומים — עוצר הליכי ממוש</a></li>
      <li>← <a href="/rights/skhomim-mugganim/" class="text-brand hover:underline">מה עוד מוגן מעיקול?</a></li>
      <li>← <a href="/guides/bitul-ikul/" class="text-brand hover:underline">ביטול עיקול — מדריך מלא</a></li>
      <li>← <a href="/insolvency/what-is/" class="text-brand hover:underline">האם חדלות פירעון יכולה לעזור?</a></li>
    </ul>
  </div>

</GuideLayout>
