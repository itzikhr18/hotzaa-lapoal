---
import GuideLayout from '../../layouts/GuideLayout.astro';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'איך לבטל עיכוב יציאה מהארץ בהוצאה לפועל',
  description: 'שלבים לביטול עיכוב יציאה מהארץ שהוטל בגין חוב בהוצאה לפועל',
  totalTime: 'P30D',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'בדוק מדוע הוטל עיכוב היציאה', text: 'עיכוב יציאה מוטל כשחוב עולה על 10,000 ₪ והחייב לא שיתף פעולה. ברר את הסיבה הספציפית.' },
    { '@type': 'HowToStep', position: 2, name: 'שלם את החוב או הגש בקשה לצו תשלומים', text: 'תשלום מלא, צו תשלומים, או ערובה בנקאית — כל אחת יכולה להוביל לביטול עיכוב היציאה.' },
    { '@type': 'HowToStep', position: 3, name: 'הכן מסמכי הוכחה', text: 'אם מדובר בנסיבות הומניטריות — הכן מסמכים רפואיים, אישורי מעסיק, כרטיסי טיסה.' },
    { '@type': 'HowToStep', position: 4, name: 'הגש בקשה לביטול לרשם ההוצאה לפועל', text: 'הגש בקשה רשמית. כלול: נימוק הבקשה, הוכחת הסדרת החוב, ומסמכים תומכים. ביטול לא קורה אוטומטית.' },
    { '@type': 'HowToStep', position: 5, name: 'המתן להחלטת הרשם', text: 'הרשם מחליט בדרך כלל תוך מספר ימים. אם אושר — הגבלת היציאה מוסרת.' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'מתי מוטל עיכוב יציאה מהארץ?', acceptedAnswer: { '@type': 'Answer', text: 'עיכוב יציאה מוטל כאשר החוב עולה על 10,000 ₪ והחייב לא שיתף פעולה — לא הגיע לחקירת יכולת, לא עמד בצו תשלומים, או לא הגיש מסמכים. הנושה צריך לבקש אותו ספציפית; הוא אינו מוטל אוטומטית.' } },
    { '@type': 'Question', name: 'האם שלילת רישיון נהיגה עדיין אפשרית?', acceptedAnswer: { '@type': 'Answer', text: 'לא. שלילת רישיון נהיגה בוטלה לחלוטין בפברואר 2022 לפי תיקון 69 לחוק ההוצאה לפועל. לא ניתן עוד להטיל הגבלה חדשה, וכל ההגבלות הישנות בוטלו אוטומטית.' } },
    { '@type': 'Question', name: 'מה זה חייב מוגבל באמצעים?', acceptedAnswer: { '@type': 'Answer', text: 'חייב מוגבל הוא מעמד מיוחד לחייב שחובו עולה על כ-160,000 ₪, אינו עומד בצו תשלומים, ולא שיתף פעולה. מעמד זה מביא להגבלות קיצוניות: ביטול כרטיסי אשראי, איסור פתיחת חשבון בנק ועוד.' } },
    { '@type': 'Question', name: 'איך מבטלים עיכוב יציאה מהארץ?', acceptedAnswer: { '@type': 'Answer', text: 'ניתן לבטל בכמה דרכים: תשלום מלא, צו תשלומים ועמידה בו, ערובה בנקאית, או בקשה הומניטרית מנומקת. ביטול לא קורה אוטומטי — יש לפנות לרשם ולבקש רשמית.' } },
    { '@type': 'Question', name: 'אילו הגבלות אוטומטיות ואילו דורשות צו?', acceptedAnswer: { '@type': 'Answer', text: 'עיקול שכר ועיקול חשבון בנק — אוטומטיים לאחר פתיחת תיק. עיכוב יציאה מהארץ, ביטול כרטיסי אשראי, ומינוי חייב מוגבל — דורשים בקשה מהנושה ואישור הרשם.' } },
    { '@type': 'Question', name: 'האם יש הגבלות מיוחדות לחייב במזונות?', acceptedAnswer: { '@type': 'Answer', text: 'כן. חייב במזונות שאינו משלם כפוף להגבלות מחמירות יותר: עיכוב יציאה מוטל גם בחוב נמוך, אפשרות מאסר (לאחר בחינת יכולת), ואין הגנות של "חייב מוגבל" על חוב מזונות.' } },
  ],
};
---

<GuideLayout
  title="הגבלות על חייב בהוצאה לפועל — מה מותר ומה אסור"
  description="עיכוב יציאה מהארץ, עיקול שכר, ביטול כרטיסי אשראי, חייב מוגבל — מה ניתן להטיל עליך, מה בוטל, ואיך מבטלים. הגבלת רישיון נהיגה בוטלה 2022. מדריך 2026."
  breadcrumb={[{ label: 'זכויות חייבים', href: '/rights/' }, { label: 'הגבלות על חייב', href: '/rights/hagbalot/' }]}
  publishDate="2025-03-01"
  updateDate="2026-03-28"
  readTime="10 דקות"
  schema={[faqSchema, howToSchema]}
>

  <p>
    מעבר לעיקולים, רשות האכיפה יכולה להטיל על חייב גם הגבלות אישיות. חשוב לדעת
    מתי ניתן להטיל אותן, כמה זמן הן תקפות, ואיך ניתן לבטל אותן.
    חלק מהן אוטומטיות, חלקן דורשות בקשה — וחלק בוטלו לחלוטין.
  </p>

  <div class="not-prose bg-green-50 border border-green-300 rounded-xl p-4 mb-6">
    <p class="font-bold text-green-800 mb-1">עדכון 2022: הגבלת רישיון נהיגה בוטלה לחלוטין</p>
    <p class="text-sm text-green-700">מפברואר 2022, לפי תיקון 69 לחוק, <strong>לא ניתן עוד להגביל רישיון נהיגה</strong> של חייב. כל ההגבלות הישנות בוטלו אוטומטית. <a href="/guides/rishayon-nehiga/" class="underline font-semibold">קרא עוד ←</a></p>
  </div>

  <h2>טבלת כל ההגבלות האפשריות — 2026</h2>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">סוג ההגבלה</th>
          <th class="text-right p-3 border border-gray-200">סף מינימלי לחוב</th>
          <th class="text-right p-3 border border-gray-200">אוטומטי / דורש צו</th>
          <th class="text-right p-3 border border-gray-200">איך מבטלים</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['עיקול שכר', '1 ₪ (כל חוב)', 'אוטומטי לאחר פתיחת תיק', 'תשלום מלא / צו תשלומים'],
          ['עיקול חשבון בנק', '1 ₪ (כל חוב)', 'אוטומטי לאחר פתיחת תיק', 'תשלום / הסדרת חוב'],
          ['עיקול נכסים', '1 ₪ (כל חוב)', 'דורש בקשת נושה', 'תשלום / הסדר'],
          ['עיכוב יציאה מהארץ', 'מעל 10,000 ₪', 'דורש בקשת נושה + אישור רשם', 'תשלום / צו תשלומים / ערובה'],
          ['ביטול דרכון', 'מעל 10,000 ₪', 'נלווה לעיכוב יציאה', 'כנ"ל'],
          ['ביטול כרטיסי אשראי', 'מעל ~160,000 ₪', 'חייב מוגבל — דורש הכרזה', 'הסדרת חוב + בקשה'],
          ['איסור פתיחת חשבון בנק', 'מעל ~160,000 ₪', 'חייב מוגבל — דורש הכרזה', 'הסדרת חוב + בקשה'],
          ['צו הבאה', 'כל חוב', 'דורש סירוב להתייצב', 'הגעה לדיון'],
          ['שלילת רישיון נהיגה', 'בוטלה לחלוטין!', 'בוטלה — תיקון 69, פברואר 2022', 'לא רלוונטי'],
        ].map(([type, threshold, auto, cancel], i) => (
          <tr class={type.includes('בוטלה') ? 'bg-green-50' : i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class={`p-3 border border-gray-200 font-semibold ${type.includes('בוטלה') ? 'text-green-700 line-through' : 'text-gray-800'}`}>{type}</td>
            <td class="p-3 border border-gray-200 text-gray-600 text-xs">{threshold}</td>
            <td class="p-3 border border-gray-200 text-gray-600 text-xs">{auto}</td>
            <td class="p-3 border border-gray-200 text-brand text-xs">{cancel}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>עיקול שכר — כמה אפשר לעקל?</h2>
  <p>
    עיקול שכר הוא ההגבלה השכיחה ביותר — וגם ההגבלה שיש לה גבולות ברורים בחוק.
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">מה אפשר לעקל מהשכר?</p>
    <ul class="space-y-1">
      <li><strong>לא ניתן לעקל את כל השכר</strong> — החוק מגן על "שכר מינימום" שנשאר בידי העובד</li>
      <li><strong>תקרת עיקול שכר</strong> — עד 1/3 משכר כולל בגין חובות אזרחיים רגילים</li>
      <li><strong>חוב מזונות</strong> — ניתן לעקל עד 50% מהשכר (כולל קצבאות)</li>
      <li><strong>שכר מינימום מוגן</strong> — חייב תמיד מקבל לפחות שכר מינימום (6,443.85 ₪ ברוטו — אפריל 2026)</li>
      <li><strong>ריבוי עיקולים</strong> — סכום עיקולים מרובים לא יעלה על תקרת ה-1/3</li>
    </ul>
  </div>

  <h2>עיקול חשבון בנק — מה מוגן?</h2>
  <p>
    עיקול חשבון בנק מוטל על ידי הנושה ישירות על הבנק. הבנק מחויב להעביר את הכספים
    ישירות ללשכת ההוצאה לפועל. אבל גם כאן — יש הגנות:
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">סוג כסף בחשבון</th>
          <th class="text-right p-3 border border-gray-200">ניתן לעיקול?</th>
          <th class="text-right p-3 border border-gray-200">הסבר</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['שכר עבודה רגיל', 'חלקי — עד 1/3', 'תקרת עיקול שכר חלה גם בחשבון'],
          ['קצבת ילדים', 'לא', 'קצבאות ביטוח לאומי לילדים — מוגנות'],
          ['קצבת נכות', 'לא', 'מוגנת לחלוטין מעיקול'],
          ['קצבת הבטחת הכנסה', 'לא', 'מוגנת לחלוטין מעיקול'],
          ['מענקי עבודה', 'כן', 'לרוב ניתנים לעיקול'],
          ['חסכונות כלליים', 'כן', 'ניתנים לעיקול'],
          ['קרנות השתלמות (לא מבוגרת)', 'מוגבל', 'עיקול אפשרי אך קשה'],
          ['פנסיה / גמל', 'לא (בדרך כלל)', 'מוגנת לפי חוק קופות גמל'],
        ].map(([type, attachable, explanation], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-semibold text-gray-700">{type}</td>
            <td class={`p-3 border border-gray-200 font-semibold text-xs ${attachable === 'לא' ? 'text-green-600' : attachable === 'כן' ? 'text-red-600' : 'text-amber-600'}`}>{attachable}</td>
            <td class="p-3 border border-gray-200 text-gray-500 text-xs">{explanation}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>עיכוב יציאה מהארץ — כל מה שצריך לדעת</h2>
  <p>
    עיכוב יציאה מהארץ הוא אחת ההגבלות המפחידות ביותר — אבל חשוב להבין שיש לה מגבלות
    ברורות ואפשרויות ביטול.
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">פרמטר</th>
          <th class="text-right p-3 border border-gray-200">פרטים</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['סף חוב להטלה', 'מעל 10,000 ₪'],
          ['תנאי נוסף', 'חייב לא שיתף פעולה (לא הגיע לחקירה, לא עמד בצו תשלומים)'],
          ['מי מגיש?', 'הנושה — הגבלה אינה אוטומטית'],
          ['מי מאשר?', 'רשם ההוצאה לפועל'],
          ['תקופת תוקף', 'שנה אחת — ניתן לחדש בבקשה'],
          ['ניתן לערעור?', 'כן — לבית משפט מחוזי'],
          ['נסיעה הומניטרית', 'ניתן לבקש אישור לנסיעה ספציפית (רפואי, עבודה)'],
          ['ביטול מלא', 'תשלום חוב / צו תשלומים + בקשה / ערובה בנקאית'],
        ].map(([param, detail], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-semibold text-gray-700">{param}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{detail}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">דרכים לביטול עיכוב יציאה מהארץ:</p>
    <ol class="space-y-1 list-decimal list-inside">
      <li><strong>תשלום מלא של החוב</strong> — הדרך המהירה ביותר</li>
      <li><strong>קבלת צו תשלומים ועמידה בו</strong> — הרשם רשאי לבטל את העיכוב</li>
      <li><strong>הגשת ערובה בנקאית</strong> — ערבות של גוף בנקאי על הסכום</li>
      <li><strong>בקשה הומניטרית</strong> — לנסיעה מוגדרת (רפואי, עבודה, לווייה) עם מסמכים</li>
      <li><strong>ערעור לבית משפט מחוזי</strong> — אם הטלת העיכוב לא כדין</li>
    </ol>
  </div>

  <h2>שלילת רישיון נהיגה — בוטלה! (תיקון 69)</h2>

  <div class="not-prose bg-green-50 border border-green-300 rounded-xl p-5 my-6">
    <p class="font-bold text-green-800 mb-2">עדכון חשוב — תיקון 69 לחוק ההוצאה לפועל, פברואר 2022</p>
    <div class="text-sm text-green-700 space-y-2">
      <p>מפברואר 2022, <strong>הגבלת רישיון נהיגה בהוצאה לפועל בוטלה לחלוטין</strong>.</p>
      <p>הרקע: כלכלנים ומחוקקים הכירו בכך שלקיחת רישיון הנהיגה פוגעת ביכולת החייב להתפרנס ולשלם את חובו — תוצאה הפוכה לחלוטין ממה שרצו להשיג.</p>
      <ul class="mt-2 space-y-1">
        <li>• לא ניתן עוד להטיל הגבלה חדשה</li>
        <li>• כל ההגבלות שהיו בתוקף — בוטלו אוטומטית</li>
        <li>• אם יש לך הגבלה ישנה ועדיין לא בוטלה — פנה ללשכת ההוצאה לפועל מיד</li>
      </ul>
    </div>
  </div>

  <h2>חייב מוגבל באמצעים — מה זה ומה ההשלכות?</h2>
  <p>
    "חייב מוגבל באמצעים" הוא מעמד מיוחד שמוטל על חייבים עם חובות גדולים שלא שיתפו פעולה.
  </p>

  <h3>תנאים למינוי "חייב מוגבל":</h3>
  <ul>
    <li>חוב כולל מעל <strong>~160,000 ₪</strong> (הסכום מתעדכן מדי שנה)</li>
    <li>לא עומד בצו תשלומים פעיל</li>
    <li>לא שיתף פעולה עם רשות האכיפה (לא הגיע לדיונים, לא הגיש מסמכים)</li>
  </ul>

  <h3>הגבלות על "חייב מוגבל":</h3>

  <div class="alert-box">
    <p class="font-semibold text-red-800 mb-2">הגבלות חריפות על "חייב מוגבל":</p>
    <ul class="space-y-1">
      <li>ביטול כרטיסי אשראי קיימים</li>
      <li>איסור פתיחת חשבון עו"ש חדש (חשבון מוגבל בלבד)</li>
      <li>איסור על רכב על שמו (בתנאים מסוימים)</li>
      <li>הגבלה על פתיחת עסק / קבלת רישיון עסק</li>
      <li>פרסום שמו ברשימה ציבורית (בתנאים)</li>
    </ul>
  </div>

  <h3>הגבלות שלא חלות על "חייב מוגבל":</h3>

  <div class="tip-box">
    <p class="font-semibold text-green-800 mb-2">מה "חייב מוגבל" יכול עדיין לעשות:</p>
    <ul class="space-y-1">
      <li>לשמור חשבון בנק מוגבל (לקבלת שכר ולתשלומים בסיסיים)</li>
      <li>לנסוע בארץ — אין הגבלת נסיעות פנים (רישיון נהיגה לא מוגבל)</li>
      <li>לעבוד — אין הגבלה על עיסוק (מרבית המקצועות)</li>
      <li>לגור בביתו — אין פינוי אוטומטי</li>
      <li>לקבל קצבאות ביטוח לאומי — מוגנות מעיקול</li>
    </ul>
  </div>

  <h3>כיצד מסירים מעמד "חייב מוגבל"?</h3>

  <ol class="step-list">
    <li><span class="step-num">1</span><span><strong>הגשת בקשה לרשם</strong> — בקשה לביטול מעמד חייב מוגבל, עם הסבר לנסיבות</span></li>
    <li><span class="step-num">2</span><span><strong>הוכחת שיתוף פעולה</strong> — הגעה לכל הדיונים, הגשת מסמכים שנדרשו, דיווחים</span></li>
    <li><span class="step-num">3</span><span><strong>הצעת תוכנית תשלום</strong> — בקשה לצו תשלומים ועמידה בו לתקופה מסוימת</span></li>
    <li><span class="step-num">4</span><span><strong>ערעור על ההכרזה</strong> — אם ההכרזה לא כדין, ניתן לערער לבית משפט מחוזי</span></li>
  </ol>

  <h2>כיצד מוסרת כל הגבלה — מדריך מעשי</h2>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">הגבלה</th>
          <th class="text-right p-3 border border-gray-200">הדרך להסרה</th>
