          ['עיכוב יציאה מהארץ', 'תשלום / צו תשלומים / ערובה + בקשה לרשם', 'שבועיים–חודש'],
          ['ביטול כרטיסי אשראי (חייב מוגבל)', 'הסדרת חוב + בקשה לביטול מעמד', 'חודשיים–שלושה חודשים'],
          ['חשבון מוגבל', 'הסדרת חוב + בקשה לבנק ולרשם', 'חודשיים–שלושה חודשים'],
