---
import GuideLayout from '../../layouts/GuideLayout.astro';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'איך לבטל עיכוב יציאה מהארץ בהוצאה לפועל',
  description: 'שלבים לביטול עיכוב יציאה מהארץ שהוטל בגין חוב בהוצאה לפועל',
  totalTime: 'P30D',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'בדוק מדוע הוטל עיכוב היציאה', text: 'עיכוב יציאה מוטל כשחוב עולה על 10,000 ₪ והחייב לא שיתף פעולה — לא הגיע לחקירת יכולת, לא עמד בצו תשלומים, לא הגיש מסמכים. ברר את הסיבה הספציפית.' },
    { '@type': 'HowToStep', position: 2, name: 'שלם את החוב או הגש בקשה לצו תשלומים', text: 'האפשרויות: תשלום מלא של החוב, קבלת צו תשלומים ועמידה בו, או הפקדת ערובה בנקאית. כל אחת מהן יכולה להוביל לביטול עיכוב היציאה.' },
    { '@type': 'HowToStep', position: 3, name: 'הכן מסמכי הוכחה', text: 'אם מדובר בנסיבות הומניטריות (רפואה, עבודה) — הכן מסמכים רפואיים, אישורי מעסיק, או כרטיסי טיסה. הרשם שוקל כל בקשה לגופה.' },
    { '@type': 'HowToStep', position: 4, name: 'הגש בקשה לביטול לרשם ההוצאה לפועל', text: 'הגש בקשה רשמית לרשם ההוצאה לפועל. כלול: נימוק הבקשה, הוכחת הסדרת החוב או הנסיבות, ומסמכים תומכים. ביטול לא קורה אוטומטית — יש לבקש רשמית.' },
    { '@type': 'HowToStep', position: 5, name: 'המתן להחלטת הרשם', text: 'הרשם מחליט בדרך כלל תוך מספר ימים. אם הבקשה אושרה — הגבלת היציאה מוסרת ויש לעדכן את הגורמים הרלוונטיים (שדה התעופה, גורמי הגבול).' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'מתי מוטל עיכוב יציאה מהארץ?',
      acceptedAnswer: { '@type': 'Answer', text: 'עיכוב יציאה מהארץ מוטל כאשר החוב עולה על 10,000 ₪ והחייב לא שיתף פעולה עם רשות האכיפה — למשל לא הגיע לחקירת יכולת, לא עמד בצו תשלומים, או לא הגיש מסמכים שנדרשו. הנושה צריך לבקש אותו ספציפית מהרשם; הוא אינו מוטל אוטומטית.' },
    },
    {
      '@type': 'Question',
      name: 'האם שלילת רישיון נהיגה עדיין אפשרית?',
      acceptedAnswer: { '@type': 'Answer', text: 'לא. שלילת רישיון נהיגה כהליך בהוצאה לפועל בוטלה לחלוטין בפברואר 2022 לפי תיקון 69 לחוק ההוצאה לפועל. לא ניתן עוד להטיל הגבלה חדשה, וכל ההגבלות הישנות בוטלו אוטומטית.' },
    },
    {
      '@type': 'Question',
      name: 'מה זה חייב מוגבל באמצעים?',
      acceptedAnswer: { '@type': 'Answer', text: 'חייב מוגבל באמצעים הוא מעמד מיוחד המוטל על חייב שחובו הכולל עולה על כ-160,000 ש"ח, אינו עומד בצו תשלומים, ולא שיתף פעולה עם רשות האכיפה. מעמד זה מביא להגבלות קיצוניות יותר: ביטול כרטיסי אשראי, איסור פתיחת חשבון בנק, ועוד. חייב מוגבל יכול לערער על המעמד.' },
    },
    {
      '@type': 'Question',
      name: 'איך מבטלים עיכוב יציאה מהארץ?',
      acceptedAnswer: { '@type': 'Answer', text: 'ניתן לבטל עיכוב יציאה מהארץ בכמה דרכים: תשלום מלא של החוב, קבלת צו תשלומים ועמידה בו, הגשת בקשה לרשם עם ערובה בנקאית או ערב, או הגשת בקשה מנומקת על בסיס נסיבות הומניטריות (כגון טיפול רפואי, נסיעת עבודה). ביטול לא קורה אוטומטי — יש לפנות לרשם ולבקש רשמית.' },
    },
    {
      '@type': 'Question',
      name: 'כמה זמן תקפות ההגבלות?',
      acceptedAnswer: { '@type': 'Answer', text: 'ההגבלות נשארות בתוקף עד שהחוב מסולק במלואו או מוסדר בצורה מספקת. אין תאריך פקיעה אוטומטי. הן מוסרות רק לאחר שהחייב פועל לטיפול בחוב ומבקש את ביטולן מהרשם.' },
    },
  ],
};
---

<GuideLayout
  title="הגבלות על חייב בהוצאה לפועל — מה מותר ומה אסור"
  description="עיכוב יציאה מהארץ, הגבלת כרטיסי אשראי, חשבון מוגבל — מה ניתן להטיל עליך ומה אפשר לעשות. הגבלת רישיון נהיגה בוטלה בפברואר 2022. מדריך מעודכן 2026."
  breadcrumb={[{ label: 'זכויות חייבים', href: '/rights/' }, { label: 'הגבלות על חייב', href: '/rights/hagbalot/' }]}
  publishDate="2025-03-01"
  updateDate="2026-03-28"
  readTime="6 דקות"
  schema={[faqSchema, howToSchema]}
>

  <p>
    מעבר לעיקולים, רשות האכיפה יכולה להטיל על חייב גם הגבלות אישיות. חשוב לדעת
    מתי ניתן להטיל אותן, כמה זמן הן תקפות, ואיך ניתן לבטל אותן.
  </p>
  <div class="not-prose bg-green-50 border border-green-300 rounded-xl p-4 mb-2">
    <p class="font-bold text-green-800 mb-1">🎉 עדכון 2022: הגבלת רישיון נהיגה בוטלה לחלוטין</p>
    <p class="text-sm text-green-700">מפברואר 2022, לפי תיקון 69 לחוק, <strong>לא ניתן עוד להגביל רישיון נהיגה</strong> של חייב. כל ההגבלות הישנות בוטלו אוטומטית. <a href="/guides/rishayon-nehiga/" class="underline font-semibold">קרא עוד ←</a></p>
  </div>

  <h2>סוגי ההגבלות האפשריות</h2>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">סוג ההגבלה</th>
          <th class="text-right p-3 border border-gray-200">מתי מוטלת?</th>
          <th class="text-right p-3 border border-gray-200">איך מבטלים?</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['עיכוב יציאה מהארץ', 'חוב מעל 10,000 ₪, לא שיתף פעולה', 'תשלום, צו תשלומים, או ערעור'],
          ['שלילת רישיון נהיגה — בוטלה!', 'בוטלה לחלוטין בפברואר 2022 (תיקון 69)', '✅ לא רלוונטי — הגבלה זו אינה קיימת עוד'],
          ['ביטול דרכון', 'עיכוב יציאה + דרכון בתוקף', 'כנ"ל'],
          ['הגבלת כרטיסי אשראי', 'חייב מוגבל (חוב גדול + אי שיתוף)', 'תשלום חלקי משמעותי'],
          ['איסור פתיחת חשבון בנק', 'חייב מוגבל', 'הסדרת החוב'],
          ['צו הבאה', 'סירוב להגיע לחקירת יכולת', 'הגעה לדיון'],
        ].map(([type, when, how], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-semibold text-gray-800">{type}</td>
            <td class="p-3 border border-gray-200 text-gray-600 text-xs">{when}</td>
            <td class="p-3 border border-gray-200 text-brand text-xs">{how}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>עיכוב יציאה מהארץ — מה צריך לדעת</h2>
  <p>
    עיכוב יציאה מהארץ הוא אחת ההגבלות המפחידות ביותר, אבל חשוב להבין את המגבלות שלה:
  </p>

  <div class="info-box">
    <ul class="space-y-1">
      <li><strong>לא אוטומטי</strong> — הנושה צריך לבקש אותו ספציפית מהרשם</li>
      <li><strong>תקופה מוגבלת</strong> — ניתן לבקש הארכה, אבל לא אינסופי</li>
      <li><strong>ניתן לערעור</strong> — אם יש טעמים (כגון נסיעת עבודה, חינוך ילדים, רפואי)</li>
      <li><strong>דחייה זמנית אפשרית</strong> — לצורך נסיעה ספציפית, עם ערובה</li>
    </ul>
  </div>

  <div class="not-prose bg-green-50 border border-green-300 rounded-xl p-4 my-4">
    <p class="font-bold text-green-800 mb-1">🎉 עדכון חשוב — שלילת רישיון נהיגה בוטלה</p>
    <p class="text-sm text-green-700">מפברואר 2022, לפי תיקון 69 לחוק ההוצאה לפועל, הגבלת רישיון נהיגה <strong>בוטלה לחלוטין</strong>. לא ניתן עוד להטיל הגבלה חדשה, וכל ההגבלות הישנות בוטלו אוטומטית. <a href="/guides/rishayon-nehiga/" class="underline font-semibold">קרא עוד ←</a></p>
  </div>

  <h2>מה זה "חייב מוגבל"?</h2>
  <p>
    "חייב מוגבל" הוא מעמד מיוחד שמוטל על חייב שעומד בתנאים מצטברים:
  </p>
  <ul>
    <li>חוב כולל מעל ~160,000 ש"ח</li>
    <li>לא עומד בצו תשלומים</li>
    <li>לא שיתף פעולה עם רשות האכיפה</li>
  </ul>
  <p>
    חייב מוגבל מקבל הגבלות רחבות יותר. אבל גם כאן — יש תהליך ויש ערעור.
    אם הוטל עליך מעמד "חייב מוגבל" — מומלץ מאוד להתייעץ עם עורך דין.
  </p>

  <h2>שלילת רישיון נהיגה — בוטלה!</h2>
  <p>
    מפברואר 2022 <strong>לא ניתן עוד לשלול רישיון נהיגה</strong> כהליך בהוצאה לפועל (תיקון 69).
    אם הייתה לך הגבלה כזו בעבר — היא בוטלה אוטומטית.
    <a href="/guides/rishayon-nehiga/" class="text-brand hover:underline">קרא את המדריך המלא ←</a>
  </p>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">⚠️ הכי חשוב</p>
    <p>ההגבלות האלה מוטלות בדרך כלל כשחייב <strong>לא שיתף פעולה</strong> עם הרשות. השיתוף פעולה — הגעה לדיונים, הגשת מסמכים, הגשת בקשות — הוא ההגנה הכי טובה שיש.</p>
  </div>

  <h2>שאלות נפוצות</h2>
  <div class="space-y-4 my-6">
    <details class="border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        מתי מוטל עיכוב יציאה מהארץ?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">כאשר החוב עולה על 10,000 ₪ והחייב לא שיתף פעולה — לא הגיע לחקירת יכולת, לא עמד בצו תשלומים, או לא הגיש מסמכים שנדרשו. הנושה צריך לבקש אותו ספציפית; הוא אינו מוטל אוטומטית.</p>
    </details>

    <details class="border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        האם שלילת רישיון נהיגה עדיין אפשרית?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">לא. שלילת רישיון נהיגה בהוצאה לפועל בוטלה לחלוטין בפברואר 2022 לפי תיקון 69 לחוק. לא ניתן להטיל הגבלה חדשה, וכל ההגבלות הישנות בוטלו אוטומטית.</p>
    </details>

    <details class="border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        איך מבטלים עיכוב יציאה מהארץ?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">ניתן לבטל בכמה דרכים: תשלום מלא של החוב, עמידה בצו תשלומים, הגשת בקשה לרשם עם ערובה בנקאית, או בקשה מנומקת על בסיס נסיבות הומניטריות. הביטול אינו אוטומטי — יש לפנות לרשם ולבקש רשמית.</p>
    </details>

    <details class="border border-neutral-border rounded-xl group">
      <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center">
        כמה זמן תקפות ההגבלות?
        <span class="text-neutral-muted group-open:rotate-180 transition-transform">▼</span>
      </summary>
      <p class="px-4 pb-4 text-gray-600">ההגבלות נשארות בתוקף עד שהחוב מסולק במלואו או מוסדר בצורה מספקת. אין תאריך פקיעה אוטומטי — הן מוסרות רק לאחר שהחייב פועל לטיפול בחוב ומבקש את ביטולן מהרשם.</p>
    </details>
  </div>

  <div slot="next-steps" class="not-prose mt-10 p-6 bg-brand-pale border border-brand-light rounded-xl">
    <h3 class="text-lg font-bold text-brand-dark mb-3">מה עכשיו?</h3>
    <ul class="space-y-2 text-sm">
      <li>← <a href="/rights/10-zchuyot/" class="text-brand hover:underline">כל הזכויות שמגיעות לך</a></li>
      <li>← <a href="/guides/tzav-tashlumim/" class="text-brand hover:underline">צו תשלומים — הדרך לצאת ממעגל ההגבלות</a></li>
      <li>← <a href="/guides/ichud-tikim/" class="text-brand hover:underline">איחוד תיקים — לחייב עם הרבה חובות</a></li>
    </ul>
  </div>

</GuideLayout>
