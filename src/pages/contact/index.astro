---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="יצירת קשר"
  description="שאלה על הוצאה לפועל? צור קשר עם הוצאהלפועל.info"
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-12">

    <nav class="text-sm text-neutral-muted mb-6">
      <a href="/">בית</a> › <span class="text-gray-700">יצירת קשר</span>
    </nav>

    <h1 class="text-3xl font-bold text-brand-dark mb-3">יצירת קשר</h1>
    <p class="text-gray-600 mb-10">שאלה? הצעה? רוצה לדווח על שגיאה? אנחנו כאן.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <div class="bg-white border border-neutral-border rounded-xl p-5">
        <h2 class="font-bold text-gray-800 mb-3">📧 דואר אלקטרוני</h2>
        <p class="text-sm text-gray-600 mb-1">לשאלות כלליות:</p>
        <p class="font-medium text-brand">info@hotzaa-lapoal.info</p>
        <p class="text-sm text-gray-600 mt-3 mb-1">לנושאי פרטיות:</p>
        <p class="font-medium text-brand">privacy@hotzaa-lapoal.info</p>
      </div>

      <div class="bg-white border border-neutral-border rounded-xl p-5">
        <h2 class="font-bold text-gray-800 mb-3">⏱️ זמן תגובה</h2>
        <ul class="text-sm text-gray-600 space-y-1">
          <li>• שאלות כלליות: 1-2 ימי עסקים</li>
          <li>• בקשות מחיקת מידע: עד 30 יום</li>
        </ul>
      </div>

    </div>

    <div class="mt-8 bg-brand-pale border border-brand-light rounded-xl p-5">
      <h2 class="font-bold text-brand-dark mb-3">צריך עזרה משפטית?</h2>
      <p class="text-sm text-gray-600 mb-4">אנחנו לא משרד עורכי דין. לסיוע משפטי — פנה לגורמים הרשמיים:</p>
      <ul class="space-y-2 text-sm">
        <li><a href="https://www.gov.il/he/departments/ministry_of_justice_legal_aid/govil-landing-page" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline font-medium">← הלשכה לסיוע משפטי — ייצוג חינמי לזכאים</a></li>
        <li><a href="https://www.kolzchut.org.il" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline font-medium">← כל-זכות — מידע על זכויות בישראל</a></li>
        <li><a href="https://www.gov.il/he/departments/law_enforcement_and_collection_system_authority" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline font-medium">← רשות האכיפה והגבייה — טפסים ובקשות</a></li>
      </ul>
    </div>

    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800">
      ⚠️ אנחנו לא משרד עורכי דין ולא נותנים ייעוץ משפטי אישי.
    </div>

  </main>
  <Footer />
</BaseLayout>
