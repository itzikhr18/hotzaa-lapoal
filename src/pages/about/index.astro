---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'אודות הוצאהלפועל.info',
  description: 'מי אנחנו, מה המטרה, ואיך אנחנו שומרים על דיוק המידע',
  url: 'https://hotzaa-lapoal.info/about/',
  mainEntity: {
    '@type': 'Organization',
    name: 'הוצאהלפועל.info',
    url: 'https://hotzaa-lapoal.info',
    description: 'מידע חינמי על הוצאה לפועל וחדלות פירעון לחייבים בישראל',
    foundingDate: '2024',
    areaServed: 'IL',
    inLanguage: 'he',
  },
};
---

<BaseLayout
  title="אודות הוצאהלפועל.info — מי אנחנו ולמה בנינו את האתר"
  description="הוצאהלפועל.info נוצר כדי לעזור ל-570,000 ישראלים עם תיק הוצאה לפועל שאין להם ייצוג. מידע פשוט, כלים חינמיים, ומתודולוגיה קפדנית לדיוק."
  schema={schema}
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-12">

    <nav class="text-sm text-neutral-muted mb-6">
      <a href="/">בית</a> › <span class="text-gray-700">אודות</span>
    </nav>

    <h1 class="text-3xl font-bold text-brand-dark mb-8">אודות הוצאהלפועל.info</h1>

    <div class="rtl-prose space-y-8">

      <div class="bg-brand-pale border border-brand-light rounded-2xl p-6">
        <p class="text-lg text-brand-dark font-medium leading-relaxed">
          570,000 ישראלים חיים עם תיק הוצאה לפועל פעיל. 77% מהם ללא ייצוג משפטי.
          רק 1.2% מגישים בקשות — לא כי אין להם אפשרויות, אלא כי הם לא יודעים שיש להם.
          בנינו את האתר הזה כדי לשנות את זה.
        </p>
      </div>

      <section>
        <h2>למה בנינו את האתר הזה</h2>
        <p>
          המידע על הוצאה לפועל בישראל קיים — בחוק, בפסקי דין, באתרי ממשלה.
          אבל הוא כתוב בשפה משפטית שאדם רגיל לא יכול להבין.
        </p>
        <p>
          בנינו את הוצאהלפועל.info כדי לגשר על הפער הזה. לתרגם את המידע המשפטי
          לעברית פשוטה, להוסיף כלים שלא היו קיימים (כמו מחשבון ריבית תיקון 9),
          ולחבר בין חייבים לגורמי סיוע שיכולים לעזור.
        </p>
        <p>
          המציאות היא שחייב שיודע את זכויותיו — ופועל בהתאם — יכול לשפר משמעותית
          את מצבו. הידע הוא הכוח.
        </p>
      </section>

      <section>
        <h2>איך אנחנו שומרים על דיוק המידע</h2>
        <p>המידע באתר עובר בדיקה קפדנית לפני פרסום ומעודכן באופן שוטף:</p>
        <ul>
          <li><strong>מקורות ראשוניים בלבד</strong> — חוקים, תקנות, וחוזרי רשות האכיפה והגבייה</li>
          <li><strong>עדכון לפי שינויי חקיקה</strong> — כגון תיקון 9 (ינואר 2025), תיקון 69 (פברואר 2022), ועדכוני שכר מינימום</li>
          <li><strong>תאריכי עדכון גלויים</strong> — כל עמוד מציג מתי עודכן לאחרונה</li>
          <li><strong>הפרדה בין עובדה לייעוץ</strong> — המידע הוא כללי; לייעוץ אישי מציינים לפנות לעורך דין</li>
          <li><strong>תיקון שגיאות</strong> — אם מצאת טעות, אנא <a href="/contact/">פנה אלינו</a> ונתקן מיד</li>
        </ul>
      </section>

      <section>
        <h2>מה אנחנו מציעים</h2>
        <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-3">
          {[
            { icon: '📚', title: 'מדריכים מפורטים', desc: '25+ מדריכים לכל שלב בהוצאה לפועל — בשפה פשוטה' },
            { icon: '🧮', title: 'מחשבון ריבית תיקון 9', desc: 'חשב כמה אתה באמת חייב לפי החוק מינואר 2025' },
            { icon: '💬', title: "צ'אטבוט AI", desc: 'עונה על שאלות 24/7 — בחינם, מבוסס מאגר מאומת' },
            { icon: '✅', title: 'בדיקת זכאות', desc: '4 שאלות ותדע לאיזה הסדר אתה זכאי' },
            { icon: '❓', title: '60+ שאלות נפוצות', desc: 'תשובות לכל השאלות שאנשים שואלים' },
            { icon: '🔗', title: 'קישורים לגורמי סיוע', desc: 'הלשכה לסיוע משפטי, כל-זכות, ורשות האכיפה' },
          ].map(item => (
            <div class="flex gap-3 p-3 bg-white border border-neutral-border rounded-xl">
              <span class="text-2xl">{item.icon}</span>
              <div>
                <p class="font-semibold text-gray-800 text-sm">{item.title}</p>
                <p class="text-xs text-gray-500 mt-0.5">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2>מה אנחנו לא</h2>
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 not-prose">
          <ul class="text-sm text-gray-700 space-y-1.5">
            <li>✗ <strong>לא משרד עורכי דין</strong> — המידע שלנו הוא כללי ואינו ייעוץ משפטי</li>
            <li>✗ <strong>לא אחראים לתוצאות בתיק הספציפי שלך</strong> — כל מקרה שונה</li>
            <li>✗ <strong>לא מבטיחים שהמידע מדויק לחלוטין</strong> — החוק משתנה, תמיד בדוק עם עורך דין לפני פעולה</li>
            <li>✗ <strong>לא גובים תשלום</strong> — כל המידע, הכלים, והמדריכים חינמיים לחלוטין</li>
          </ul>
        </div>
      </section>

      <section>
        <h2>מקורות המידע שלנו</h2>
        <p>המידע באתר מבוסס על:</p>
        <ul>
          <li>חוק ההוצאה לפועל, התשכ"ז-1967 ותיקוניו</li>
          <li>חוק חדלות פירעון ושיקום כלכלי, התשע"ח-2018</li>
          <li>חוק פסיקת ריבית והצמדה, התשכ"א-1961 (כולל תיקון 9, 2025)</li>
          <li>חוק שכר מינימום, התשמ"ז-1987 (ועדכוני שכר שוטפים)</li>
          <li>אתר רשות האכיפה והגבייה (gov.il)</li>
          <li>פסיקת בית המשפט העליון ובתי המשפט המחוזיים</li>
          <li>חוזרי מנהל בתי המשפט</li>
        </ul>
      </section>

      <section>
        <h2>מודל הכנסה — שקיפות מלאה</h2>
        <p>
          האתר מממן את עצמו דרך פרסום (Google AdSense) בלבד.
          אנחנו לא אוספים פרטים אישיים מעבר לנדרש, לא מעבירים מידע לצדדים שלישיים,
          ולא גובים תשלום על שום שירות באתר.
        </p>
        <p>
          אנחנו לא מקבלים תשלום מעורכי דין עבור הפניות, ולא מקדמים שירותים משפטיים ספציפיים.
          הקישורים לגורמי סיוע (הלשכה לסיוע משפטי, כל-זכות, רשות האכיפה) הם קישורים ממשלתיים וציבוריים בלבד.
        </p>
      </section>

      <section>
        <h2>נגישות</h2>
        <p>
          אנחנו מחויבים להנגיש את האתר לכלל המשתמשים, לרבות אנשים עם מוגבלות.
          האתר מיישם את תקנות שוויון זכויות לאנשים עם מוגבלות ואת הנחיות WCAG 2.1 ברמה AA.
          <a href="/legal/accessibility/">קרא את הצהרת הנגישות המלאה ←</a>
        </p>
      </section>

      <section>
        <h2>צור קשר</h2>
        <p>
          שאלות, הצעות שיפור, או רוצה לדווח על שגיאה במידע?
          <a href="/contact/">פנה אלינו</a> — נשמח לשמוע ולשפר.
        </p>
        <p>
          <strong>נגישות:</strong> לפניות בנושאי נגישות —
          <a href="mailto:accessibility@hotzaa-lapoal.info">accessibility@hotzaa-lapoal.info</a>
        </p>
      </section>

    </div>
  </main>
  <Footer />
</BaseLayout>
