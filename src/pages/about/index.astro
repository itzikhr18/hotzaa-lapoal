---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'אודות הוצאהלפועל.info',
  description: 'מי אנחנו, מה המטרה, ואיך אנחנו שומרים על דיוק המידע',
  url: 'https://hotzaa-lapoal.info/about/',
  dateModified: '2026-03-31',
  mainEntity: {
    '@type': 'Organization',
    name: 'הוצאהלפועל.info',
    url: 'https://hotzaa-lapoal.info',
    description: 'מידע חינמי על הוצאה לפועל וחדלות פירעון לחייבים בישראל',
    foundingDate: '2024',
    areaServed: 'IL',
    inLanguage: 'he',
    knowsAbout: [
      'הוצאה לפועל בישראל',
      'חדלות פירעון ושיקום כלכלי',
      'צו תשלומים',
      'איחוד תיקים',
      'חוק פסיקת ריבית והצמדה תיקון 9',
      'זכויות חייבים',
      'הגנה על בית המגורים',
    ],
    sameAs: [
      'https://www.gov.il/he/departments/law_enforcement_and_collection_system_authority',
      'https://www.nevo.co.il/law_html/Law01/P221_001.htm',
      'https://www.kolzchut.org.il',
    ],
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      url: 'https://hotzaa-lapoal.info/contact/',
      availableLanguage: 'Hebrew',
    },
  },
};
---

<BaseLayout
  title="אודות הוצאהלפועל.info — מי אנחנו ולמה בנינו את האתר"
  description="הוצאהלפועל.info נוצר כדי לעזור ל-570,000 ישראלים עם תיק הוצאה לפועל שאין להם ייצוג. מידע פשוט, כלים חינמיים, ומתודולוגיה קפדנית לדיוק."
  schema={schema}
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-12">

    <nav class="text-sm text-neutral-muted mb-6">
      <a href="/">בית</a> › <span class="text-gray-700">אודות</span>
    </nav>

    <h1 class="text-3xl font-bold text-brand-dark mb-8">אודות הוצאהלפועל.info</h1>

    <div class="rtl-prose space-y-8">

      <div class="bg-brand-pale border border-brand-light rounded-2xl p-6">
        <p class="text-lg text-brand-dark font-medium leading-relaxed">
          570,000 ישראלים חיים עם תיק הוצאה לפועל פעיל. 77% מהם ללא ייצוג משפטי.
          רק 1.2% מגישים בקשות — לא כי אין להם אפשרויות, אלא כי הם לא יודעים שיש להם.
          בנינו את האתר הזה כדי לשנות את זה.
        </p>
      </div>

      <section>
        <h2>למה בנינו את האתר הזה</h2>
        <p>
          המידע על הוצאה לפועל בישראל קיים — בחוק, בפסקי דין, באתרי ממשלה.
          אבל הוא כתוב בשפה משפטית שאדם רגיל לא יכול להבין.
        </p>
        <p>
          בנינו את הוצאהלפועל.info כדי לגשר על הפער הזה. לתרגם את המידע המשפטי
          לעברית פשוטה, להוסיף כלים שלא היו קיימים (כמו מחשבון ריבית תיקון 9),
          ולחבר בין חייבים לגורמי סיוע שיכולים לעזור.
        </p>
        <p>
          המציאות היא שחייב שיודע את זכויותיו — ופועל בהתאם — יכול לשפר משמעותית
          את מצבו. הידע הוא הכוח.
        </p>
      </section>

      <section>
        <h2>איך אנחנו שומרים על דיוק המידע</h2>
        <p>המידע באתר עובר בדיקה קפדנית לפני פרסום ומעודכן באופן שוטף:</p>
        <ul>
          <li><strong>מקורות ראשוניים בלבד</strong> — חוקים, תקנות, וחוזרי רשות האכיפה והגבייה</li>
          <li><strong>עדכון לפי שינויי חקיקה</strong> — כגון תיקון 9 (ינואר 2025), תיקון 69 (פברואר 2022), ועדכוני שכר מינימום</li>
          <li><strong>תאריכי עדכון גלויים</strong> — כל עמוד מציג מתי עודכן לאחרונה</li>
          <li><strong>הפרדה בין עובדה לייעוץ</strong> — המידע הוא כללי; לייעוץ אישי מציינים לפנות לעורך דין</li>
          <li><strong>תיקון שגיאות</strong> — אם מצאת טעות, אנא <a href="/contact/">פנה אלינו</a> ונתקן מיד</li>
        </ul>
      </section>

      <section>
        <h2>מה אנחנו מציעים</h2>
        <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-3">
          {[
            { icon: '📚', title: 'מדריכים מפורטים', desc: '33 מדריכים לכל שלב בהוצאה לפועל — בשפה פשוטה' },
            { icon: '🧮', title: 'מחשבון ריבית תיקון 9', desc: 'חשב כמה אתה באמת חייב לפי החוק מינואר 2025' },
            { icon: '💬', title: "צ'אטבוט AI", desc: 'עונה על שאלות 24/7 — בחינם, מבוסס מאגר מאומת' },
            { icon: '✅', title: 'בדיקת זכאות', desc: '4 שאלות ותדע לאיזה הסדר אתה זכאי' },
            { icon: '❓', title: '101 שאלות נפוצות', desc: 'תשובות לכל השאלות שאנשים שואלים' },
            { icon: '🔗', title: 'קישורים לגורמי סיוע', desc: 'הלשכה לסיוע משפטי, כל-זכות, ורשות האכיפה' },
          ].map(item => (
            <div class="flex gap-3 p-3 bg-white border border-neutral-border rounded-xl">
              <span class="text-2xl">{item.icon}</span>
              <div>
                <p class="font-semibold text-gray-800 text-sm">{item.title}</p>
                <p class="text-xs text-gray-500 mt-0.5">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2>המשימה שלנו</h2>
        <p>
          המשימה שלנו פשוטה: לספק מידע חינמי ומדויק לחייבים שאין להם כסף לעורך דין.
          בישראל יש כיום כ-570,000 תיקי הוצאה לפועל פעילים, ו-77% מהחייבים מגיעים
          לדיונים ללא ייצוג משפטי. פער הידע הזה עולה לאנשים בכסף, בזמן, ובנפש.
        </p>
        <p>
          אנחנו מאמינים שגישה למידע משפטי ברור ומדויק היא זכות יסוד — לא פריווילגיה
          של מי שיכול לשלם 400–800 ₪ לשעת ייעוץ. כל מדריך, כלי, ושאלה שאנחנו עונים
          עליה מכוון לאותה מטרה: לצמצם את הפער הזה.
        </p>
      </section>

      <section>
        <h2>מי כותב את התוכן</h2>
        <div class="bg-green-50 border border-green-200 rounded-xl p-5 not-prose">
          <p class="text-gray-800 leading-relaxed text-sm">
            התוכן באתר נכתב ונערך על ידי <strong>מומחים בתחום הוצאה לפועל וחדלות פירעון</strong>
            ועבר בדיקת עובדות מול מקורות משפטיים רשמיים. כל מדריך נבדק לפני פרסום
            ומעודכן בכל פעם שחל שינוי בחוק או בתקנות הרלוונטיות.
          </p>
          <ul class="mt-3 text-sm text-gray-700 space-y-1">
            <li>✓ בדיקת עובדות מול חוקים ותקנות ראשוניים</li>
            <li>✓ השוואה לפסיקת בית המשפט העליון</li>
            <li>✓ עדכון שוטף לפי שינויי חקיקה</li>
            <li>✓ הפרדה ברורה בין מידע כללי לייעוץ אישי</li>
          </ul>
        </div>
      </section>

      <section>
        <h2>המקורות שלנו</h2>
        <p>כל מידע באתר מבוסס על מקורות ראשוניים ורשמיים בלבד:</p>
        <ul>
          <li>
            <strong>חוק ההוצאה לפועל, התשכ"ז-1967</strong> — החוק הבסיסי המסדיר
            את כל הליכי הגביה בישראל, כולל כל תיקוניו
          </li>
          <li>
            <strong>אתר רשות האכיפה והגבייה (gov.il)</strong> — המקור הממשלתי
            הרשמי לנהלים, טפסים, ותעריפים עדכניים
          </li>
          <li>
            <strong>פסיקת בית המשפט העליון</strong> — פרשנות מחייבת לחוק,
            במיוחד בנושאי הגנה על בית מגורים וצו תשלומים
          </li>
          <li>
            <strong>נתוני הלשכה המרכזית לסטטיסטיקה (הלמ"ס)</strong> — נתונים
            דמוגרפיים וכלכליים על חייבים ומצב החוב בישראל
          </li>
          <li>
            <strong>חוק חדלות פירעון ושיקום כלכלי, התשע"ח-2018</strong> —
            מסלול השיקום הכלכלי לחייבים בעלי חוב שלא ניתן לפירעון
          </li>
          <li>
            <strong>חוזרי מנהל בתי המשפט</strong> — הנחיות פנימיות
            לרשמי ההוצאה לפועל
          </li>
        </ul>
      </section>

      <section>
        <h2>מדיניות עדכונים</h2>
        <p>
          המדריכים באתר מתעדכנים עם כל שינוי בחוק, בתקנות, או בתעריפים הרלוונטיים.
          <strong>עדכון אחרון: מרץ 2026.</strong>
        </p>
        <p>
          לאחרונה עדכנו את כל המדריכים הקשורים לתיקון 9 לחוק פסיקת ריבית והצמדה
          (בתוקף מינואר 2025), שינה את ריבית הפיגורים ומשפיע על מאות אלפי חייבים.
          תאריכי העדכון של כל עמוד מוצגים בראש הדף.
        </p>
      </section>

      <section>
        <h2>נתונים על האתר</h2>
        <div class="not-prose grid grid-cols-3 gap-3 text-center">
          {[
            { num: '33', label: 'מדריכים מפורטים' },
            { num: '101', label: 'שאלות FAQ' },
            { num: '2026', label: 'עדכני לשנת' },
          ].map(item => (
            <div class="bg-brand-pale border border-brand-light rounded-xl p-4">
              <p class="text-3xl font-bold text-brand-dark">{item.num}</p>
              <p class="text-xs text-gray-600 mt-1">{item.label}</p>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2>מה אנחנו לא</h2>
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 not-prose">
          <ul class="text-sm text-gray-700 space-y-1.5">
            <li>✗ <strong>לא משרד עורכי דין</strong> — המידע שלנו הוא כללי ואינו ייעוץ משפטי</li>
            <li>✗ <strong>לא אחראים לתוצאות בתיק הספציפי שלך</strong> — כל מקרה שונה</li>
            <li>✗ <strong>לא מבטיחים שהמידע מדויק לחלוטין</strong> — החוק משתנה, תמיד בדוק עם עורך דין לפני פעולה</li>
            <li>✗ <strong>לא גובים תשלום</strong> — כל המידע, הכלים, והמדריכים חינמיים לחלוטין</li>
          </ul>
        </div>
      </section>

      <section>
        <h2>מקורות המידע שלנו</h2>
        <p>המידע באתר מבוסס על:</p>
        <ul>
          <li>חוק ההוצאה לפועל, התשכ"ז-1967 ותיקוניו</li>
          <li>חוק חדלות פירעון ושיקום כלכלי, התשע"ח-2018</li>
          <li>חוק פסיקת ריבית והצמדה, התשכ"א-1961 (כולל תיקון 9, 2025)</li>
          <li>חוק שכר מינימום, התשמ"ז-1987 (ועדכוני שכר שוטפים)</li>
          <li>אתר רשות האכיפה והגבייה (gov.il)</li>
          <li>פסיקת בית המשפט העליון ובתי המשפט המחוזיים</li>
          <li>חוזרי מנהל בתי המשפט</li>
        </ul>
      </section>

      <section>
        <h2>מודל הכנסה — שקיפות מלאה</h2>
        <p>
          האתר מממן את עצמו דרך פרסום (Google AdSense) בלבד.
          אנחנו לא אוספים פרטים אישיים מעבר לנדרש, לא מעבירים מידע לצדדים שלישיים,
          ולא גובים תשלום על שום שירות באתר.
        </p>
        <p>
          אנחנו לא מקבלים תשלום מעורכי דין עבור הפניות, ולא מקדמים שירותים משפטיים ספציפיים.
          הקישורים לגורמי סיוע (הלשכה לסיוע משפטי, כל-זכות, רשות האכיפה) הם קישורים ממשלתיים וציבוריים בלבד.
        </p>
      </section>

      <section>
        <h2>נגישות</h2>
        <p>
          אנחנו מחויבים להנגיש את האתר לכלל המשתמשים, לרבות אנשים עם מוגבלות.
          האתר מיישם את תקנות שוויון זכויות לאנשים עם מוגבלות ואת הנחיות WCAG 2.1 ברמה AA.
          <a href="/legal/accessibility/">קרא את הצהרת הנגישות המלאה ←</a>
        </p>
      </section>

      <section>
        <h2>כתב ויתור</h2>
        <div class="bg-yellow-50 border border-yellow-300 rounded-xl p-5 not-prose">
          <p class="text-sm text-gray-800 leading-relaxed">
            <strong>המידע באתר זה הוא כללי בלבד</strong> ואינו מהווה ייעוץ משפטי.
            אין בו כדי להחליף פנייה לעורך דין המכיר את נסיבות המקרה הספציפי שלך.
            לייעוץ אישי — פנה לעורך דין או ל
            <a href="https://www.gov.il/he/departments/bureaus/mofa_legal_aid_unit" class="text-brand-dark underline" target="_blank" rel="noopener noreferrer">הלשכה לסיוע משפטי</a>.
            כל פעולה משפטית שתנקוט על בסיס המידע באתר היא באחריותך בלבד.
          </p>
        </div>
      </section>

      <section>
        <h2>צור קשר</h2>
        <p>
          שאלות, הצעות שיפור, או רוצה לדווח על שגיאה במידע?
          <a href="/contact/">פנה אלינו בדף יצירת הקשר</a> — נשמח לשמוע ולשפר.
          אנחנו מתחייבים לתקן כל שגיאה עובדתית שתדווח עליה תוך 48 שעות.
        </p>
        <p>
          <strong>נגישות:</strong> לפניות בנושאי נגישות —
          <a href="mailto:accessibility@hotzaa-lapoal.info">accessibility@hotzaa-lapoal.info</a>
        </p>
      </section>

    </div>
  </main>
  <Footer />
</BaseLayout>
