---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import InterestCalculator from '../../components/InterestCalculator';
import Breadcrumb from '../../components/Breadcrumb.astro';

const siteUrl = 'https://hotzaa-lapoal.info';
const pageUrl = `${siteUrl}/tools/calculator/`;

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'בדיקת ריבית ויתרת חוב בהוצאה לפועל',
  description: 'איך בודקים את יתרת החוב הרשמית בתיק ומאיפה מקבלים את שיעורי הריבית הרשמיים.',
  url: pageUrl,
  inLanguage: 'he',
  isAccessibleForFree: true,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'איך יודעים מה הסכום המדויק בתיק הוצאה לפועל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'את היתרה הרשמית בודקים באזור האישי של רשות האכיפה והגבייה או באמצעות קבלת פירוט תיק מהלשכה המטפלת.',
      },
    },
    {
      '@type': 'Question',
      name: 'למה האתר אינו מציג כרגע מחשבון ריבית?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'החישוב הושהה עד להשלמת בדיקה מקצועית של הנוסחה ושל כל שיעורי הריבית הרשמיים, כדי לא להציג למשתמש יתרה שעלולה להיות מטעה.',
      },
    },
  ],
};
---

<BaseLayout
  title="בדיקת ריבית ויתרת חוב בהוצאה לפועל — מקורות רשמיים"
  description="כך בודקים את יתרת החוב הרשמית בתיק הוצאה לפועל ומקבלים פירוט של הקרן, הריבית וההוצאות — בלי להסתמך על אומדן לא מאומת."
  schema={[pageSchema, faqSchema]}
>
  <Header />
  <main id="main-content" class="max-w-3xl mx-auto px-4 py-10">
    <Breadcrumb items={[{ label: 'כלים', href: '/tools/' }, { label: 'בדיקת ריבית ויתרה' }]} />

    <h1 class="text-3xl font-bold text-brand-dark mb-3">בדיקת ריבית ויתרת חוב בהוצאה לפועל</h1>
    <p class="text-gray-600 mb-7 leading-relaxed">
      יתרה רשמית מתקבלת מתוך התיק עצמו. עמוד זה מפנה אותך למקור הנכון ומסביר אילו נתונים לבקש.
    </p>

    <InterestCalculator />

    <section class="mt-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-5">איך מקבלים יתרה רשמית?</h2>
      <ol class="space-y-4">
        {[
          ['היכנס לאזור האישי', 'הזדהה באתר הממשלתי ובחר את התיק הרלוונטי.'],
          ['פתח את פירוט התיק', 'בדוק בנפרד את הקרן, הריבית, דמי הפיגורים, האגרות, שכר הטרחה והתשלומים שכבר נקלטו.'],
          ['שמור אסמכתה', 'הורד או הדפס את פירוט היתרה עם תאריך ההפקה, במיוחד לפני הסדר או תשלום מלא.'],
          ['בדוק פערים', 'אם תשלום שביצעת אינו מופיע או שהחישוב אינו ברור, פנה ללשכה המטפלת או לייעוץ משפטי אישי.'],
        ].map(([title, text], index) => (
          <li class="flex gap-3 rounded-xl border border-gray-200 bg-white p-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-dark text-sm font-bold text-white">{index + 1}</span>
            <div>
              <h3 class="font-bold text-gray-900">{title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-gray-600">{text}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="mt-10 rounded-2xl border border-blue-200 bg-blue-50 p-6">
      <h2 class="text-xl font-bold text-blue-950 mb-3">מקורות רשמיים</h2>
      <ul class="space-y-3 text-sm">
        <li><a class="font-semibold text-blue-900 underline" href="https://go.gov.il/ecagovernmentident" target="_blank" rel="noopener noreferrer">האזור האישי של רשות האכיפה והגבייה</a></li>
        <li><a class="font-semibold text-blue-900 underline" href="https://ga.mof.gov.il/rate" target="_blank" rel="noopener noreferrer">שיעורי ריבית שמפרסם החשב הכללי</a></li>
        <li><a class="font-semibold text-blue-900 underline" href="https://www.gov.il/he/departments/law_enforcement_and_collection_system_authority" target="_blank" rel="noopener noreferrer">רשות האכיפה והגבייה באתר gov.il</a></li>
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">שאלות נפוצות</h2>
      <div class="space-y-3">
        <details class="rounded-xl border border-gray-200 bg-white p-4">
          <summary class="cursor-pointer font-bold text-gray-900">האם אפשר לחשב יתרה מדויקת רק מסכום ותאריך?</summary>
          <p class="mt-3 text-sm leading-relaxed text-gray-600">לא תמיד. בתיק עשויים להיות תשלומים, הוצאות, החלטות ושיעורים משתנים שאינם ידועים בלי פירוט התיק.</p>
        </details>
        <details class="rounded-xl border border-gray-200 bg-white p-4">
          <summary class="cursor-pointer font-bold text-gray-900">האם האתר שומר את פרטי התיק שלי?</summary>
          <p class="mt-3 text-sm leading-relaxed text-gray-600">לא. אין בעמוד זה טופס להזנת שם, טלפון, מספר תיק או סכום חוב.</p>
        </details>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
