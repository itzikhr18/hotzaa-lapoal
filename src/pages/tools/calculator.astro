---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import InterestCalculator from '../../components/InterestCalculator';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'מחשבון ריבית הוצאה לפועל — תיקון 9',
  description: 'חישוב ריבית חוב בהוצאה לפועל לפי תיקון 9 שנכנס לתוקף בינואר 2025',
  inLanguage: 'he',
  applicationCategory: 'FinanceApplication',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'ILS' },
};
---

<BaseLayout
  title="מחשבון ריבית הוצאה לפועל — תיקון 9 (2026)"
  description="חשב כמה אתה חייב לפי תיקון 9 שנכנס לתוקף בינואר 2025. ריבית בסיס + דמי פיגורים רבעוניים. חינם, מיידי, עם פירוט מלא."
  {schema}
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-10">

    <nav class="text-sm text-neutral-muted mb-6">
      <a href="/">בית</a> › <a href="/tools/">כלים</a> › <span class="text-gray-700">מחשבון ריבית</span>
    </nav>

    <h1 class="text-3xl font-bold text-brand-dark mb-2">מחשבון ריבית הוצאה לפועל</h1>
    <p class="text-gray-600 mb-2">כולל תיקון 9 — בתוקף מ-1 בינואר 2025</p>

    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6 text-sm text-blue-800">
      <strong>מה חדש בתיקון 9?</strong> — במקום ריבית דריבית אחת, יש עכשיו שני רכיבים נפרדים: ריבית בסיס (כלכלית) ודמי פיגורים רבעוניים עם תקרה. זה יכול לחסוך לך כסף.
    </div>

    <!-- הדרכה לפני המחשבון -->
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 mb-6">
      <h2 class="text-base font-bold text-gray-800 mb-4">📋 איפה מוצאים את המידע הדרוש?</h2>
      <div class="space-y-4 text-sm">

        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-brand-dark text-white flex items-center justify-center font-bold text-xs shrink-0 mt-0.5">1</div>
          <div>
            <p class="font-semibold text-gray-800">סכום קרן החוב</p>
            <p class="text-gray-500">הסכום המקורי שנקבע בפסק הדין או בשטר החוב — <strong>לפני</strong> ריבית. מופיע במכתב הפתיחה של תיק ההוצאה לפועל, בדרך כלל בשורה "סכום החוב".</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-brand-dark text-white flex items-center justify-center font-bold text-xs shrink-0 mt-0.5">2</div>
          <div>
            <p class="font-semibold text-gray-800">תאריך יצירת החוב</p>
            <p class="text-gray-500">התאריך שבו נוצר החוב — לרוב תאריך פסק הדין, תאריך ההמחאה שחזרה, או תאריך החשבונית שלא שולמה. מופיע גם הוא במכתב הפתיחה.</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-brand-dark text-white flex items-center justify-center font-bold text-xs shrink-0 mt-0.5">3</div>
          <div>
            <p class="font-semibold text-gray-800">האם אתה עומד בצו תשלומים?</p>
            <p class="text-gray-500">אם הגשת בקשה לצו תשלומים ואתה משלם בקביעות — סמן "כן". זה מפחית את תקרת דמי הפיגורים מ-80% ל-70% מהקרן.</p>
          </div>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 text-amber-700">
          💡 <strong>טיפ:</strong> אם אין לך את המכתב — תוכל לבקש פירוט תיק מלשכת ההוצאה לפועל הקרובה אליך, או דרך <a href="https://www.gov.il/he/departments/law_enforcement_and_collection_system_authority" target="_blank" class="underline">אתר רשות האכיפה</a>.
        </div>
      </div>
    </div>

    <div class="bg-white border border-neutral-border rounded-2xl p-6 shadow-sm">
      <InterestCalculator client:idle />
    </div>

  </main>
  <Footer />
</BaseLayout>
