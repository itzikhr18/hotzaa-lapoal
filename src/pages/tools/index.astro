---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const toolsSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'כלים חינמיים להוצאה לפועל',
  description: "כלים חינמיים לחייבים בהוצאה לפועל: מחשבון ריבית תיקון 9 וצ'אטבוט AI שעונה על שאלות 24/7",
  url: 'https://hotzaa-lapoal.info/tools/',
  inLanguage: 'he',
  hasPart: [
    { '@type': 'WebApplication', name: 'מחשבון ריבית הוצאה לפועל — תיקון 9', url: 'https://hotzaa-lapoal.info/tools/calculator/' },
    { '@type': 'WebApplication', name: "צ'אטבוט הוצאה לפועל", url: 'https://hotzaa-lapoal.info/tools/chatbot/' },
    { '@type': 'WebApplication', name: 'בדיקת מצב מהירה', url: 'https://hotzaa-lapoal.info/tools/eligibility/' },
  ],
};
---

<BaseLayout
  title="כלים חינמיים להוצאה לפועל — מחשבון ריבית וצ'אטבוט"
  description="כלים חינמיים לחייבים בהוצאה לפועל: מחשבון ריבית תיקון 9 וצ'אטבוט AI שעונה על שאלות 24/7."
  schema={toolsSchema}
>
  <Header />
  <main class="max-w-4xl mx-auto px-4 py-10">

    <nav class="text-sm text-neutral-muted mb-6">
      <a href="/">בית</a> › <span class="text-gray-700">כלים</span>
    </nav>

    <h1 class="text-3xl font-bold text-brand-dark mb-2">כלים חינמיים</h1>
    <p class="text-gray-500 mb-10">ייחודיים בשוק — פותחנו אותם כי הם לא היו קיימים</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <a href="/tools/calculator/" class="group bg-white border-2 border-neutral-border rounded-2xl p-7 hover:border-brand hover:bg-brand-pale transition-all block">
        <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-2xl mb-4">🧮</div>
        <div class="inline-block bg-orange-100 text-orange-700 text-xs font-bold px-2.5 py-1 rounded-full mb-3">חדש! תיקון 9</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-dark transition-colors">מחשבון ריבית הוצאה לפועל</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">
          חשב כמה אתה באמת חייב לפי החוק החדש מינואר 2025.
          ריבית בסיס + דמי פיגורים רבעוניים — עם פירוט מלא.
        </p>
        <span class="text-brand font-semibold text-sm group-hover:text-brand-dark transition-colors">פתח מחשבון ←</span>
      </a>

      <a href="/tools/chatbot/" class="group bg-white border-2 border-neutral-border rounded-2xl p-7 hover:border-brand hover:bg-brand-pale transition-all block">
        <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-2xl mb-4">💬</div>
        <div class="inline-block bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full mb-3">AI + עברית</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-dark transition-colors">צ'אטבוט מידע</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">
          שאל כל שאלה על הוצאה לפועל וחדלות פירעון —
          מקבל תשובה מיידית בעברית פשוטה, 24/7, בחינם.
        </p>
        <span class="text-brand font-semibold text-sm group-hover:text-brand-dark transition-colors">פתח צ'אטבוט ←</span>
      </a>

    </div>

      <a href="/tools/eligibility/" class="group bg-white border-2 border-neutral-border rounded-2xl p-7 hover:border-brand hover:bg-brand-pale transition-all block">
        <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center text-2xl mb-4">🔍</div>
        <div class="inline-block bg-purple-100 text-purple-700 text-xs font-bold px-2.5 py-1 rounded-full mb-3">4 שאלות בלבד</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-dark transition-colors">בדיקת מצב מהירה</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">
          ענה על 4 שאלות פשוטות ותקבל המלצה — מה לעשות עכשיו.
          צו תשלומים? איחוד תיקים? חדלות פירעון?
        </p>
        <span class="text-brand font-semibold text-sm group-hover:text-brand-dark transition-colors">התחל בדיקה ←</span>
      </a>

    <div class="mt-10 bg-blue-50 border border-blue-200 rounded-xl p-4 text-sm text-gray-700">
      ⚠️ הכלים מיועדים להערכה ולמידע כללי בלבד. אינם מהווים ייעוץ משפטי.
    </div>

  </main>
  <Footer />
</BaseLayout>
