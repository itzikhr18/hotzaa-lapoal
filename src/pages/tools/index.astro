
---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const toolsSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'כלים חינמיים להוצאה לפועל',
  description: "כלים חינמיים לחייבים בהוצאה לפועל: בדיקת יתרה במקור הרשמי, מחשבון עיקול משכורת, בדיקת מצב וטפסים ונוסחים להגשה עצמית.",
  url: 'https://hotzaa-lapoal.info/tools/',
  inLanguage: 'he',
  hasPart: [
    { '@type': 'WebPage', name: 'בדיקת ריבית ויתרת חוב — מקורות רשמיים', url: 'https://hotzaa-lapoal.info/tools/calculator/' },
    { '@type': 'WebApplication', name: 'מחשבון עיקול משכורת', url: 'https://hotzaa-lapoal.info/tools/ikul-maskoret/' },
    { '@type': 'WebApplication', name: 'מחולל נוסח בקשה לרשם ההוצאה לפועל', url: 'https://hotzaa-lapoal.info/tools/noseach-bakasha/' },
    { '@type': 'WebApplication', name: "צ'אטבוט הוצאה לפועל", url: 'https://hotzaa-lapoal.info/tools/chatbot/' },
    { '@type': 'WebApplication', name: 'בדיקת מצב מהירה', url: 'https://hotzaa-lapoal.info/tools/eligibility/' },
    { '@type': 'CreativeWork', name: 'טפסים ונוסחים להוצאה לפועל', url: 'https://hotzaa-lapoal.info/forms/' },
  ],
};
---

<BaseLayout
  title="כלים חינמיים להוצאה לפועל — בדיקת יתרה, מחשבונים וטפסים"
  description="כלים חינמיים לחייבים בהוצאה לפועל: בדיקת יתרה במקור הרשמי, מחשבון עיקול משכורת, בדיקת מצב מהירה וטפסים ונוסחים להגשה עצמית."
  schema={toolsSchema}
>
  <Header />
  <main id="main-content" class="max-w-4xl mx-auto px-4 py-10">

    <Breadcrumb items={[{ label: 'כלים' }]} />

    <h1 class="text-3xl font-bold text-brand-dark mb-2">כלים חינמיים</h1>
    <p class="text-gray-500 mb-10">ייחודיים בשוק — פותחנו אותם כי הם לא היו קיימים</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <a href="/tools/calculator/" class="group bg-white border-2 border-neutral-border rounded-2xl p-7 hover:border-brand hover:bg-brand-pale transition-all block">
        <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-2xl mb-4">🧮</div>
        <div class="inline-block bg-amber-100 text-amber-800 text-xs font-bold px-2.5 py-1 rounded-full mb-3">מקור רשמי</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-dark transition-colors">בדיקת ריבית ויתרת חוב</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">
          קבל את יתרת התיק מהרשות ולמד אילו רכיבים לבדוק בפירוט החוב.
          המחשבון המשוער הושהה עד להשלמת בדיקה מקצועית.
        </p>
        <span class="text-brand font-semibold text-sm group-hover:text-brand-dark transition-colors">לבדיקת יתרה ←</span>
      </a>

      <a href="/tools/ikul-maskoret/" class="group bg-white border-2 border-neutral-border rounded-2xl p-7 hover:border-brand hover:bg-brand-pale transition-all block">
        <div class="w-12 h-12 bg-rose-50 rounded-xl flex items-center justify-center text-2xl mb-4">💼</div>
        <div class="inline-block bg-rose-100 text-rose-700 text-xs font-bold px-2.5 py-1 rounded-full mb-3">חדש!</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-dark transition-colors">מחשבון עיקול משכורת</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">
          כמה מותר לעקל לך מהשכר — וכמה חייב להישאר בידך?
          שכר הגנה וכללי העיקול לפי הרכב המשפחה.
        </p>
        <span class="text-brand font-semibold text-sm group-hover:text-brand-dark transition-colors">פתח מחשבון ←</span>
      </a>

      <a href="/tools/noseach-bakasha/" class="group bg-white border-2 border-neutral-border rounded-2xl p-7 hover:border-brand hover:bg-brand-pale transition-all block">
        <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center text-2xl mb-4">✍️</div>
        <div class="inline-block bg-teal-100 text-teal-700 text-xs font-bold px-2.5 py-1 rounded-full mb-3">חדש! מוכן להגשה</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-dark transition-colors">מחולל נוסח בקשה</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">
          בקשה מנוסחת לרשם תוך דקה: ביטול עיקול חשבון או משכורת,
          צו תשלומים והשבת כסף שנוכה ביתר.
        </p>
        <span class="text-brand font-semibold text-sm group-hover:text-brand-dark transition-colors">צור נוסח ←</span>
      </a>

      <a href="/tools/chatbot/" class="group bg-white border-2 border-neutral-border rounded-2xl p-7 hover:border-brand hover:bg-brand-pale transition-all block">
        <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-2xl mb-4">💬</div>
        <div class="inline-block bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full mb-3">AI + עברית</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-dark transition-colors">צ'אטבוט מידע</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">
          שאל כל שאלה על הוצאה לפועל וחדלות פירעון —
          מקבל תשובה מיידית בעברית פשוטה, 24/7, בחינם.
        </p>
        <span class="text-brand font-semibold text-sm group-hover:text-brand-dark transition-colors">פתח צ'אטבוט ←</span>
      </a>
      <a href="/tools/eligibility/" class="group bg-white border-2 border-neutral-border rounded-2xl p-7 hover:border-brand hover:bg-brand-pale transition-all block">
        <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center text-2xl mb-4">🔍</div>
        <div class="inline-block bg-purple-100 text-purple-700 text-xs font-bold px-2.5 py-1 rounded-full mb-3">4 שאלות בלבד</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-dark transition-colors">בדיקת מצב מהירה</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">
          ענה על 4 שאלות פשוטות ותקבל המלצה — מה לעשות עכשיו.
          צו תשלומים? איחוד תיקים? חדלות פירעון?
        </p>
        <span class="text-brand font-semibold text-sm group-hover:text-brand-dark transition-colors">התחל בדיקה ←</span>
      </a>

      <a href="/forms/" class="group bg-white border-2 border-neutral-border rounded-2xl p-7 hover:border-brand hover:bg-brand-pale transition-all block">
        <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center text-2xl mb-4">📋</div>
        <div class="inline-block bg-amber-100 text-amber-700 text-xs font-bold px-2.5 py-1 rounded-full mb-3">נוסחים לעריכה</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-dark transition-colors">טפסים ונוסחים</h2>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">
          ריכוז טפסים ובקשות נפוצות: ביטול עיקול, צו תשלומים, בדיקת תיק ובקשה דחופה לעיכוב הליכים.
        </p>
        <span class="text-brand font-semibold text-sm group-hover:text-brand-dark transition-colors">פתח טפסים ←</span>
      </a>
    </div>

    <div class="mt-10 bg-blue-50 border border-blue-200 rounded-xl p-4 text-sm text-gray-700">
      ⚠️ הכלים מיועדים להערכה ולמידע כללי בלבד. אינם מהווים ייעוץ משפטי.
    </div>

  </main>
  <Footer />
</BaseLayout>
