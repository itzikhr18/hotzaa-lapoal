---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const updateDate = "2026-04-24";

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'מה זה הוצאה לפועל?', acceptedAnswer: { '@type': 'Answer', text: 'הוצאה לפועל היא מערכת משפטית המאפשרת לנושה לגבות חוב שנקבע בפסק דין או מסמך משפטי. הגוף האחראי נקרא רשות האכיפה והגבייה.' } },
    { '@type': 'Question', name: 'כמה זמן יש לי להגיב להודעת הוצאה לפועל?', acceptedAnswer: { '@type': 'Answer', text: 'בדרך כלל 20 יום מיום קבלת הודעת התשלום. אי מענה מאפשר לנושה לנקוט בהליכי גבייה.' } },
    { '@type': 'Question', name: 'האם ניתן לעקל את כל המשכורת שלי?', acceptedAnswer: { '@type': 'Answer', text: 'לא. מקסימום שליש מהמשכורת נטו. שכר מינימום (6,443.85 ₪ ברוטו נכון לאפריל 2026) מוגן לחלוטין.' } },
    { '@type': 'Question', name: 'האם קצבאות ביטוח לאומי ניתנות לעיקול?', acceptedAnswer: { '@type': 'Answer', text: 'לא. קצבאות ביטוח לאומי — ילדים, נכות, זקנה, שאירים, אבטלה — מוגנות לחלוטין מעיקול.' } },
    { '@type': 'Question', name: 'מה זה צו תשלומים?', acceptedAnswer: { '@type': 'Answer', text: 'צו תשלומים הוא החלטת רשם הקובעת תשלום חודשי קבוע לכיסוי החוב לפי יכולת החייב. ברגע שיש צו ואתה עומד בו — הנושה לא יכול לנקוט עיקולים נוספים.' } },
    { '@type': 'Question', name: 'מה זה תיקון 9 לחוק פסיקת ריבית?', acceptedAnswer: { '@type': 'Answer', text: 'תיקון 9 (ינואר 2025) שינה את חישוב ריבית הפיגורים. כיום הריבית צמודה לריבית בנק ישראל (4.3%) + 3.5% + דמי פיגורים 1% שנתי. סה"כ כ-8.8% לשנה.' } },
    { '@type': 'Question', name: 'מה ההבדל בין חדלות פירעון לאיחוד תיקים?', acceptedAnswer: { '@type': 'Answer', text: 'איחוד תיקים: תשלום מסודר דרך הרשם, החוב לא נמחק. חדלות פירעון: הליך ארוך (~4 שנים) ויקר יותר, אבל בסוף — הפטר וביטול החובות.' } },
    { '@type': 'Question', name: 'האם ניתן לעקל את דירת המגורים שלי?', acceptedAnswer: { '@type': 'Answer', text: 'ניתן לרשום עיקול רישומי, אבל ממוש (מכירה כפויה) הוא הליך מורכב מאוד הדורש אישור בית משפט ולוקח שנים. יש הגנות משמעותיות על דירת מגורים ראשית.' } },
    { '@type': 'Question', name: 'האם אפשר לנהל מו"מ ישיר עם הנושה?', acceptedAnswer: { '@type': 'Answer', text: 'כן. פנייה ישירה לנושה יכולה להוביל להסדר עם הנחה בחוב. עדיף לעגן כל הסדר בכתב ולוודא קבלת אישור סגירת התיק.' } },
    { '@type': 'Question', name: 'האם חוב מזונות ניתן לביטול בחדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'לא. חוב מזונות (לילדים ולבן/בת זוג לשעבר) הוא מהחובות שאינם ניתנים להפטר בחדלות פירעון. גם לאחר קבלת הפטר — חוב מזונות שצבר ממשיך לעמוד.' } },
    { '@type': 'Question', name: 'מה קורה לחוב כשמשתנה כתובת?', acceptedAnswer: { '@type': 'Answer', text: 'החוב לא קשור לכתובת — הוא נשאר. שינוי כתובת לא מבטל חוב. אם עיקול על חשבון הבנק — הוא יישאר גם אם תעבור לעיר אחרת.' } },
    { '@type': 'Question', name: 'האם פעולות גבייה אגרסיביות מותרות?', acceptedAnswer: { '@type': 'Answer', text: 'לא. גורם גבייה לא רשאי להתקשר בשעות לא סבירות, לאיים, להטעות, או לפנות לצדדים שלישיים ללא סיבה. הפרת חוק הגבייה מאפשרת הגשת תלונה לרשם הגבייה.' } },
    { '@type': 'Question', name: 'מה הכסף המוגן בחשבון בנק מעיקול?', acceptedAnswer: { '@type': 'Answer', text: 'הרשם רשאי להותיר לחייב סכום מינימום לצרכי קיום — בדרך כלל כ-5,000 ₪ בסיס קיום. בנוסף, קצבאות ביטוח לאומי שהופקדו בחשבון מוגנות לחלוטין מעיקול.' } },
    { '@type': 'Question', name: 'תוך כמה זמן הבנק מקפיא חשבון אחרי קבלת צו עיקול?', acceptedAnswer: { '@type': 'Answer', text: 'הבנק מחויב להקפיא את החשבון כמעט באופן מיידי — בדרך כלל תוך יום עסקים אחד עד שניים מקבלת הצו. הקפאה פירושה שלא ניתן למשוך כסף מעל הסכום המוגן.' } },
    { '@type': 'Question', name: 'האם אפשר לפתוח חשבון בנק חדש אחרי עיקול?', acceptedAnswer: { '@type': 'Answer', text: 'חייב מוגבל מתקשה לפתוח חשבון בנק רגיל, אבל הבנקים מחויבים לאפשר לו לפחות חשבון בסיסי לצרכי קיום. פנה לבנק בבקשה לחשבון בסיסי לפי תקנות בנק ישראל.' } },
    { '@type': 'Question', name: 'עיקול על חשבון בנק משותף — איך מתחלק?', acceptedAnswer: { '@type': 'Answer', text: 'עיקול חל על חלקו של החייב בחשבון המשותף. בהיעדר הוכחה אחרת, מניחים שהחלקים שווים (50/50). בן/בת הזוג שאינם חייבים יכולים להוכיח בעלות על חלק מהסכום ולבקש שחרורו.' } },
    { '@type': 'Question', name: 'כמה אפשר לעקל ממשכורת?', acceptedAnswer: { '@type': 'Answer', text: 'מקסימום שליש (1/3) מהמשכורת נטו. שכר מינימום (6,443.85 ₪ ברוטו נכון לאפריל 2026) מוגן לחלוטין. כלומר, אם מרוויחים שכר מינימום — לא ניתן לעקל כלל.' } },
    { '@type': 'Question', name: 'מה קורה אם המעסיק לא מעביר את הכסף המעוקל?', acceptedAnswer: { '@type': 'Answer', text: 'מעסיק שמתעלם מצו עיקול ואינו מעביר את הסכום לרשות האכיפה עלול להיחשב כחייב בעצמו בסכום שלא הועבר. ניתן לנקוט הליכים גם נגד המעסיק.' } },
    { '@type': 'Question', name: 'האם פרילנסר יכול להיות מעוקל על הכנסה?', acceptedAnswer: { '@type': 'Answer', text: 'כן. הכנסות פרילנסר ניתנות לעיקול דרך "חייב" — הלקוח שמשלם לפרילנסר. הרשם רשאי להורות ללקוחות להעביר תשלומים ישירות לרשות האכיפה. כללי שליש נטו חלים גם כאן.' } },
    { '@type': 'Question', name: 'מה ההגנה לשכר מינימום מעיקול?', acceptedAnswer: { '@type': 'Answer', text: 'שכר מינימום (6,443.85 ₪ ברוטו, כ-5,450 ₪ נטו, נכון לאפריל 2026) מוגן לחלוטין מעיקול. אם שכרך שווה לשכר מינימום — אין עיקול. רק מעל שכר מינימום ניתן לעקל שליש מהעודף.' } },
  ]
};

