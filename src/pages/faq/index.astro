---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'מה זה הוצאה לפועל?', acceptedAnswer: { '@type': 'Answer', text: 'הוצאה לפועל היא מערכת משפטית המאפשרת לנושה לגבות חוב שנקבע בפסק דין או מסמך משפטי. הגוף האחראי נקרא רשות האכיפה והגבייה.' } },
    { '@type': 'Question', name: 'כמה זמן יש לי להגיב להודעת הוצאה לפועל?', acceptedAnswer: { '@type': 'Answer', text: 'בדרך כלל 20 יום מיום קבלת הודעת התשלום. אי מענה מאפשר לנושה לנקוט בהליכי גבייה.' } },
    { '@type': 'Question', name: 'האם ניתן לעקל את כל המשכורת שלי?', acceptedAnswer: { '@type': 'Answer', text: 'לא. מקסימום שליש מהמשכורת נטו. שכר מינימום (6,247.67 ₪ ברוטו נכון לאפריל 2025) מוגן לחלוטין.' } },
    { '@type': 'Question', name: 'האם קצבאות ביטוח לאומי ניתנות לעיקול?', acceptedAnswer: { '@type': 'Answer', text: 'לא. קצבאות ביטוח לאומי — ילדים, נכות, זקנה, שאירים, אבטלה — מוגנות לחלוטין מעיקול.' } },
    { '@type': 'Question', name: 'מה זה צו תשלומים?', acceptedAnswer: { '@type': 'Answer', text: 'צו תשלומים הוא החלטת רשם הקובעת תשלום חודשי קבוע לכיסוי החוב לפי יכולת החייב. ברגע שיש צו ואתה עומד בו — הנושה לא יכול לנקוט עיקולים נוספים.' } },
    { '@type': 'Question', name: 'מה זה תיקון 9 לחוק פסיקת ריבית?', acceptedAnswer: { '@type': 'Answer', text: 'תיקון 9 (ינואר 2025) שינה את חישוב ריבית הפיגורים. כיום הריבית צמודה לריבית בנק ישראל (4.5%) + 3.5% + דמי פיגורים 1% שנתי. סה"כ כ-9% לשנה.' } },
    { '@type': 'Question', name: 'מה ההבדל בין חדלות פירעון לאיחוד תיקים?', acceptedAnswer: { '@type': 'Answer', text: 'איחוד תיקים: תשלום מסודר דרך הרשם, החוב לא נמחק. חדלות פירעון: הליך ארוך (~4 שנים) ויקר יותר, אבל בסוף — הפטר וביטול החובות.' } },
    { '@type': 'Question', name: 'האם ניתן לעקל את דירת המגורים שלי?', acceptedAnswer: { '@type': 'Answer', text: 'ניתן לרשום עיקול רישומי, אבל ממוש (מכירה כפויה) הוא הליך מורכב מאוד הדורש אישור בית משפט ולוקח שנים. יש הגנות משמעותיות על דירת מגורים ראשית.' } },
    { '@type': 'Question', name: 'האם אפשר לנהל מו"מ ישיר עם הנושה?', acceptedAnswer: { '@type': 'Answer', text: 'כן. פנייה ישירה לנושה יכולה להוביל להסדר עם הנחה בחוב. עדיף לעגן כל הסדר בכתב ולוודא קבלת אישור סגירת התיק.' } },
    { '@type': 'Question', name: 'האם חוב מזונות ניתן לביטול בחדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'לא. חוב מזונות (לילדים ולבן/בת זוג לשעבר) הוא מהחובות שאינם ניתנים להפטר בחדלות פירעון. גם לאחר קבלת הפטר — חוב מזונות שצבר ממשיך לעמוד.' } },
    { '@type': 'Question', name: 'מה קורה לחוב כשמשתנה כתובת?', acceptedAnswer: { '@type': 'Answer', text: 'החוב לא קשור לכתובת — הוא נשאר. שינוי כתובת לא מבטל חוב. אם עיקול על חשבון הבנק — הוא יישאר גם אם תעבור לעיר אחרת.' } },
    { '@type': 'Question', name: 'האם פעולות גבייה אגרסיביות מותרות?', acceptedAnswer: { '@type': 'Answer', text: 'לא. גורם גבייה לא רשאי להתקשר בשעות לא סבירות, לאיים, להטעות, או לפנות לצדדים שלישיים ללא סיבה. הפרת חוק הגבייה מאפשרת הגשת תלונה לרשם הגבייה.' } },
  ]
};

const categories = [
  {
    id: 'basics',
    icon: '📋',
    title: 'יסודות ההוצאה לפועל',
    questions: [
      { q: 'מה זה הוצאה לפועל?', a: 'הוצאה לפועל היא המערכת המשפטית שמאפשרת לנושה לגבות חוב שנקבע בפסק דין, שטר חוב, או מסמך משפטי אחר. הגוף שמנהל את ההליך נקרא רשות האכיפה והגבייה.' },
      { q: 'מי יכול לפתוח נגדי תיק הוצאה לפועל?', a: 'כל מי שיש לו פסק דין, שטר חוב, המחאה שחזרה, או חוב שהוכר משפטית. זה יכול להיות בנק, ספק, בעל דירה, חברת אשראי, או אדם פרטי.' },
      { q: 'כמה זמן יש לי להגיב להודעת הוצאה לפועל?', a: 'בדרך כלל 20 יום מיום קבלת הודעת התשלום (האזהרה). אחרי 20 יום — הנושה יכול לבקש להמשיך בהליכי גבייה.' },
      { q: 'האם אני יכול לראות מה כתוב בתיק שלי?', a: 'כן. כל חייב רשאי לעיין בתיק שלו בכל עת. פנה ללשכת ההוצאה לפועל הרלוונטית עם תעודת זהות, או דרך המערכת המקוונת של רשות האכיפה.' },
      { q: 'מה קורה אם אתעלם מהמכתב?', a: 'הנושה ממשיך בהליכים — עיקול חשבון, עיקול משכורת, עיקול נכסים, הגבלות. ככל שמאחרים לפעול — האפשרויות מצטמצמות.' },
      { q: 'האם החוב יכול להיות שגוי?', a: 'כן. לפעמים מדובר בחוב שכבר שולם, חוב שלא שלך, או חוב שפג תוקף ההתיישנות (7 שנים בדרך כלל). ניתן להגיש התנגדות.' },
      { q: 'כמה שנים ניתן לגבות חוב?', a: 'תקופת ההתיישנות היא בדרך כלל 7 שנים מיום שנוצר העילה. אחרי 7 שנים — ניתן לטעון התיישנות כהגנה. אבל: פסק דין מחדש את מניין הזמן.' },
    ]
  },
  {
    id: 'seizure',
    icon: '🏦',
    title: 'עיקולים',
    questions: [
      { q: 'האם ניתן לעקל את כל הכסף בחשבון הבנק שלי?', a: 'לא. קצבאות ביטוח לאומי מוגנות לחלוטין. הרשם יכול לקבוע סכום מינימום שנשאר פנוי. פנה לרשם מיד אם עיקלו יותר מהמותר.' },
      { q: 'כמה ניתן לעקל ממשכורת?', a: 'מקסימום שליש מהמשכורת נטו. שכר מינימום (6,247.67 ₪ ברוטו נכון לאפריל 2025) מוגן לחלוטין — לא ניתן לעקל ממנו כלום.' },
      { q: 'האם קצבאות ביטוח לאומי ניתנות לעיקול?', a: 'לא. כל קצבאות ביטוח לאומי — ילדים, נכות, זקנה, שאירים, דמי אבטלה, גמלת סיעוד — מוגנות לחלוטין מעיקול.' },
      { q: 'האם ניתן לעקל את הרכב שלי?', a: 'כן, בתנאים מסוימים. אבל אם הרכב נחוץ לפרנסה — ניתן לבקש הגנה מהרשם. בית המשפט מהסס לעקל רכב שמשמש לעבודה.' },
      { q: 'האם ניתן לעקל את הבית שלי?', a: 'ניתן לרשום עיקול רישומי (שמונע מכירה), אבל ממוש (מכירה כפויה) של דירת מגורים ראשית הוא הליך מורכב מאוד שדורש אישור בית משפט.' },
      { q: 'כמה זמן לוקח לבטל עיקול על חשבון?', a: 'בדרך כלל 5-14 ימי עסקים ממועד הגשת הבקשה. אם יש דחיפות — ניתן לבקש עיכוב ביצוע מיידי.' },
      { q: 'האם המעסיק יכול לפטר אותי בגלל עיקול משכורת?', a: 'לא. פיטורים בגלל עיקול משכורת הם פיטורים שלא כדין. אם זה קרה — יש עילה לתביעה.' },
      { q: 'מה ניתן לעקל מהבית — ריהוט, טלוויזיה?', a: 'חפצים בסיסיים מוגנים: מיטה, שולחן, כיסאות, מקרר, כיריים, מכונת כביסה, בגדים. טלוויזיה גדולה יוקרתית, תכשיטים יקרים — עלולים להיות בסיכון.' },
    ]
  },
  {
    id: 'arrangements',
    icon: '🤝',
    title: 'הסדרים ותשלומים',
    questions: [
      { q: 'מה זה צו תשלומים?', a: 'צו תשלומים הוא החלטת רשם הקובעת תשלום חודשי לפי יכולת החייב. ברגע שיש צו ואתה עומד בו — הנושה לא יכול לנקוט עיקולים נוספים.' },
      { q: 'כמה עולה לבקש צו תשלומים?', a: 'הגשה עצמית — אגרה של כמה עשרות שקלים בלבד. ייצוג עורך דין עולה 3,000-6,000 ₪ בהתאם למורכבות.' },
      { q: 'מה קורה אם לא אעמוד בצו התשלומים?', a: 'הנושה יכול לבקש לבטל את הצו ולחדש עיקולים. אם נסיבותיך השתנו — פנה לרשם ובקש עדכון הצו לפני שמפגרים.' },
      { q: 'מה זה איחוד תיקים?', a: 'איחוד תיקים מאגד את כל התיקים הפתוחים נגדך תחת ניהול אחד, עם תשלום חודשי אחד. כל העיקולים מוקפאים ברגע האישור.' },
      { q: 'האם ניתן לנהל מו"מ ישיר עם הנושה?', a: 'כן, ולפעמים זה הפתרון הכי טוב. הסדר ישיר עם הנושה — לעתים בהנחה משמעותית — חוסך הליכים ועלויות.' },
      { q: 'האם אפשר לשלם חוב בתשלומים ללא צו?', a: 'כן, בהסכמת הנושה. אבל ללא צו רשמי — הנושה יכול לחזור בו ולנקוט בהליכים. עדיף לעגן הסדר בכתב ורצוי דרך הרשם.' },
    ]
  },
  {
    id: 'restrictions',
    icon: '🚫',
    title: 'הגבלות על חייב',
    questions: [
      { q: 'מתי ניתן להטיל עיכוב יציאה מהארץ?', a: 'כשחוב עולה על 10,000 ₪ והחייב לא שיתף פעולה. הנושה צריך לבקש זאת ספציפית מהרשם — זה לא אוטומטי.' },
      { q: 'האם ניתן לקבל אישור לנסיעה לחו"ל בזמן עיכוב יציאה?', a: 'כן. ניתן לבקש מבית המשפט אישור לנסיעה ספציפית, בדרך כלל עם ערובה (פיקדון) להבטחת החזרה.' },
      { q: 'מה זה "חייב מוגבל"?', a: 'מעמד שמוטל על חייב עם חוב גדול (מעל ~160,000 ₪) שלא שיתף פעולה. כולל הגבלות על כרטיסי אשראי, חשבון בנק, ורישיון נהיגה.' },
      { q: 'האם שלילת רישיון נהיגה בהוצאה לפועל אפשרית?', a: 'כן, לחייב מוגבל. אבל אם הרישיון נחוץ לפרנסה — ניתן לבקש הקלה מהרשם בטיעון שהשלילה פוגעת ביכולת ההחזר.' },
      { q: 'כמה זמן נמשכות ההגבלות?', a: 'עד שהחוב מסולק, מוסדר בהסדר, או מאושרת חדלות פירעון. ניתן לבקש ביטול הגבלות ספציפיות מהרשם.' },
    ]
  },
  {
    id: 'insolvency',
    icon: '⚖️',
    title: 'חדלות פירעון',
    questions: [
      { q: 'מה ההבדל בין חדלות פירעון לפשיטת רגל?', a: 'אין הבדל — אותו הדבר. חוק חדלות פירעון (2019) החליף את חוק פשיטת הרגל הישן. השם החדש מדגיש שיקום ולא כישלון.' },
      { q: 'מה סכום החוב המינימלי לחדלות פירעון?', a: '57,445 ₪ נכון ל-2026. הסכום מתעדכן מדי שנה לפי מדד.' },
      { q: 'כמה זמן נמשך הליך חדלות פירעון?', a: 'כ-4 שנים בממוצע: שנת ביניים לבחינה וגיבוש תוכנית, ו-3 שנות שיקום.' },
      { q: 'האם חדלות פירעון מוחקת את כל החובות?', a: 'לא את כולם. מזונות, קנסות פליליים וחובות שנוצרו במרמה לא ניתנים להפטר. רוב החובות הרגילים — כן.' },
      { q: 'כמה עולה הליך חדלות פירעון?', a: 'בין 8,000 ל-25,000 ₪ בממוצע: אגרת בית משפט (1,564 ₪) + שכר טרחת עורך דין (6,000-20,000 ₪). ניתן לבקש פטור מאגרה.' },
      { q: 'האם אפשר לעבוד בזמן הליך חדלות פירעון?', a: 'כן, ואפילו נדרש. חלק מהכנסות מועברות לנושים, אבל החייב ממשיך לעבוד ולהתפרנס.' },
      { q: 'האם אפשר לפתוח עסק אחרי הפטר?', a: 'כן. מרגע ההפטר — אתה חופשי. אין מגבלות על פתיחת עסק, לקיחת אשראי, או רכישת נכסים.' },
      { q: 'מה ההבדל בין חדלות פירעון לאיחוד תיקים?', a: 'איחוד תיקים: תשלום מסודר, החוב לא נמחק. חדלות פירעון: הליך ארוך ויקר יותר, אבל בסוף — הפטר וביטול החובות.' },
    ]
  },
  {
    id: 'rights',
    icon: '✅',
    title: 'זכויות חייבים',
    questions: [
      { q: 'האם מגיע לי עורך דין בחינם?', a: 'אם הכנסתך נמוכה — כן. הלשכה לסיוע משפטי של משרד המשפטים מספקת ייצוג חינמי לזכאים. גם קליניקות משפטיות באוניברסיטאות מסייעות בחינם.' },
      { q: 'האם חייב יכול לערער על החלטת הרשם?', a: 'כן. ניתן לערער בפני ראש ההוצאה לפועל ואחר כך בית משפט. יש מועדים קצרים — בדרך כלל 20-30 יום.' },
      { q: 'האם נושה יכול להתקשר אליי ולהטריד אותי?', a: 'הנושה יכול לפנות אליך, אבל הטרדה, איומים, או פניות בשעות לא סבירות — הן הפרת חוק. ניתן לתלונן למשטרה.' },
      { q: 'האם אפשר לדחות תשלום בגלל מחלה או אובדן עבודה?', a: 'כן. שינוי נסיבות מהותי (פיטורים, אשפוז, אסון) מאפשר לפנות לרשם ולבקש עדכון צו התשלומים.' },
      { q: 'האם בן/בת זוג חייב בחובות שלי?', a: 'בדרך כלל לא — אלא אם חתם/ה כערב או לווה משותף. חוב אישי הוא אישי. יש לבדוק כל מקרה לגופו.' },
      { q: 'מה קורה לחובות שלי אחרי פטירה?', a: 'חובות עוברים לעיזבון, לא ליורשים ישירות. אם אין עיזבון — החוב לא עובר לילדים. מומלץ להתייעץ עם עורך דין.' },
    ]
  },
  {
    id: 'tikun9',
    icon: '📰',
    title: 'תיקון 9 וריבית — 2025',
    questions: [
      { q: 'מה זה תיקון 9 לחוק פסיקת ריבית?', a: 'תיקון 9 (נכנס לתוקף ינואר 2025) שינה את שיטת חישוב ריבית הפיגורים בחובות אזרחיים. במקום ריבית קבועה של 8%, כיום הריבית צמודה לריבית בנק ישראל (4.5%) + מרווח של 3.5%, ועוד דמי פיגורים רבעוניים.' },
      { q: 'כמה ריבית משלמים עכשיו על חוב בהוצאה לפועל?', a: 'נכון לאפריל 2025: ריבית בנק ישראל (4.5%) + 3.5% = 8% בשנה, בתוספת דמי פיגורים של 0.25% לרבעון (1% בשנה). סה"כ כ-9% לשנה על חובות שלא שולמו.' },
      { q: 'האם תיקון 9 חל על חובות ישנים שנפתחו לפני 2025?', a: 'כן. תיקון 9 חל על חובות קיימים מינואר 2025 ואילך. חישוב הריבית החדש פועל על הקרן שנותרה מינואר 2025.' },
      { q: 'האם ריבית הפיגורים יכולה לגדול?', a: 'כן. הריבית מתעדכנת בכל פעם שבנק ישראל משנה את הריבית (בדרך כלל כל 6 שבועות). כשריבית בנק ישראל עולה — גם ריבית הפיגורים עולה.' },
      { q: 'איך מחשבים כמה אני חייב לפי תיקון 9?', a: 'השתמש במחשבון הריבית שלנו — הוא עודכן לפי תיקון 9 ומחשב את הסכום המעודכן כולל ריבית ודמי פיגורים.' },
      { q: 'מה תקרת דמי הפיגורים לפי תיקון 9?', a: 'לפי תיקון 9, דמי הפיגורים מוגבלים ל-80% מהקרן המקורית (70% אם עומדים בצו תשלומים). זה אומר שהחוב לא יכול לגדול לאינסוף — יש תקרה ברורה.' },
    ]
  },
  {
    id: 'mazamot',
    icon: '👨‍👧',
    title: 'מזונות בהוצאה לפועל',
    questions: [
      { q: 'איך גובים מזונות שלא שולמו דרך הוצאה לפועל?', a: 'מגישים בקשה לפתיחת תיק הוצאה לפועל עם פסק הדין למזונות. הרשם מוציא אזהרה לחייב, ואם לא משלם — עיקול חשבון בנק, עיקול משכורת, עיכוב יציאה מהארץ, ופסילת רישיון נהיגה.' },
      { q: 'האם מזונות מוגנים מחדלות פירעון?', a: 'כן. חוב מזונות (לילדים ולבן/בת זוג לשעבר) אינו ניתן להפטר בהליך חדלות פירעון. גם אחרי מחיקת כל החובות האחרים — חוב מזונות ממשיך לעמוד ולצבור ריבית.' },
      { q: 'מה קורה כשאב לא יכול לשלם מזונות?', a: 'ביטוח לאומי משלם לאם "גמלת מזונות" (עד 1,558 ₪ לילד/חודש ב-2026) כשאב לא משלם ותיק הוצאה לפועל פתוח. לאחר מכן ביטוח לאומי גובה מהאב בעצמו.' },
      { q: 'האם ניתן לעקל 100% מהמשכורת לצורך מזונות?', a: 'לא 100%, אבל עיקול מזונות ממשכורת יכול לעלות על שליש הרגיל — עד 50% לעיתים. בית המשפט מחליט לפי כל מקרה, תוך התחשבות בצרכי הילדים וביכולת האב.' },
      { q: 'האם ניתן להפחית מזונות אחרי פסיקה?', a: 'כן, דרך בקשה לבית המשפט לענייני משפחה. אם הכנסתך ירדה משמעותית — ניתן לבקש עדכון סכום המזונות. עד שפסק הדין משתנה — ממשיכים לצבור חוב לפי הפסיקה המקורית.' },
      { q: 'האם עיכוב יציאה מהארץ חל אוטומטית על חייב מזונות?', a: 'כן, עיכוב יציאה מהארץ ניתן לחייבי מזונות בתנאים קלים יותר מחובות רגילים — ניתן להטיל מהר יחסית ולחדש אוטומטית. לנסיעה לחו"ל נדרש אישור בית משפט.' },
    ]
  },
  {
    id: 'practical',
    icon: '🛠️',
    title: 'שאלות מעשיות',
    questions: [
      { q: 'איפה מוגישים בקשה בהוצאה לפועל?', a: 'בלשכת ההוצאה לפועל הקרובה למקום מגוריך, או דרך המערכת המקוונת של רשות האכיפה והגבייה באתר gov.il.' },
      { q: 'כמה עולה להגיש בקשה לבד?', a: 'בקשות רוב — אגרות מינימליות של כמה עשרות שקלים. בקשות מסוימות (ערעור, איחוד תיקים) עלולות לדרוש אגרה גבוהה יותר.' },
      { q: 'מה מסמכים צריך להביא לחקירת יכולת?', a: 'תלושי משכורת 3 חודשים אחרונים, דפי חשבון בנק, קבלות הוצאות קבועות (שכר דירה, חשמל, תרופות), תעודת זהות.' },
      { q: 'האם אפשר להגיש בקשות אונליין?', a: 'כן. רשות האכיפה והגבייה מאפשרת הגשת מגוון בקשות דרך אתר gov.il. לחלק מהבקשות נדרשת הגשה פיזית.' },
      { q: 'מה עושים אם לא מבין את המכתב?', a: 'פנה לרשות האכיפה לבקשת הסבר, התייעץ עם עורך דין, או השתמש בצ\'אטבוט שלנו לקבלת מידע ראשוני.' },
      { q: 'האם אפשר לשלם חוב הוצאה לפועל בכרטיס אשראי?', a: 'כן. ניתן לשלם דרך מערכת הוצאה לפועל המקוונת, בדואר, או בלשכה — בכרטיס אשראי, העברה בנקאית, או מזומן.' },
      { q: 'כמה זמן נשאר הרישום בדוח האשראי?', a: 'רישום שלילי נשאר בדרך כלל 7 שנים מתאריך העסקה. אחרי הפטר בחדלות פירעון — הרישום מתעדכן בהתאם.' },
    ]
  },
];
---

<BaseLayout
  title="שאלות נפוצות על הוצאה לפועל — תשובות מעודכנות 2025–2026"
  description="כל השאלות שאתה שואל על הוצאה לפועל — עיקולים, צו תשלומים, תיקון 9, זכויות חייבים, חדלות פירעון. תשובות ברורות בעברית פשוטה, מעודכן 2025."
  schema={faqSchema}
>
  <Header />
  <main class="max-w-4xl mx-auto px-4 py-10">

    <nav class="text-sm text-neutral-muted mb-6">
      <a href="/">בית</a> › <span class="text-gray-700">שאלות נפוצות</span>
    </nav>

    <h1 class="text-3xl font-bold text-brand-dark mb-2">שאלות נפוצות</h1>
    <p class="text-gray-500 mb-8">
      {categories.reduce((sum, c) => sum + c.questions.length, 0)}+ תשובות לשאלות הנפוצות ביותר על הוצאה לפועל וחדלות פירעון
    </p>

    <!-- ניווט מהיר בין קטגוריות -->
    <div class="flex flex-wrap gap-2 mb-10">
      {categories.map(cat => (
        <a
          href={`#${cat.id}`}
          class="flex items-center gap-1.5 px-3 py-1.5 bg-white border border-neutral-border rounded-full text-sm text-gray-600 hover:border-brand hover:text-brand-dark transition-all"
        >
          <span>{cat.icon}</span>
          <span>{cat.title}</span>
        </a>
      ))}
    </div>

    <!-- קטגוריות ושאלות -->
    <div class="space-y-12">
      {categories.map(cat => (
        <section id={cat.id}>
          <h2 class="text-xl font-bold text-brand-dark mb-5 flex items-center gap-2">
            <span class="text-2xl">{cat.icon}</span>
            {cat.title}
          </h2>
          <div class="space-y-3">
            {cat.questions.map(faq => (
              <details class="border border-neutral-border rounded-xl group bg-white">
                <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center gap-4">
                  <span>{faq.q}</span>
                  <span class="text-neutral-muted shrink-0 group-open:rotate-180 transition-transform text-lg">▼</span>
                </summary>
                <div class="px-4 pb-4 pt-1 text-gray-600 leading-relaxed border-t border-neutral-border">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-14 bg-brand-dark text-white rounded-2xl p-8 text-center">
      <h2 class="text-xl font-bold mb-2">לא מצאת תשובה?</h2>
      <p class="text-brand-light mb-6">שאל את הצ'אטבוט שלנו — עונה 24/7 על שאלות על הוצאה לפועל</p>
      <a
        href="/tools/chatbot/"
        class="inline-block bg-white text-brand-dark font-bold px-6 py-3 rounded-lg hover:bg-brand-pale transition-colors"
      >
        לצ'אטבוט ←
      </a>
    </div>

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-xl p-4 text-sm text-gray-700">
      ⚠️ המידע כאן הוא כללי בלבד ואינו מהווה ייעוץ משפטי. לייעוץ אישי בתיק שלך — פנה לעורך דין.
    </div>

  </main>
  <Footer />
</BaseLayout>
