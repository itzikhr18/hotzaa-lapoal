---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const contactEmail = 'partners@hotzaa-lapoal.info';
const contactSubject = encodeURIComponent('התעניינות בפיילוט רישוי כלים למשרד עורכי דין');
const contactHref = `mailto:${contactEmail}?subject=${contactSubject}`;

const benefits = [
  {
    title: 'חוויה דיגיטלית תחת המותג שלכם',
    text: 'התאמת צבעים, לוגו, ניסוחים וקישורי יצירת קשר כך שהכלים ירגישו חלק טבעי מאתר המשרד.',
    icon: 'brand',
  },
  {
    title: 'כלים שמסבירים לפני השיחה',
    text: 'מחשבונים, שאלוני הכוונה ומחוללי נוסחים שמסייעים לגולש להבין את הנושא ולהגיע לשיחה ממוקדת יותר.',
    icon: 'flow',
  },
  {
    title: 'הקמה ותחזוקה מרוכזות',
    text: 'אנחנו מטפלים בהטמעה, בהתאמות הטכניות ובשיפור שוטף לפי ההיקף שיוגדר בהסכם.',
    icon: 'tools',
  },
];

const faq = [
  {
    q: 'האם אתם מוכרים לידים או פרטי גולשים?',
    a: 'לא. מסלול הרישוי מבוסס על דמי הקמה ותשלום חודשי עבור שימוש בכלים. הוא אינו כולל מכירת פרטי גולשים או תשלום עבור הפניה לעורך דין.',
  },
  {
    q: 'אילו כלים אפשר להתאים למשרד?',
    a: 'ההתאמה יכולה לכלול מחשבונים, שאלוני הכוונה, מחוללי נוסחים ורכיבי תוכן אינטראקטיביים. היקף הפיילוט נקבע יחד, לאחר בדיקה של אתר המשרד והצרכים שלו.',
  },
  {
    q: 'האם הכלים נותנים ייעוץ משפטי?',
    a: 'לא. הכלים מיועדים למסירת מידע כללי ולהכנת הגולש לשיחה מקצועית. המשרד אחראי לבדיקת הנוסחים המשפטיים, להנחיות המקצועיות ולייעוץ האישי ללקוח.',
  },
  {
    q: 'כמה עולה הרישוי?',
    a: 'המודל כולל דמי הקמה ותשלום חודשי. המחיר נקבע לפי מספר הכלים, עומק ההתאמה, החיבורים הנדרשים ורמת התחזוקה.',
  },
  {
    q: 'איך מתחילים?',
    a: 'שולחים דוא״ל קצר עם כתובת אתר המשרד והכלי שמעניין אתכם. לאחר התאמה ראשונית נגדיר פיילוט מצומצם, יעדים ולוח זמנים.',
  },
];
---

<BaseLayout
  title="רישוי כלים דיגיטליים למשרדי עורכי דין"
  description="כלים דיגיטליים White-Label למשרדי עורכי דין בתחום הוצאה לפועל וחדלות פירעון — התאמה למותג, הטמעה ותחזוקה במודל רישוי."
>
  <Header />
  <main id="main-content">
    <section class="relative overflow-hidden border-b border-neutral-border bg-gradient-to-b from-brand-pale to-white">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute -top-24 -left-24 h-72 w-72 rounded-full bg-blue-100/70 blur-3xl"></div>
        <div class="absolute -bottom-28 -right-20 h-80 w-80 rounded-full bg-cyan-100/60 blur-3xl"></div>
      </div>

      <div class="relative max-w-6xl mx-auto px-4 pt-8 pb-16 md:pt-12 md:pb-24">
        <Breadcrumb items={[{ label: 'רישוי למשרדי עורכי דין' }]} />

        <div class="max-w-4xl mx-auto text-center pt-6">
          <span class="inline-flex items-center rounded-full border border-brand-light bg-white px-4 py-2 text-sm font-semibold text-brand-dark shadow-sm">
            פיילוט למשרדים בתחום הוצאה לפועל וחדלות פירעון
          </span>
          <h1 class="mt-6 text-4xl md:text-6xl font-bold leading-tight text-gray-950">
            הכלים הדיגיטליים שהלקוחות שלכם צריכים — תחת המותג שלכם
          </h1>
          <p class="mt-6 max-w-3xl mx-auto text-lg md:text-xl leading-relaxed text-gray-700">
            רישוי White-Label של כלים אינטראקטיביים לאתר המשרד: התאמת מיתוג, הטמעה ותחזוקה — בלי לבנות מוצר מאפס ובלי לרכוש לידים.
          </p>
          <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href={contactHref}
              class="inline-flex min-h-12 w-full sm:w-auto items-center justify-center rounded-xl bg-brand-dark px-7 py-3 font-bold text-white shadow-lg transition-all duration-200 hover:-translate-y-0.5 hover:bg-brand focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-dark"
            >
              בדיקת התאמה לפיילוט
            </a>
            <a
              href="#how-it-works"
              class="inline-flex min-h-12 w-full sm:w-auto items-center justify-center rounded-xl border border-neutral-border bg-white px-7 py-3 font-bold text-brand-dark transition-colors duration-200 hover:border-brand hover:bg-brand-pale focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-dark"
            >
              איך זה עובד
            </a>
          </div>
          <p class="mt-4 text-sm text-gray-600">פנייה ראשונית בדוא״ל · ללא התחייבות · הפיילוט מותאם לצורכי המשרד</p>
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-4 py-16 md:py-20">
      <div class="max-w-3xl mx-auto text-center mb-10">
        <p class="text-sm font-bold uppercase tracking-wider text-brand">הערך למשרד</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold text-gray-950">להוסיף שירות דיגיטלי בלי להקים צוות מוצר</h2>
        <p class="mt-4 text-gray-700 leading-relaxed">
          המטרה היא לא להחליף את שיקול הדעת המקצועי, אלא לשפר את הדרך שבה המשרד מנגיש מידע ומכין פונים לשיחה.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {benefits.map((benefit) => (
          <article class="rounded-2xl border border-neutral-border bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-brand-light hover:shadow-md">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-pale text-brand-dark" aria-hidden="true">
              {benefit.icon === 'brand' && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M12 3l7 4v5c0 4.6-2.8 7.7-7 9-4.2-1.3-7-4.4-7-9V7l7-4z"></path>
                  <path d="M9 12l2 2 4-4"></path>
                </svg>
              )}
              {benefit.icon === 'flow' && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8">
                  <rect x="3" y="4" width="7" height="5" rx="1"></rect>
                  <rect x="14" y="15" width="7" height="5" rx="1"></rect>
                  <path d="M10 6.5h4a3 3 0 013 3V15M7 9v7a2 2 0 002 2h5"></path>
                </svg>
              )}
              {benefit.icon === 'tools' && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M14.5 6.5a4 4 0 01-5 5L4 17l3 3 5.5-5.5a4 4 0 005-5l-2.5 2.5-3-3L14.5 6.5z"></path>
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-gray-950">{benefit.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-gray-700">{benefit.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="how-it-works" class="border-y border-neutral-border bg-gray-50 scroll-mt-24">
      <div class="max-w-6xl mx-auto px-4 py-16 md:py-20">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div>
            <p class="text-sm font-bold uppercase tracking-wider text-brand">פיילוט ממוקד</p>
            <h2 class="mt-3 text-3xl md:text-4xl font-bold text-gray-950">מתחילים קטן, מודדים, ורק אז מרחיבים</h2>
            <p class="mt-5 leading-relaxed text-gray-700">
              במקום פרויקט גדול וארוך, בוחרים כלי אחד שמשרת צורך ברור באתר המשרד. לאחר ההטמעה בודקים שימוש, איכות פניות ומשוב מהצוות.
            </p>
          </div>

          <ol class="space-y-4">
            {[
              ['1', 'מיפוי קצר', 'מזהים את קהל היעד, השאלות החוזרות והכלי המתאים ביותר לפיילוט.'],
              ['2', 'התאמה למשרד', 'מתאימים את המיתוג, הניסוחים, הגילויים וקישורי ההמשך.'],
              ['3', 'הטמעה ובדיקה', 'מעלים את הכלי לסביבת המשרד ובודקים תצוגה, נגישות ושימוש במובייל.'],
              ['4', 'מדידה והחלטה', 'בוחנים את תוצאות הפיילוט ומחליטים אם לשפר, להרחיב או לעצור.'],
            ].map(([number, title, text]) => (
              <li class="flex gap-4 rounded-2xl border border-neutral-border bg-white p-5">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-dark font-bold text-white" aria-hidden="true">{number}</span>
                <div>
                  <h3 class="font-bold text-gray-950">{title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-gray-700">{text}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-4 py-16 md:py-20">
      <div class="max-w-3xl mx-auto text-center mb-10">
        <p class="text-sm font-bold uppercase tracking-wider text-brand">שקיפות מסחרית</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold text-gray-950">מודל רישוי, לא מודל מכירת לידים</h2>
        <p class="mt-4 leading-relaxed text-gray-700">
          התשלום הוא עבור התאמה, רישוי ותחזוקת הכלים. פרטי גולשים אינם מוצר ואינם נמכרים לצדדים שלישיים.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-neutral-border p-6 text-center">
          <p class="text-sm text-gray-600">שלב ראשון</p>
          <p class="mt-2 text-xl font-bold text-gray-950">דמי הקמה</p>
          <p class="mt-2 text-sm text-gray-700">לפי עומק ההתאמה וההטמעה</p>
        </div>
        <div class="rounded-2xl border border-brand-light bg-brand-pale p-6 text-center">
          <p class="text-sm text-gray-600">לאחר ההשקה</p>
          <p class="mt-2 text-xl font-bold text-gray-950">רישוי חודשי</p>
          <p class="mt-2 text-sm text-gray-700">לפי מספר הכלים ורמת התחזוקה</p>
        </div>
        <div class="rounded-2xl border border-neutral-border p-6 text-center">
          <p class="text-sm text-gray-600">העיקרון</p>
          <p class="mt-2 text-xl font-bold text-gray-950">ללא תשלום לליד</p>
          <p class="mt-2 text-sm text-gray-700">ללא מכירת פרטי גולשים</p>
        </div>
      </div>
    </section>

    <section class="border-y border-neutral-border bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 py-16 md:py-20">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-950">שאלות נפוצות</h2>
        </div>
        <div class="space-y-3">
          {faq.map((item) => (
            <details class="group rounded-xl border border-neutral-border bg-white p-5">
              <summary class="cursor-pointer list-none font-bold text-gray-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand-dark">
                <span class="flex items-center justify-between gap-4">
                  {item.q}
                  <svg viewBox="0 0 20 20" class="h-5 w-5 shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M5 7.5l5 5 5-5"></path>
                  </svg>
                </span>
              </summary>
              <p class="mt-4 border-t border-neutral-border pt-4 text-sm leading-relaxed text-gray-700">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-4 py-16 md:py-24">
      <div class="overflow-hidden rounded-3xl bg-brand-dark px-6 py-12 text-center text-white shadow-xl md:px-12 md:py-16">
        <h2 class="text-3xl md:text-4xl font-bold">רוצים לבדוק אם פיילוט מתאים למשרד שלכם?</h2>
        <p class="mx-auto mt-4 max-w-2xl text-blue-100 leading-relaxed">
          כתבו לנו באיזה תחום המשרד מתמקד, צרפו קישור לאתר וציינו איזה כלי הייתם רוצים להציע ללקוחות.
        </p>
        <a
          href={contactHref}
          class="mt-8 inline-flex min-h-12 items-center justify-center rounded-xl bg-white px-7 py-3 font-bold text-brand-dark transition-all duration-200 hover:-translate-y-0.5 hover:bg-brand-pale focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
        >
          שלחו פנייה לפיילוט
        </a>
        <p class="mt-4 text-sm text-blue-100">{contactEmail}</p>
      </div>
    </section>

    <section class="max-w-4xl mx-auto px-4 pb-8 text-center text-xs leading-relaxed text-gray-600">
      <p>
        הכלים מספקים מידע כללי בלבד ואינם מחליפים ייעוץ משפטי. כל התקשרות מסחרית תהיה כפופה להסכם רישוי נפרד ולבדיקה משפטית של הצדדים.
      </p>
      <p class="mt-2">
        למידע נוסף ראו <a href="/legal/terms/" class="underline hover:text-brand-dark">תנאי שימוש</a> ו<a href="/legal/privacy/" class="underline hover:text-brand-dark">מדיניות פרטיות</a>.
      </p>
    </section>
  </main>
  <Footer />
</BaseLayout>
