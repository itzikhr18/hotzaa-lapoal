      '׳¨׳©׳™׳׳× ׳©׳׳׳•׳× ׳§׳¦׳¨׳”: ׳׳” ׳׳ ׳‘׳¨׳•׳¨ ׳•׳׳” ׳×׳¨׳¦׳• ׳׳”׳‘׳™׳ ׳‘׳₪׳’׳™׳©׳”',
    ],
  };

  let selectedTopic = '';
  const topicButtons = Array.from(document.querySelectorAll('.topic-button'));
  const documentChecks = Array.from(document.querySelectorAll('.document-check'));
  const buildButton = document.getElementById('build-checklist');
  const errorMessage = document.getElementById('selection-error');
  const result = document.getElementById('checklist-result');
  const resultTopic = document.getElementById('result-topic');
  const recommendedList = document.getElementById('recommended-list');
  const existingWrapper = document.getElementById('existing-wrapper');
  const existingList = document.getElementById('existing-list');

  const appendListItem = (list, text) => {
    const item = document.createElement('li');
    item.className = 'flex gap-2';
    const marker = document.createElement('span');
    marker.className = 'font-bold text-brand-dark';
    marker.setAttribute('aria-hidden', 'true');
    marker.textContent = 'ג“';
    const content = document.createElement('span');
    content.textContent = text;
    item.append(marker, content);
    list?.appendChild(item);
  };

  topicButtons.forEach((button) => {
    button.addEventListener('click', () => {
      selectedTopic = button.getAttribute('data-topic') || '';
      topicButtons.forEach((candidate) => {
        const isSelected = candidate === button;
        candidate.setAttribute('aria-pressed', String(isSelected));
        candidate.classList.toggle('border-brand', isSelected);
        candidate.classList.toggle('bg-brand-pale', isSelected);
      });
      errorMessage?.classList.add('hidden');
    });
  });

  buildButton?.addEventListener('click', () => {
    if (!selectedTopic) {
      errorMessage?.classList.remove('hidden');
      topicButtons[0]?.focus();
      return;
    }

    if (resultTopic) resultTopic.textContent = selectedTopic;
    if (recommendedList) recommendedList.textContent = '';
    recommendations[selectedTopic]?.forEach((item) => appendListItem(recommendedList, item));

    const existing = documentChecks
      .filter((check) => check.checked)
      .map((check) => check.getAttribute('data-label'))
      .filter(Boolean);

    if (existingList) existingList.textContent = '';
    existing.forEach((item) => appendListItem(existingList, item));
    existingWrapper?.classList.toggle('hidden', existing.length === 0);

    result?.classList.remove('hidden');
    result?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  document.getElementById('print-checklist')?.addEventListener('click', () => window.print());

  document.getElementById('reset-checklist')?.addEventListener('click', () => {
    selectedTopic = '';
    topicButtons.forEach((button) => {
      button.setAttribute('aria-pressed', 'false');
      button.classList.remove('border-brand', 'bg-brand-pale');
    });
    documentChecks.forEach((check) => { check.checked = false; });
    result?.classList.add('hidden');
    errorMessage?.classList.add('hidden');
    document.getElementById('topic-heading')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
</script>

<style>
  @media print {
    header,
    footer,
    #topic-options,
    #documents-heading,
    #build-checklist,
    #print-checklist,
    #reset-checklist,
    main > section:last-of-type,
    [aria-label*="׳¦'׳׳˜׳‘׳•׳˜"] {
      display: none !important;
    }

    #checklist-result {
      display: block !important;
      border: 1px solid #94a3b8 !important;
      background: white !important;
    }
  }
</style>

