---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const siteUrl = 'https://hotzaa-lapoal.info';
const lastVerified = '2026-07-03';

const officialLinks = {
  personalArea: 'https://go.gov.il/ecagovernmentident',
  appointment: 'https://go.gov.il/ecagovisit',
  bureaus: 'https://www.gov.il/he/departments/Bureaus?OfficeId=c673e628-43e7-40e5-9610-19b2ffabce3b&cities=',
  authority: 'https://www.gov.il/he/departments/law_enforcement_and_collection_system_authority',
  form233: 'https://www.gov.il/BlobFolder/generalpage/eca-digital-forms2/he/Forms_form233.docx',
  form529: 'https://www.gov.il/BlobFolder/generalpage/eca-digital-forms2/he/Forms_form529.docx',
};

const forms = [
  {
    title: 'בקשה לביטול או עיכוב עיקול',
    form: 'טופס 214',
    intent: 'כשעוקל חשבון בנק, משכורת, רכב, דירה או כספים מוגנים.',
    documents: ['הודעת העיקול', 'דפי חשבון 3 חודשים', 'אישור מקור כספים מוגנים', 'תלושי שכר או אישור קצבה'],
    guide: '/guides/bitul-ikul/',
    onlineHref: officialLinks.personalArea,
    onlineLabel: 'הגשה אונליין באזור האישי',
    manualLinks: [
      { label: 'נוסח עזר לביטול עיקול', href: '#template-bitul-ikul', external: false },
      { label: 'מדריך מילוי טופס 214', href: '/guides/bitul-ikul/', external: false },
    ],
    note: 'באונליין בדרך כלל מגישים את הבקשה מתוך האזור האישי ומצרפים מסמכים. הנוסח שלנו הוא עזר לנימוקים, לא הטופס הרשמי עצמו.',
    lastVerified,
    sourceStatus: 'נבדק מול מסלול ההגשה באזור האישי. לפני הגשה ידנית יש לוודא באתר הרשות שהטופס או ההליך לא עודכנו.',
  },
  {
    title: 'בקשה לצו תשלומים',
    form: 'טופס 233 + שאלון וכתב ויתור על סודיות',
    intent: 'כשמודים בחוב אבל לא יכולים לשלם את כולו בבת אחת.',
    documents: ['צילום תעודת זהות וספח', '6 תלושי שכר אחרונים', 'דפי בנק 6 חודשים', 'הוצאות קבועות והתחייבויות'],
    guide: '/guides/tzav-tashlumim/',
    onlineHref: officialLinks.personalArea,
    onlineLabel: 'הגשה אונליין באזור האישי',
    manualLinks: [
      { label: 'הורדת טופס 233 רשמי', href: officialLinks.form233, external: true },
      { label: 'הורדת טופס 529 רשמי', href: officialLinks.form529, external: true },
      { label: 'נוסח עזר לצו תשלומים', href: '#template-tzav-tashlumim', external: false },
    ],
    note: 'כאן כן יש קבצים רשמיים מאומתים להורדה. בהגשה אונליין עדיין כדאי להכין אותם ואת המסמכים לפני שמתחילים.',
    lastVerified,
    sourceStatus: 'קישורי ההורדה לטופס 233 ולטופס 529 מפנים לקבצי gov.il רשמיים.',
  },
  {
    title: 'בקשה לבדיקת תיק והבנת מצב',
    form: 'אזור אישי הוצאה לפועל',
    intent: 'כשלא ברור איזה תיק פתוח, מה סכום החוב או מי הזוכה.',
    documents: ['תעודת זהות', 'מספר תיק אם קיים', 'מכתב אזהרה או הודעת בנק', 'פרטי הזדהות ממשלתית'],
    guide: '/guides/bdika-tik/',
    onlineHref: officialLinks.personalArea,
    onlineLabel: 'כניסה לאזור האישי',
    manualLinks: [
      { label: 'זימון תור ללשכה', href: officialLinks.appointment, external: true },
      { label: 'איתור לשכת הוצאה לפועל', href: officialLinks.bureaus, external: true },
    ],
    note: 'לבדיקת תיק אין בהכרח טופס להורדה. הדרך המעשית היא כניסה לאזור האישי או פנייה ללשכה עם תעודת זהות.',
    lastVerified,
    sourceStatus: 'הקישורים מפנים לאזור האישי, לזימון תור ולרשימת לשכות רשמית של רשות האכיפה והגבייה.',
  },
  {
    title: 'בקשה לביטול הגבלות',
    form: 'בקשה כללית בתיק',
    intent: 'כשיש הגבלת חשבון, כרטיס אשראי, דרכון, רישיון או עיכוב יציאה.',
    documents: ['החלטת ההגבלה', 'מסמכי הכנסה', 'הוכחת צורך דחוף', 'אישור תשלום ראשון אם יש צו'],
    guide: '/guides/bitul-hagbalot/',
    onlineHref: officialLinks.personalArea,
    onlineLabel: 'הגשה אונליין באזור האישי',
    manualLinks: [
      { label: 'נוסח עזר לעיכוב הליכים', href: '#template-urgent-delay', external: false },
      { label: 'מדריך ביטול הגבלות', href: '/guides/bitul-hagbalot/', external: false },
    ],
    note: 'הגבלות מבטלים בדרך כלל באמצעות בקשה בתיק וצירוף ראיות. אם מגישים ידנית, כדאי לשמור אישור מסירה או אישור תור.',
    lastVerified,
    sourceStatus: 'הבקשה מתבצעת בדרך כלל דרך האזור האישי או דרך לשכה; יש לבדוק את ההליך העדכני לפני הגשה.',
  },
];

const officialSources = [
  { label: 'האזור האישי של רשות האכיפה והגבייה', href: officialLinks.personalArea },
  { label: 'רשות האכיפה והגבייה באתר gov.il', href: officialLinks.authority },
  { label: 'זימון תור ללשכת הוצאה לפועל', href: officialLinks.appointment },
  { label: 'איתור לשכות הוצאה לפועל', href: officialLinks.bureaus },
  { label: 'טופס 233 רשמי - בקשה לצו תשלומים', href: officialLinks.form233 },
  { label: 'טופס 529 רשמי - כתב ויתור על סודיות', href: officialLinks.form529 },
];

const quickTemplates = [
  {
    id: 'template-bitul-ikul',
    title: 'נוסח קצר לביטול עיקול חשבון בנק',
    text: `לכבוד רשם ההוצאה לפועל,

אני מבקש/ת לעכב ולבטל את העיקול שהוטל על חשבון הבנק בתיק מספר ________.
העיקול פוגע ביכולתי לשלם הוצאות בסיסיות, וחלק מהכספים בחשבון מקורם ב________ ולכן הם מוגנים מעיקול.

מצורפים: דפי חשבון, אישור מקור הכספים, תלושי שכר/אישור קצבה וכל מסמך תומך נוסף.
אבקש החלטה דחופה והודעה מיידית לבנק במקרה של קבלת הבקשה.

שם, תאריך, חתימה`,
  },
  {
    id: 'template-tzav-tashlumim',
    title: 'נוסח קצר לצו תשלומים',
    text: `לכבוד רשם ההוצאה לפועל,

אני מודה בקיום החוב בתיק מספר ________, אך איני מסוגל/ת לשלם את מלוא החוב בבת אחת.
לאור הכנסותיי והוצאותיי החודשיות, אבקש לקבוע צו תשלומים בסך ________ ש"ח לחודש.

מצורפים מסמכים המעידים על מצבי הכלכלי: תלושי שכר, דפי חשבון, הוצאות קבועות והתחייבויות.
אבקש לעכב הליכי גבייה ועיקולים כל עוד אני עומד/ת בתשלומים שייקבעו.

שם, תאריך, חתימה`,
  },
  {
    id: 'template-urgent-delay',
    title: 'נוסח קצר לבקשה דחופה לעיכוב הליכים',
    text: `לכבוד רשם ההוצאה לפועל,

אבקש לעכב באופן דחוף את ההליכים בתיק מספר ________ עד למתן החלטה בבקשתי.
ההליך שננקט גורם לפגיעה מיידית וקשה ביכולת הקיום/הפרנסה שלי, במיוחד משום ש________.

מצורפים מסמכים תומכים להוכחת הדחיפות והפגיעה.
אבקש לתת החלטה בהקדם האפשרי ולהודיע לצדדים הרלוונטיים.

שם, תאריך, חתימה`,
  },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'טפסים ונוסחים להוצאה לפועל',
  description: 'מרכז טפסים ונוסחים לחייבים בהוצאה לפועל: ביטול עיקול, צו תשלומים, בדיקת תיק, ביטול הגבלות ובקשות דחופות.',
  url: `${siteUrl}/forms/`,
  inLanguage: 'he',
  dateModified: lastVerified,
  hasPart: forms.map(item => ({
    '@type': 'CreativeWork',
    name: item.title,
    description: item.intent,
    url: `${siteUrl}${item.guide}`,
    dateModified: item.lastVerified,
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'האם חייבים להוריד את הטפסים או שאפשר להגיש אונליין?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ברוב הבקשות אפשר להגיש אונליין דרך האזור האישי של רשות האכיפה והגבייה. אם מגישים בלשכה, בדואר, בפקס או במייל, צריך בדרך כלל להוריד או למלא את הטופס ולצרף מסמכים.',
      },
    },
    {
      '@type': 'Question',
      name: 'איזה טופס מגישים לביטול עיקול?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ברוב המקרים משתמשים בטופס 214, בקשה לביטול או עיכוב הליכים והגבלות, ומצרפים מסמכים שמראים למה יש לבטל את העיקול.',
      },
    },
    {
      '@type': 'Question',
      name: 'איזה טופס צריך לצו תשלומים?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לצו תשלומים מגישים בדרך כלל טופס בקשה לצו תשלומים, שאלון וכתב ויתור על סודיות, בצירוף מסמכים על הכנסות, הוצאות ונכסים.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר להשתמש בנוסחים באתר כמו שהם?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'הנוסחים באתר הם בסיס כללי בלבד. צריך להתאים אותם לפרטי התיק, לצרף מסמכים ולבדוק באתר הרשמי של רשות האכיפה והגבייה אם הטופס או ההליך עודכנו.',
      },
    },
  ],
};
---

<BaseLayout
  title="טפסים ונוסחים להוצאה לפועל - ביטול עיקול, צו תשלומים ובקשות דחופות"
  description="מרכז טפסים ונוסחים להוצאה לפועל: איזה טופס צריך לביטול עיקול, צו תשלומים, בדיקת תיק וביטול הגבלות, אילו מסמכים לצרף ונוסחים בסיסיים לעריכה."
  canonicalUrl={`${siteUrl}/forms/`}
  schema={[pageSchema, faqSchema]}
>
  <Header />

  <main id="main-content" class="max-w-4xl mx-auto px-4 py-10">
<Breadcrumb items={[{ label: 'טפסים ונוסחים' }]} />

    <header class="mb-10">
      <p class="text-brand text-sm font-bold uppercase tracking-wide mb-2">מרכז פעולה</p>
      <h1 class="text-3xl md:text-4xl font-bold text-brand-dark leading-tight mb-4">
        טפסים ונוסחים להוצאה לפועל
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed max-w-3xl">
        ריכוז מעשי של הטפסים, המסמכים והנוסחים שחייבים מחפשים בזמן לחץ: ביטול עיקול,
        צו תשלומים, בדיקת תיק, ביטול הגבלות ובקשה דחופה לעיכוב הליכים.
      </p>
      <div class="mt-5 rounded-xl border border-teal-200 bg-teal-50 p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div class="text-sm text-gray-700">
          <p class="font-bold text-teal-800 mb-1">✍️ חדש: מחולל נוסח בקשה אוטומטי</p>
          <p>ממלאים פרטים ומסמנים נימוקים — ומקבלים בקשה מנוסחת ומוכנה להגשה לרשם, בחינם ובלי לשלוח פרטים לשרת.</p>
        </div>
        <a href="/tools/noseach-bakasha/" class="shrink-0 text-sm font-semibold text-white bg-teal-600 hover:bg-teal-700 px-4 py-2 rounded-full transition-colors text-center">
          פתח את המחולל ←
        </a>
      </div>
      <div class="mt-5 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
        המידע כאן הוא כללי בלבד. לפני הגשה בפועל בדקו את הטופס העדכני באתר הרשמי של
        <a href="https://www.gov.il/he/departments/law_enforcement_and_collection_system_authority" target="_blank" rel="noopener noreferrer" class="font-semibold underline">רשות האכיפה והגבייה</a>
        והתאימו את הנוסח לפרטי התיק שלכם.
      </div>
    </header>

    <section class="mb-10 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-green-50 border border-green-200 rounded-xl p-5">
        <h2 class="text-lg font-bold text-green-900 mb-2">אפשר להגיש אונליין</h2>
        <p class="text-sm text-gray-700 leading-relaxed mb-4">
          ברוב הבקשות אין חובה להדפיס. נכנסים לאזור האישי של הוצאה לפועל,
          בוחרים את סוג הבקשה, ממלאים פרטים ומעלים מסמכים סרוקים או קבצי PDF.
        </p>
        <a href={officialLinks.personalArea} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-green-700 hover:bg-green-800 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
          כניסה לאזור האישי
        </a>
      </div>
      <div class="bg-white border border-neutral-border rounded-xl p-5">
        <h2 class="text-lg font-bold text-gray-900 mb-2">מתי מורידים טופס?</h2>
        <p class="text-sm text-gray-700 leading-relaxed mb-4">
          מורידים טופס כשמגישים ידנית בלשכה, בדואר, בפקס או במייל, או כשצריך להכין
          מראש נוסח חתום ומסמכים לפני ההגשה המקוונת.
        </p>
        <a href={officialLinks.appointment} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center border border-brand text-brand-dark hover:bg-brand-pale text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
          זימון תור ללשכה
        </a>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">איזה טופס צריך?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {forms.map(item => (
          <article class="bg-white border border-neutral-border rounded-xl p-5">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <p class="text-xs font-bold text-brand">{item.form}</p>
              <span class="text-[11px] font-semibold text-gray-500 bg-gray-100 border border-gray-200 rounded-full px-2 py-0.5">
                אומת: {item.lastVerified}
              </span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-sm text-gray-600 mb-4 leading-relaxed">{item.intent}</p>
            <p class="text-sm font-semibold text-gray-800 mb-2">מסמכים שכדאי להכין:</p>
            <ul class="space-y-1 text-sm text-gray-600 mb-4">
              {item.documents.map(doc => <li>- {doc}</li>)}
            </ul>
            <div class="flex flex-col gap-2">
              <a href={item.onlineHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-brand-dark hover:bg-brand-trust text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
                {item.onlineLabel}
              </a>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {item.manualLinks.map(link => (
                  <a
                    href={link.href}
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                    class="inline-flex items-center justify-center border border-neutral-border hover:border-brand hover:bg-brand-pale text-gray-700 hover:text-brand-dark text-sm font-semibold px-3 py-2 rounded-lg transition-colors"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
              <a href={item.guide} class="inline-flex text-sm font-semibold text-brand hover:text-brand-dark">
                למדריך המלא
              </a>
            </div>
            <p class="text-xs text-neutral-muted mt-3 leading-relaxed">{item.note}</p>
            <p class="text-xs text-gray-600 mt-2 leading-relaxed">
              <strong>מקור:</strong> {item.sourceStatus}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">נוסחים בסיסיים שאפשר להתאים</h2>
      <div class="space-y-5">
        {quickTemplates.map(template => (
          <article id={template.id} class="bg-white border border-neutral-border rounded-xl overflow-hidden scroll-mt-24">
            <div class="border-b border-neutral-border bg-gray-50 px-5 py-3">
              <h3 class="font-bold text-gray-900">{template.title}</h3>
            </div>
            <pre class="whitespace-pre-wrap text-sm leading-relaxed text-gray-700 p-5 bg-white overflow-x-auto font-sans">{template.text}</pre>
          </article>
        ))}
      </div>
    </section>

    <section class="mb-12 bg-blue-50 border border-blue-200 rounded-xl p-5">
      <h2 class="text-xl font-bold text-blue-900 mb-3">איך להגיש נכון ולא להיתקע?</h2>
      <ol class="space-y-2 text-sm text-gray-700 list-decimal list-inside">
        <li>בדקו באיזה תיק מדובר ומה מספר התיק המדויק.</li>
        <li>בחרו את הטופס לפי סוג הפעולה: עיקול, צו תשלומים, הגבלה או בדיקת מידע.</li>
        <li>צרפו ראיות, לא רק הסבר: דפי חשבון, תלושים, אישורי קצבאות, החלטות קודמות.</li>
        <li>כתבו בקשה קצרה וברורה: מה קרה, מה אתם מבקשים, ומה מצורף.</li>
        <li>שמרו אישור הגשה ומספר פנייה, ובדקו החלטות באזור האישי.</li>
      </ol>
