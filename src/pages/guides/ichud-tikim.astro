---
import GuideLayout from '../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'מי יכול להגיש בקשה לאיחוד תיקים?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כל חייב שיש נגדו שני תיקים או יותר בהוצאה לפועל, ואין ביכולתו לשלם את כולם בנפרד. אין דרישת סף מינימלי לגובה החוב — מספיק שקיימים לפחות שני תיקים פעילים.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם איחוד תיקים מבטל את החובות?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לא. האיחוד לא מבטל חובות — הוא קובע תשלום חודשי אחד שמחולק בין הנושים. החוב עדיין קיים אבל נוהל בצורה מסודרת עד לסילוקו המלא.',
      },
    },
    {
      '@type': 'Question',
      name: 'כמה זמן נמשך הליך איחוד תיקים?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'הגשת הבקשה ועיבודה אורכת 2-4 שבועות. ההליך עצמו נמשך עד שהחוב מסולק במלואו — תלוי בסכום הכולל ובגובה התשלום החודשי שנקבע.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם איחוד תיקים עוצר עיקולים?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כן. ברגע שהרשם מאשר את הבקשה לאיחוד, כל העיקולים הקיימים מוקפאים ואין אפשרות להטיל עיקולים חדשים, כל עוד החייב עומד בתשלום החודשי שנקבע.',
      },
    },
    {
      '@type': 'Question',
      name: 'כמה מינימום חוב צריך לאחוד?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'אין סף מינימלי לסכום החוב. הדרישה הבסיסית היא קיומם של לפחות שני תיקים פעילים בהוצאה לפועל. עם זאת, ברוב המקרים הרשם יקפיד יותר כשמדובר בסכומים קטנים מאוד — ייתכן שיעדיף לקבוע צו תשלומים רגיל.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם אני לא עומד בתשלום החודשי?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'אם החייב מחמיץ תשלום, כל אחד מהנושים רשאי לבקש ביטול האיחוד. ברגע שהאיחוד מבוטל — כל העיקולים חוזרים לתוקף, כל נושה יכול לפעול בנפרד, ומצב החייב מחמיר. חשוב לפנות לרשם מיד בעת קושי לעמוד בתשלום ולבקש הפחתה.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם ניתן לאחד גם חובות למדינה?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'חובות לרשות המסים, לביטוח לאומי, לרשויות מקומיות ולגופים ממשלתיים אחרים יכולים להיכלל באיחוד תיקים, אך רק אם הם כבר הועברו לגבייה בהוצאה לפועל. חובות שעדיין בשלב הגבייה המנהלית אצל הרשות עצמה אינם ניתנים לאיחוד.',
      },
    },
  ],
};
---

<GuideLayout
  title="איחוד תיקים בהוצאה לפועל — מדריך מלא לחייב עם כמה תיקים"
  description="יש לך כמה תיקים בהוצאה לפועל וכמה עיקולים? איחוד תיקים מאפשר לנהל הכל בתשלום אחד מסודר. למד מי זכאי, איך מגישים, מה קורה לעיקולים, וכמה תשלם בחודש."
  breadcrumb={[{ label: 'מדריכים', href: '/guides/' }, { label: 'איחוד תיקים', href: '/guides/ichud-tikim/' }]}
  publishDate="2025-02-10"
  updateDate="2026-03-31"
  readTime="10 דקות"
  schema={[faqSchema, {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'איך מגישים בקשה לאיחוד תיקים בהוצאה לפועל',
    description: 'שלבים להגשת בקשת איחוד תיקים — תשלום אחד במקום כמה עיקולים',
    totalTime: 'P14D',
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'וודא שיש לפחות 2 תיקים פעילים',
        text: 'איחוד תיקים מותנה בקיומם של לפחות שני תיקי הוצאה לפועל פעילים נגדך. אסוף פרטים על כל התיקים (מספרי תיק, שמות נושים, סכומי חוב).',
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'הכן רשימת הכנסות והוצאות',
        text: 'הכן תמונה מלאה של מצבך הכלכלי: הכנסה חודשית, שכר דירה, הוצאות קבועות. הרשם יקבע תשלום חודשי לפי המידע שתספק.',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'הגש בקשת איחוד תיקים',
        text: 'הגש בקשה לאיחוד תיקים ללשכת ההוצאה לפועל שמנהלת את התיק הגדול ביותר. צרף רשימת כל התיקים, מסמכי הכנסה, ותעודת זהות.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'הגע לדיון',
        text: 'הרשם יקבע דיון שבו יקבע את סכום התשלום החודשי. בוא עם כל מסמכי ההכנסה וההוצאות. ניתן לבקש הפחתה אם יש נסיבות קשות.',
      },
      {
        '@type': 'HowToStep',
        position: 5,
        name: 'שלם בקביעות',
        text: 'ברגע שהאיחוד אושר — כל העיקולים מוקפאים. שלם כל חודש בזמן. החמצת תשלום מבטלת את האיחוד ועיקולים חוזרים.',
      },
    ],
  }]}
>

  <p>
    יש לך שלושה תיקים בהוצאה לפועל, שניים עיקלו לך את החשבון, ואחד עיקל את המשכורת.
    זה נשמע כאוס — ובצדק. כל נושה דורש תשלום, כל לשכה שולחת מכתבים, ואתה לא יודע
    מאיפה להתחיל. איחוד תיקים נועד בדיוק לזה: לקחת את הבלגן הזה ולהפוך אותו
    לתשלום חודשי אחד שאתה יכול לנהל — תחת ניהול ריכוזי של רשם אחד.
  </p>

  <h2>מה זה איחוד תיקים?</h2>
  <p>
    איחוד תיקים (המכונה גם "צו איחוד") הוא הליך מנהלי לפי חוק ההוצאה לפועל, תשכ"ז-1967,
    שבו כל התיקים הפתוחים נגדך מרוכזים תחת ניהול של רשם אחד בלשכה אחת.
    במקום להתמודד עם כל נושה בנפרד — הרשם קובע תשלום חודשי יחיד לפי יכולתך הכלכלית,
    ומחלק אותו בין כל הנושים לפי סדר עדיפויות שנקבע בחוק.
  </p>
  <p>
    חשוב להבין: איחוד תיקים אינו מחיקת חובות. החוב ממשיך להתקיים בשלמותו.
    מה שמשתנה הוא אופן הניהול — מבלגן של מספר תיקים עצמאיים, להליך אחד מסודר
    עם תשלום קבוע ומוגדר.
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">מה קורה ביום שמאשרים איחוד:</p>
    <ul>
      <li>כל העיקולים הפעילים (בנק, משכורת, נכסים) מוקפאים מיידית</li>
      <li>כל התיקים עוברים לניהול רשם אחד בלשכה אחת</li>
      <li>נקבע תשלום חודשי אחד לפי יכולתך הכלכלית</li>
      <li>הנושים מקבלים חלק יחסי מהתשלום — לפי דירוג עדיפויות</li>
      <li>הנושים לא יכולים לנקוט הליכים חדשים נגדך ישירות</li>
    </ul>
  </div>

  <h2>איחוד תיקים, צו תשלומים, או חדלות פירעון — מה מתאים לך?</h2>
  <p>
    לפני שמחליטים על נתיב, חשוב להבין את ההבדל בין שלושת האפשרויות העיקריות.
    הטבלה הבאה מסכמת מתי כל הליך מתאים:
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-100">
          <th class="text-right p-3 border border-gray-200">קריטריון</th>
          <th class="text-right p-3 border border-gray-200">צו תשלומים</th>
          <th class="text-right p-3 border border-gray-200">איחוד תיקים</th>
          <th class="text-right p-3 border border-gray-200">חדלות פירעון</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['מספר תיקים נדרש', 'תיק אחד מספיק', 'לפחות שני תיקים', 'לא רלוונטי'],
          ['מי מנהל', 'רשם הוצאה לפועל', 'רשם הוצאה לפועל', 'בית משפט / רשם חדלות פירעון'],
          ['ביטול חובות', 'לא', 'לא', 'כן — אפשרי הפטר מלא'],
          ['עצירת עיקולים', 'חלקית — לפי שיקול הרשם', 'כן — מיידית באישור', 'כן — מיידית בצו'],
          ['משך הליך', 'עד סילוק החוב', 'עד סילוק החוב', 'כ-4 שנים בממוצע'],
          ['עלות משוערת', 'אגרה בלבד', 'אגרה בלבד', '8,000–25,000 ש"ח'],
          ['השפעה על נכסים', 'מינימלית', 'מינימלית', 'ייתכן מימוש נכסים'],
          ['מתאים כשיש', 'חוב אחד שאפשר לפרוס', 'כמה חובות — הכנסה קיימת', 'חובות שאי-אפשר לשלם לעולם'],
          ['הגשה דרך', 'לשכת הוצאה לפועל', 'לשכת הוצאה לפועל', 'בית משפט מחוזי'],
        ].map(([k, a, b, c], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-medium text-gray-700">{k}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{a}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{b}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{c}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="tip-box">
    <p class="font-semibold mb-1">כלל אצבע פשוט:</p>
    <p>
      אם יש לך הכנסה קבועה אבל אינך מסוגל לשלם לכל הנושים במקביל — <strong>איחוד תיקים</strong> הוא הכלי הנכון.
      אם החובות גדולים כל כך שגם בעוד 20 שנה לא תוכל לסלק אותם — שקול <strong>חדלות פירעון</strong>.
    </p>
  </div>

  <h2>מי זכאי לאיחוד תיקים?</h2>
  <p>
    החוק קובע תנאי סף מינימליים להגשת בקשה לאיחוד תיקים. אם אתה עומד בכולם — הרשם
    מחויב לדון בבקשה, אם כי האישור הסופי תלוי בנסיבות:
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-6 not-prose">
    {[
      { icon: '📂', title: 'לפחות שני תיקים פעילים', desc: 'חייבים להיות קיימים לפחות שני תיקים פתוחים ופעילים בהוצאה לפועל. תיק סגור או מוקפא אינו נספר.' },
      { icon: '💸', title: 'חוסר יכולת לשלם לכולם', desc: 'אינך חייב להיות "חדל פירעון" — מספיק שאין ביכולתך לעמוד בכל הדרישות בו-זמנית.' },
      { icon: '📋', title: 'הצהרת מצב כלכלי', desc: 'תצטרך להגיש פירוט מלא של הכנסות, הוצאות, נכסים וחובות. מסמכים לא מדויקים עלולים לפגוע בבקשה.' },
      { icon: '🏛️', title: 'אין הליכי פשיטת רגל תלויים', desc: 'אם כבר הוגשה בקשה לחדלות פירעון — לא ניתן להגיש במקביל בקשה לאיחוד תיקים.' },
    ].map(item => (
      <div class="border border-neutral-border rounded-xl p-4 bg-white">
        <div class="text-2xl mb-2">{item.icon}</div>
        <h3 class="font-bold text-gray-800 mb-1">{item.title}</h3>
        <p class="text-sm text-gray-600">{item.desc}</p>
      </div>
    ))}
  </div>

  <div class="warn-box">
    <p class="font-semibold mb-1">מי לא יכול להגיש?</p>
    <ul class="mt-1 space-y-1">
      <li>מי שנגדו כבר ניתן צו לפתיחת הליכי חדלות פירעון</li>
      <li>מי שהוגשה נגדו בקשה לפשיטת רגל בטרם בוטלה</li>
      <li>מי שמנהל רק תיק עצמאי אחד (צריך לפחות שניים)</li>
      <li>חייב שביטלו לו איחוד בעבר בשל אי-עמידה בתשלומים — ייתכן שיידרש להמתין תקופה</li>
    </ul>
  </div>

  <h2>איך מגישים בקשה לאיחוד תיקים — שלב אחרי שלב</h2>
  <p>
    ההליך כולו מתנהל בלשכת ההוצאה לפועל הקרובה למקום מגוריך. לא נדרש עורך דין,
    אם כי ייעוץ משפטי תמיד מומלץ לפני הגשה.
  </p>

  <ol class="step-list">
    <li>
      <span class="step-num">1</span>
      <span>
        <strong>אסוף מידע על כל התיקים הפתוחים נגדך</strong> — שם כל נושה, מספר תיק, גובה החוב הנוכחי.
        ניתן לקבל רשימה מעודכנת בלשכה או דרך אתר רשות האכיפה והגבייה (gov.il).
        שמור על כל מכתב שקיבלת — הם מקור מידע חשוב.
      </span>
    </li>
    <li>
      <span class="step-num">2</span>
      <span>
        <strong>מלא טופס בקשה לאיחוד תיקים (טופס 8)</strong> — זהו הטופס הרשמי של רשות האכיפה והגבייה.
        ניתן להוריד מאתר gov.il או לקבל מהלשכה. יש לפרט בו את כל התיקים, סכום כל חוב,
        ופירוט מלא של מצבך הכלכלי.
      </span>
    </li>
    <li>
      <span class="step-num">3</span>
      <span>
        <strong>מלא הצהרת מצב כלכלי (טופס 7)</strong> — הצהרה מפורטת על: הכנסות חודשיות (משכורת, קצבאות, שכר דירה),
        הוצאות קבועות (שכר דירה, ביטוח בריאות, תשלומי חובה), נכסים (דירה, רכב, חסכונות), וחובות נוספים.
        דיוק מלא — הצהרה כוזבת היא עבירה פלילית.
      </span>
    </li>
    <li>
      <span class="step-num">4</span>
      <span>
        <strong>צרף מסמכים תומכים</strong> — שלושה תלושי משכורת אחרונים, דפי בנק של שלושת החודשים האחרונים,
        אישור מגורים, קבלות על הוצאות קבועות (שכר דירה, ביטוח לאומי, תשלומי ילדים),
        ואם רלוונטי — אישורים על קצבאות או הכנסות נוספות.
      </span>
    </li>
    <li>
      <span class="step-num">5</span>
      <span>
        <strong>הגש ללשכת ההוצאה לפועל ושלם אגרה</strong> — ההגשה פיזית בלשכה הרלוונטית למקום מגוריך.
        יש לשלם אגרת הגשה (בדוק את הסכום המעודכן באתר הרשות — עשויה להשתנות).
        קבל אישור הגשה עם מספר תיק מאוחד.
      </span>
    </li>
    <li>
      <span class="step-num">6</span>
      <span>
        <strong>המתן להזמנה לדיון אצל הרשם</strong> — תוך 2-4 שבועות תקבל זימון. הרשם יבחן את מצבך,
        ישאל שאלות על הכנסות והוצאות, ויקבע את גובה התשלום החודשי. בוא מוכן עם כל המסמכים.
      </span>
    </li>
    <li>
      <span class="step-num">7</span>
      <span>
        <strong>קבלת צו האיחוד ותחילת תשלומים</strong> — לאחר הדיון ייתן הרשם את צו האיחוד.
        מהרגע הזה: כל העיקולים מוקפאים, ואתה משלם סכום חודשי קבוע לחשבון הלשכה.
        הלשכה מחלקת את הכספים לנושים.
      </span>
    </li>
  </ol>

  <div class="tip-box">
    <p class="font-semibold mb-1">טיפ: בוא מוכן לדיון</p>
    <p>
      הדיון אצל הרשם הוא הרגע הקריטי — הרשם יקבע שם את התשלום החודשי.
      הכן טבלה ברורה של כל הכנסותיך והוצאותיך. ככל שההצגה מסודרת ומפורטת יותר,
      כך גדל הסיכוי לתשלום חודשי שאתה יכול לעמוד בו.
    </p>
  </div>

  <h2>מה קורה לעיקולים אחרי האיחוד?</h2>
  <p>
    אחד היתרונות המיידיים והמשמעותיים ביותר של איחוד תיקים הוא השפעתו על העיקולים הקיימים.
    כך זה עובד בפועל:
  </p>

