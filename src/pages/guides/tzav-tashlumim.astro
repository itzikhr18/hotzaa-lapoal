      acceptedAnswer: {
        '@type': 'Answer',
        text: 'הגשה עצמית כמעט חינמית — אגרה של כמה עשרות שקלים בלבד. ייצוג עורך דין עולה 3,000-6,000 ש"ח בהתאם למורכבות.',
      },
    },
    {
