---
import GuideLayout from '../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'האם עדיין ניתן לשלול רישיון נהיגה בהוצאה לפועל?',
      acceptedAnswer: { '@type': 'Answer', text: 'לא. מפברואר 2022 הגבלת רישיון נהיגה בוטלה לחלוטין כהליך בהוצאה לפועל. לא ניתן להטיל הגבלה חדשה, וכל הגבלות הרישיון שהיו קיימות בוטלו אוטומטית על פי תיקון 69 לחוק ההוצאה לפועל.' },
    },
    {
      '@type': 'Question',
      name: 'יש לי הגבלה ישנה על הרישיון — האם היא עדיין בתוקף?',
      acceptedAnswer: { '@type': 'Answer', text: 'לא. כל הגבלות הרישיון שהיו קיימות בהוצאה לפועל בוטלו אוטומטית בעקבות תיקון 69 לחוק. אם הגבלה עדיין מופיעה במשרד הרישוי — פנה לרשות האכיפה והגבייה בטופס 214 לתיקון טעות.' },
    },
    {
      '@type': 'Question',
      name: 'מה ניתן לעשות נגד חייב שלא משלם — אם לא רישיון?',
      acceptedAnswer: { '@type': 'Answer', text: 'כלים אחרים נשארו: עיכוב יציאה מהארץ, חשבון בנק מוגבל מיוחד, איסור כרטיסי חיוב ואשראי, איסור ייסוד חברה, ועיקולים על חשבון בנק, משכורת ונכסים.' },
    },
    {
      '@type': 'Question',
      name: 'מתי בוטלה הגבלת הרישיון בדיוק?',
      acceptedAnswer: { '@type': 'Answer', text: 'ב-10 בפברואר 2022, עם כניסת תיקון 69 לחוק ההוצאה לפועל לתוקף. הביטול חל מיידית — גם על הגבלות קיימות, ללא צורך בהגשת בקשה.' },
    },
    {
      '@type': 'Question',
      name: 'האם ניתן לבקש שיחדשו לי רישיון שנשלל בגלל חוב?',
      acceptedAnswer: { '@type': 'Answer', text: 'כן. אם הרישיון לא חודש בגלל הגבלת הוצאה לפועל — פנה למשרד הרישוי עם אישור מרשות האכיפה שההגבלה בוטלה. אם ישנה טעות במערכת — ניתן לתקן דרך טופס 214.' },
    },
    {
      '@type': 'Question',
      name: 'האם ביטול רישיון בגלל עבירות תנועה שונה מהגבלת הוצאה לפועל?',
      acceptedAnswer: { '@type': 'Answer', text: 'כן, לחלוטין. תיקון 69 ביטל רק את ההגבלה הנובעת מחוב כספי בהוצאה לפועל. שלילת רישיון בגין עבירות תנועה (שתיית אלכוהול, עבירות קצב, תאונות) ממשיכה כרגיל ואינה קשורה לחוב.' },
    },
    {
      '@type': 'Question',
      name: 'אם אין הגבלת רישיון — למה חייבים בכלל לשלם?',
      acceptedAnswer: { '@type': 'Answer', text: 'כי יש הרבה כלים אחרים: עיקול חשבון בנק, עיקול משכורת, עיכוב יציאה מהארץ, וחשבון מוגבל. אי תשלום גם מעלה את סכום החוב עם ריבית פיגורים גבוהה ועלויות הוצאה לפועל.' },
    },
    {
      '@type': 'Question',
      name: 'האם ניתן לנהוג בזמן שיש חוב בהוצאה לפועל?',
      acceptedAnswer: { '@type': 'Answer', text: 'כן, כל עוד הרישיון תקף מבחינת עבירות תנועה ובריאות. מאז תיקון 69 (פברואר 2022), חוב בהוצאה לפועל אינו מונע חידוש רישיון נהיגה.' },
    },
  ],
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'מה לעשות אם הגבלת רישיון ישנה עדיין מופיעה',
  description: 'צעדים לתיקון הגבלת רישיון ישנה שנותרה במערכת בטעות',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'בקש אישור ביטול', text: 'פנה לרשות האכיפה והגבייה ובקש אישור כתוב שהגבלת הרישיון בוטלה (הצג תעודת זהות ומספר תיק).' },
    { '@type': 'HowToStep', position: 2, name: 'מלא טופס 214', text: 'מלא טופס 214 — "בקשה לתיקון טעות" — ושלח לרשות האכיפה עם האישור.' },
    { '@type': 'HowToStep', position: 3, name: 'פנה למשרד הרישוי', text: 'לאחר שרשות האכיפה אישרה את התיקון, פנה למשרד הרישוי עם האישור לחידוש הרישיון.' },
    { '@type': 'HowToStep', position: 4, name: 'שמור תיעוד', text: 'שמור עותק מכל המסמכים לכל מקרה של טעות עתידית.' },
  ],
};
---

<GuideLayout
  title="הגבלת רישיון נהיגה בהוצאה לפועל — בוטלה! מה שחשוב לדעת (2026)"
  description="שמעת שהוצאה לפועל יכולה לשלול רישיון נהיגה? זה כבר לא נכון. מפברואר 2022 הגבלה זו בוטלה לחלוטין לפי תיקון 69. הנה כל מה שצריך לדעת."
  breadcrumb={[{ label: 'מדריכים', href: '/guides/' }, { label: 'רישיון נהיגה', href: '/guides/rishayon-nehiga/' }]}
  publishDate="2026-02-05"
  updateDate="2026-04-24"
  readTime="6 דקות"
  schema={[faqSchema, howToSchema]}
>

  <div class="not-prose bg-green-50 border-2 border-green-300 rounded-2xl p-6 mb-8">
    <div class="flex items-start gap-3">
      <span class="text-3xl">🎉</span>
      <div>
        <p class="font-bold text-green-800 text-lg mb-1">חדשות טובות — הגבלת רישיון בוטלה</p>
        <p class="text-green-700 text-sm leading-relaxed">
          מ-10 בפברואר 2022, לפי <strong>תיקון 69 לחוק ההוצאה לפועל</strong>, <strong>לא ניתן עוד להגביל רישיון נהיגה
          של חייב</strong>. כל ההגבלות הקיימות בוטלו אוטומטית — ללא צורך בשום בקשה.
        </p>
      </div>
    </div>
  </div>

  <p>
    שנים רבות, הגבלת רישיון נהיגה הייתה אחד מכלי הלחץ העיקריים של ההוצאה לפועל.
    חייבים שלא שילמו מצאו את עצמם לא יכולים לחדש את רישיון הנהיגה — מה שפגע
    קשות ביכולתם להגיע לעבודה ולהתפרנס.
  </p>
  <p>
    ב-10 בפברואר 2022 שינה המחוקק הישראלי את הכללים: הגבלת רישיון נהיגה הוסרה
    לחלוטין מארגז הכלים של ההוצאה לפועל.
  </p>

  <h2>מה זה תיקון 69 ולמה הוא חשוב?</h2>
  <p>
    תיקון 69 לחוק ההוצאה לפועל (תשכ"ז-1967) עבר בכנסת ונכנס לתוקף ב-10 בפברואר 2022.
    המהלך היה חלק מרפורמה רחבה יותר לשיפור המצב של חייבים שאינם מסוגלים לעמוד בתשלומים.
  </p>
  <p>
    לפני התיקון, רשם ההוצאה לפועל היה יכול להורות על הגבלת רישיון נהיגה של חייב שלא
    שילם את חובותיו. ההגבלה מנעה מהחייב לחדש את הרישיון עד לפירעון החוב.
  </p>

  <div class="info-box">
    <strong>תיקון 69 ביטל:</strong> את סעיף 66ב לחוק ההוצאה לפועל, שאפשר הגבלת רישיון נהיגה.
    הביטול הוא מוחלט — אין עוד אפשרות להגביל רישיון, גם לא בנסיבות חריגות.
  </div>

  <h2>למה בוטלה ההגבלה?</h2>
  <p>
    הכנסת הגיעה למסקנה שהגבלת רישיון נהיגה <strong>מחטיאה את המטרה</strong> ופוגעת
    דווקא ביכולת החייב לפרוע את חובותיו:
  </p>
  <ul>
    <li><strong>מונעת הכנסה:</strong> חייב שלא יכול להגיע לעבודה — לא יכול להרוויח ולשלם</li>
    <li><strong>פגיעה בפריפריה:</strong> בערים ובישובים ללא תחבורה ציבורית מספקת, הרישיון הוא קיומי</li>
    <li><strong>פגיעה בבני משפחה:</strong> ילדים, קשישים ואנשים תלויים שזקוקים לרכב</li>
    <li><strong>חוסר מידתיות:</strong> בתי המשפט קיבלו עשרות עתירות נגד ההגבלה בשנים האחרונות</li>
    <li><strong>לא אפקטיבית:</strong> מחקרים הראו שההגבלה לא האיצה גבייה אלא רק העמיקה את המצוקה</li>
  </ul>

  <h2>מה קורה לחובות שהיו עם הגבלת רישיון?</h2>
  <p>
    החוב עצמו לא נמחק. תיקון 69 ביטל רק את <em>מנגנון הלחץ</em> של הגבלת הרישיון.
    אם היה לך חוב בהוצאה לפועל עם הגבלת רישיון — החוב עדיין קיים, אבל ההגבלה על הרישיון בוטלה.
  </p>

  <div class="warn-box">
    <strong>חשוב לדעת:</strong> ביטול הגבלת הרישיון לא ביטל הגבלות אחרות — כגון עיכוב יציאה מהארץ, חשבון בנק מוגבל, או עיקולים.
    החוב ממשיך לצבור ריבית ועלויות גבייה.
  </div>

  <h2>אילו הגבלות עדיין קיימות?</h2>
  <p>
    גם לאחר ביטול הגבלת הרישיון, רשות האכיפה והגבייה יכולה להשתמש בכלים אחרים:
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">הגבלה</th>
          <th class="text-right p-3 border border-gray-200">סטאטוס</th>
          <th class="text-right p-3 border border-gray-200">פירוט</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['הגבלת רישיון נהיגה', '🟢 בוטלה', 'בוטלה לחלוטין מפברואר 2022 (תיקון 69)'],
          ['עיכוב יציאה מהארץ', '🔴 קיים', 'מנועים ממעבר גבול — ניתן לבקש ביטול'],
          ['חשבון בנק מוגבל מיוחד', '🔴 קיים', 'מגביל פעולות בנקאיות'],
          ['איסור כרטיסי חיוב ואשראי', '🔴 קיים', 'לא ניתן לקבל כרטיסים חדשים'],
          ['איסור ייסוד חברה / שותפות', '🔴 קיים', 'לא ניתן לרשום ישות עסקית'],
          ['עיקול חשבון בנק', '🔴 קיים', 'ניתן לעקל עד לגובה החוב'],
          ['עיקול משכורת', '🔴 קיים', 'עד שליש (1/3) מהמשכורת'],
          ['עיקול נכסים (רכב, דירה)', '🔴 קיים', 'בכפוף למגבלות ולהגנות מפורשות'],
        ].map(([restriction, status, details], i) => (
          <tr class={i === 0 ? 'bg-green-50 font-semibold' : i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200">{restriction}</td>
            <td class="p-3 border border-gray-200 text-sm">{status}</td>
            <td class="p-3 border border-gray-200 text-gray-600">{details}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>מה לעשות אם הגבלה ישנה עדיין מופיעה על הרישיון?</h2>
  <p>
    כל הגבלות הרישיון שהיו קיימות <strong>בוטלו אוטומטית</strong> עם כניסת החוק לתוקף.
    לא היה צריך להגיש בקשה — זה קרה בלי שתצטרך לעשות כלום.
  </p>
  <p>
    אם מסיבה כלשהי הגבלה עדיין מופיעה במשרד הרישוי — זו <strong>טעות בירוקרטית</strong>,
    לא הגבלה חוקית. כך תתקן אותה:
  </p>

  <ol class="step-list">
    <li>
      <span class="step-num">1</span>
      <div>
        <strong>בקש אישור ביטול מרשות האכיפה</strong>
        <p>פנה לרשות האכיפה והגבייה (בלשכה הקרובה אליך או בטלפון 073-3900900) ובקש אישור כתוב שהגבלת הרישיון בוטלה. הצג תעודת זהות ומספר תיק הוצאה לפועל.</p>
      </div>
    </li>
    <li>
      <span class="step-num">2</span>
      <div>
        <strong>מלא טופס 214</strong>
        <p>אם יש טעות בגין ההגבלה, מלא טופס 214 — "בקשה לתיקון טעות" — ושלח לרשות האכיפה. ניתן להוריד מאתר רשות האכיפה.</p>
      </div>
    </li>
    <li>
      <span class="step-num">3</span>
      <div>
        <strong>פנה למשרד הרישוי</strong>
        <p>לאחר שרשות האכיפה אישרה את התיקון, פנה למשרד הרישוי עם האישור לחידוש הרישיון. הרישיון יחודש ללא תשלום בגין ההגבלה הישנה.</p>
      </div>
    </li>
    <li>
      <span class="step-num">4</span>
      <div>
        <strong>שמור תיעוד</strong>
        <p>שמור עותק מכל המסמכים. במידה ותצוץ בעיה עתידית, התיעוד יועיל.</p>
      </div>
    </li>
  </ol>

  <h2>הגבלת רישיון לעומת שלילה בשל עבירות תנועה</h2>
  <p>
    חשוב להבדיל בין שני סוגי ביטולי רישיון שונים לחלוטין:
  </p>
  <ul>
    <li>
      <strong>הגבלה מהוצאה לפועל (בוטלה):</strong> נבעה מחוב כספי, ובוטלה לחלוטין בתיקון 69.
      אין לה שום קשר לכישורי הנהיגה.
    </li>
    <li>
      <strong>שלילה בגין עבירות תנועה (עדיין קיימת):</strong> בית משפט לתעבורה יכול לשלול רישיון
      בשל עבירות כגון נהיגה בשכרות, תאונות, עבירות קצב חמורות. זה הליך שיפוטי נפרד לחלוטין.
    </li>
  </ul>

  <div class="tip-box">
    <strong>שים לב:</strong> אם יש לך גם חוב בהוצאה לפועל וגם שלילת רישיון בגין עבירת תנועה —
    תיקון 69 עוזר לך רק בנוגע לחוב. שלילת הרישיון בגין עבירת תנועה תמשיך כרגיל.
  </div>

  <h2>מה עדיין ניתן לעשות אם יש חוב?</h2>
  <p>
    ביטול הגבלת הרישיון לא אומר שאפשר להתעלם מחובות. הכלים שנותרו פעילים:
  </p>
  <ul>
    <li><a href="/guides/ikul-heshbon/">עיקול חשבון בנק</a> — פעיל, עד לגובה החוב</li>
    <li><a href="/guides/ikul-maskoret/">עיקול משכורת</a> — עד שליש (1/3) מהמשכורת</li>
    <li><a href="/guides/ikul-yetzia/">עיכוב יציאה מהארץ</a> — עדיין מטיל מגבלת נסיעה לחו"ל</li>
    <li><a href="/guides/ikul-dira/">עיקול דירה ונכסים</a> — בכפוף להגנת בית המגורים</li>
    <li><a href="/guides/hayav-mugbal/">חשבון מוגבל מיוחד</a> — מגביל פעולות בנקאיות</li>
  </ul>
  <p>
    בנוסף, החוב ממשיך לגדול עם <a href="/guides/ribit-hotzaa/">ריבית פיגורים</a> ועלויות גבייה.
    לכן מומלץ לפעול להסדרת החוב גם בלי לחץ של הגבלת רישיון.
  </p>

  <h2>אפשרויות לסגירת החוב</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-6 not-prose">
    <div class="bg-white border border-neutral-border rounded-xl p-4">
      <p class="font-bold text-gray-800 mb-2">⚡ מהיר: הסדר עם הנושה</p>
      <p class="text-sm text-gray-600">פנייה ישירה לנושה להסדר — לעיתים ניתן למחוק חלק מהחוב בתמורה לסגירה מיידית.</p>
      <a href="/guides/hisdurim-chov/" class="text-brand text-sm hover:underline mt-2 block">← מדריך הסדר חוב</a>
    </div>
    <div class="bg-white border border-neutral-border rounded-xl p-4">
      <p class="font-bold text-gray-800 mb-2">📋 צו תשלומים</p>
      <p class="text-sm text-gray-600">הגשת בקשה לצו תשלומים — עוצר הגבלות חדשות ומאפשר לשלם בתשלומים חודשיים.</p>
      <a href="/guides/tzav-tashlumim/" class="text-brand text-sm hover:underline mt-2 block">← מדריך צו תשלומים</a>
    </div>
    <div class="bg-white border border-neutral-border rounded-xl p-4">
