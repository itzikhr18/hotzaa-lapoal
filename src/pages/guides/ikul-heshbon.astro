  mainEntity: [
    {
      '@type': 'Question',
      name: 'כמה זמן לוקח לבטל עיקול חשבון בנק?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'בדרך כלל 5-14 ימי עסקים ממועד הגשת הבקשה לרשם ההוצאה לפועל. אם יש דחיפות — ניתן לבקש עיכוב ביצוע מיידי.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר לבטל עיקול גם אם החוב אמיתי?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כן. גם אם אתה חייב את הכסף, אתה יכול לבקש הסדרת תשלומים (צו תשלומים) שיפיג את העיקול. אתה לא חייב לשלם הכל בבת אחת.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם כל הכסף בחשבון יכול להיות מעוקל?',
      acceptedAnswer: {
        '@type': 'Answer',
