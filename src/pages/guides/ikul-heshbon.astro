---
import GuideLayout from '../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'כמה זמן לוקח לבטל עיקול חשבון בנק?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'בדרך כלל 5-14 ימי עסקים ממועד הגשת הבקשה לרשם ההוצאה לפועל. לאחר אישור הרשם, הוא חייב להודיע לבנק תוך 24 שעות. אם יש דחיפות — ניתן לבקש עיכוב ביצוע מיידי, במיוחד בתוך חלון ה-24 שעות הראשון לאחר הטלת העיקול.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר לבטל עיקול גם אם החוב אמיתי?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כן. גם אם אתה חייב את הכסף, אתה יכול לבקש הסדרת תשלומים (צו תשלומים) שיפיג את העיקול. אתה לא חייב לשלם הכל בבת אחת. ברגע שרשם ההוצאה לפועל מאשר צו תשלומים ואתה עומד בו, ניתן לבקש הקפאה או ביטול של העיקול.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם כל הכסף בחשבון יכול להיות מעוקל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לא. קצבאות ביטוח לאומי (ילדים, נכות, זקנה, שאירים), גמלת סיעוד, מזונות שנפסקו בבית משפט, חלק מפיצויי פיטורין, ושכר מינימום (6,247.67 ₪ לחודש נכון לאפריל 2025) — כל אלו מוגנים בחוק ואינם ניתנים לעיקול. בנוסף, סכום בסיס קיום של 5,000 ₪ מוגן תמיד.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה ההבדל בין עיקול חשבון משותף לעיקול חשבון פרטי?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'בחשבון משותף, העיקול חל רק על חלקו של החייב — בדרך כלל מחצית מהיתרה אלא אם הוכח אחרת. השותף בחשבון יכול לפנות לרשם ולהוכיח שחלק מהכסף שייך לו בלבד, ולבקש שחרור אותו חלק. בחשבון פרטי — כל היתרה חשופה לעיקול, למעט הסכומים המוגנים בחוק.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם חשבון הבנק ריק בעת העיקול?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'אם בעת הטלת העיקול אין כסף בחשבון, הבנק מדווח לרשות האכיפה שאין יתרה לעיקל. הצו נשאר "רדום" על החשבון — כל סכום שיופקד בעתיד ייעצר אוטומטית עד לגובה החוב. הנושה יכול להחזיק צו עיקול פעיל למשך שנים.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם הבנק מתעלם מצו העיקול?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'אם הבנק קיבל צו עיקול ולא ציית לו — הוא חשוף לאחריות אישית כ"מחזיק" לפי חוק ההוצאה לפועל. רשם ההוצאה לפועל יכול להורות לבנק לשלם את סכום החוב מכספיו שלו. בפועל בנקים ממלאים תמיד אחר צווי עיקול — אי-ציות הוא נדיר ביותר.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה ההבדל בין "עיכוב הליכים" לבין "ביטול עיקול"?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'עיכוב הליכים (stay of proceedings) עוצר זמנית את כל ההליכים — כולל העיקול — בדרך כלל ל-20 יום, כדי לאפשר לך להגיש בקשות. ביטול עיקול הוא הסרה מלאה של צו העיקול. עיכוב הליכים הוא בדרך כלל הצעד הראשון והמהיר ביותר לעצור את מימוש הכספים.',
      },
    },
  ],
};
