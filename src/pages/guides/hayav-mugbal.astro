        </tr>
      </thead>
      <tbody>
        {[
          ['חובות מזונות', 'הגנה על ילדים ובן/בת זוג גוברת על כל שיקול אחר'],
          ['חובות לרשות המסים', 'גבייה מנהלית לפי חוק מיוחד, אינה כפופה לרשם הוצאה לפועל'],
          ['חובות לביטוח לאומי', 'אותה סיבה — גבייה מנהלית עצמאית'],
          ['עיקולים על נכסי מקרקעין', 'ממשיכים כרגיל, אין עיכוב אוטומטי'],
