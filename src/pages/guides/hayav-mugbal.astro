---
import GuideLayout from '../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'מה זה חייב מוגבל באמצעים?',
      acceptedAnswer: { '@type': 'Answer', text: 'חייב מוגבל באמצעים הוא מעמד לפי חוק ההוצאה לפועל שהוכרז לחייבים שרשם ההוצאה לפועל קבע כי אינם יכולים לפרוע את חובם בפרקי הזמן שקבע החוק: שנתיים (חוב עד 20,000 ש"ח), 3 שנים (20,000–100,000 ש"ח) או 4 שנים (מעל 100,000 ש"ח). מאז 15.9.2019 לא מכריזים על חייבים מוגבלים חדשים — המסלול הוחלף בהליכי חדלות פירעון ושיקום כלכלי.' },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר היום להגיש בקשה להכרזה כחייב מוגבל באמצעים?',
      acceptedAnswer: { '@type': 'Answer', text: 'לא. מאז כניסת חוק חדלות פירעון ושיקום כלכלי לתוקף (15.9.2019) לא ניתן עוד להכריז על חייבים מוגבלים באמצעים חדשים. מי שאין ביכולתו לפרוע את חובותיו יכול כיום לפנות להליכי חדלות פירעון, לבקש צו תשלומים, או לבקש איחוד תיקים. מי שהוכרז לפני 2019 — נשאר במעמד כל עוד לא בוטל.' },
    },
    {
      '@type': 'Question',
      name: 'אילו הגבלות חלות על חייב מוגבל באמצעים?',
      acceptedAnswer: { '@type': 'Answer', text: 'על חייב מוגבל באמצעים חלות בדרך כלל: עיכוב יציאה מהארץ (ללא הגבלת זמן), הגבלה כלקוח מוגבל מיוחד בבנק (הגבלת שיקים), הגבלת שימוש בכרטיסי אשראי, והגבלה על ייסוד תאגיד. במקביל, החייב משלם צו תשלומים שנקבע לפי יכולתו, וכל התיקים מאוחדים.' },
    },
    {
      '@type': 'Question',
      name: 'מה חובות הדיווח של חייב מוגבל באמצעים?',
      acceptedAnswer: { '@type': 'Answer', text: 'חייב מוגבל באמצעים (כמו כל חייב בצו תשלומים) חייב להודיע לרשם ההוצאה לפועל בכתב, בהקדם האפשרי בנסיבות העניין, על כל שינוי ביכולת הפירעון שלו — לטובה או לרעה. הסתרת מידע או נכסים עלולה להוביל לביטול המעמד ואף להליכים בגין הפרת החוק.' },
    },
    {
      '@type': 'Question',
      name: 'מה עדיף היום — חדלות פירעון, צו תשלומים או איחוד תיקים?',
      acceptedAnswer: { '@type': 'Answer', text: 'תלוי במצב: חדלות פירעון מתאימה למי שאין סיכוי ממשי שיפרע את חובותיו (מעל 58,794 ש"ח נכון ל-2026) — ההליך מסתיים בהפטר ומחיקת רוב החובות. צו תשלומים מתאים למי שיכול לפרוע בתשלומים חודשיים. איחוד תיקים מתאים למי שיש נגדו כמה תיקים ורוצה לנהל אותם בתשלום חודשי אחד.' },
    },
    {
      '@type': 'Question',
      name: 'האם חייב מוגבל באמצעים יכול לעבור להליך חדלות פירעון?',
      acceptedAnswer: { '@type': 'Answer', text: 'כן. חייב שהוכרז מוגבל באמצעים לפני 2019 יכול לפתוח הליך חדלות פירעון ושיקום כלכלי — ולרוב זה משתלם, כי הליך חדלות פירעון מסתיים בהפטר (מחיקת חובות), בעוד מעמד מוגבל באמצעים יכול להימשך שנים ארוכות ללא מחיקה. מומלץ להתייעץ עם עורך דין או עם הלשכה לסיוע משפטי.' },
    },
  ],
};
---

<GuideLayout
  title="חייב מוגבל באמצעים — מה זה, מה ההגבלות, ומה עושים היום (2026)"
  description="מעמד 'חייב מוגבל באמצעים' סגור לחייבים חדשים מאז 2019 — הוחלף בהליכי חדלות פירעון. מה משמעות המעמד למי שהוכרז בעבר, אילו הגבלות חלות, ומה החלופות היום."
  breadcrumb={[{ label: 'מדריכים', href: '/guides/' }, { label: 'חייב מוגבל', href: '/guides/hayav-mugbal/' }]}
  publishDate="2026-01-20"
  updateDate="2026-07-07"
  readTime="7 דקות"
  schema={[faqSchema]}
>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">עדכון חשוב — המסלול סגור לחייבים חדשים</p>
    <p>
      מאז כניסת חוק חדלות פירעון ושיקום כלכלי לתוקף (<strong>15.9.2019</strong>),
      <strong>לא ניתן עוד להכריז על חייבים מוגבלים באמצעים חדשים</strong>.
      המסלול הוחלף בהליכי חדלות פירעון. מי שהוכרז לפני כן — נשאר במעמד כל עוד
      לא בוטל, וכל האמור בהמשך רלוונטי עבורו. אם אתה מחפש פתרון לחובות היום —
      דלג ל<a href="#alternatives" class="underline font-semibold">חלופות הקיימות</a>.
    </p>
  </div>

  <h2>מה זה "חייב מוגבל באמצעים"?</h2>
  <p>
    בניגוד למה שהרבה אנשים חושבים — מוגבל באמצעים <strong>אינו</strong> הכרזה
    שמישהו "בעל יכולת המשתמט מתשלום". זה בדיוק ההיפך. הכרזה על "חייב מוגבל
    באמצעים" פירושה שהרשם <em>הכיר</em> בכך שלחייב אין יכולת אמיתית לפרוע את
    חובותיו בפרקי הזמן שקבע החוק.
  </p>
  <p>
    לפי סעיף 69ג לחוק ההוצאה לפועל, חייב הוכרז מוגבל באמצעים אם לא יכול היה
    לפרוע את חובו בתוך:
  </p>
  <ul>
    <li><strong>שנתיים</strong> — כשהחוב עד 20,000 ש"ח</li>
    <li><strong>3 שנים</strong> — כשהחוב בין 20,000 ל-100,000 ש"ח</li>
    <li><strong>4 שנים</strong> — כשהחוב מעל 100,000 ש"ח</li>
  </ul>
  <p>
    עם ההכרזה נקבע לחייב צו תשלומים לפי יכולתו, תיקיו אוחדו, והוטלו עליו
    הגבלות (ראו בהמשך). המעמד יכול היה להימשך שנים — בלי מחיקת חובות בסופו.
  </p>

  <h2>מי שהוכרז לפני 2019 — מה חל עליו היום</h2>

  <h3>ההגבלות שחלות על חייב מוגבל באמצעים</h3>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">הגבלה</th>
          <th class="text-right p-3 border border-gray-200">פירוט</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['עיכוב יציאה מהארץ', 'מוטל ללא הגבלת זמן (בשונה מצו רגיל שתוקפו שנה). ניתן לבקש היתר יציאה נקודתי בנסיבות מיוחדות, לרוב בצירוף ערובה'],
          ['לקוח מוגבל מיוחד בבנק', 'הגבלת שיקים לפי חוק שיקים ללא כיסוי'],
          ['הגבלת כרטיסי אשראי', 'לא ניתן להחזיק או לקבל כרטיסי אשראי חדשים (למעט כרטיס דביט/חיוב מיידי)'],
          ['הגבלה על ייסוד תאגיד', 'אסור לייסד חברה או להיות בעל עניין בתאגיד ללא אישור הרשם'],
          ['הגבלת רישיון נהיגה', 'בוטלה לחלוטין בתיקון 69 (פברואר 2022) — לא חלה על אף חייב'],
        ].map(([restriction, details], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-semibold text-gray-800">{restriction}</td>
            <td class="p-3 border border-gray-200 text-gray-700">{details}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h3>חובות החייב במעמד</h3>
  <ul>
    <li><strong>עמידה בצו התשלומים</strong> — תשלום חודשי קבוע שנקבע לפי היכולת. אי-תשלום רצוף עלול להוביל לביטול המעמד וחידוש הליכי הגבייה.</li>
    <li><strong>דיווח על שינוי ביכולת</strong> — חובה להודיע לרשם בכתב, בהקדם האפשרי בנסיבות העניין, על כל שינוי ביכולת הפירעון — לטובה או לרעה (עבודה חדשה, ירושה, פיטורין, מחלה).</li>
    <li><strong>גילוי מלא</strong> — הסתרת נכסים או הכנסות עלולה להוביל לביטול המעמד ולהליכים בגין הפרת החוק.</li>
    <li><strong>התייצבות לדיונים</strong> — אם הרשם מזמן לחקירת יכולת או לדיון, חובה להופיע.</li>
  </ul>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">לא יכול לעמוד בתשלום החודשי?</p>
    <p>
      אם יכולתך ירדה וצו התשלומים כבד מדי — הגש בקשה לשינוי הצו <strong>מיד</strong>,
      לפני שאתה מפסיק לשלם. הרשם מעדיף להתאים את הצו למציאות מאשר לבטל את המעמד.
    </p>
  </div>

  <h3>שווה לשקול: מעבר להליך חדלות פירעון</h3>
  <p>
    חייב מוגבל באמצעים יכול להימצא במעמד <strong>שנים ארוכות בלי שהחוב נמחק</strong> —
    הריבית ממשיכה להיצבר, וההגבלות נשארות. הליך חדלות פירעון ושיקום כלכלי, לעומת זאת,
    מסתיים בדרך כלל תוך כ-4 שנים <strong>בהפטר</strong> — מחיקת רוב החובות. לכן,
    לרוב החייבים המוגבלים באמצעים כדאי לבחון מעבר להליך חדלות פירעון.
    <a href="/insolvency/eligibility/">בדוק זכאות לחדלות פירעון ←</a>
  </p>

  <h2 id="alternatives">אין לך יכולת לשלם חובות היום? אלו החלופות</h2>
  <p>
    מי שמתמודד היום עם חובות שאין ביכולתו לפרוע — אלו שלושת המסלולים הקיימים:
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-dark text-white">
          <th class="text-right p-3 border border-gray-200">קריטריון</th>
          <th class="text-right p-3 border border-gray-200">צו תשלומים</th>
          <th class="text-right p-3 border border-gray-200">איחוד תיקים</th>
          <th class="text-right p-3 border border-gray-200">חדלות פירעון</th>
        </tr>
      </thead>
      <tbody>
        {[
          ['למי מתאים?', 'יכול לפרוע בתשלומים חודשיים', 'כמה תיקים במקביל — תשלום אחד', 'אין סיכוי ממשי לפרוע את החוב'],
          ['סף חוב', 'ללא סף', 'ללא סף', 'מעל 58,794 ש"ח (2026); במקרים מיוחדים גם פחות'],
          ['גוף מטפל', 'רשם ההוצאה לפועל', 'רשם ההוצאה לפועל', 'רשם ההוצל"פ (עד 176,923 ש"ח) או הממונה + בית משפט השלום'],
          ['מחיקת חובות בסוף?', 'לא', 'לא', 'כן — הפטר (בתנאים)'],
          ['משך טיפוסי', 'עד סילוק החוב', 'שנים — עד סילוק החוב', 'כ-4 שנים (שנת ביניים + 3 שנות תוכנית)'],
          ['הגנה מהליכי גבייה', 'עמידה בצו עוצרת הליכים חדשים', 'חלקית', 'מלאה — עיכוב הליכים עם צו פתיחה'],
        ].map(([criterion, tzav, unified, insolvency], i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="p-3 border border-gray-200 font-semibold text-gray-800">{criterion}</td>
            <td class="p-3 border border-gray-200 text-gray-700">{tzav}</td>
            <td class="p-3 border border-gray-200 text-gray-700">{unified}</td>
            <td class="p-3 border border-gray-200 text-gray-700">{insolvency}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="tip-box">
    <p class="font-semibold mb-1">לא בטוח מה מתאים לך?</p>
    <p>
      השתמש ב<a href="/tools/eligibility/">בדיקת המצב המהירה</a> שלנו — 4 שאלות
      שמכוונות אותך למסלול המתאים, או קרא את המדריכים המלאים:
      <a href="/guides/tzav-tashlumim/">צו תשלומים</a>,
      <a href="/guides/ichud-tikim/">איחוד תיקים</a>,
      <a href="/guides/pshitat-regel/">חדלות פירעון</a>.
    </p>
  </div>

  <h2>שאלות נפוצות</h2>
