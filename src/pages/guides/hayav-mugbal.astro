---
import GuideLayout from '../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'מה זה חייב מוגבל באמצעים?',
      acceptedAnswer: { '@type': 'Answer', text: 'חייב מוגבל באמצעים הוא חייב שחובותיו נמוכים מסף מסוים (בדרך כלל עד 150,000 ש"ח) ורשם ההוצאה לפועל קבע שאין לו יכולת לפרוע את חובותיו. הסטטוס מעניק הגנות מיוחדות — כמו עיכוב חלק מהגבלות — ומחייב מסלול מיוחד של טיפול בתיק.' },
    },
    {
      '@type': 'Question',
      name: 'מה ההבדל בין חייב מוגבל באמצעים לאיחוד תיקים?',
      acceptedAnswer: { '@type': 'Answer', text: 'חייב מוגבל באמצעים הוא סטטוס שמוגש לרשם ההוצאה לפועל, מיועד לחובות נמוכים יחסית (עד 150,000 ש"ח), וכולל הגנות ספציפיות. איחוד תיקים מאגד מספר תיקים תחת רשם אחד, ומתאים גם לסכומים גבוהים יותר. חדלות פירעון (פשיטת רגל) מיועדת לחובות גבוהים מאוד ומאפשרת מחיקת חובות בסוף ההליך.' },
    },
    {
      '@type': 'Question',
      name: 'כמה זמן תקף הסטטוס של חייב מוגבל באמצעים?',
      acceptedAnswer: { '@type': 'Answer', text: 'הסטטוס ניתן לתקופה של 18 חודשים לכתחילה, ומחייב חידוש בתום התקופה. החייב חייב להגיש בקשת חידוש עם מסמכים מעודכנים לפני פקיעת הסטטוס. אי-חידוש בזמן עלול להוביל לחידוש הליכי גבייה מלאים.' },
    },
    {
      '@type': 'Question',
      name: 'אילו עיקולים נעצרים כשמקבלים סטטוס חייב מוגבל?',
      acceptedAnswer: { '@type': 'Answer', text: 'עם קבלת הסטטוס נעצרים: עיקול משכורת מעבר לסכום המוגן, עיכוב יציאה מהארץ (ניתן לבקש ביטולו), הגבלות חשבון בנק מסוימות. ממשיכים: עיקולים על נכסים, חובות מזונות וחובות לרשויות מס — אלה אינם מושהים.' },
    },
    {
      '@type': 'Question',
      name: 'האם ניתן לצאת לחו"ל עם סטטוס חייב מוגבל באמצעים?',
      acceptedAnswer: { '@type': 'Answer', text: 'עם קבלת הסטטוס לא מוטלת אוטומטית הגבלת יציאה. אם קיימת הגבלת יציאה מתיקים קודמים, ניתן לבקש את הסרתה בנפרד. הרשם רשאי לאשר יציאה זמנית לצורך עבודה, טיפול רפואי או מצב חירום, לעיתים בצירוף ערובה.' },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם לא מדווח על שינוי בהכנסה?',
      acceptedAnswer: { '@type': 'Answer', text: 'אי-דיווח על שינוי בהכנסה בתוך 14 יום מהשינוי הוא הפרת תנאי הסטטוס. הרשם רשאי לבטל את הסטטוס, לחדש את כל הליכי הגבייה, ואף להטיל הגבלות נוספות. במקרים חמורים ניתן להגיש תלונה פלילית על הסתרת נכסים.' },
    },
    {
      '@type': 'Question',
      name: 'איך מאבדים את הסטטוס ומה ניתן לעשות?',
      acceptedAnswer: { '@type': 'Answer', text: 'הסטטוס עלול להתבטל אם החייב לא עומד בתשלומים שנקבעו, לא מדווח על שינויים, הכנסתו עלתה מעל הסף, הוכח שהסתיר נכסים, או לא מגיע לדיונים. לאחר הביטול ניתן לערער לרשם, להגיש בקשה חוזרת עם נימוקים חדשים, או לבחון מעבר להליך איחוד תיקים.' },
    },
  ],
};
