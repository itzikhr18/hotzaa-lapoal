---
import GuideLayout from '../../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'האם ניתן למחוק חוב מזונות בהליך חדלות פירעון?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לא. חוב מזונות אינו בר-מחיקה בהליך חדלות פירעון (פשיטת רגל). גם לאחר קבלת "הפטר" מכלל החובות, חוב המזונות נשאר בתוקפו המלא. זהו אחד החובות היחידים שמוחרגים במפורש מהפטר על-פי חוק חדלות פירעון ושיקום כלכלי, תשע"ח-2018.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה קורה כשאב לא משלם מזונות? מתי מתערב ביטוח לאומי?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כאשר האב לא משלם מזונות ולא ניתן לגבות ממנו בהוצאה לפועל, האם יכולה להגיש תביעה לביטוח לאומי לקבלת "גמלת מזונות". ביטוח לאומי ישלם לאם עד תקרה חודשית (כ-1,550 ש"ח לילד הראשון נכון ל-2025) ויפעל בעצמו לגביית החוב מהאב. הזכאות מותנית בכך שהאם היא תושבת ישראל, הילד מתגורר עמה, ויש פסק דין מזונות תקף שלא בוצע.',
      },
    },
    {
      '@type': 'Question',
      name: 'כמה מהמשכורת ניתן לעקל בגין מזונות?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'עיקול שכר בגין מזונות מיוחד משאר חובות. בעוד שבחובות רגילים המגבלה היא שליש מהשכר הנטו, בחוב מזונות ניתן לעקל עד 50% מהמשכורת. בנוסף, עיקול מזונות חל גם על שכר שאינו עולה על שכר המינימום — מה שאינו מותר בחובות רגילים.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם צו עיכוב יציאה מהארץ מוצא אוטומטית בגין חוב מזונות?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כן. בשונה מחובות כספיים רגילים, בגין פיגור בתשלום מזונות ניתן להוציא צו עיכוב יציאה מהארץ ללא צורך בפנייה מיוחדת של הזוכה — הדבר יכול להיעשות באופן יזום על-ידי רשם ההוצאה לפועל. הצו מוצא ברגע שנצבר פיגור משמעותי, ומוסר לרשויות הגבול.',
      },
    },
    {
      '@type': 'Question',
      name: 'איך מפחיתים חוב מזונות שנצבר?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ניתן לפנות לבית המשפט לענייני משפחה ולבקש "הפחתת מזונות" או "ביטול פיגורים" (מחיקת חוב צבור). הבית משפט יבחן את הנסיבות — שינוי במצב הכלכלי של האב, נישואין שניים, ילדים נוספים, מצב הילד. חשוב לדעת: ניתן לבקש הפחתה לעתיד, אך ביטול פיגורי עבר הוא נדיר ומצריך הוכחת נסיבות חריגות. לא ניתן לבטל חוב מזונות בהוצאה לפועל עצמה — רק בית המשפט הוא הסמכות לכך.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה ההבדל בין מזונות ילדים למזונות אישה בהוצאה לפועל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'שניהם ניתנים לאכיפה בהוצאה לפועל, אך ישנם הבדלים: מזונות ילדים נהנים מעדיפות גבוהה יותר בסדר הגבייה ומגמלת ביטוח לאומי. מזונות אישה (מדור, מזון, ביגוד לפי הדין האישי) ניתנים לאכיפה בגדרי הדין הדתי — לרוב בבית הדין הרבני — אך ניתן לפתוח תיק גבייה גם בהוצאה לפועל. שיעור עיקול השכר זהה בשני המקרים (עד 50%).',
      },
    },
    {
      '@type': 'Question',
      name: 'האם בית הדין הרבני או בית המשפט לענייני משפחה מוסמכים לדון במזונות?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'בישראל יש תחרות סמכויות. בית הדין הרבני מוסמך לדון במזונות אישה כשהצדדים יהודים, ובמזונות ילדים אם הוגשה גם תביעת גירושין. בית המשפט לענייני משפחה מוסמך לדון במזונות ילדים בכל עת, ובמזונות אישה אם תביעת הגירושין לא הוגשה לבית הדין. בפועל, לאחר גירושין, מרבית תיקי המזונות מטופלים בבית המשפט לענייני משפחה. ביצוע פסק הדין — גביית הכסף בפועל — נעשה תמיד דרך לשכת ההוצאה לפועל.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה עושים כשהאב מסתיר נכסים כדי להתחמק מתשלום מזונות?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ניתן לנקוט בכמה פעולות: (1) לבקש מרשם ההוצאה לפועל לזמן את החייב לחקירת יכולת — גם אם יש חשש שהוא מסתיר הכנסות. (2) לדרוש גילוי נכסים מלא. (3) לפנות לרשות המסים ולמוסד לביטוח לאומי לקבלת מידע. (4) להגיש תביעה נפרדת בבית המשפט לקביעת "מזונות מוגברים" אם מתברר שהאב הרוויח יותר מהצהרתו. הסתרת נכסים מהוצאה לפועל עלולה להוות עבירה פלילית.',
      },
    },
  ],
};
