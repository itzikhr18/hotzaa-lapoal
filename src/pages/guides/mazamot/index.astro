        <tr style="background:#1e3a5f;color:#fff;">
          <th style="padding:0.6rem 0.8rem;text-align:right;">ילד</th>
          <th style="padding:0.6rem 0.8rem;text-align:right;">סכום חודשי מרבי</th>
