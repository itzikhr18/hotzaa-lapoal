---
import GuideLayout from '../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'כמה אפשר לעקל ממשכורת בהוצאה לפועל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לפי החוק, ניתן לעקל עד שליש (33%) מהמשכורת נטו. אם המשכורת נטו שלך נמוכה משכר המינימום (6,247 ₪ ברוטו נכון לאפריל 2025) — המשכורת מוגנת לחלוטין ואי אפשר לעקל ממנה כלל. בתיקי מזונות — אין הגבלה.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם המעסיק יכול לפטר אותי בגלל עיקול משכורת?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לא. פיטורים בגלל עיקול משכורת הם פיטורים שלא כדין לפי חוק הגנת השכר. אם קיבלת פיטורים או איום בפיטורים בשל עיקול — פנה מיד לייעוץ משפטי. עומדת לך עילת תביעה.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם המעסיק לא מעביר את הכסף המעוקל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'מעסיק שלא מציית לצו עיקול משכורת עלול לשאת באחריות אישית לסכום שלא הועבר. רשות האכיפה והגבייה יכולה לנקוט נגדו בהליכים משפטיים כולל הגשת תביעה אזרחית.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם קצבאות ביטוח לאומי ניתנות לעיקול?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'רוב קצבאות הביטוח הלאומי מוגנות מעיקול: קצבת ילדים, קצבת נכות, קצבת זקנה, דמי לידה, ודמי אבטלה — כולן מוגנות לחלוטין. גמלת שמירת הריון מוגנת גם היא.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה ההבדל בין עיקול משכורת לצו תשלומים?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'עיקול משכורת הוא הליך כפוי שבו הנושה גובה ישירות מהמעסיק. צו תשלומים הוא הסדר מוסכם שבו החייב מעביר תשלומים חודשיים קבועים. קבלת צו תשלומים בדרך כלל מבטלת או מפחיתה את עיקול המשכורת.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר לבקש להפחית את שיעור עיקול המשכורת?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כן. אפשר לפנות לרשם ההוצאה לפועל בבקשה להפחתת שיעור העיקול אם אתה מוכיח שהמינוי הנוכחי גורם לך לא לעמוד בהוצאות קיום בסיסיות כגון שכר דירה, מזון ותרופות. יש להגיש בקשה בכתב עם מסמכים תומכים.',
      },
    },
  ],
};
---

<GuideLayout
  title="עיקול משכורת בהוצאה לפועל 2025 — כמה מותר, מה מוגן, ואיך מבטלים"
  description="עיקלו לך את המשכורת? מדריך מלא ועדכני: כמה מותר לעקל לפי החוק, אילו סכומים מוגנים, שכר מינימום עדכני 2025, ואיך מגישים בקשה להפחתה או ביטול."
  breadcrumb={[{ label: 'מדריכים', href: '/guides/' }, { label: 'עיקול משכורת', href: '/guides/ikul-maskoret/' }]}
  publishDate="2025-01-20"
  updateDate="2026-03-28"
  readTime="8 דקות"
  schema={[faqSchema, {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'איך מפחיתים או מבטלים עיקול משכורת בהוצאה לפועל',
    description: 'צעדים מעשיים להפחתת עיקול משכורת — טופס, נימוקים, מסמכים',
    totalTime: 'P7D',
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'וודא שהמשכורת אינה מוגנת מראש',
        text: 'אם שכרך נטו נמוך מ-6,247 ₪ (שכר מינימום 2025) — המשכורת מוגנת לחלוטין. פנה לרשם בבקשה לביטול על בסיס זה עם תלוש שכר.',
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'אסוף מסמכי הוצאות',
        text: 'אסוף מסמכים המוכיחים הוצאות קיום בסיסיות: חוזה שכירות, חשבונות חשמל/מים, קבלות תרופות, קבלות גן ילדים. ככל שיש יותר — כך גדלים סיכויי הפחתת העיקול.',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'מלא טופס בקשה להפחתת עיקול',
        text: 'הגש בקשה בכתב לרשם ההוצאה לפועל עם פירוט הכנסות והוצאות. בקש הפחתה ל-15% במקום 33%, או הפחתה לפי מצב כלכלי. אפשר גם לבקש צו תשלומים שיחליף את העיקול.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'הגש את הבקשה',
        text: 'הגש ללשכת ההוצאה לפועל שפתחה את התיק — פיזית או דרך האזור האישי. שמור אישור הגשה ותאריך.',
      },
      {
        '@type': 'HowToStep',
        position: 5,
        name: 'הגע לדיון אם נקבע',
        text: 'הרשם עשוי לקבוע דיון. בוא עם כל המסמכים. אם אין דיון — ההחלטה תינתן בכתב. אם הבקשה אושרה, מעסיקך יקבל הודעה תוך 24 שעות.',
      },
    ],
  }]}
>

  <p>
    גילית שמנכים לך כסף מהמשכורת — ולא ידעת שזה עומד לקרות. זה מרגיש כמו מכה ישירה לכיס,
    ולא פעם זה מגיע בהפתעה מוחלטת. אבל לפני שמתחילים לפעול, חשוב להבין את הכללים
    — כי החוק בישראל מגן עליך יותר ממה שרוב האנשים יודעים.
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-1">מספרים עדכניים למרץ 2026</p>
    <ul class="space-y-1 text-sm">
      <li>שכר מינימום (מאפריל 2025): <strong>6,247.67 ₪ ברוטו לחודש</strong></li>
      <li>מקסימום עיקול: <strong>שליש (33%) מהמשכורת נטו</strong></li>
      <li>בתיקי מזונות: <strong>אין הגבלה</strong></li>
    </ul>
  </div>

  <h2>כמה אפשר לעקל ממשכורת — הכלל הבסיסי</h2>
  <p>
    חוק ההוצאה לפועל קובע תקרה ברורה: <strong>לא יותר משליש מהמשכורת נטו</strong>.
    "נטו" פירושו אחרי ניכויי חובה — מס הכנסה, ביטוח לאומי, ביטוח בריאות — אבל לפני
    ניכויים רצוניים כמו ביטוחי חיים, קופות גמל, או הלוואות מהמעסיק.
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-3">דוגמאות מהחיים (נכון ל-2026):</p>
    <div class="space-y-3 text-sm">
      <div class="bg-white rounded-lg p-3 border border-blue-100">
        <p class="font-semibold mb-1">משכורת נטו 9,000 ₪</p>
        <p>מקסימום עיקול: 3,000 ₪ | נשאר לך: 6,000 ₪</p>
      </div>
      <div class="bg-white rounded-lg p-3 border border-blue-100">
        <p class="font-semibold mb-1">משכורת נטו 6,000 ₪</p>
        <p>מקסימום עיקול: 2,000 ₪ | נשאר לך: 4,000 ₪</p>
      </div>
      <div class="bg-white rounded-lg p-3 border border-blue-100">
        <p class="font-semibold mb-1">משכורת נטו 5,000 ₪ (≈ שכר מינימום)</p>
        <p class="text-green-700 font-semibold">מוגן לחלוטין — אפס עיקול</p>
      </div>
    </div>
  </div>

  <h2>שכר מינימום — הגנה מוחלטת</h2>
  <p>
    זוהי אחת ההגנות החזקות ביותר שיש לחייבים בישראל: <strong>אם המשכורת הנטו שלך
    נמוכה משכר המינימום — אי אפשר לעקל ממנה שקל אחד.</strong>
  </p>
  <p>
    שכר המינימום עודכן ב-1 באפריל 2025 ל-<strong>6,247.67 ₪ ברוטו לחודש</strong>
    (34.32 ₪ לשעה). בשכר נטו, מדובר בכ-5,400–5,600 ₪ תלוי בניכויים.
    אפילו אם חוב ענק תלוי עליך — אין מה לעשות לנושה אם המשכורת שלך בגובה המינימום.
    זו הגנה חוקית מוחלטת.
  </p>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">חריג חשוב: תיקי מזונות</p>
    <p>
      בתיקים של מזונות ילדים, אין תקרת שליש ואין הגנת שכר מינימום.
      ניתן לעקל עד 100% מהמשכורת בתיקי מזונות, בהחלטת רשם.
      זה הליך שונה לחלוטין מתיקי חוב רגילים.
    </p>
  </div>

  <h2>אילו הכנסות נוספות מוגנות מעיקול?</h2>
  <p>
    מעבר למשכורת, יש הכנסות נוספות שהחוק מגן עליהן במפורש:
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-6 not-prose">
    {[
      { title: 'קצבאות ביטוח לאומי', items: ['קצבת ילדים', 'קצבת נכות כללית', 'קצבת זקנה', 'קצבת שאירים', 'גמלת ניידות'], color: 'border-green-200 bg-green-50' },
      { title: 'גמלות ותגמולים', items: ['דמי אבטלה', 'דמי לידה', 'גמלת סיעוד', 'גמלת שמירת הריון', 'תגמולי מילואים'], color: 'border-green-200 bg-green-50' },
      { title: 'הכנסות מיוחדות', items: ['מזונות ילדים שנפסקו לזכותך', 'פיצויים בגין נזק גוף (חלקית)', 'כספי גמלה מקופת חולים'], color: 'border-blue-200 bg-blue-50' },
      { title: 'מה לא מוגן לחלוטין', items: ['בונוסים ושעות נוספות', 'דמי הבראה', 'קרן השתלמות לאחר 6 שנים', 'הכנסות מעסק עצמאי (חלקית)'], color: 'border-orange-200 bg-orange-50' },
    ].map(group => (
      <div class={`border rounded-xl p-4 ${group.color}`}>
        <h3 class="font-bold text-gray-800 mb-2">{group.title}</h3>
        <ul class="text-sm text-gray-600 space-y-1">
          {group.items.map(item => <li>• {item}</li>)}
        </ul>
      </div>
    ))}
  </div>

  <h2>מה קורה כשמגיע צו עיקול למעסיק?</h2>
  <p>
    כשרשות האכיפה והגבייה שולחת צו עיקול משכורת למעסיק, זה הליך מוגדר בחוק:
  </p>
  <ol class="step-list">
    <li>
      <span class="step-num">1</span>
      <span><strong>הצו מגיע למעסיק</strong> — בדרך כלל בדואר רשום או בהמצאה מיוחדת. המעסיק נדרש לאשר קבלה.</span>
    </li>
    <li>
      <span class="step-num">2</span>
      <span><strong>המעסיק חייב לציית</strong> — אין שיקול דעת. מרגע שקיבל את הצו, הוא מחויב לנכות את הסכום מידי חודש.</span>
    </li>
    <li>
      <span class="step-num">3</span>
      <span><strong>ההעברה לרשות</strong> — הכסף המנוכה מועבר ישירות לקופת רשות האכיפה, שממנה מועבר לנושה.</span>
    </li>
    <li>
      <span class="step-num">4</span>
      <span><strong>תלוש שקוף</strong> — בתלוש המשכורת שלך חייב להופיע הניכוי בבירור עם ציון "עיקול הוצאה לפועל".</span>
    </li>
  </ol>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">⚠️ המעסיק לא יכול לפטר אותך</p>
    <p>
      פיטורים בגלל עיקול משכורת הם עבירה על חוק הגנת השכר.
      המעסיק לא יכול לפטר אותך, לא להוריד לך בשכר, ולא להרע את תנאי העסקתך
      בשל קיום עיקול. אם זה קרה — עומדת לך תביעה בבית דין לעבודה.
    </p>
  </div>

  <h2>מה קורה אם המעסיק לא מציית לצו?</h2>
  <p>
    מעסיק שמתעלם מצו עיקול משכורת חושף את עצמו לסיכון אישי:
  </p>
  <ul>
    <li>רשות האכיפה יכולה לנקוט נגדו בהליכים לגביית החוב ישירות ממנו</li>
    <li>המעסיק עלול להיות מוכרז כ"צד שלישי חייב" ולשאת באחריות אישית</li>
    <li>ניתן להגיש נגדו תביעה לתשלום הסכום שהיה צריך להעביר</li>
    <li>במקרים קיצוניים — ניתן לבקש הטלת קנס על המעסיק</li>
  </ul>
  <p>
    בפועל, רוב המעסיקים מציינים לצווי עיקול מיד עם קבלתם, כדי להימנע מהסיכון הזה.
  </p>

  <h2>5 דרכים להתמודד עם עיקול משכורת</h2>

  <ol class="step-list">
    <li>
      <span class="step-num">1</span>
      <div>
        <strong>הגש בקשה לצו תשלומים</strong>
        <p class="text-sm text-gray-600 mt-1">
          זה הכלי הכי יעיל. פנה לרשם ההוצאה לפועל בבקשה לקבוע תשלומים חודשיים קבועים
          שאתה יכול לעמוד בהם. ברגע שהרשם מוציא צו תשלומים — העיקול ירד מהמשכורת,
          ובמקומו תשלם ישירות לרשות האכיפה מדי חודש.
        </p>
      </div>
    </li>
    <li>
      <span class="step-num">2</span>
      <div>
        <strong>בקש הפחתת שיעור העיקול</strong>
        <p class="text-sm text-gray-600 mt-1">
          אם שליש מהמשכורת גורם לך לא לעמוד בהוצאות קיום בסיסיות —
          אפשר לבקש מהרשם להפחית את השיעור. יש להגיש בקשה בכתב עם מסמכים:
          חוזה שכירות, חשבונות שוטפים, מרשם רפואי לתרופות, וכו'.
        </p>
      </div>
    </li>
    <li>
      <span class="step-num">3</span>
      <div>
        <strong>שקול איחוד תיקים</strong>
        <p class="text-sm text-gray-600 mt-1">
          אם יש לך כמה תיקים פתוחים נגדך — איחוד תיקים קובע תשלום חודשי אחד לכולם,
          ובדרך כלל מבטל עיקולי משכורת מרובים. נכון ל-2026 — לא נדרשת עוד הפקדת 3% מסך החובות.
        </p>
      </div>
    </li>
    <li>
      <span class="step-num">4</span>
      <div>
        <strong>בדוק אם החוב תקף</strong>
        <p class="text-sm text-gray-600 mt-1">
          לפעמים עיקול מוצא בגין חוב שכבר שולם, חוב שפג תוקף ההתיישנות (7 שנים בדרך כלל),
          או חוב שאינו שייך לך. במקרה כזה — ניתן להגיש התנגדות.
        </p>
      </div>
    </li>
    <li>
      <span class="step-num">5</span>
      <div>
        <strong>פנה לחדלות פירעון</strong>
        <p class="text-sm text-gray-600 mt-1">
          אם החובות גדולים מאוד ולא ניתן להתמודד איתם — הליך חדלות פירעון יכול להביא
          לעצירת כל הליכי הגבייה כולל עיקולי משכורת. אגרת הפתיחה נכון ל-2026 היא 900 ₪.
        </p>
      </div>
    </li>
  </ol>

  <h2>איך מגישים בקשה להפחתת עיקול — שלב אחרי שלב</h2>
  <p>
    רוצה להגיש בקשה להפחתת שיעור העיקול? הנה התהליך המדויק:
  </p>
  <ol class="step-list">
    <li>
      <span class="step-num">1</span>
      <span><strong>אסוף מסמכים</strong> — 3 תלושי משכורת אחרונים, חוזה שכירות או משכנתה, חשבונות חשמל/מים/ארנונה, קבלות על תרופות קבועות, ואישורים על בני משפחה תלויים.</span>
    </li>
    <li>
      <span class="step-num">2</span>
      <span><strong>הכן תחשיב הכנסות-הוצאות</strong> — הצג בצורה ברורה: כמה נכנס, כמה יוצא, ומה נשאר אחרי העיקול. כתוב אותו בצורה ברורה ומפורטת.</span>
    </li>
    <li>
      <span class="step-num">3</span>
      <span><strong>הגש בקשה לרשם</strong> — ניתן להגיש דרך האתר הממשלתי של רשות האכיפה והגבייה (gov.il) או פיזית בלשכה. ציין מפורשות שאתה מבקש "הפחתת שיעור עיקול משכורת".</span>
    </li>
    <li>
      <span class="step-num">4</span>
      <span><strong>המתן להחלטה</strong> — הרשם יכול לקיים דיון או להחליט על הנייר. בדרך כלל ניתנת תשובה תוך כמה שבועות.</span>
    </li>
    <li>
      <span class="step-num">5</span>
      <span><strong>הצו יישלח למעסיק</strong> — אם הבקשה אושרה, הרשם שולח למעסיק צו מעודכן עם השיעור החדש.</span>
    </li>
  </ol>

  <h2>עצמאים: האם אפשר לעקל הכנסות מעסק?</h2>
  <p>
    עצמאים נמצאים במצב שונה: אין להם "מעסיק" שאפשר לשלוח לו צו. אבל הנושה יכול:
  </p>
  <ul>
    <li><strong>לעקל חשבון עסקי</strong> — הצו נשלח לבנק שבו מתנהל חשבון העסק</li>
    <li><strong>לעקל לקוחות</strong> — להטיל עיקול על כספים שלקוחות חייבים לעסק שלך</li>
    <li><strong>לעקל ציוד עסקי</strong> — במקרים קיצוניים, ניתן לעקל נכסי עסק</li>
  </ul>
  <p>
    עצמאי שמתקשה בגלל עיקולים יכול לפנות לבקשת צו תשלומים בדיוק כמו שכיר.
    הסכום ייקבע לפי ממוצע הכנסות על בסיס דוחות שנתיים.
  </p>

  <h2>ריבית על החוב — מה השתנה בתיקון 9 (2025)</h2>
  <p>
    נכון לינואר 2025 נכנס לתוקף <strong>תיקון 9 לחוק פסיקת ריבית והצמדה</strong>,
    שמשנה מהותית את קצב תפיחת חוב בהוצאה לפועל:
  </p>
  <ul>
    <li><strong>ריבית שקלית</strong> — מחושבת על בסיס ריבית בנק ישראל (4.5% נכון ל-2025)</li>
    <li><strong>דמי פיגורים</strong> — מצטרפים לחוב פעם בשלושה חודשים בלבד (לא יום-יום)</li>
    <li><strong>ההשפעה</strong> — הפחתה של עד 80% בקצב תפיחת החוב, בעיקר למי שעומד בתשלומים</li>
  </ul>
  <p>
    זו בשורה טובה: אם אתה עומד בצו התשלומים שלך, החוב שלך כבר לא "בועה" שמתנפחת כל יום.
  </p>

