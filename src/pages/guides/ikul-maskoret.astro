---
import GuideLayout from '../../layouts/GuideLayout.astro';
import { wage, wageList, wageSentence, wageRangeText, fmtILS, WAGE_AS_OF } from '../../data/protected-amounts';

// חישוב העיקול המקסימלי לפי סעיף 8 לחוק הגנת השכר:
// שכר ≤ סכום מוגן → 0; סכום מוגן < 80% מהנטו → היתרה שמעל הסכום המוגן;
// סכום מוגן בין 80%-100% מהנטו → 20% מהנטו.
const maxGarnish = (net: number, protectedW: number): number =>
  net <= protectedW ? 0 : protectedW < net * 0.8 ? net - protectedW : Math.round(net * 0.2);

const exampleNets = [4000, 5450, 6800, 9800];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'כמה אפשר לעקל ממשכורת בהוצאה לפועל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: `לפי סעיף 8 לחוק הגנת השכר, מוגן מעיקול סכום נטו חודשי שמשתנה לפי הרכב המשפחה: ${wageSentence}. שכר נטו שאינו עולה על הסכום המוגן — לא ניתן לעקל כלל. אם הסכום המוגן נמוך מ-80% מהנטו — נשאר בידי החייב הסכום המוגן והיתרה ניתנת לעיקול; אם הסכום המוגן הוא 80%-100% מהנטו — ניתן לעקל 20% מהנטו בלבד. "נטו" מחושב לאחר ניכויי חובה אך לפני ניכויים רצוניים. בתיקי מזונות ההגנה אינה חלה.`,
      },
    },
    {
      '@type': 'Question',
      name: 'האם המעסיק יכול לפטר אותי בגלל עיקול משכורת?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לא. פיטורים בגלל עיקול משכורת הם פיטורים שלא כדין לפי חוק הגנת השכר. המעסיק אינו רשאי לפטר, להוריד בשכר, או להרע את תנאי העסקתך בשל קיום עיקול. אם קיבלת פיטורים או איום בפיטורים בשל עיקול — פנה מיד לייעוץ משפטי. עומדת לך עילת תביעה בבית הדין לעבודה.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם המעסיק לא מעביר את הכסף המעוקל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'מעסיק שלא מציית לצו עיקול משכורת עלול לשאת באחריות אישית לסכום שלא הועבר. רשות האכיפה והגבייה יכולה להכריז עליו כ"צד שלישי חייב" ולנקוט נגדו בהליכים משפטיים, כולל הגשת תביעה אזרחית לגביית הסכום שהיה צריך להעביר. בפועל, רוב המעסיקים מציינים לצווים מיידית כדי להימנע מחשיפה אישית.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם קצבאות ביטוח לאומי ניתנות לעיקול?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'רוב קצבאות הביטוח הלאומי מוגנות מעיקול לחלוטין לפי חוק הביטוח הלאומי: קצבת ילדים, קצבת נכות כללית, קצבת זקנה, קצבת שאירים, גמלת ניידות, דמי לידה, דמי אבטלה וגמלת שמירת הריון — כולן מוגנות. אם כספי קצבה הועברו לחשבון בנק שעוקל — יש לפנות מיידית ללשכה ולבקש שחרור הסכום המוגן.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה ההבדל בין עיקול משכורת לצו תשלומים?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'עיקול משכורת הוא הליך כפוי — הנושה גובה ישירות מהמעסיק ללא הסכמתך. צו תשלומים הוא הסדר מוסכם שבו אתה מעביר תשלומים חודשיים קבועים ישירות לרשות האכיפה. קבלת צו תשלומים בדרך כלל מבטלת או מפחיתה את עיקול המשכורת — זאת הדרך הכי יעילה לצאת מהמצב.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר לבקש להפחית את שיעור עיקול המשכורת?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כן. ניתן לפנות לרשם ההוצאה לפועל בבקשה להפחתת שיעור העיקול אם ניתן להוכיח שהניכוי הנוכחי מונע עמידה בהוצאות קיום בסיסיות: שכר דירה, מזון, תרופות, גן ילדים. יש להגיש בקשה בכתב עם מסמכים תומכים. הרשם רשאי להפחית את סכום העיקול משמעותית מתחת למקסימום החוקי, בהתאם לנסיבות.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה עושים אם ניכו ממני יותר מהמותר בחוק?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'אם ניכו ממך יותר מהמותר — למשל עיקלו ממשכורת שאינה עולה על הסכום המוגן המגיע לך, או שנותר בידך פחות מהסכום המוגן (או פחות מ-80% מהנטו כשהסכום המוגן גבוה ממנו) — יש לפנות מיידית לרשם ההוצאה לפועל בבקשה להשבת הסכום העודף. יש לצרף תלושי שכר כראיה. הרשם מחויב לתקן את הצו ולהורות על החזר הסכום העודף. ניתן גם לפנות ישירות למעסיק לפני הפנייה לרשם.',
      },
    },
  ],
};
---

<GuideLayout
  title="עיקול משכורת בהוצאה לפועל 2026 — כמה מותר, מה מוגן, ואיך מבטלים"
  description="עיקלו לך את המשכורת? כמה מותר לעקל לפי החוק, שכר הגנה לפי הרכב משפחה (2026), השוואת תקרות לפי סוג חוב, ואיך מגישים בקשה להפחתה או ביטול."
  breadcrumb={[{ label: 'מדריכים', href: '/guides/' }, { label: 'עיקול משכורת', href: '/guides/ikul-maskoret/' }]}
  publishDate="2025-01-20"
  updateDate="2026-06-24"
  readTime="9 דקות"
  schema={[faqSchema, {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'איך מפחיתים או מבטלים עיקול משכורת בהוצאה לפועל',
    description: 'צעדים מעשיים להפחתת עיקול משכורת — טופס, נימוקים, מסמכים',
    totalTime: 'P7D',
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'בדוק אם המשכורת מוגנת מראש',
        text: `אם משכורתך הנטו אינה עולה על שכר ההגנה שלך — לרוב לא ניתן לעקל. שכר ההגנה משתנה לפי הרכב המשפחה: ${wageSentence}. פנה לרשם בבקשת ביטול וצרף תלוש שכר.`,
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'אסוף מסמכי הכנסה והוצאות',
        text: 'אסוף: 3 תלושי שכר אחרונים, חוזה שכירות או תשלומי משכנתה, חשבונות חשמל ומים, קבלות תרופות קבועות, ואישורים על בני משפחה תלויים. ככל שהמסמכים מפורטים יותר — כך גדלים סיכויי ההפחתה.',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'הכן תחשיב הכנסות-הוצאות',
        text: 'הצג בצורה ברורה: כמה נכנס לחשבון בחודש, מה כל הוצאה חיונית, ומה נשאר אחרי העיקול. הדגש כי הסכום הנותר אינו מכסה הוצאות קיום בסיסיות.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'הגש בקשה לרשם ההוצאה לפועל',
        text: 'הגש בקשה בכתב ללשכת ההוצאה לפועל שפתחה את התיק — פיזית או דרך האזור האישי ב-gov.il. בקש מפורשות "הפחתת שיעור עיקול משכורת" או "ביטול עיקול משכורת". צרף את כל המסמכים ושמור אישור הגשה.',
      },
      {
        '@type': 'HowToStep',
        position: 5,
        name: 'הגע לדיון אם נקבע',
        text: 'הרשם עשוי לקבוע דיון. בוא עם כל המסמכים המקוריים. אם לא נקבע דיון — ההחלטה תינתן בכתב, בדרך כלל תוך 2–4 שבועות.',
      },
    ],
  }]}
  relatedGuides={[
    { title: 'צו תשלומים', href: '/guides/tzav-tashlumim/' },
    { title: 'עיקול חשבון בנק', href: '/guides/ikul-heshbon/' },
    { title: 'ביטול עיקול', href: '/guides/bitul-ikul/' },
    { title: 'סכומים מוגנים', href: '/rights/skhomim-mugganim/' },
    { title: 'איחוד תיקים', href: '/guides/ichud-tikim/' },
  ]}
>

  <p>
    גילית שמנכים לך כסף מהמשכורת — ולא ידעת שזה עומד לקרות. זה מרגיש כמו מכה ישירה לכיס,
    ולא פעם זה מגיע בהפתעה מוחלטת. אבל לפני שמתחילים לפעול, חשוב להבין את הכללים
    — כי החוק בישראל מגן עליך יותר ממה שרוב האנשים יודעים.
  </p>

  <div class="not-prose my-6 bg-green-50 border-r-4 border-green-500 rounded-xl p-5">
    <p class="font-bold text-green-800 mb-3 text-base">בקצרה: כמה מותר לעקל מהמשכורת? (2026)</p>
    <ul class="space-y-1.5 text-sm text-gray-700 list-none">
      <li>• <strong>סכום מוגן לפי משפחה</strong> — תמיד נשאר ביד החייב <strong>הסכום המוגן מעיקול</strong> (סכום נטו שמשתנה לפי הרכב המשפחה — {fmtILS(wage.single)} ליחיד עד {fmtILS(wage.singleParentPlus2)} להורה יחיד עם 2+ ילדים).</li>
      <li>• <strong>שכר נמוך מהסכום המוגן</strong> — לא ניתן לעקל ממנו <strong>בכלל</strong>.</li>
      <li>• <strong>שכר גבוה מהסכום המוגן</strong> — היתרה שמעל הסכום המוגן ניתנת לעיקול; ואם הסכום המוגן גבוה מ-80% מהנטו, מעקלים לכל היותר <strong>20% מהנטו</strong>.</li>
      <li>• <strong>בפועל</strong> — הרשם קובע את גובה העיקול וניתן לבקש הפחתה או צו תשלומים.</li>
      <li>• <strong>בתיקי מזונות</strong> — ההגנה אינה חלה; ייתכן ניכוי גבוה משמעותית.</li>
      <li>• <strong>קצבאות ביטוח לאומי</strong> — נהנות מהגנה מיוחדת בכפוף לאופן ההפקדה ולהוראות הדין.</li>
      <li>• <strong>ניכו יותר מדי?</strong> — פנה לרשם ההוצאה לפועל עם תלושי שכר לשחרור הסכום העודף.</li>
    </ul>
  </div>

  <div class="not-prose my-6 bg-rose-50 border border-rose-200 rounded-xl p-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <p class="font-bold text-rose-800 mb-1">💼 רוצה מספר מדויק למצב שלך?</p>
      <p class="text-sm text-gray-700">הזן משכורת נטו והרכב משפחה — וקבל מיד כמה מותר לעקל וכמה חייב להישאר בידך.</p>
    </div>
    <a href="/tools/ikul-maskoret/" class="shrink-0 text-sm font-semibold text-white bg-rose-600 hover:bg-rose-700 px-4 py-2 rounded-full transition-colors text-center">
      פתח מחשבון עיקול משכורת ←
    </a>
  </div>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">שכר הגנה לפי משפחה (2026 — kolzchut)</p>
    <ul class="space-y-1 text-sm">
      {wageList.map(w => (
        <li>{w.label}: <strong>~{fmtILS(w.amount)} נטו</strong></li>
      ))}
    </ul>
    <p class="text-xs text-gray-500 mt-2">סכומים מתעדכנים מעת לעת. לבדיקה עדכנית — <a href="https://www.kolzchut.org.il/he/%D7%A9%D7%9B%D7%A8_%D7%A2%D7%91%D7%95%D7%93%D7%94_%D7%A9%D7%9C%D7%90_%D7%A0%D7%99%D7%AA%D7%9F_%D7%9C%D7%A2%D7%A7%D7%9C_%D7%90%D7%95_%D7%9C%D7%A9%D7%A2%D7%91%D7%93" target="_blank" rel="noopener noreferrer">כל-זכות</a>.</p>
  </div>

  <h2>הבסיס החוקי — מה אומר החוק?</h2>
  <p>
    ההגנה על משכורת מעיקול קבועה ב<strong>סעיף 8 לחוק הגנת השכר, תשי"ח-1958</strong>
    (הליך העיקול אצל צד שלישי מוסדר בחוק ההוצאה לפועל, תשכ"ז-1967). החוק קובע כי
    ניתן לעקל רק חלק מהמשכורת של חייב לשם גביית חוב פסוק — תוך שמירה על
    <strong>רמת מחיה מינימלית</strong>. הרציונל: גביית חוב לא צריכה להותיר את החייב ומשפחתו
    ללא אמצעי קיום בסיסיים.
  </p>
  <p>
    שלושה עקרונות יסוד עומדים בבסיס ההסדר:
  </p>
  <ul>
    <li><strong>סכום מוגן לפי הרכב המשפחה</strong> — סכום נטו חודשי (מבוסס על שיעורי הבטחת הכנסה) שאינו ניתן לעיקול; שכר שנמוך ממנו מוגן במלואו</li>
    <li><strong>כלל 80%</strong> — כשהסכום המוגן גבוה מ-80% מהנטו, ההגנה מצטמצמת ל-80% מהשכר (כלומר ניתן לעקל עד 20% מהנטו)</li>
    <li><strong>שיקול דעת הרשם</strong> — הרשם רשאי להפחית את סכום העיקול בפועל הרבה מתחת למקסימום החוקי, לפי מצבו הכלכלי של החייב</li>
  </ul>

  <div class="tip-box">
    <p class="font-semibold mb-1">מה נחשב "משכורת נטו" לצורך עיקול?</p>
    <p class="text-sm">
      המשכורת נטו לצורך חישוב העיקול היא <strong>לאחר ניכויי חובה בלבד</strong>:
      מס הכנסה, ביטוח לאומי, וביטוח בריאות. ניכויים רצוניים — כגון ביטוח חיים, קופת גמל,
      קרן השתלמות, או הלוואה ממעסיק — <strong>אינם</strong> מורידים את הבסיס לחישוב.
      כלומר, אם יש לך ניכויים רצוניים גדולים, החייב בפועל עלול לגבות יותר ממה שמרגיש הוגן.
    </p>
  </div>

  <h2>טבלת השוואה: תקרות עיקול לפי סוג חוב</h2>
  <p>
    לא כל חוב נגבה לפי אותם כללים. הטבלה הבאה מסכמת את תקרות העיקול לפי
    סוג התיק — ומה ההגנות שחלות בכל מקרה:
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-100 text-gray-700">
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">סוג חוב</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">תקרת עיקול</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">סכום מינימום מוגן</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">הערות</th>
        </tr>
      </thead>
      <tbody>
        <tr class="bg-white">
          <td class="border border-gray-300 px-4 py-2 font-semibold">חוב אזרחי רגיל<br/><span class="font-normal text-gray-500">(הלוואה, ספק, שוכר)</span></td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-blue-700">היתרה שמעל הסכום המוגן<br/><span class="text-xs font-normal">(לפחות 80% מהנטו נשארים כשהסכום המוגן גבוה מ-80%)</span></td>
          <td class="border border-gray-300 px-4 py-2 text-center">סכום מוגן — <strong>{wageRangeText}</strong> נטו לפי משפחה</td>
          <td class="border border-gray-300 px-4 py-2">הרשם יכול להפחית לפי מצב כלכלי</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-300 px-4 py-2 font-semibold">מזונות ילדים / בן זוג</td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-red-700">ללא תקרת אחוז אוטומטית</td>
          <td class="border border-gray-300 px-4 py-2 text-center text-red-600">אין תקרת הגנה אוטומטית</td>
          <td class="border border-gray-300 px-4 py-2">הרשם או בית המשפט קובעים לפי סכום המזונות והיכולת</td>
        </tr>
        <tr class="bg-white">
          <td class="border border-gray-300 px-4 py-2 font-semibold">חובות לרשות המסים<br/><span class="font-normal text-gray-500">(מס הכנסה, מע"מ)</span></td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-orange-700">לפי פקודת המסים (גביה)</td>
          <td class="border border-gray-300 px-4 py-2 text-center">סכומי הגנה לפי דין</td>
          <td class="border border-gray-300 px-4 py-2">פועל במסלול נפרד — ייתכן צו מנהלי ישיר למעסיק</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-300 px-4 py-2 font-semibold">חובות ביטוח לאומי</td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-orange-700">לפי תקנות ביטוח לאומי</td>
          <td class="border border-gray-300 px-4 py-2 text-center">סכומי הגנה לפי דין</td>
          <td class="border border-gray-300 px-4 py-2">ביטוח לאומי פועל גם ישירות — לא רק דרך הוצאה לפועל</td>
        </tr>
        <tr class="bg-white">
          <td class="border border-gray-300 px-4 py-2 font-semibold">חוב לרשות מקומית<br/><span class="font-normal text-gray-500">(ארנונה, היטלים)</span></td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-blue-700">היתרה שמעל הסכום המוגן</td>
          <td class="border border-gray-300 px-4 py-2 text-center">סכום מוגן (לפי משפחה)</td>
          <td class="border border-gray-300 px-4 py-2">רשויות מקומיות מגישות לרוב לפי הנוהל הרגיל</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">חריג בתיקי מזונות</p>
    <p class="text-sm">
      בתיקים של מזונות ילדים אין תקרת אחוז אוטומטית ואין תקרת הגנה אוטומטית של שכר הגנה.
      הרשם רשאי לעקל שיעור גבוה משמעותית מהמותר בחוב רגיל — בייחוד כשמדובר בחוב מזונות
      צבור ("פיגורים") — אך ניתן לבקש מהרשם להתחשב בצורכי מחיה בסיסיים.
      זה הליך שונה מהותית מתיקי חוב רגילים.
    </p>
  </div>

  <h2>הגנת שכר הגנה — הסכום המוגן בפירוט</h2>
  <p>
    זוהי אחת ההגנות החזקות ביותר שיש לחייבים בישראל:
    <strong>אם המשכורת נטו שלך אינה עולה על שכר ההגנה המגיע לך — לרוב לא ניתן לעקל ממנה.</strong>
  </p>
  <p>
    שכר ההגנה הוא <strong>סכום נטו</strong> שמשתנה לפי הרכב המשפחה:
    {wageSentence}. אם השכר הנטו שלך
    אינו עולה על השכר ההגנה המתאים למשפחתך — הניכוי אסור (למעט תיקי מזונות).
  </p>

  <h2>טבלת דוגמאות — כמה ינוכה מהמשכורת שלך?</h2>
  <p>
    ארבעה תרחישים מהחיים, שיראו בדיוק כיצד חישוב העיקול עובד בפועל:
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-100 text-gray-700">
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">משכורת נטו</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">יחיד (מוגן {fmtILS(wage.single)}) — ניתן לעקל עד</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">זוג + 2 ילדים (מוגן {fmtILS(wage.couplePlus2)}) — ניתן לעקל עד</th>
        </tr>
      </thead>
      <tbody>
        {exampleNets.map((net, i) => (
