---
import GuideLayout from '../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'כמה אפשר לעקל ממשכורת בהוצאה לפועל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לפי חוק ההוצאה לפועל, ניתן לעקל עד שליש (33%) מהמשכורת נטו בלבד. "נטו" מחושב לאחר ניכויי חובה (מס הכנסה, ביטוח לאומי, ביטוח בריאות) אך לפני ניכויים רצוניים. אם המשכורת נטו נמוכה משכר המינימום — 6,247.67 ₪ ברוטו מאפריל 2025 — המשכורת מוגנת לחלוטין ואי אפשר לעקל ממנה כלל. בתיקי מזונות אין הגבלת שליש ועד מחצית מהמשכורת ניתן לעקל.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם המעסיק יכול לפטר אותי בגלל עיקול משכורת?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לא. פיטורים בגלל עיקול משכורת הם פיטורים שלא כדין לפי חוק הגנת השכר. המעסיק אינו רשאי לפטר, להוריד בשכר, או להרע את תנאי העסקתך בשל קיום עיקול. אם קיבלת פיטורים או איום בפיטורים בשל עיקול — פנה מיד לייעוץ משפטי. עומדת לך עילת תביעה בבית הדין לעבודה.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם המעסיק לא מעביר את הכסף המעוקל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'מעסיק שלא מציית לצו עיקול משכורת עלול לשאת באחריות אישית לסכום שלא הועבר. רשות האכיפה והגבייה יכולה להכריז עליו כ"צד שלישי חייב" ולנקוט נגדו בהליכים משפטיים, כולל הגשת תביעה אזרחית לגביית הסכום שהיה צריך להעביר. בפועל, רוב המעסיקים מציינים לצווים מיידית כדי להימנע מחשיפה אישית.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם קצבאות ביטוח לאומי ניתנות לעיקול?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'רוב קצבאות הביטוח הלאומי מוגנות מעיקול לחלוטין לפי חוק הביטוח הלאומי: קצבת ילדים, קצבת נכות כללית, קצבת זקנה, קצבת שאירים, גמלת ניידות, דמי לידה, דמי אבטלה וגמלת שמירת הריון — כולן מוגנות. אם כספי קצבה הועברו לחשבון בנק שעוקל — יש לפנות מיידית ללשכה ולבקש שחרור הסכום המוגן.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה ההבדל בין עיקול משכורת לצו תשלומים?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'עיקול משכורת הוא הליך כפוי — הנושה גובה ישירות מהמעסיק ללא הסכמתך. צו תשלומים הוא הסדר מוסכם שבו אתה מעביר תשלומים חודשיים קבועים ישירות לרשות האכיפה. קבלת צו תשלומים בדרך כלל מבטלת או מפחיתה את עיקול המשכורת — זאת הדרך הכי יעילה לצאת מהמצב.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר לבקש להפחית את שיעור עיקול המשכורת?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כן. ניתן לפנות לרשם ההוצאה לפועל בבקשה להפחתת שיעור העיקול אם ניתן להוכיח שהניכוי הנוכחי מונע עמידה בהוצאות קיום בסיסיות: שכר דירה, מזון, תרופות, גן ילדים. יש להגיש בקשה בכתב עם מסמכים תומכים. הרשם יכול להפחית מ-33% ל-15% או פחות, בהתאם לנסיבות.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה עושים אם ניכו ממני יותר מהמותר בחוק?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'אם ניכו ממך יותר משליש מהמשכורת נטו, או שעיקלו ממשכורת בגובה שכר מינימום — יש לפנות מיידית לרשם ההוצאה לפועל בבקשה להשבת הסכום העודף. יש לצרף תלושי שכר כראיה. הרשם מחויב לתקן את הצו ולהורות על החזר הסכום העודף. ניתן גם לפנות ישירות למעסיק לפני הפנייה לרשם.',
      },
    },
  ],
};
---

<GuideLayout
  title="עיקול משכורת בהוצאה לפועל 2025 — כמה מותר, מה מוגן, ואיך מבטלים"
  description="עיקלו לך את המשכורת? מדריך מלא ועדכני: כמה מותר לעקל לפי החוק, אילו סכומים מוגנים, שכר מינימום עדכני 2025, השוואת תקרות, ואיך מגישים בקשה להפחתה או ביטול."
  breadcrumb={[{ label: 'מדריכים', href: '/guides/' }, { label: 'עיקול משכורת', href: '/guides/ikul-maskoret/' }]}
  publishDate="2025-01-20"
  updateDate="2026-03-28"
  readTime="9 דקות"
  schema={[faqSchema, {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'איך מפחיתים או מבטלים עיקול משכורת בהוצאה לפועל',
    description: 'צעדים מעשיים להפחתת עיקול משכורת — טופס, נימוקים, מסמכים',
    totalTime: 'P7D',
    step: [
      {
        '@type': 'HowToStep',
        position: 1,
        name: 'בדוק אם המשכורת מוגנת מראש',
        text: 'אם משכורתך נטו נמוכה מ-6,247.67 ₪ (שכר מינימום 2025) — המשכורת מוגנת לחלוטין. פנה לרשם בבקשה לביטול מיידי על בסיס זה, וצרף תלוש שכר.',
      },
      {
        '@type': 'HowToStep',
        position: 2,
        name: 'אסוף מסמכי הכנסה והוצאות',
        text: 'אסוף: 3 תלושי שכר אחרונים, חוזה שכירות או תשלומי משכנתה, חשבונות חשמל ומים, קבלות תרופות קבועות, ואישורים על בני משפחה תלויים. ככל שהמסמכים מפורטים יותר — כך גדלים סיכויי ההפחתה.',
      },
      {
        '@type': 'HowToStep',
        position: 3,
        name: 'הכן תחשיב הכנסות-הוצאות',
        text: 'הצג בצורה ברורה: כמה נכנס לחשבון בחודש, מה כל הוצאה חיונית, ומה נשאר אחרי העיקול. הדגש כי הסכום הנותר אינו מכסה הוצאות קיום בסיסיות.',
      },
      {
        '@type': 'HowToStep',
        position: 4,
        name: 'הגש בקשה לרשם ההוצאה לפועל',
        text: 'הגש בקשה בכתב ללשכת ההוצאה לפועל שפתחה את התיק — פיזית או דרך האזור האישי ב-gov.il. בקש מפורשות "הפחתת שיעור עיקול משכורת" או "ביטול עיקול משכורת". צרף את כל המסמכים ושמור אישור הגשה.',
      },
      {
        '@type': 'HowToStep',
        position: 5,
        name: 'הגע לדיון אם נקבע',
        text: 'הרשם עשוי לקבוע דיון. בוא עם כל המסמכים המקוריים. אם לא נקבע דיון — ההחלטה תינתן בכתב, בדרך כלל תוך 2–4 שבועות.',
      },
    ],
  }]}
>

  <p>
    גילית שמנכים לך כסף מהמשכורת — ולא ידעת שזה עומד לקרות. זה מרגיש כמו מכה ישירה לכיס,
    ולא פעם זה מגיע בהפתעה מוחלטת. אבל לפני שמתחילים לפעול, חשוב להבין את הכללים
    — כי החוק בישראל מגן עליך יותר ממה שרוב האנשים יודעים.
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">מספרים עדכניים — מרץ 2026</p>
    <ul class="space-y-1 text-sm">
      <li>שכר מינימום (מאפריל 2025): <strong>6,247.67 ₪ ברוטו לחודש</strong></li>
      <li>מקסימום עיקול בחוב רגיל: <strong>שליש (33%) מהמשכורת נטו</strong></li>
      <li>מקסימום עיקול בתיקי מזונות: <strong>עד מחצית (50%) מהמשכורת</strong></li>
      <li>חובות לרשויות המדינה: <strong>ייתכן שיעור שונה — ראה טבלה למטה</strong></li>
    </ul>
  </div>

  <h2>הבסיס החוקי — מה אומר חוק ההוצאה לפועל?</h2>
  <p>
    עיקול משכורת מוסדר בסעיפים 48–52 לחוק ההוצאה לפועל, תשכ"ז-1967. החוק קובע כי
    ניתן לעקל חלק מהמשכורת של חייב לשם גביית חוב פסוק — אך תוך שמירה על
    <strong>רמת מחיה מינימלית</strong>. הרציונל: גביית חוב לא צריכה להותיר את החייב ומשפחתו
    ללא אמצעי קיום בסיסיים.
  </p>
  <p>
    שלושה עקרונות יסוד עומדים בבסיס ההסדר:
  </p>
  <ul>
    <li><strong>תקרת שליש</strong> — לא ניתן לגבות יותר משליש מהמשכורת נטו בחוב אזרחי רגיל</li>
    <li><strong>הגנת שכר מינימום</strong> — משכורת בגובה שכר מינימום מוגנת לחלוטין</li>
    <li><strong>שיקול דעת הרשם</strong> — הרשם רשאי להפחית את שיעור העיקול בנסיבות מיוחדות</li>
  </ul>

  <div class="tip-box">
    <p class="font-semibold mb-1">מה נחשב "משכורת נטו" לצורך עיקול?</p>
    <p class="text-sm">
      המשכורת נטו לצורך חישוב העיקול היא <strong>לאחר ניכויי חובה בלבד</strong>:
      מס הכנסה, ביטוח לאומי, וביטוח בריאות. ניכויים רצוניים — כגון ביטוח חיים, קופת גמל,
      קרן השתלמות, או הלוואה ממעסיק — <strong>אינם</strong> מורידים את הבסיס לחישוב.
      כלומר, אם יש לך ניכויים רצוניים גדולים, החייב בפועל עלול לגבות יותר ממה שמרגיש הוגן.
    </p>
  </div>

  <h2>טבלת השוואה: תקרות עיקול לפי סוג חוב</h2>
  <p>
    לא כל חוב נגבה לפי אותם כללים. הטבלה הבאה מסכמת את תקרות העיקול לפי
    סוג התיק — ומה ההגנות שחלות בכל מקרה:
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-100 text-gray-700">
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">סוג חוב</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">תקרת עיקול</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">סכום מינימום מוגן</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">הערות</th>
        </tr>
      </thead>
      <tbody>
        <tr class="bg-white">
          <td class="border border-gray-300 px-4 py-2 font-semibold">חוב אזרחי רגיל<br/><span class="font-normal text-gray-500">(הלוואה, ספק, שוכר)</span></td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-blue-700">33% מנטו</td>
          <td class="border border-gray-300 px-4 py-2 text-center">שכר מינימום — <strong>6,247.67 ₪</strong> ברוטו</td>
          <td class="border border-gray-300 px-4 py-2">הרשם יכול להפחית לפי מצב כלכלי</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-300 px-4 py-2 font-semibold">מזונות ילדים / בן זוג</td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-red-700">עד 50% מנטו</td>
          <td class="border border-gray-300 px-4 py-2 text-center text-red-600">אין הגנת שכר מינימום</td>
          <td class="border border-gray-300 px-4 py-2">ניתן לגבות עד 100% בהחלטת רשם מנומקת</td>
        </tr>
        <tr class="bg-white">
          <td class="border border-gray-300 px-4 py-2 font-semibold">חובות לרשות המסים<br/><span class="font-normal text-gray-500">(מס הכנסה, מע"מ)</span></td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-orange-700">עד 33% מנטו</td>
          <td class="border border-gray-300 px-4 py-2 text-center">שכר מינימום בסיסי</td>
          <td class="border border-gray-300 px-4 py-2">ניתן לגבות גם ישירות ממעסיק בצו מנהלי</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-300 px-4 py-2 font-semibold">חובות ביטוח לאומי</td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-orange-700">עד 33% מנטו</td>
          <td class="border border-gray-300 px-4 py-2 text-center">שכר מינימום בסיסי</td>
          <td class="border border-gray-300 px-4 py-2">ביטוח לאומי פועל גם ישירות — לא רק דרך הוצאה לפועל</td>
        </tr>
        <tr class="bg-white">
          <td class="border border-gray-300 px-4 py-2 font-semibold">חוב לרשות מקומית<br/><span class="font-normal text-gray-500">(ארנונה, היטלים)</span></td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-blue-700">33% מנטו</td>
          <td class="border border-gray-300 px-4 py-2 text-center">שכר מינימום</td>
          <td class="border border-gray-300 px-4 py-2">רשויות מקומיות מגישות לרוב לפי הנוהל הרגיל</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-1">חריג בתיקי מזונות</p>
    <p class="text-sm">
      בתיקים של מזונות ילדים אין תקרת שליש ואין הגנת שכר מינימום.
      הרשם יכול לעקל עד 100% מהמשכורת במקרים קיצוניים — בייחוד כשמדובר בחוב מזונות
      צבורים ("פיגורים"). זה הליך שונה לחלוטין מתיקי חוב רגילים.
    </p>
  </div>

  <h2>הגנת שכר מינימום — הסכום המוגן בפירוט</h2>
  <p>
    זוהי אחת ההגנות החזקות ביותר שיש לחייבים בישראל:
    <strong>אם המשכורת נטו שלך נמוכה משכר המינימום — אי אפשר לעקל ממנה שקל אחד.</strong>
  </p>
  <p>
    שכר המינימום עודכן ב-1 באפריל 2025 ל-<strong>6,247.67 ₪ ברוטו לחודש</strong>
    (34.32 ₪ לשעה). בשכר נטו, מדובר בכ-5,400–5,600 ₪ תלוי בניכויים ובמספר נקודות
    הזיכוי. אפילו אם חוב ענק תלוי עליך — אין מה לעשות לנושה אם המשכורת שלך בגובה המינימום.
    זו הגנה חוקית מוחלטת שאין לעקוף.
  </p>

  <h2>טבלת דוגמאות — כמה ינוכה מהמשכורת שלך?</h2>
  <p>
    ארבעה תרחישים מהחיים, שיראו בדיוק כיצד חישוב העיקול עובד בפועל:
  </p>

  <div class="not-prose overflow-x-auto my-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-100 text-gray-700">
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">משכורת ברוטו</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">משכורת נטו (משוער)</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">מקסימום עיקול (33%)</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">נשאר בידך</th>
          <th class="border border-gray-300 px-4 py-2 text-right font-bold">הערה</th>
        </tr>
      </thead>
      <tbody>
        <tr class="bg-red-50">
          <td class="border border-gray-300 px-4 py-2 font-semibold">6,247 ₪</td>
          <td class="border border-gray-300 px-4 py-2">~5,450 ₪</td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-green-700">0 ₪</td>
          <td class="border border-gray-300 px-4 py-2 font-semibold text-green-700">5,450 ₪</td>
          <td class="border border-gray-300 px-4 py-2 text-green-700 font-semibold">מוגן לחלוטין — שכר מינימום</td>
        </tr>
        <tr class="bg-white">
          <td class="border border-gray-300 px-4 py-2 font-semibold">8,000 ₪</td>
          <td class="border border-gray-300 px-4 py-2">~6,800 ₪</td>
          <td class="border border-gray-300 px-4 py-2 text-center font-bold text-orange-700">~2,266 ₪</td>
          <td class="border border-gray-300 px-4 py-2">~4,534 ₪</td>
