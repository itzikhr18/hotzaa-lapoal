---
import GuideLayout from '../../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'מה ההבדל בין ערב רגיל לערב מוגן?', acceptedAnswer: { '@type': 'Answer', text: 'ערב רגיל — הנושה יכול לפנות אליו מיד כשהחייב לא משלם. ערב מוגן (לפי תיקון 1 לחוק הערבות) — הנושה חייב קודם לנסות לגבות מהחייב הראשי, ולהוכיח שהניסיון נכשל, לפני שיוכל לפנות לערב.' } },
    { '@type': 'Question', name: 'מה זה ערב מוגן ומי זכאי להגנה?', acceptedAnswer: { '@type': 'Answer', text: 'ערב מוגן הוא יחיד שערב לחוב שאינו לצורך עסקי, וסכום הערבות אינו עולה על 100,000 ₪ (מוצמד למדד). ההגנה: הנושה חייב לנסות לגבות מהחייב הראשי תוך 90 יום לפני פנייה לערב.' } },
    { '@type': 'Question', name: 'האם יש התיישנות על ערבות?', acceptedAnswer: { '@type': 'Answer', text: 'כן. תקופת ההתיישנות על ערבות היא 7 שנים מהיום שהחוב הפך לתביעה מול הערב. אם הנושה לא תבע את הערב תוך 7 שנים, החוב עלול להיות מותיישן.' } },
    { '@type': 'Question', name: 'האם אפשר לבטל ערבות?', acceptedAnswer: { '@type': 'Answer', text: 'ביטול ערבות אפשרי במספר מקרים: אם הנושה שינה את תנאי ההלוואה ללא הסכמת הערב, אם הנושה ויתר על בטוחות שהיו מכסות את החוב, או אם יש פגמים בחוזה הערבות המקורי.' } },
    { '@type': 'Question', name: 'אם שילמתי כערב, האם אני יכול לתבוע את החייב?', acceptedAnswer: { '@type': 'Answer', text: 'כן. חוק הערבות מעניק לערב שפרע את החוב זכות חזרה (סוברוגציה) כנגד החייב הראשי. הערב שילם יכול לתבוע את החייב בגין הסכום ששולם, בתוספת ריבית.' } },
    { '@type': 'Question', name: 'מה קורה לערבות אם החייב הגיש לחדלות פירעון?', acceptedAnswer: { '@type': 'Answer', text: 'כשחייב מגיש לחדלות פירעון, הנושה יכול לפנות לערב ישירות — ההליך של חדלות פירעון אינו מגן על הערב.' } },
    { '@type': 'Question', name: 'קיבלתי צו תשלומים כערב — מה עושים?', acceptedAnswer: { '@type': 'Answer', text: 'יש 20 יום להגיש התנגדות. ניתן להתנגד אם: לא ידעת על החוב, יש טענת התיישנות, אתה ערב מוגן והנושה לא ניסה לגבות מהחייב תחילה, או אם שונו תנאי ההלוואה ללא הסכמתך.' } },
  ],
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'מה לעשות אם קיבלת תביעה כערב בהוצאה לפועל',
  totalTime: 'PT3H',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'בדוק את סוג הערבות שלך', text: 'פתח את חוזה הערבות המקורי. האם הערבות היא לחוב אישי (לא עסקי) ועד 100,000 ₪? אם כן — ייתכן שאתה ערב מוגן עם הגנות נוספות.' },
    { '@type': 'HowToStep', position: 2, name: 'בדוק אם הנושה פנה קודם לחייב', text: 'אם אתה ערב מוגן, הנושה היה חייב לנסות לגבות מהחייב הראשי תוך 90 יום לפני שפנה אליך. אם לא — יש לך עילת הגנה.' },
    { '@type': 'HowToStep', position: 3, name: 'בדוק התיישנות', text: 'מתי נוצר החוב? מתי שלחו לך לראשונה תביעה? אם עברו יותר מ-7 שנים ולא הייתה פעולה — ייתכן שהחוב התיישן.' },
    { '@type': 'HowToStep', position: 4, name: 'בדוק אם תנאי ההלוואה שונו', text: 'האם הנושה הגדיל את סכום ההלוואה, האריך את תקופתה, או שינה ריבית ללא הסכמתך? שינוי מהותי יכול לשחרר אותך מהערבות.' },
    { '@type': 'HowToStep', position: 5, name: 'הגש התנגדות תוך 20 יום', text: 'אם יש לך עילת הגנה, הגש התנגדות לתיק ההוצאה לפועל תוך 20 יום מקבלת האזהרה. ציין את הנימוקים בכתב.' },
  ],
};
---

<GuideLayout
  title="ערב בהוצאה לפועל — זכויות, הגנות וצעדים דחופים"
  description="קיבלת תביעה כערב בהוצאה לפועל? מדריך מלא: ערב מוגן לפי חוק הערבות, התיישנות, ביטול ערבות, וצעדים שצריך לנקוט תוך 20 יום."
  breadcrumb={[
    { label: 'מדריכים', href: '/guides/' },
    { label: 'ערב בהוצאה לפועל', href: '/guides/arev/' },
  ]}
  schema={[faqSchema, howToSchema]}
  lastUpdated="מרץ 2026"
>

  <p class="lead">
    ערבת לחוב של חבר, בן משפחה, או שותף עסקי — ועכשיו ההוצאה לפועל פונה אליך?
    לפני שאתה משלם, חשוב לדעת: לערבים יש זכויות משמעותיות שרבים לא מודעים אליהן.
  </p>

  <div class="alert-box">
    ⏰ <strong>20 יום להגיב.</strong> אם קיבלת אזהרה מהוצאה לפועל — יש לך 20 יום בלבד להגיש התנגדות. אל תמתין.
  </div>

  <h2>שני סוגי ערבים — הגנות שונות לגמרי</h2>

  <div class="overflow-x-auto">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="bg-brand-pale">
          <th class="border border-neutral-border p-3 text-right font-bold">סוג ערב</th>
          <th class="border border-neutral-border p-3 text-right font-bold">מה מותר לנושה לעשות</th>
          <th class="border border-neutral-border p-3 text-right font-bold">ההגנה שלך</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-neutral-border p-3 font-medium">ערב רגיל</td>
          <td class="border border-neutral-border p-3">לפנות אליך מיד כשהחייב לא משלם</td>
          <td class="border border-neutral-border p-3">התיישנות, פגמים בחוזה, שינוי תנאים</td>
        </tr>
        <tr class="bg-green-50">
          <td class="border border-neutral-border p-3 font-medium text-green-800">ערב מוגן ✓</td>
          <td class="border border-neutral-border p-3">לפנות אליך רק אחרי שניסה לגבות מהחייב</td>
          <td class="border border-neutral-border p-3">כל ההגנות של ערב רגיל + חובת גבייה מהחייב תחילה</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>ערב מוגן — מה זה ואיך יודעים?</h2>

  <p>
    <strong>תיקון 1 לחוק הערבות</strong> קבע שיחיד שערב לחוב שאינו לצורך עסקי,
    בסכום שאינו עולה על 100,000 ₪ (מוצמד למדד), הוא <strong>ערב מוגן</strong>.
  </p>

  <p>כערב מוגן, הנושה חייב:</p>
  <ul>
    <li>לשלוח לך הודעה תוך 90 יום מהיום שהחייב פיגר בתשלום</li>
    <li>לנסות לגבות מהחייב הראשי לפני שפונה אליך</li>
    <li>לדווח לך מדי שנה על מצב החוב</li>
  </ul>

  <div class="bg-green-50 border border-green-200 rounded-xl p-4 my-4">
    <p class="text-sm text-green-800 font-medium">
      אם הנושה לא עמד בתנאים אלה — ייתכן שאתה פטור מהתשלום. פנה לעורך דין לבדיקה.
    </p>
  </div>

  <h2>התיישנות ערבות — 7 שנים</h2>

  <p>
    תקופת ההתיישנות על ערבות היא <strong>7 שנים</strong> מהיום שנוצרה עילת התביעה נגד הערב.
    אם הנושה לא פעל תוך 7 שנים — החוב עלול להיות מותיישן.
  </p>

  <p><strong>פעולות שמאפסות את שעון ההתיישנות:</strong></p>
  <ul>
    <li>הודאה בחוב בכתב</li>
    <li>ביצוע תשלום חלקי</li>
    <li>הגשת תביעה משפטית</li>
    <li>הצעת הסדר לנושה</li>
  </ul>

  <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 my-4">
    <p class="text-sm text-yellow-800">
      ⚠️ <strong>אל תשלם חלק מהחוב</strong> מבלי לקבל ייעוץ משפטי — תשלום חלקי יכול לאפס את ההתיישנות.
    </p>
  </div>

  <h2>5 הגנות שיכולות לפטור אותך מהחוב</h2>

  <ol class="space-y-3">
    <li><strong>נושה לא עמד בחובת גבייה מהחייב תחילה</strong> — אם אתה ערב מוגן והנושה פנה אליך לפני שניסה לגבות מהחייב.</li>
    <li><strong>התיישנות</strong> — חלפו יותר מ-7 שנים ולא הייתה פעולה שאיפסה את ההתיישנות.</li>
    <li><strong>שינוי תנאי ההלוואה ללא הסכמתך</strong> — הגדלת סכום, הארכת תקופה, שינוי ריבית.</li>
    <li><strong>הנושה ויתר על בטוחות</strong> — ויתור על משכנתה שהייתה מכסה את החוב משחרר את הערב באותו שיעור.</li>
    <li><strong>פגמים בחוזה הערבות</strong> — חוזה שנחתם תחת לחץ, ללא הבנה מספקת, או ללא גילוי נאות.</li>
  </ol>

  <h2>מה עושים עכשיו — 5 צעדים</h2>

  <ol class="space-y-4">
    <li><strong>אסוף את כל המסמכים</strong> — חוזה הערבות המקורי, חוזה ההלוואה, כל ההתכתבויות עם הנושה.</li>
    <li><strong>בדוק את תאריכי החוב</strong> — מתי נוצר החוב? מתי פיגר החייב? מתי קיבלת הודעה?</li>
    <li><strong>בדוק אם הנושה פנה לחייב תחילה</strong> — בקש תיעוד ניסיונות הגבייה מהחייב הראשי.</li>
    <li><strong>הגש התנגדות תוך 20 יום</strong> — דרך אתר רשות האכיפה והגבייה.</li>
    <li><strong>פנה לסיוע משפטי</strong> — הלשכה לסיוע משפטי מציעה ייעוץ חינמי לזכאים.</li>
  </ol>

  <h2>שאלות נפוצות</h2>

  <details class="faq-item">
    <summary>מה ההבדל בין ערב רגיל לערב מוגן?</summary>
    <p>ערב רגיל — הנושה יכול לפנות אליו מיד. ערב מוגן — הנושה חייב קודם לנסות לגבות מהחייב הראשי. ערב מוגן הוא יחיד שערב לחוב שאינו עסקי, עד 100,000 ₪.</p>
  </details>

  <details class="faq-item">
    <summary>האם יש התיישנות על ערבות?</summary>
    <p>כן — 7 שנים. הודאה בחוב, תשלום חלקי, או תביעה משפטית מאפסים את השעון. אל תשלם כלום לפני ייעוץ משפטי.</p>
  </details>

  <details class="faq-item">
    <summary>האם אפשר לבטל ערבות?</summary>
    <p>ביטול אפשרי אם הנושה שינה תנאי ההלוואה ללא הסכמתך, ויתר על בטוחות, או אם יש פגמים בחוזה. פנה לעורך דין.</p>
  </details>

  <details class="faq-item">
    <summary>שילמתי כערב — האם אני יכול לתבוע את החייב?</summary>
    <p>כן. חוק הערבות מעניק לך זכות חזרה — תוכל לתבוע את החייב הראשי בגין הסכום ששולמת, בתוספת ריבית.</p>
  </details>

  <details class="faq-item">
    <summary>מה קורה אם החייב הגיש לחדלות פירעון?</summary>
    <p>חדלות פירעון לא מגינה על הערב. הנושה יכול לפנות אליך ישירות גם אז. אם תשלם, תוכל להגיש תביעת חוב בתיק חדלות הפירעון.</p>
  </details>

  <details class="faq-item">
    <summary>קיבלתי צו תשלומים כערב — מה עושים?</summary>
    <p>יש 20 יום להגיש התנגדות. אפשר להתנגד אם יש טענת התיישנות, אתה ערב מוגן והנושה לא ניסה קודם לגבות מהחייב, או אם שונו תנאי ההלוואה ללא הסכמתך.</p>
  </details>

</GuideLayout>
