---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const categories = [
  {
    name: 'קיבלתי מכתב — מה עושים?',
    icon: '✉️',
    guides: [
      { title: 'קיבלתי מכתב מהוצאה לפועל', href: '/guides/michtav-hotzaa/', kw: '6,200/חודש' },
      { title: 'בדיקת תיק הוצאה לפועל — כל הדרכים', href: '/guides/bdika-tik/', kw: '8,000/חודש' },
      { title: 'לשכת הוצאה לפועל — המדריך המלא', href: '/guides/lishkat-hotzaa/', kw: '5,000/חודש' },
    ]
  },
  {
    name: 'עיקולים',
    icon: '🔒',
    guides: [
      { title: 'עיקלו לי את חשבון הבנק — מה עושים?', href: '/guides/ikul-heshbon/', kw: '9,500/חודש' },
      { title: 'עיקול משכורת — מתי מותר ואיך מבטלים', href: '/guides/ikul-maskoret/', kw: '5,800/חודש' },
      { title: 'עיקול על נכסים — דירה ורכב', href: '/guides/ikul-nechassim/', kw: '' },
      { title: 'עיקול רכב בהוצאה לפועל — מה מותר ואיך מבטלים', href: '/guides/ikul-rechev/', kw: '3,800/חודש' },
      { title: 'עיקול דירה ומקרקעין — הגנות וזכויות', href: '/guides/ikul-dira/', kw: '5,200/חודש' },
      { title: 'עיקול פנסיה וקצבאות — מה מוגן', href: '/guides/ikul-pensiya/', kw: '4,500/חודש' },
      { title: 'כינוס נכסים — מה זה ואיך עוצרים את זה', href: '/guides/kinnus-nechasim/', kw: '4,200/חודש' },
      { title: 'איך מבטלים עיקול', href: '/guides/bitul-ikul/', kw: '8,200/חודש' },
    ]
  },
  {
    name: 'הסדרת החוב',
    icon: '🤝',
    guides: [
      { title: 'בקשה לצו תשלומים — איך מגישים לבד', href: '/guides/tzav-tashlumim/', kw: '5,100/חודש' },
      { title: 'הסדר חוב עם נושים — משא ומתן ומחיקה', href: '/guides/hisdurim-chov/', kw: '7,800/חודש' },
      { title: 'ריבית בהוצאה לפועל — חישוב ועצירה', href: '/guides/ribit-hotzaa/', kw: '5,000/חודש' },
      { title: 'איחוד תיקים בהוצאה לפועל', href: '/guides/ichud-tikim/', kw: '3,800/חודש' },
      { title: 'חייב מוגבל באמצעים — מה עושים', href: '/guides/hayav-mugbal/', kw: '' },
    ]
  },
  {
    name: 'הגבלות על החייב',
    icon: '⚠️',
    guides: [
      { title: 'עיכוב יציאה מהארץ — המדריך המלא', href: '/guides/ikul-yetzia/', kw: '4,400/חודש' },
      { title: 'ביטול הגבלות בהוצאה לפועל — המדריך המלא', href: '/guides/bitul-hagbalot/', kw: '4,500/חודש' },
      { title: 'עיקול זמני — מה זה ואיך מבטלים', href: '/guides/ikul-zman/', kw: '3,800/חודש' },
      { title: 'הגבלת רישיון נהיגה — בוטלה! (תיקון 69)', href: '/guides/rishayon-nehiga/', kw: '' },
    ]
  },
  {
    name: 'הליכים משפטיים',
    icon: '⚖️',
    guides: [
      { title: 'ערב בהוצאה לפועל — זכויות והגנות', href: '/guides/arev/', kw: '3,500/חודש' },
      { title: 'ערעור על החלטת הוצאה לפועל', href: '/guides/irur-hotzaa/', kw: '2,900/חודש' },
      { title: 'פסק דין בהוצאה לפועל — מה לעשות', href: '/guides/psak-din/', kw: '8,000/חודש' },
      { title: 'עורך דין הוצאה לפועל — מתי צריך', href: '/guides/orech-din/', kw: '6,000/חודש' },
      { title: 'חקירת יכולת — מה זה ואיך להתכונן', href: '/guides/hakirat-yecholet/', kw: '3,600/חודש' },
      { title: 'התנגדות לתיק הוצאה לפועל', href: '/guides/hitnagdut-letik/', kw: '2,900/חודש' },
      { title: 'התיישנות חוב — האם החוב שלי עוד תקף?', href: '/guides/hitiyashnoot-chov/', kw: '3,200/חודש' },
    ]
  },
  {
    name: 'מדריכים מיוחדים',
    icon: '📋',
    guides: [
      { title: 'הוצאה לפועל לעצמאים — מדריך לבעלי עסקים', href: '/guides/atzmait/', kw: '2,400/חודש' },
      { title: 'חוב ארנונה — עיקולים, הנחות וזכויות', href: '/guides/chov-arnona/', kw: '3,100/חודש' },
      { title: 'פשיטת רגל בישראל — מה השתנה ואיך מגישים', href: '/guides/pshitat-regel/', kw: '5,900/חודש' },
      { title: 'סגירת תיק הוצאה לפועל — כיצד ומתי', href: '/guides/sgor-tik/', kw: '2,600/חודש' },
      { title: 'מזונות בהוצאה לפועל — עיקולים, גבייה וזכויות', href: '/guides/mazamot/', kw: '6,500/חודש' },
    ]
  },
  {
    name: 'חוקים ועדכונים 2025–2026',
    icon: '📰',
    guides: [
      { title: 'תיקון 9 לחוק ריבית — מה השתנה מינואר 2025', href: '/guides/tikunim-2025/', kw: '2,800/חודש' },
    ]
  },
];

// CollectionPage schema — נבנית אוטומטית מכל המדריכים שמוצגים בעמוד
const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'מדריכים לחייבים — הוצאה לפועל בעברית פשוטה',
  description: 'מדריכים מפורטים לכל שלב בהוצאה לפועל — עיקולים, הסדרים, זכויות. כתוב בשפה פשוטה, עדכני ל-2026.',
  inLanguage: 'he',
  url: 'https://hotzaa-lapoal.info/guides/',
  hasPart: categories.flatMap(cat =>
    cat.guides.map(g => ({
      '@type': 'Article',
      name: g.title,
      url: `https://hotzaa-lapoal.info${g.href}`,
    }))
  ),
};
---

<BaseLayout
  title="מדריכים לחייבים — הוצאה לפועל בעברית פשוטה"
  description="מדריכים מפורטים לכל שלב בהוצאה לפועל — עיקולים, הסדרים, זכויות. כתוב בשפה פשוטה, עדכני ל-2026."
  schema={schema}
>
  <Header />
  <main id="main-content" class="max-w-4xl mx-auto px-4 py-10">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-brand-dark mb-2">מדריכים לחייבים</h1>
      <p class="text-gray-500">כתוב בשפה פשוטה — בלי ז'רגון משפטי</p>
      <span class="inline-block mt-2 px-3 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full border border-green-200">עדכני לתיקון 9 — מרץ 2026</span>
    </div>

    <!-- חיפוש + ניווט מהיר בין קטגוריות -->
    <div class="mb-8">
      <label for="guides-search" class="sr-only">חיפוש מדריך</label>
      <input
        id="guides-search"
        type="search"
        inputmode="search"
        autocomplete="off"
        placeholder="🔍 חיפוש מדריך (למשל: עיקול רכב, ערב, מזונות)…"
        class="w-full border border-neutral-border rounded-xl px-4 py-3 text-base focus:ring-2 focus:ring-brand focus:outline-none mb-4"
      />
      <div class="flex flex-wrap gap-2">
        {categories.map((cat, i) => (
          <a href={`#cat-${i}`} class="flex items-center gap-1.5 px-3 py-1.5 bg-white border border-neutral-border rounded-full text-sm text-gray-600 hover:border-brand hover:text-brand-dark transition-all">
            <span>{cat.icon}</span><span>{cat.name}</span>
          </a>
        ))}
      </div>
      <p id="guides-noresults" class="hidden mt-3 text-sm text-gray-500">
        לא נמצא מדריך תואם. נסו ניסוח אחר, או <a href="/tools/chatbot/" class="text-brand underline">שאלו את הצ'אטבוט</a>.
      </p>
    </div>

    <div class="space-y-10">
      {categories.map((cat, i) => (
        <section id={`cat-${i}`} class="scroll-mt-24">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-xl">{cat.icon}</span>
            <h2 class="text-lg font-bold text-brand-dark">{cat.name}</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {cat.guides.map(g => (
              <a
                href={g.href}
                class="flex items-start justify-between gap-4 p-4 bg-white border border-neutral-border rounded-xl hover:border-brand hover:bg-brand-pale transition-all group"
              >
                <div class="flex-1">
                  <h3 class="text-sm font-bold text-gray-800 group-hover:text-brand-dark transition-colors leading-snug">
                    {g.title}
                  </h3>
                </div>
                <span class="text-brand-dark text-base mt-0.5 group-hover:translate-x-[-4px] transition-transform flex-shrink-0">←</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>

  <script>
    const input = document.getElementById('guides-search');
    const noResults = document.getElementById('guides-noresults');
    const sections = Array.from(document.querySelectorAll('main section[id^="cat-"]'));
    const norm = (s) => (s || '').toLowerCase();
    input?.addEventListener('input', () => {
      const q = norm(input.value.trim());
      let anyVisible = false;
      sections.forEach(sec => {
        let secVisible = false;
        sec.querySelectorAll('a[href^="/guides/"], a[href^="/insolvency/"], a[href^="/rights/"], a[href^="/forms/"]').forEach(card => {
          const match = !q || norm(card.textContent).includes(q);
          card.style.display = match ? '' : 'none';
          if (match) secVisible = true;
        });
        sec.style.display = secVisible ? '' : 'none';
        if (secVisible) anyVisible = true;
      });
      if (noResults) noResults.classList.toggle('hidden', anyVisible || !q);
    });
  </script>

  <Footer />
</BaseLayout>
