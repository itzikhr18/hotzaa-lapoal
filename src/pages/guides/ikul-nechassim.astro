---
import GuideLayout from '../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'האם יכולים לעקל את הדירה שאני גר בה?',
      acceptedAnswer: { '@type': 'Answer', text: 'ניתן לרשום עיקול רישומי על דירת מגורים ראשית, אבל ממוש (מכירה כפויה) הוא הליך מורכב מאוד הדורש אישור בית משפט. כאשר מדובר בדירה יחידה, בני משפחה המתגוררים בה, או קטינים — בתי המשפט מהססים מאוד ורף ההוכחה לנושה גבוה מאוד. תהליך שלם יכול לקחת שנים.' },
    },
    {
      '@type': 'Question',
      name: 'האם יכולים לעקל רכב שמשמש לעבודה?',
      acceptedAnswer: { '@type': 'Answer', text: 'ניתן לרשום עיקול על רכב, אך אם הרכב נחוץ לפרנסה — כגון נהג, שליח, עצמאי, או מי שאין לו תחבורה ציבורית סבירה למקום עבודתו — ניתן לבקש מרשם ההוצאה לפועל הגנה על הרכב. יש להגיש בקשה עם מסמכים המוכיחים את הנחיצות. אם הרכב עוקל ונגרר, ניתן לבקש את שחרורו בהקדם.' },
    },
    {
      '@type': 'Question',
      name: 'מה ההבדל בין עיקול רישומי לממוש?',
      acceptedAnswer: { '@type': 'Answer', text: 'עיקול רישומי מונע מכירה או העברת בעלות בנכס, אך אינו מוציא אותך ממנו — אתה ממשיך לגור בדירה ולהשתמש ברכב. ממוש הוא מכירה כפויה בפועל — שלב הרבה יותר מורכב הדורש הליכים משפטיים נוספים, שמאות, ואישורים. רוב הנושים מעדיפים להגיע להסדר לפני שלב הממוש.' },
    },
    {
      '@type': 'Question',
      name: 'כמה זמן עד שמוכרים נכס מעוקל?',
      acceptedAnswer: { '@type': 'Answer', text: 'בדירת מגורים — התהליך מרגע הגשת בקשת הממוש ועד למכירה בפועל יכול לקחת בין שנה לשלוש שנים, לעיתים אף יותר. עיכובים נוצרים בשל שמיעות בבית משפט, שמאות, ערעורים, ופרסום מכרז. בממוש רכב התהליך מהיר יותר — כמה חודשים — אבל גם שם ניתן לעכב באמצעות בקשות שחרור והגנה.' },
    },
    {
      '@type': 'Question',
      name: 'מה זה נכס פטור מעיקול?',
      acceptedAnswer: { '@type': 'Answer', text: 'חוק ההוצאה לפועל מגדיר נכסים שלא ניתן לעקל כלל: ציוד עבודה הכרחי לפרנסה (עד תקרת שווי מסוימת), רהיטים בסיסיים ומוצרי חשמל חיוניים לבית, ציוד רפואי ועזרי ניידות, ספרי לימוד, מזון, וביגוד. כמו כן, חלק מהכנסה פטור מעיקול — בשנת 2025 הסכום המוגן הוא 6,247.67 ₪ לחודש (שכר המינימום).' },
    },
    {
      '@type': 'Question',
      name: 'איך מגישים התנגדות לעיקול נכס?',
      acceptedAnswer: { '@type': 'Answer', text: 'להתנגד לעיקול יש להגיש בקשה מתאימה לרשם ההוצאה לפועל. לעיקול רכב שמשמש לעבודה — טופס בקשה לשחרור עיקול רכב (טופס 8 או בקשה חופשית). להגנה על דירה — בקשה לביטול בקשת ממוש עם תצהיר ומסמכים. בכל מקרה מומלץ לצרף ראיות (תלושי שכר, חוזה עבודה, חוות דעת רפואית לפי הצורך).' },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם מוכרים את הנכס המעוקל — לאן הולך הכסף?',
      acceptedAnswer: { '@type': 'Answer', text: 'לאחר מכירה פומבית של נכס מעוקל, התמורה מחולקת לפי סדר עדיפויות: קודם כל עלויות ההליך (שמאות, עמלות, פרסום), לאחר מכן חובות בעלי עדיפות (משכנתא, מזונות, רשויות מס), ורק לאחר מכן שאר הנושים. אם נותר עודף לאחר פרעון כל החובות — הוא מוחזר לחייב.' },
    },
  ],
};
---

<GuideLayout
  title="עיקול על נכסים — דירה ורכב בהוצאה לפועל"
  description="מאיימים לעקל את הדירה או הרכב שלך? מה ההגנות החוקיות, מתי ניתן לממש נכסים, אילו נכסים פטורים לחלוטין מעיקול, ומה עושים כדי להגן על עצמך — מדריך מלא בעברית פשוטה."
  breadcrumb={[{ label: 'מדריכים', href: '/guides/' }, { label: 'עיקול נכסים', href: '/guides/ikul-nechassim/' }]}
  publishDate="2025-03-01"
  updateDate="2026-03-31"
  readTime="12 דקות"
  schema={[faqSchema, {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'איך להגן על נכסים מפני עיקול בהוצאה לפועל',
    description: 'צעדים מעשיים להגנה על דירה ורכב מפני עיקול וממוש',
    totalTime: 'P14D',
    step: [
      { '@type': 'HowToStep', position: 1, name: 'זהה את סוג העיקול', text: 'האם זה עיקול רישומי (הערה בטאבו/רשיון רכב) או בקשת ממוש? עיקול רישומי — אתה ממשיך להשתמש בנכס. ממוש — דורש פעולה מיידית.' },
      { '@type': 'HowToStep', position: 2, name: 'הגש בקשה לצו תשלומים מיד', text: 'הגש ללשכת ההוצאה לפועל בקשה לצו תשלומים. ברגע שיש צו פעיל ואתה עומד בו — לרוב לא ניתן לנקוט הליכי ממוש.' },
      { '@type': 'HowToStep', position: 3, name: 'הגש בקשת הגנה על הנכס', text: 'לרכב שמשמש לעבודה — הגש בקשה לשחרור עיקול עם מסמכים. לדירה — הגש התנגדות לממוש עם ציון ילדים קטינים, דירה יחידה.' },
      { '@type': 'HowToStep', position: 4, name: 'פנה לנושה ישירות', text: 'נושים מעדיפים לרוב הסדר תשלומים על פני הליך ממוש ארוך ויקר. פנה ישירות לנושה להסדר.' },
      { '@type': 'HowToStep', position: 5, name: 'שקול ייעוץ משפטי', text: 'בנושא דירה — ייצוג משפטי שווה את עלותו. פנה ללשכה לסיוע משפטי לייצוג חינמי אם אין אמצעים.' },
    ],
  }]}
>

  <p>
    האיום על דירה או רכב הוא אחד הדברים המפחידים ביותר בהוצאה לפועל. אבל חשוב לדעת:
    יש הבדל גדול בין <strong>עיקול רישומי</strong> לבין <strong>ממוש בפועל</strong> — והמעבר בין השניים
    הוא לא אוטומטי כלל. מעבר לכך, החוק הישראלי מגן על סוגים רבים של נכסים מפני עיקול לחלוטין.
  </p>

  <h2>שני סוגי עיקול שחשוב להכיר</h2>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-1">מה זה ממוש?</p>
    <p class="text-sm">
      <strong>ממוש</strong> = מכירה כפויה בפועל. כלומר — הנושה לא מסתפק בעיקול רישומי (שמונע ממך למכור),
      אלא מבקש מבית המשפט לאשר מכירה של הנכס, למצוא קונה, ולקחת את הכסף מהתמורה.
      זה השלב שכולם פוחדים ממנו — והוא הרבה פחות שכיח ממה שחושבים.
    </p>
  </div>

  <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-4 my-6">
    <div class="border-2 border-orange-200 bg-orange-50 rounded-xl p-5">
      <h3 class="font-bold text-orange-800 mb-2">עיקול רישומי</h3>
      <p class="text-sm text-gray-700 mb-3">רישום בטאבו (דירה) או ברשם הרכבים — מונע מכירה או העברת בעלות.</p>
      <ul class="text-sm text-gray-600 space-y-1">
        <li>✓ אתה ממשיך לגור בדירה</li>
        <li>✓ אתה ממשיך להשתמש ברכב</li>
        <li>✗ לא ניתן למכור ללא סילוק החוב</li>
      </ul>
    </div>
    <div class="border-2 border-red-200 bg-red-50 rounded-xl p-5">
      <h3 class="font-bold text-red-800 mb-2">ממוש הנכס</h3>
      <p class="text-sm text-gray-700 mb-3">מכירה כפויה בפועל — זה השלב שכולם פוחדים ממנו.</p>
      <ul class="text-sm text-gray-600 space-y-1">
        <li>✗ דורש אישור בית משפט</li>
        <li>✗ תהליך ארוך ויקר לנושה</li>
        <li>✗ ניתן להתנגד ולעכב</li>
      </ul>
    </div>
  </div>

  <h2>עיקול דירה — מה מגן עליך</h2>
  <p>
    ממוש דירת מגורים ראשית הוא אחד ההליכים הקשים ביותר לנושה לבצע בישראל.
    הנה הגורמים שמגנים עליך:
  </p>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">הגורמים שמקשים על ממוש הדירה:</p>
    <ul class="space-y-1">
      <li><strong>זו הדירה היחידה שלך</strong> — בית יחיד נהנה מהגנה משמעותית</li>
      <li><strong>ילדים קטינים מתגוררים בה</strong> — בתי המשפט מהססים מאוד</li>
      <li><strong>בן/בת זוג שלא חייב</strong> — דורש הסכמתו/ה</li>
      <li><strong>החוב קטן ביחס לשווי הדירה</strong> — הרשם עשוי לדחות</li>
      <li><strong>שמאות + הוצאות משפטיות</strong> — עולה לנושה הרבה כסף</li>
    </ul>
  </div>

  <p>
    בפועל — רוב הנושים מעדיפים להגיע להסדר תשלומים מאשר לעבור את כל הבירוקרטיה
    של ממוש דירה. הכלי הכי חזק שלך הוא לפנות לרשם ולהציע צו תשלומים <strong>לפני</strong>
    שמגיעים לשלב הממוש.
  </p>

  <h2>עיקול דירה — מתי זה יכול לקרות ומתי לא</h2>

  <p>
    עיקול דירה מתחיל ברישום הערת אזהרה בלשכת רישום המקרקעין (טאבו). הרישום נעשה על בסיס בקשת הנושה
    ואינו דורש הסכמתך. עם זאת — הרישום בלבד אינו מוציא אותך מהדירה, ואינו מאפשר לנושה למכור אותה ללא
    עמידה בתנאים חוקיים קפדניים.
  </p>

  <div class="warn-box">
    <p class="font-semibold text-amber-800 mb-2">מתי ניתן לרשום עיקול על דירה?</p>
    <ul class="space-y-1 text-sm">
      <li>קיים פסק דין חלוט נגדך, או תיק הוצאה לפועל פתוח</li>
      <li>הנושה הגיש בקשה לרשם ההוצאה לפועל</li>
      <li>לנושה אין בטוחות אחרות מספיקות לגביית החוב</li>
    </ul>
  </div>

  <div class="tip-box">
    <p class="font-semibold mb-2">מתי לא ניתן לממש (למכור) דירת מגורים?</p>
    <ul class="space-y-1 text-sm">
      <li><strong>דירה יחידה + חוב קטן</strong> — כאשר החוב אינו פרופורציונלי לשווי הנכס, הרשם עשוי לסרב לבקשת ממוש</li>
      <li><strong>קטינים או נכים מתגוררים בדירה</strong> — נדרשת הגנה מיוחדת ואישור ערכאה גבוהה יותר</li>
      <li><strong>בעלות משותפת עם צד שלישי שאינו חייב</strong> — חלקו של הצד השלישי אינו ניתן לעיקול</li>
      <li><strong>משכנתא גדולה מהשווי</strong> — אם אין עודף לאחר פרעון המשכנתא, ממוש אינו כלכלי לנושה</li>
    </ul>
  </div>

  <h2>שלבי ממוש דירה — למה זה לוקח זמן</h2>

  <ol class="step-list">
    <li><span class="step-num">1</span><span>רישום עיקול בטאבו</span></li>
    <li><span class="step-num">2</span><span>הגשת בקשה לממוש לרשם ההוצאה לפועל</span></li>
    <li><span class="step-num">3</span><span>שמיעת עמדת החייב ובני ביתו — <strong>כאן אפשר להתנגד</strong></span></li>
    <li><span class="step-num">4</span><span>שמאות לקביעת שווי הנכס (על חשבון הנושה)</span></li>
    <li><span class="step-num">5</span><span>פרסום מכרז ומכירה פומבית</span></li>
    <li><span class="step-num">6</span><span>תשלום לנושים לפי סדר עדיפויות</span></li>
  </ol>

  <p>
    כל התהליך יכול לקחת <strong>שנים</strong> — ועולה לנושה עשרות אלפי שקלים.
  </p>

  <h2>עיקול רכב — כיצד זה עובד בפועל</h2>

  <p>
    עיקול רכב פשוט יותר מבחינה טכנית מאשר עיקול דירה — הוא נרשם ברשם הרכבים ולא בטאבו.
    אבל ישנן שתי דרגות של עיקול רכב שחשוב להבדיל ביניהן:
  </p>

  <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-4 my-6">
    <div class="border-2 border-blue-200 bg-blue-50 rounded-xl p-5">
      <h3 class="font-bold text-blue-800 mb-2">עיקול רישומי על רכב</h3>
      <p class="text-sm text-gray-700 mb-3">רישום ברשם הרכבים בלבד — הרכב נשאר אצלך.</p>
      <ul class="text-sm text-gray-600 space-y-1">
        <li>✓ ממשיך להשתמש ברכב</li>
        <li>✓ ממשיך לנסוע לעבודה</li>
        <li>✗ לא ניתן למכור ללא סילוק החוב</li>
        <li>✗ לא ניתן להעביר בעלות</li>
      </ul>
    </div>
    <div class="border-2 border-red-200 bg-red-50 rounded-xl p-5">
      <h3 class="font-bold text-red-800 mb-2">תפיסה פיזית וגרירה</h3>
      <p class="text-sm text-gray-700 mb-3">הרכב נלקח פיזית — מגרר, מוחסן, ועשוי להימכר.</p>
      <ul class="text-sm text-gray-600 space-y-1">
        <li>✗ הרכב מוסר לחברת גרירה</li>
        <li>✗ עלויות חנייה ואחסון מצטברות</li>
        <li>✗ תהליך מכירה מהיר יחסית</li>
        <li>✓ ניתן לבקש שחרור מיידי</li>
      </ul>
    </div>
  </div>

  <h3>מה קורה כאשר גוררים את הרכב?</h3>
  <p>
    כאשר ניתן צו לתפיסת רכב פיזית, הנושה מזמין גרירה לרכב בתיאום עם ההוצאה לפועל.
    הרכב מועבר למגרש חנייה מאושר. מרגע הגרירה מתחילות להצטבר עלויות אחסון יומיות —
    ולכן חשוב לפעול מהר.
  </p>

  <ol class="step-list">
    <li><span class="step-num">1</span><span>קבלת הודעה על עיקול רכב מרשם ההוצאה לפועל</span></li>
    <li><span class="step-num">2</span><span>גרירת הרכב לחניון מאושר — עלות אחסון יומית מצטברת</span></li>
    <li><span class="step-num">3</span><span>הגשת בקשת שחרור מיידי אם הרכב נחוץ לעבודה</span></li>
    <li><span class="step-num">4</span><span>שמאות לקביעת שווי הרכב</span></li>
    <li><span class="step-num">5</span><span>מכירה פומבית (מכרז) — לרוב במחיר נמוך מהשוק</span></li>
  </ol>

  <div class="info-box">
    <p class="font-semibold text-blue-800 mb-2">מתי ניתן לבקש הגנה על הרכב:</p>
    <ul class="space-y-1">
      <li><strong>הרכב נחוץ לעבודה</strong> — נהג, שליח, עצמאי, או שאין תחבורה ציבורית</li>
      <li><strong>הרכב משמש לניוד אדם עם מוגבלות</strong> — בין אם החייב עצמו או בן משפחתו</li>
      <li><strong>שווי הרכב נמוך מאוד</strong> — ממוש לא משתלם לנושה</li>
      <li><strong>הרכב בבעלות משותפת</strong> — חלקו של הצד שאינו חייב אינו ניתן לעיקול</li>
    </ul>
    <p class="mt-2 text-sm">בקשת הגנה מוגשת לרשם ההוצאה לפועל עם הוכחות לנחיצות הרכב (תלוש שכר, חוזה עבודה, תצהיר מעביד).</p>
  </div>

  <h2>נכסים פטורים מעיקול — מה לא ניתן לגעת בו</h2>

  <p>
