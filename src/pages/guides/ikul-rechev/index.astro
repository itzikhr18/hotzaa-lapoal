---
import GuideLayout from '../../../layouts/GuideLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'מה ההבדל בין עיקול רישומי לעיקול ממשי על רכב?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'עיקול רישומי הוא רישום ברשות הרישוי שמונע מכירה או העברת בעלות — הרכב נשאר בידיך ואתה ממשיך לנהוג בו כרגיל. עיקול ממשי (כינוס) הוא תפיסה פיזית של הרכב, וזה שלב הרבה יותר חמור שדורש צו כינוס נסכים מיוחד מרשם ההוצאה לפועל. רוב החייבים נתקלים בעיקול רישומי בלבד — הרכב נשאר אצלם אבל לא ניתן למכרו.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם ניתן לעקל רכב שמשמש לעבודה?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'כן — ניתן לרשום עיקול רישומי על כל רכב, כולל רכב עבודה. אבל אם הרכב נחוץ לפרנסתך — למשל נהג, שליח, קבלן עצמאי, או עובד שאין לו תחבורה ציבורית סבירה — ניתן לבקש מרשם ההוצאה לפועל הגנה על הרכב ושחרורו מעיקול. יש להגיש בקשה עם מסמכים (חוזה עבודה, תלוש שכר, תצהיר) המוכיחים את הצורך. לעניין עיקול ממשי (תפיסה) — רכב עבודה מוגן יותר, ורשם לא יורה על כינוסו אם יש חלופות גבייה.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה קורה אם הרכב ממומן בהלוואה או בליסינג?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'אם הרכב ממומן בהלוואת רכב (רשום כבטוחה לטובת הבנק) או בליסינג (הרכב בבעלות חברת הליסינג) — הגוף המממן הוא בעל עדיפות חוקית על הרכב. בליסינג, הרכב אינו שייך לך כלל ולא ניתן לעקלו לטובת נושה אחר. בהלוואת רכב, הבנק המממן ירשם ראשון, והנושה בהוצאה לפועל מקבל רק את ה"זכות השיורית" — כלומר, מה שנשאר לאחר פרעון ההלוואה לבנק. לרוב אין ערך שיורי משמעותי.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם ניתן לעקל רכב שרשום על שם אחר (בן/בת זוג, הורה)?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ככלל לא — עיקול בהוצאה לפועל חל על נכסי החייב עצמו. אם הרכב רשום על שם בן/בת הזוג, הורה, או כל אדם אחר שאינו החייב — לא ניתן לעקלו ישירות. יש חריג: אם הנושה מוכיח שהעברת הרישום נעשתה לצורך הברחת נכסים (למשל, הועבר לאחרונה בלי תמורה), ניתן לבקש בטול עסקה בבית משפט. אך זה הליך משפטי נפרד, לא אוטומטי.',
      },
    },
    {
      '@type': 'Question',
      name: 'מה סף הערך — מתי רכב פטור מעיקול ממשי?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'חוק ההוצאה לפועל קובע שניתן לפטור רכב מכינוס (עיקול ממשי) אם שוויו נמוך מדי יחסית לחוב, או כאשר הרכב נחוץ לפרנסה. בפרקטיקה, רכבים ששוויים נמוך מ-50,000 ש"ח בערך (לפי הערכת שמאי) לא תמיד ממוּשִׁים כי עלויות ההליך (שמאות, גרירה, אחסנה, מכרז) עלולות לעלות על התמורה. אין סכום קבוע בחוק — הרשם שוקל כדאיות כלכלית בכל מקרה.',
      },
    },
    {
      '@type': 'Question',
      name: 'כמה זמן לוקח לבטל עיקול על רכב?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ביטול עיקול רישומי לאחר הסדר חוב: בדרך כלל 3–10 ימי עסקים מרגע הגשת הבקשה לרשם ההוצאה לפועל. הנושה צריך להגיש הודעת ביטול, ולאחריה מתעדכן הרישום ברשות הרישוי. אם קיבלת טופס 214 (אישור לצורכי מכירה) — זה מאפשר מכירה חרף העיקול. שחרור רכב שנגרר (עיקול ממשי) — ניתן לבקש מיידית, אך עלול לדרוש הפקדת ערובה.',
      },
    },
    {
      '@type': 'Question',
      name: 'האם אפשר למכור רכב מעוקל?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'לא ניתן להעביר בעלות על רכב מעוקל ברשות הרישוי — הרישום חוסם זאת אוטומטית. כדי למכור את הרכב יש לקבל אישור מרשם ההוצאה לפועל (לרוב דרך טופס 214 — אישור לצורכי העברת בעלות), שמאפשר ביצוע המכירה בתנאי שחלק מהתמורה מועבר לסגירת החוב. אפשרות נוספת: לסגור את החוב ולבטל את העיקול, ואז לנהל את המכירה בחופשיות.',
      },
    },
  ],
};

const howToSchema = {
