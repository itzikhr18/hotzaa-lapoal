const title = "התיישנות חוב בהוצאה לפועל — המדריך המלא 2025";
const description = "חוב ישן מעל 7 שנים עשוי להיות מוגן מגבייה. מה זה התיישנות חוב, איך בודקים, ואיך מגישים טענת התיישנות — מדריך מלא ומעודכן.";
const publishDate = "2026-03-28";
const updateDate = "2026-03-28";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishDate,
  "dateModified": updateDate,
  "inLanguage": "he",
