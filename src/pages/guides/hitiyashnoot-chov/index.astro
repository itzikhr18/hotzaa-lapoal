const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "מה זה התיישנות חוב?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "התיישנות חוב היא עקרון משפטי לפיו לאחר שחלף פרק זמן מוגדר בחוק ללא פעולה משפטית, הנושה מאבד את הזכות לאכוף את החוב דרך בית המשפט. בישראל, על פי חוק ההתיישנות תשי\"ח-1958, תקופת ההתיישנות הרגילה לחובות אזרחיים היא 7 שנים מיום שנולדה עילת התביעה."
      }
    },
    {
      "@type": "Question",
      "name": "כמה שנים עד שחוב מתיישן בישראל?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "לרוב החובות האזרחיים — 7 שנים מיום שנוצרה עילת התביעה (לרוב מועד הפירעון האחרון). לחוב שכבר קיבל פסק דין חלוט — 25 שנה. לחובות מס ולחובות ממשלתיים מסוימים — כללים שונים. חשוב לבדוק בכל מקרה לגופו."
      }
    },
    {
      "@type": "Question",
      "name": "האם החוב נעלם אוטומטית אחרי 7 שנים?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "לא. התיישנות אינה אוטומטית ואינה מוחקת את החוב. על החייב לטעון אקטיבית את טענת ההתיישנות בפני רשם ההוצאה לפועל או בית המשפט, בתוך 20 יום מקבלת האזהרה. אם לא מגישים התנגדות בזמן — הזכות נאבדת גם אם החוב ישן."
      }
    },
    {
      "@type": "Question",
      "name": "איך מגישים טענת התיישנות?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "יש להגיש התנגדות (טענת התיישנות) ללשכת ההוצאה לפועל בתוך 20 יום מקבלת מכתב האזהרה. בהתנגדות יש לציין את עילת ההתיישנות, לצרף ראיות (כגון תאריך תשלום אחרון), ולבקש עיכוב הליכים. מומלץ להיעזר בעורך דין או בסיוע משפטי."
      }
    },
    {
      "@type": "Question",
      "name": "מה מפסיק את מניין ההתיישנות?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "מניין ההתיישנות נפסק ומתחיל מחדש כאשר: החייב מבצע תשלום כלשהו (אפילו חלקי), החייב מודה בחוב בכתב, הנושה מגיש תביעה לבית המשפט, או בית המשפט נותן פסיקה בעניין. גם נסיבות מסוימות כמו קטינות, שהות בחו\"ל חוסר כושר משפטי עשויות לעכב את מניין ההתיישנות."
      }
    },
    {
      "@type": "Question",
      "name": "האם פסק דין גם מתיישן?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "כן, אך בתקופה ארוכה הרבה יותר — 25 שנה מיום מתן פסק הדין החלוט. כלומר, אם קיבל נגדך פסק דין ב-2005, הנושה יכול לפתוח בהליכי הוצאה לפועל עד שנת 2030. בפועל, מרבית פסקי הדין מנוצלים הרבה לפני כן."
      }
    },
    {
      "@type": "Question",
      "name": "האם חוב ישן משפיע על דוח האשראי?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "כן. רישומים שליליים בדוח האשראי נשארים למשך 7 שנים ממועד הרישום — ללא קשר למצב ההתיישנות של החוב עצמו. כלומר, גם אם חוב מוגן מגבייה בגלל התיישנות, הוא עדיין עשוי להופיע בדוח האשראי ולפגוע בדירוג."
      }
    }
  ]
};
