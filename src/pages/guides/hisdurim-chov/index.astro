    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-brand-pale text-brand-dark">
          <th class="border border-gray-300 p-2.5 text-right font-semibold">קריטריון</th>
          <th class="border border-gray-300 p-2.5 text-right font-semibold">הסדר חוב ישיר</th>
          <th class="border border-gray-300 p-2.5 text-right font-semibold"><a href="/guides/tzav-tashlumim/" class="underline">צו תשלומים</a></th>
