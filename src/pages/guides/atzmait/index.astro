---
// src/pages/guides/atzmait/index.astro
import GuideLayout from '../../../layouts/GuideLayout.astro';

const title = "הוצאה לפועל לעצמאים — המדריך המלא לבעלי עסקים";
const description = "עצמאי עם תיק הוצאה לפועל? יש הבדלים חשובים בין חייב שכיר לעצמאי. הנה מה שחייב לדעת — על חקירת יכולת, עיקול הכנסות, הגנה על ציוד, ומה קורה לעסק.";
const publishDate = "2026-03-26";
const updateDate = "2026-03-26";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishDate,
  "dateModified": updateDate,
  "inLanguage": "he",
  "author": {
    "@type": "Organization",
    "name": "הוצאהלפועל.info"
  },
  "publisher": {
    "@type": "Organization",
    "name": "הוצאהלפועל.info",
    "url": "https://hotzaa-lapoal.pages.dev"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://hotzaa-lapoal.pages.dev/guides/atzmait/"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "האם אפשר לעקל את חשבון העסק של עצמאי?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "כן. אם החוב הוא אישי (על שמך כאדם פרטי), ניתן לעקל גם חשבון עסקי שפתחת על שמך. אם העסק הוא חברה בע\"מ עם חשבון נפרד — המצב שונה, ויש להתייעץ עם עורך דין."
      }
    },
    {
      "@type": "Question",
      "name": "האם אפשר לעקל את ציוד העסק שלי?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ציוד שנחוץ לפרנסה בסיסית מוגן חלקית מעיקול — כמו כלי עבודה ספציפיים. אבל ציוד יקר ערך כמו משאיות, מכונות תעשייתיות או ציוד מחשוב יקר עשוי להיות נתון לעיקול. הגבול לא תמיד ברור וכדאי להתייעץ."
      }
    },
    {
      "@type": "Question",
      "name": "אני עצמאי עם הכנסה לא קבועה — איך קובעים את צו התשלומים שלי?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "בחקירת יכולת לעצמאי, הרשם מסתכל על ממוצע הכנסות של 6–12 חודשים אחרונים, לא על חודש ספציפי. חשוב להביא תיעוד מלא: דוחות רווח והפסד, תדפיסי חשבון, ואישורי מס הכנסה. הכנסה עונתית או לא סדירה ניתנת להסברה."
      }
    },
    {
      "@type": "Question",
      "name": "חוב של העסק שלי — האם זה גם חוב שלי אישית?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "תלוי במבנה העסק. עצמאי (עוסק מורשה / עוסק פטור) — החוב העסקי הוא גם חוב אישי שלך, ואין הפרדה. חברה בע\"מ — החוב של החברה אינו חוב אישי שלך, אלא אם חתמת ערבות אישית. זהו הבדל קריטי שמשפיע על כל ההליך."
      }
    },
    {
      "@type": "Question",
      "name": "האם עצמאי יכול להגיש לחדלות פירעון?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "כן. עצמאי שחובותיו עולים על 57,445 ש\"ח (נכון ל-2026) יכול להגיש בקשה לפתיחת הליכי חדלות פירעון — בדיוק כמו שכיר. ההליך כולל בחינת כל הנכסים, כולל נכסי העסק, ומסתיים בהפטר אם עומדים בתנאים."
      }
    }
  ]
};
---

<GuideLayout
  title={title}
  description={description}
  publishDate={publishDate}
  updateDate={updateDate}
  readTime="8 דקות"
  schema={[faqSchema, {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'מה עצמאי עם תיק הוצאה לפועל צריך לעשות',
    description: 'צעדים מעשיים לעצמאי שנפתח נגדו תיק הוצאה לפועל',
    totalTime: 'P30D',
    step: [
      { '@type': 'HowToStep', position: 1, name: 'הפרד בין נכסי עסק לנכסים אישיים', text: 'חשבון עסקי נפרד, כלי עבודה רשומים — נכסי פרנסה מוגנים. נכסים אישיים — ניתנים לעיקול.' },
      { '@type': 'HowToStep', position: 2, name: 'הגש בקשה לצו תשלומים', text: 'הגש ללשכת ההוצאה לפועל בקשה לצו תשלומים. ציין הכנסות עסקיות ועונתיות. הרשם יתחשב בתנודות של עצמאים.' },
      { '@type': 'HowToStep', position: 3, name: 'הגן על כלי העבודה', text: 'הגש לרשם בקשה לאי-עיקול כלי עבודה — מחשב, רכב עסקי, ציוד מקצועי. מוגנים בחוק אם נחוצים לפרנסה.' },
      { '@type': 'HowToStep', position: 4, name: 'שקול איחוד תיקים', text: 'כמה חובות לנושים שונים? בקש איחוד תיקים. תשלום אחד, עיקולים מוקפאים, עסק ממשיך לפעול.' },
      { '@type': 'HowToStep', position: 5, name: 'שקול ייעוץ על הפרדה משפטית', text: 'ייעוץ משפטי על הפרדה בין חובות עסקיים לאישיים. חובות חברה בע"מ — לרוב לא עוברים לחייב האישי.' },
    ],
  }]}
  breadcrumb={[
    { label: "מדריכים", href: "/guides/" },
    { label: "הוצאה לפועל לעצמאים", href: "/guides/atzmait/" }
  ]}
>

  <article class="guide-content" dir="rtl" lang="he">

    <div class="alert-box warning-box">
      <p>
        <strong>גילוי נאות:</strong> המידע במאמר זה הוא כללי בלבד ואינו מהווה ייעוץ משפטי.
        המצב של עצמאים בהוצאה לפועל מורכב במיוחד — לכל מקרה ספציפי יש להתייעץ עם עורך דין.
      </p>
    </div>

    <p class="lead-paragraph">
      עצמאי שנקלע לחובות עומד בפני אתגרים שונים משכיר.
      אין תלוש משכורת, ההכנסה לא קבועה, יש ציוד עסקי, לקוחות, וחשבונות בנק שמעורבבים
      לפעמים עם החשבון האישי. כל אלה משפיעים ישירות על הדרך שבה מתנהל תיק הוצאה לפועל נגדך.
    </p>

    <p>
      המדריך הזה מסביר את ההבדלים החשובים בין עצמאי לשכיר בהוצאה לפועל,
      ומה ניתן לעשות כדי להגן על העסק ועל הפרנסה.
    </p>

    <nav class="table-of-contents" aria-label="תוכן עניינים">
      <h2>תוכן עניינים</h2>
      <ol>
        <li><a href="#atzmait-vs-sachir">עצמאי מול שכיר — מה שונה?</a></li>
        <li><a href="#ikul-hachnasa">עיקול הכנסות עצמאי</a></li>
        <li><a href="#ikul-tziyud">עיקול ציוד ונכסי עסק</a></li>
        <li><a href="#hakira">חקירת יכולת לעצמאי — איך מתכוננים?</a></li>
        <li><a href="#hevra-baam">חברה בע"מ מול עוסק מורשה — הבדל קריטי</a></li>
        <li><a href="#protect">איך להגן על העסק?</a></li>
        <li><a href="#insolvency">חדלות פירעון לעצמאים</a></li>
        <li><a href="#rights">הזכויות שלך</a></li>
        <li><a href="#faq">שאלות נפוצות</a></li>
      </ol>
    </nav>

    <!-- סעיף 1 -->
    <section id="atzmait-vs-sachir">
      <h2>עצמאי מול שכיר — מה שונה?</h2>

      <p>
        כשנפתח תיק הוצאה לפועל נגד שכיר — הדרך ברורה יחסית: בודקים את המשכורת,
        מעקלים עד 25% ממנה, ומגיעים לצו תשלומים. עם עצמאי — זה מורכב הרבה יותר.
      </p>

      <div class="steps-container">

        <div class="step">
          <h3>הכנסה לא קבועה</h3>
          <p>
            אין תלוש משכורת חודשי קבוע. הכנסות יכולות להשתנות דרמטית בין חודש לחודש,
            בין עונה לעונה. זה מקשה על קביעת צו תשלומים ריאלי.
          </p>
        </div>

        <div class="step">
          <h3>חשבון בנק מעורב</h3>
          <p>
            הרבה עצמאים מנהלים הכנסות עסקיות בחשבון האישי — מה שמקשה על הפרדה בין
            "כסף של העסק" לבין "כסף שלי". לרשם ולזוכה — הכל נחשב.
          </p>
        </div>

        <div class="step">
          <h3>נכסים עסקיים</h3>
          <p>
            ציוד, מלאי, רכב עסקי, מחשבים — כל אלה יכולים להיות מושא לעיקול,
            בנוסף לנכסים האישיים. זה מאיים לא רק עליך אלא על יכולת הפרנסה שלך.
          </p>
        </div>

        <div class="step">
          <h3>חוב עסקי = חוב אישי (לעוסק מורשה)</h3>
          <p>
            אם אתה עוסק מורשה — אין הפרדה משפטית בין "אתה" לבין "העסק שלך".
            חוב שנצבר בעסק הוא חוב שלך אישית. זה שונה מחברה בע"מ.
          </p>
        </div>

      </div>
    </section>

    <!-- סעיף 2 -->
    <section id="ikul-hachnasa">
      <h2>עיקול הכנסות עצמאי</h2>

      <p>
        שכיר מוגן מעיקול על חלק מהמשכורת — עד 25% בלבד ניתן לעקל, והשאר מוגן.
        עצמאי — המצב שונה.
      </p>

      <p>
        מכיוון שאין "משכורת" מוגדרת, הזוכה יכול לנסות לעקל:
      </p>

      <ul>
        <li><strong>חשבון עסקי</strong> — אם הוא על שמך האישי, ניתן לעיקול כמו כל חשבון בנק</li>
        <li><strong>תשלומים מלקוחות</strong> — ניתן להטיל עיקול צד שלישי על לקוחות שחייבים לך כסף</li>
        <li><strong>תשלומים מביטוח לאומי</strong> — דמי אבטלה, קצבאות — חלקם מוגנים מעיקול</li>
      </ul>

      <div class="info-box">
        <h3>עיקול צד שלישי — מה זה?</h3>
        <p>
          הזוכה יכול לשלוח הודעת עיקול ישירות ל<strong>לקוחות שלך</strong> —
          ולדרוש מהם לשלם לו ישירות את הכסף שהם חייבים לך.
          זה כלי שכיח נגד עצמאים ויכול לפגוע קשה בתזרים העסקי.
          אם זה קורה — פנה לעורך דין בהקדם.
        </p>
      </div>

      <div class="tip-box">
        <h3>מה מוגן?</h3>
        <p>
          גם עצמאי זכאי לסכום מחיה מינימלי — לא ניתן לעקל כסף עד לסף מסוים
          שמאפשר קיום בסיסי. אבל ההגנה פחות ברורה מאשר לשכיר.
          <a href="/rights/skhomim-mugganim/">ראה: סכומים ונכסים מוגנים מעיקול</a>.
        </p>
      </div>

      <div class="info-box">
        <h3>הגנה על חשבון עסקי — ניתן לבקש</h3>
        <p>
          בקשת עיכוב עיקול, ניתן לבקש מהרשם <strong>הגנה על 50–70% מהחשבון העסקי</strong>
          כ"מקור פרנסה". זה לא אוטומטי — צריך לבקש במפורש ולנמק שהחשבון הכרחי
          לפעילות העסק ולפרנסה השוטפת. הגש את הבקשה בד בבד עם בקשת צו תשלומים.
        </p>
      </div>
    </section>

    <!-- סעיף 3 -->
    <section id="ikul-tziyud">
      <h2>עיקול ציוד ונכסי עסק</h2>

      <p>
        הזוכה יכול לבקש עיקול על נכסי העסק — ציוד, מלאי, רכב עסקי.
        אבל יש גבולות חשובים שהחוק מציב.
      </p>

      <p><strong>מה ניתן לעיקול:</strong></p>
      <ul>
        <li>ציוד יקר ערך שאינו הכרחי לפרנסה בסיסית</li>
        <li>מלאי מוצרים</li>
        <li>רכב עסקי (בתנאים מסוימים)</li>
        <li>ריהוט משרדי ומחשבים (מעבר לבסיסי)</li>
      </ul>

      <p><strong>מה מוגן (חלקית):</strong></p>
      <ul>
        <li>כלי עבודה בסיסיים שנחוצים ישירות לפרנסה — נגר, אינסטלטור, ספר</li>
        <li>ציוד רפואי לבעל מקצוע רפואי</li>
        <li>מחשב יחיד לעובד עצמאי שפרנסתו תלויה בו</li>
      </ul>

      <div class="alert-box warning-box">
        <p>
          <strong>שים לב:</strong> הגבול בין "כלי עבודה הכרחיים" לבין "ציוד הניתן לעיקול"
          אינו תמיד ברור. אם יש עיקול על ציוד שאתה חושב שמוגן — הגש בקשת ביטול עיקול
          מיד ופנה לעורך דין.
        </p>
      </div>
    </section>

    <!-- סעיף 4 -->
    <section id="hakira">
      <h2>חקירת יכולת לעצמאי — איך מתכוננים?</h2>

      <p>
        חקירת יכולת לעצמאי היא מורכבת יותר משכיר — כי צריך להוכיח הכנסה שאין לה
        תלוש אחד ברור. הנה מה להביא:
      </p>

      <ul>
        <li>
          <strong>דוחות רווח והפסד</strong> — של 12 חודשים אחרונים לפחות.
          אם אין — ניתן להכין עם רואה חשבון.
        </li>
        <li>
          <strong>תדפיסי חשבון בנק</strong> — עסקי ואישי, 6–12 חודשים אחרונים.
        </li>
        <li>
          <strong>אישורי מס הכנסה</strong> — שומות אחרונות, אישור על הכנסה שנתית.
        </li>
        <li>
          <strong>תשלומים לביטוח לאומי</strong> — אישור על גובה התשלומים החודשיים.
        </li>
        <li>
          <strong>הוצאות עסקיות קבועות</strong> — שכר דירה לעסק, ציוד, ספקים, משכורות עובדים.
        </li>
        <li>
          <strong>חובות עסקיים נוספים</strong> — הלוואות עסקיות, חובות לספקים.
        </li>
      </ul>

      <div class="tip-box">
        <h3>טיפ חשוב</h3>
        <p>
          הרשם מסתכל על <strong>הכנסה נטו ממוצעת</strong> — לא על החודש הטוב ביותר שלך.
          אם יש חודשים חלשים וחודשים חזקים — הראה את הממוצע האמיתי.
          הכנסה עונתית (למשל קייטרינג, מדריך סקי) ניתנת להסברה.
        </p>
        <p>
          <strong>דוגמה:</strong> הכנסה ברוטו 15,000 ש"ח פחות הוצאות עסקיות 9,000 ש"ח
          = נטו 6,000 ש"ח. הצו ייקבע על בסיס הנטו — לא הברוטו.
        </p>
      </div>

      <div class="info-box">
        <h3>צ'ק-ליסט מסמכים לחקירת יכולת — עצמאי</h3>
        <table class="data-table">
          <thead>
            <tr>
              <th>מסמך</th>
              <th>פירוט</th>
              <th>חובה / מומלץ</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>תדפיס בנק</td>
              <td>חשבון עסקי + פרטי, 6 חודשים אחרונים</td>
              <td>חובה</td>
            </tr>
            <tr>
              <td>דוח רווח והפסד</td>
              <td>12 חודשים אחרונים לפחות</td>
              <td>חובה</td>
            </tr>
            <tr>
              <td>חשבוניות</td>
              <td>20 חשבוניות אחרונות</td>
              <td>חובה</td>
            </tr>
            <tr>
              <td>דוחות מס</td>
              <td>טפסי 1301, 161, ודוחות מע"מ</td>
              <td>חובה</td>
            </tr>
            <tr>
              <td>רשימת הוצאות</td>
              <td>שכירות משרד, דלק, פרסום, ביטוח עסקי, תוכנות</td>
              <td>מומלץ מאוד</td>
            </tr>
          </tbody>
        </table>
        <p>
          <strong>אזהרה:</strong> הגשת שאלון ריק ללא מסמכים עלולה לגרור עיקול אוטומטי.
          אי-הצגת הוצאות עסקיות מביאה לצו תשלומים גבוה מהנדרש.
        </p>
      </div>
    </section>

    <!-- סעיף 5 -->
    <section id="hevra-baam">
      <h2>חברה בע"מ מול עוסק מורשה — הבדל קריטי</h2>

      <p>
        זה אחד ההבדלים החשובים ביותר שכל עצמאי חייב להבין:
      </p>

      <div class="steps-container">

        <div class="step">
          <h3>עוסק מורשה / עוסק פטור</h3>
          <p>
            אתה והעסק שלך הם <strong>אותו הדבר</strong> מבחינה משפטית.
            חוב עסקי = חוב אישי שלך. מי שנפתח נגדו תיק הוצאה לפועל — זה אתה, האדם.
            כל הנכסים שלך — אישיים ועסקיים — חשופים.
          </p>
        </div>

        <div class="step">
          <h3>חברה בע"מ</h3>
          <p>
            החברה היא ישות משפטית נפרדת ממך. חוב של החברה — אינו חוב אישי שלך,
            אלא אם <strong>חתמת ערבות אישית</strong> (מה שקורה לרוב מול בנקים).
            תיק הוצאה לפועל נגד חברה בע"מ מתנהל אחרת לגמרי.
          </p>
        </div>

      </div>

      <div class="alert-box info-box">
        <p>
          <strong>ערבות אישית — הסיכון הנסתר:</strong>
          רוב בעלי חברות קטנות חתמו ערבות אישית על הלוואות בנקאיות.
          במקרה כזה — גם אם החברה היא בע"מ, אתה אישית ערב לחוב
          והבנק יכול לתבוע אותך באופן אישי. בדוק מה חתמת.
        </p>
      </div>
    </section>

    <!-- סעיף 6 -->
    <section id="protect">
      <h2>איך להגן על העסק?</h2>

      <p>יש כמה צעדים שיכולים לעזור למזער נזקים:</p>

      <ol>
        <li>
          <strong>פתח חשבון עסקי נפרד</strong> — אם עדיין לא עשית זאת.
          הפרדה בין כספים אישיים לעסקיים עוזרת גם משפטית וגם מעשית.
        </li>
        <li>
          <strong>הגש בקשה לצו תשלומים מוקדם</strong> — לפני שמגיעים לעיקולים.
          צו תשלומים שאתה יוזם נותן לך שליטה על התהליך.
        </li>
        <li>
          <strong>תעד הכנסות והוצאות בסדר</strong> — תיעוד מסודר מחזק את עמדתך בחקירת יכולת.
        </li>
        <li>
          <strong>פנה לרואה חשבון</strong> — לפני חקירת יכולת, רואה חשבון יכול לעזור
          להציג את התמונה הכלכלית האמיתית בצורה הטובה ביותר.
        </li>
        <li>
          <strong>בדוק אפשרות לחדלות פירעון</strong> — אם החובות גבוהים ואין יכולת לשלם,
          חדלות פירעון יכולה להיות הפתרון שמסיים את ההליכים ומאפשר התחלה מחדש.
        </li>
      </ol>
    </section>

    <!-- סעיף 7 -->
    <section id="insolvency">
      <h2>חדלות פירעון לעצמאים</h2>

      <p>
        עצמאי שחובותיו עולים על <strong>57,445 ש"ח</strong> (נכון ל-2026)
        יכול לפתוח הליך חדלות פירעון — בדיוק כמו שכיר.
      </p>

      <p>
        ההליך בוחן את כל הנכסים — אישיים ועסקיים — ומגיע בסופו להפטר:
        מחיקת החובות שנותרו לאחר תקופת שיקום של כ-3 שנים.
      </p>

      <p>מה שחשוב לדעת לעצמאי:</p>

      <ul>
        <li>
          <strong>נכסי העסק נבחנים</strong> — ציוד, מלאי, קניין רוחני, כל מה ששייך לעסק
          נכנס לבחינה של הנאמן.
        </li>
        <li>
          <strong>ניתן להמשיך לעבוד</strong> — בתקופת חדלות פירעון אפשר להמשיך לעבוד
          כעצמאי ולהרוויח, תוך עמידה בתנאי תוכנית התשלומים.
        </li>
        <li>
          <strong>הגבלות בתקופת הביניים</strong> — עיכוב יציאה מהארץ, הגבלות על כרטיסי אשראי,
          חובת דיווח דו-חודשי על הכנסות.
        </li>
      </ul>

      <p>
        <a href="/insolvency/eligibility/">בדוק אם אתה זכאי לפתוח הליך חדלות פירעון</a> ←
      </p>

      <div class="tip-box">
        <h3>מסלול מקוצר — לחובות עד 25,000 ש"ח</h3>
        <p>
          אם סך חובותיך נמוך יחסית, ייתכן שאתה זכאי ל<strong>מסלול מקוצר</strong> —
          אגרה אחת שמכסה את כל ההליך, ותהליך מהיר של כ-8 חודשים בלבד.
          בדוק זכאות באתר ממשל זמין או בלשכת ההוצאה לפועל.
        </p>
      </div>
    </section>

    <!-- סעיף 8 -->
    <section id="rights">
      <h2>הזכויות שלך כעצמאי</h2>

      <ul>
        <li>
          <strong>הזכות לסכום מחיה מינימלי</strong> — גם עצמאי לא ניתן לדרוש ממנו לשלם
          כסף שמונע ממנו ומשפחתו קיום בסיסי.
        </li>
        <li>
          <strong>הזכות להגן על כלי עבודה בסיסיים</strong> — ציוד שנחוץ ישירות לפרנסה
          מוגן חלקית מעיקול.
        </li>
        <li>
          <strong>הזכות לצו תשלומים ריאלי</strong> — הרשם חייב לקחת בחשבון את
          אי-הסדירות של ההכנסה כעצמאי.
        </li>
        <li>
          <strong>הזכות לייצוג</strong> — עורך דין יכול לייצג אותך בכל שלב,
          כולל
          <a href="https://www.gov.il/he/departments/legal_aid" target="_blank" rel="noopener">
            סיוע משפטי חינם
          </a>
          בכפוף לזכאות.
        </li>
        <li>
          <strong>הזכות לערר</strong> — על כל החלטת רשם ניתן לערור לבית משפט השלום
          תוך 20 יום.
        </li>
      </ul>
    </section>

    <!-- שאלות נפוצות -->
    <section id="faq">
      <h2>שאלות נפוצות</h2>

      <div class="faq-list">

        <details class="faq-item">
          <summary>פתחתי עסק חדש אחרי שנוצר החוב — האם יעקלו אותו גם כן?</summary>
          <p>
            אם אתה עוסק מורשה — כן, כי אתה ועסקך הם אותו הדבר. הכנסות מהעסק החדש
            עשויות להיות נתונות לעיקול. אם פתחת חברה בע"מ חדשה — המצב שונה,
            אבל יש לשים לב לכל מעורבות אישית ולהתייעץ עם עורך דין.
          </p>
        </details>

        <details class="faq-item">
          <summary>יש לי עובדים — האם יפגע השכר שלהם?</summary>
          <p>
            שכר עובדים הוא התחייבות שלך כמעסיק ועדיפה על חובות אחרים בדרך כלל.
            אבל במצב של עיקול חשבון הבנק — ייתכן שלא תוכל להעביר שכר בזמן.
            זה מצב דחוף שדורש טיפול מיידי — פנה לעורך דין.
          </p>
        </details>

        <details class="faq-item">
          <summary>אני עצמאי עם חובות לרשויות (מס הכנסה, ביטוח לאומי) — זה שונה?</summary>
          <p>
            כן. חובות לרשויות המס ולביטוח לאומי הם חובות שנגבים לעיתים בהוצאה לפועל
            ולעיתים בהליכים מיוחדים לגבייה מנהלית. לרשויות סמכויות גבייה רחבות יותר
            מזוכה רגיל. מומלץ לטפל בחובות לרשויות בעדיפות גבוהה.
          </p>
        </details>

        <details class="faq-item">
          <summary>האם כדאי לסגור את העסק כדי להימנע מעיקולים?</summary>
          <p>
            סגירת עסק לא מוחקת את החובות שנצברו — היא רק מורידה את ההכנסה שממנה
            ניתן לשלם אותם. לעיתים זה פוגע יותר מאשר מועיל. לפני כל צעד כזה —
            התייעץ עם עורך דין שיבחן את כל ההשלכות.
          </p>
        </details>

        <details class="faq-item">
          <summary>לקוח שלי קיבל הודעת עיקול — מה עכשיו?</summary>
          <p>
            אם לקוח שלך קיבל צו עיקול צד שלישי, הוא חייב לשלם לזוכה ולא לך —
            עד לגובה החוב שלך. זה מצב שדורש פעולה מיידית: הגש בקשת עיכוב הליכים
            ופנה לעורך דין. לפעמים ניתן לבטל עיקול כזה אם יש בסיס להתנגדות.
          </p>
        </details>

      </div>
    </section>

