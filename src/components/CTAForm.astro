---
export interface Props {
  compact?: boolean;
  title?: string;
}
const { compact = false } = Astro.props;
---

<div class={`bg-brand-pale border border-brand-light rounded-xl p-5 ${compact ? '' : 'max-w-md mx-auto'}`}>
  <h3 class={`font-bold text-brand-dark mb-2 ${compact ? 'text-base' : 'text-lg'}`}>
    צריך עזרה משפטית?
  </h3>
  <p class="text-sm text-gray-600 mb-4">
    הגורמים הרשמיים הבאים מספקים סיוע חינמי או בעלות נמוכה:
  </p>
  <ul class="space-y-3 text-sm">
    <li>
      <a
        href="https://www.gov.il/he/departments/ministry_of_justice_legal_aid/govil-landing-page"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-brand hover:text-brand-dark hover:underline transition-colors font-medium"
      >
        ← הלשכה לסיוע משפטי — משרד המשפטים
      </a>
      <span class="text-xs text-neutral-muted">ייצוג חינמי לזכאים לפי הכנסה</span>
    </li>
    <li>
      <a
        href="https://www.kolzchut.org.il"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-brand hover:text-brand-dark hover:underline transition-colors font-medium"
      >
        ← כל-זכות — מידע על זכויות בישראל
      </a>
      <span class="text-xs text-neutral-muted">מידע משפטי מקיף בחינם</span>
    </li>
    <li>
      <a
        href="https://www.gov.il/he/departments/law_enforcement_and_collection_system_authority"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-brand hover:text-brand-dark hover:underline transition-colors font-medium"
      >
        ← רשות האכיפה והגבייה — אתר רשמי
      </a>
      <span class="text-xs text-neutral-muted">הגשת בקשות וטפסים רשמיים</span>
    </li>
  </ul>
</div>
