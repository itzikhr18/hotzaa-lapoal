---
import '../styles/global.css';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import LeadCaptureWidget from '../components/LeadCaptureWidget';
import { ADS_ENABLED, ADSENSE_CLIENT, AD_SLOTS } from '../data/ads';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  publishedTime?: string;
  modifiedTime?: string;
  articleSection?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const siteUrl = 'https://hotzaa-lapoal.info';

const {
  title,
  description,
  // ברירת מחדל: canonical נקי לפי pathname בלבד — בלי query string
  canonicalUrl = `${siteUrl}${Astro.url.pathname}`,
  ogTitle = title,
  ogDescription = description,
  ogImage = `${siteUrl}/og-image.png`,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  articleSection,
  schema,
  noindex = false,
} = Astro.props;

// זיהוי המותג בכל צורותיו — מרווח ("הוצאה לפועל"), צמוד ("הוצאהלפועל") או ראשי-תיבות ("הוצל״פ")
// כדי לא להוסיף סיומת מותג כפולה כשהכותרת כבר מכילה אותו
const hasBrand = /הוצאה ?לפועל|הוצל["'״]/.test(title);
const fullTitle = hasBrand ? title : `${title} | הוצאהלפועל.info`;
const schemas = Array.isArray(schema) ? schema : schema ? [schema] : [];

// AdSense נטען רק כשיש לפחות יחידת מודעה מוגדרת — אחרת הסקריפט מוריד ביצועים בחינם
const adsActive = ADS_ENABLED && Object.values(AD_SLOTS).some(Boolean);
---

<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="he" href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

  <!-- Geo -->
  <meta name="geo.region" content="IL" />
  <meta name="geo.placename" content="Israel" />
  <meta name="language" content="Hebrew" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:locale" content="he_IL" />
  <meta property="og:site_name" content="הוצאהלפועל.info" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:alt" content={ogTitle} />
  {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  {ogType === 'article' && articleSection && <meta property="article:section" content={articleSection} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={ogTitle} />

  {adsActive && (
    <>
      <!-- Preconnect for AdSense CDN -->
      <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
      <link rel="preconnect" href="https://googleads.g.doubleclick.net" />
      <link rel="dns-prefetch" href="https://www.googletagservices.com" />
    </>
  )}

  <!-- Fonts — self-hosted for zero CDN latency -->
  <link rel="preload" as="font" href="/fonts/assistant-hebrew.woff2" type="font/woff2" crossorigin />
  <link rel="preload" as="font" href="/fonts/assistant-latin.woff2" type="font/woff2" crossorigin />

  <!-- Favicon + PWA -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#1B4F72" />

  <!-- Schema.org JSON-LD -->
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- Google Search Console Verification -->
  <meta name="google-site-verification" content="X5NDXZCjqVjRvuyONLtPJ0UBFHrgFZRr-ybS83-hUWo" />
  <meta name="google-site-verification" content="S0rlBUmhG4a_Mtd6kXKk9PaMPyGMJN5xVDVh8cfJo1k" />

  <!-- Google Analytics 4 — data-cfasync="false" prevents Cloudflare Rocket Loader from deferring these scripts -->
  <script is:inline data-cfasync="false" async src="https://www.googletagmanager.com/gtag/js?id=G-5PKTGJZMWL"></script>
  <script is:inline data-cfasync="false">
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-5PKTGJZMWL');
  </script>

  <!-- Google AdSense — נטען רק כשיש יחידות מודעה מוגדרות (src/data/ads.ts) -->
  {adsActive && (
    <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`} crossorigin="anonymous"></script>
  )}
</head>
<body class="bg-neutral-bg text-gray-900 font-sans antialiased">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:right-2 focus:z-[10001] focus:bg-brand-dark focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg">דלג לתוכן הראשי</a>
  <AccessibilityWidget />
  <LeadCaptureWidget client:idle />
  <slot />

  {Astro.url.pathname !== '/tools/chatbot/' && (
    <a
      href="/tools/chatbot/"
      class="fixed bottom-5 left-5 z-40 bg-brand-dark hover:bg-brand-trust text-white rounded-full shadow-lg flex items-center gap-2 px-4 py-3 text-sm font-semibold transition-colors"
      aria-label="פתח את הצ'אטבוט — שאל שאלה"
    >
      <span aria-hidden="true" class="text-base">💬</span>
      <span>יש לי שאלה</span>
    </a>
  )}
</body>
</html>
