---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Disclaimer from '../components/Disclaimer.astro';
import CTAForm from '../components/CTAForm.astro';
import AdUnit from '../components/AdUnit.astro';
import { allGuides } from '../data/guides';

export interface Props {
  title: string;
  description: string;
  breadcrumb: { label: string; href: string }[];
  publishDate?: string;
  updateDate?: string;
  schema?: object | object[];
  readTime?: string;
  relatedGuides?: { title: string; href: string }[];
  sources?: { label: string; href: string }[];
  authorName?: string;
  authorTitle?: string;
  reviewerName?: string;
  reviewerTitle?: string;
  lastFactCheck?: string;
  actionLinks?: { label: string; href: string; note: string }[];
}

const defaultRelatedGuides = [
  { title: 'בדיקת תיק הוצאה לפועל', href: '/guides/bdika-tik/' },
  { title: 'עיקול חשבון בנק', href: '/guides/ikul-heshbon/' },
  { title: 'ביטול עיקול', href: '/guides/bitul-ikul/' },
  { title: 'טפסים ונוסחים', href: '/forms/' },
  { title: 'עיקול משכורת', href: '/guides/ikul-maskoret/' },
  { title: 'צו תשלומים', href: '/guides/tzav-tashlumim/' },
];

const defaultActionLinks = [
  { label: 'בדיקת תיק לפי תעודת זהות', href: '/guides/bdika-tik/', note: 'להבין מה פתוח נגדך' },
  { label: 'טפסים ונוסחים מוכנים', href: '/forms/', note: 'טופס 214, צו תשלומים ובקשות דחופות' },
  { label: 'בדיקת ריבית ויתרת חוב', href: '/tools/calculator/', note: 'קבלת יתרה רשמית והבנת רכיבי התיק' },
  { label: 'בדיקת מצב מהירה', href: '/tools/eligibility/', note: 'צו תשלומים, איחוד תיקים או חדלות פירעון' },
  { label: 'שאל את הצ׳אטבוט', href: '/tools/chatbot/', note: 'הכוונה כללית מיידית' },
];

const {
  title,
  description,
  breadcrumb,
  publishDate,
  updateDate,
  schema,
  readTime = '5 דקות',
  relatedGuides = defaultRelatedGuides,
  sources,
  authorName = 'מערכת הוצאהלפועל.info',
  authorTitle = 'עריכת תוכן משפטי לציבור',
  reviewerName,
  reviewerTitle,
  lastFactCheck = updateDate,
  actionLinks = defaultActionLinks,
} = Astro.props;

const defaultSources = [
  { label: 'רשות האכיפה והגבייה — gov.il', href: 'https://www.gov.il/he/departments/legalinfo/hotsaa_lapoal' },
  { label: 'כל-זכות — זכויות בהוצאה לפועל', href: 'https://www.kolzchut.org.il/he/%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%A4%D7%95%D7%A2%D7%9C' },
  { label: 'חוק ההוצאה לפועל, תשכ"ז-1967 — ספר החוקים', href: 'https://www.nevo.co.il/law_html/law01/055_247.htm' },
];

const pageSources = sources ?? defaultSources;
const usesGeneralSources = !sources;

const siteUrl = 'https://hotzaa-lapoal.info';

const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;

const articleSection = breadcrumb[0]?.label ?? 'מדריכים';

const authorSchema = authorName === 'מערכת הוצאהלפועל.info'
  ? {
      '@type': 'Organization',
      name: authorName,
      url: `${siteUrl}/about/`,
    }
  : {
      '@type': 'Person',
      name: authorName,
      jobTitle: authorTitle,
      url: `${siteUrl}/about/`,
    };

const reviewerSchema = reviewerName
  ? {
      '@type': 'Person',
      name: reviewerName,
      jobTitle: reviewerTitle,
    }
  : undefined;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  inLanguage: 'he',
  url: canonicalUrl,
  image: `${siteUrl}/og-image.png`,
  author: authorSchema,
  publisher: {
    '@type': 'Organization',
    name: 'הוצאהלפועל.info',
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: `${siteUrl}/og-image.png` },
  },
  datePublished: publishDate,
  dateModified: updateDate ?? publishDate,
  ...(reviewerSchema ? { reviewedBy: reviewerSchema } : {}),
  ...(lastFactCheck ? { lastReviewed: lastFactCheck } : {}),
  articleSection,
  genre: 'legal information',
  isAccessibleForFree: true,
  audience: { '@type': 'Audience', audienceType: 'חייבים בהוצאה לפועל בישראל', geographicArea: { '@type': 'Country', name: 'Israel' } },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['article h1', 'article .info-box', 'article > p:first-of-type'],
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'בית', item: siteUrl },
    ...breadcrumb.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: crumb.label,
      item: `${siteUrl}${crumb.href}`,
    })),
  ],
};

const schemas = schema
  ? [articleSchema, ...(Array.isArray(schema) ? schema : [schema]), breadcrumbSchema]
  : [articleSchema, breadcrumbSchema];

const fmtDate = (d?: string) =>
  d ? new Date(d).toLocaleDateString('he-IL', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
const fmtMonthYear = (d?: string) =>
  d ? new Date(d).toLocaleDateString('he-IL', { month: 'long', year: 'numeric' }) : '';
---

<BaseLayout
  {title}
  {description}
  ogType="article"
  publishedTime={publishDate}
  modifiedTime={updateDate ?? publishDate}
  articleSection={articleSection}
  schema={schemas}
>
  <Header />

  <main id="main-content" class="max-w-4xl mx-auto px-4 py-8">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-6 text-sm text-neutral-muted">
      <ol class="flex flex-wrap gap-1 items-center list-none">
        <li><a href="/" class="hover:text-brand-dark transition-colors">בית</a></li>
        {breadcrumb.map((crumb, i) => (
          <>
            <li class="text-neutral-border select-none">›</li>
            <li>
              {i === breadcrumb.length - 1
                ? <span class="text-gray-700">{crumb.label}</span>
                : <a href={crumb.href} class="hover:text-brand-dark transition-colors">{crumb.label}</a>
              }
            </li>
          </>
        ))}
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8 items-start">

      <!-- Main content -->
      <article class="prose prose-lg max-w-none rtl-prose">
        <header class="not-prose mb-8">
          <h1 class="text-3xl font-bold text-brand-dark leading-tight mb-3">{title}</h1>
          <div class="flex flex-wrap gap-4 text-sm text-neutral-muted">
            {updateDate && <span>עודכן: {fmtDate(updateDate)}</span>}
            <span>זמן קריאה: {readTime}</span>
          </div>

          <div class="mt-4 grid gap-3 rounded-xl border border-blue-200 bg-blue-50 p-4 text-sm text-gray-700">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
              <p>
                <strong class="text-blue-900">נכתב ונערך על ידי:</strong>
                <a href="/about/" class="text-brand hover:text-brand-dark transition-colors">{authorName}</a>
                <span class="text-gray-500"> — {authorTitle}</span>
              </p>
              {lastFactCheck && <p class="text-xs text-blue-800">בדיקת עובדות אחרונה: {fmtDate(lastFactCheck)}</p>}
            </div>
            {reviewerName ? (
              <p>
                <strong class="text-blue-900">נבדק מקצועית על ידי:</strong>
                {reviewerName}
                {reviewerTitle && <span class="text-gray-500"> — {reviewerTitle}</span>}
              </p>
            ) : (
              <p class="text-xs leading-relaxed text-gray-600">
                המידע נבדק מול מקורות רשמיים ומוצג כהכוונה כללית בלבד. כאשר יתווסף בודק משפטי אישי, שמו ותפקידו יוצגו כאן במפורש.
              </p>
            )}
          </div>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2 text-xs text-gray-500">
            <span class="flex items-center gap-1">
              <span>✓</span>
              <span>מבוסס על חוק ההוצאה לפועל תשכ"ז-1967, תיקון 9 (ינואר 2025) ותיקון 69 (פברואר 2022)</span>
            </span>
            {updateDate && (
              <span class="flex items-center gap-1">
                <span>⚖️</span>
                <span>עודכן לנתוני {fmtMonthYear(updateDate)}</span>
              </span>
            )}
            <a href="https://www.gov.il/he/departments/legalinfo/hotsaa_lapoal" rel="noopener noreferrer" target="_blank" class="flex items-center gap-1 text-brand hover:text-brand-dark transition-colors">
              <span>🔗</span>
              <span>מקור: רשות האכיפה והגבייה</span>
            </a>
            <a href="https://www.kolzchut.org.il/he/%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%A4%D7%95%D7%A2%D7%9C" rel="noopener noreferrer" target="_blank" class="flex items-center gap-1 text-brand hover:text-brand-dark transition-colors">
              <span>🔗</span>
              <span>כל-זכות</span>
            </a>
          </div>
          <p class="mt-4 text-lg text-gray-600 leading-relaxed">{description}</p>

          <div class="flex flex-wrap gap-2 mt-4">
            <a
              href={`https://wa.me/?text=${encodeURIComponent(title + ' — ' + canonicalUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-xs font-semibold bg-green-50 hover:bg-green-100 text-green-800 border border-green-200 px-3 py-1.5 rounded-full transition-colors"
              aria-label="שתף בוואטסאפ"
            >
              <span aria-hidden="true">💬</span> שתף בוואטסאפ
            </a>
            <a
              href="/tools/chatbot/"
              class="inline-flex items-center gap-2 text-xs font-semibold bg-brand-pale hover:bg-blue-100 text-brand-dark border border-brand-light px-3 py-1.5 rounded-full transition-colors"
            >
          …17319 tokens truncated…ראש ההוצאה לפועל, ומשם לבית משפט מחוזי. "תביעה נגד הוצאה לפועל" כגוף — אינה דרך המלך; המסלול הנכון הוא ערעור על החלטה ספציפית. אם בוצע נזק עקב פעולה רשלנית של הרשות — ניתן לפנות לבית משפט לעניינים אזרחיים, אך מדובר בהליך מורכב.' },
      { q: 'האם אפשר להשכיר דירה כשיש תיק הוצאה לפועל?', a: 'כן. תיק הוצאה לפועל פתוח אינו מונע בחוק את השכרת הדירה. עם זאת, בעלי דירות עשויים לבדוק דוח אשראי ולסרב לשכור. אם על הדירה שלך יש עיקול רישומי — ניתן להשכירה, אך לא למכור אותה ללא אישור. כדאי להיות שקוף עם השוכר/המשכיר.' },
    ]
  },
  {
    id: 'tikun9',
    icon: '📰',
    title: 'תיקון 9 וריבית — 2025',
    questions: [
      { q: 'מה זה תיקון 9 לחוק פסיקת ריבית?', a: 'תיקון 9, שנכנס לתוקף בינואר 2025, שינה את שיטת חישוב הריבית והפריד בין הריבית השקלית לבין דמי פיגורים המתווספים במועדים הקבועים בדין. השיעורים המדויקים מתפרסמים מדי רבעון על ידי החשב הכללי.' },
      { q: 'כמה ריבית משלמים עכשיו על חוב בהוצאה לפועל?', a: 'אין שיעור קבוע אחד לכל התקופות. הריבית השקלית ושיעור דמי הפיגורים מתעדכנים ומתפרסמים מדי רבעון. את הסכום המדויק יש לבדוק בפירוט התיק באזור האישי של רשות האכיפה והגבייה.' },
      { q: 'האם תיקון 9 חל על חובות ישנים שנפתחו לפני 2025?', a: 'כן. תיקון 9 חל על חובות קיימים מינואר 2025 ואילך. חישוב הריבית החדש פועל על הקרן שנותרה מינואר 2025.' },
      { q: 'האם ריבית הפיגורים יכולה לגדול?', a: 'כן. הריבית מתעדכנת בכל פעם שבנק ישראל משנה את הריבית (בדרך כלל כל 6 שבועות). כשריבית בנק ישראל עולה — גם ריבית הפיגורים עולה.' },
      { q: 'איך מחשבים כמה אני חייב לפי תיקון 9?', a: 'השתמש במחשבון הריבית שלנו — הוא עודכן לפי תיקון 9 ומחשב את הסכום המעודכן כולל ריבית ודמי פיגורים.' },
      { q: 'איך משפיע צו תשלומים על דמי הפיגורים?', a: 'חייב שעומד בצו תשלומים אינו צובר דמי פיגורים כלל — זו ההטבה המרכזית של תיקון 9. תיקון 9 גם ביטל את ריבית-הדריבית הישנה, כך שהחוב כבר לא מתנפח ללא שליטה. הרשם ובית המשפט רשאים גם להפחית דמי פיגורים בנסיבות מיוחדות.' },
      { q: 'מה זה "אגרת פתיחת תיק" ומי משלם?', a: 'אגרת פתיחת תיק היא התשלום שמשלם הנושה לרשות האכיפה בעת פתיחת תיק — בדרך כלל 1%-3% מגובה החוב (מינימום 185 ₪). לאחר ניצחון הנושה, האגרה נוספת לחוב של החייב, כלומר החייב מחזיר גם אותה. לתיקי מזונות קיימים פטורים מאגרה.' },
    ]
  },
  {
    id: 'mazamot',
    icon: '👨‍👧',
    title: 'מזונות בהוצאה לפועל',
    questions: [
      { q: 'איך גובים מזונות שלא שולמו דרך הוצאה לפועל?', a: 'מגישים בקשה לפתיחת תיק הוצאה לפועל עם פסק הדין למזונות. הרשם מוציא אזהרה לחייב, ואם לא משלם — עיקול חשבון בנק, עיקול משכורת, עיכוב יציאה מהארץ, ופסילת רישיון נהיגה.' },
      { q: 'האם מזונות מוגנים מחדלות פירעון?', a: 'כן. חוב מזונות (לילדים ולבן/בת זוג לשעבר) אינו ניתן להפטר בהליך חדלות פירעון. גם אחרי מחיקת כל החובות האחרים — חוב מזונות ממשיך לעמוד ולצבור ריבית.' },
      { q: 'מה קורה כשאב לא יכול לשלם מזונות?', a: 'ביטוח לאומי משלם לאם "גמלת מזונות" כשהאב לא משלם ותיק הוצאה לפועל פתוח. הסכום הוא הנמוך מבין פסק הדין לבין תקנות המזונות (הבטחת תשלום) לפי הרכב המשפחה, בניכוי הכנסות הזוכה — לבדיקה מדויקת יש מחשבון באתר ביטוח לאומי. לאחר מכן ביטוח לאומי גובה מהאב בעצמו.' },
      { q: 'האם ניתן לעקל 100% מהמשכורת לצורך מזונות?', a: 'בחוב מזונות ההגנה על שכר לפי חוק הגנת השכר אינה חלה, ועקרונית ניתן לעקל גם את מלוא השכר. בפועל, הרשם או בית המשפט קובעים את ההיקף לפי צורכי הילדים ויכולת החייב, תוך התחשבות בצורכי קיום בסיסיים שלו.' },
      { q: 'האם ניתן להפחית מזונות אחרי פסיקה?', a: 'כן, דרך בקשה לבית המשפט לענייני משפחה. אם הכנסתך ירדה משמעותית — ניתן לבקש עדכון סכום המזונות. עד שפסק הדין משתנה — ממשיכים לצבור חוב לפי הפסיקה המקורית.' },
      { q: 'האם עיכוב יציאה מהארץ חל אוטומטית על חייב מזונות?', a: 'כן, עיכוב יציאה מהארץ ניתן לחייבי מזונות בתנאים קלים יותר מחובות רגילים — ניתן להטיל מהר יחסית ולחדש אוטומטית. לנסיעה לחו"ל נדרש אישור בית משפט.' },
      { q: 'האם קיצבת ילדים מוגנת מעיקול?', a: 'כן לחלוטין. קיצבת ילדים מביטוח לאומי מוגנת מעיקול כחלק מכלל קצבאות ביטוח לאומי שאינן ניתנות לעיקול. גם אם הקיצבה הופקדה בחשבון הבנק — היא מוגנת, אם כי בפועל קשה לעתים להוכיח לבנק את מקורה. מומלץ לנהל חשבון נפרד לקצבאות.' },
    ]
  },
  {
    id: 'general',
    icon: '❓',
    title: 'שאלות כלליות',
    questions: [
      { q: 'כמה זמן נשאר מידע על תיק הוצאה לפועל?', a: 'מידע על תיקים פתוחים זמין כל עוד התיק פתוח. לאחר סגירת התיק, הרישום נשמר בארכיון הרשות. במערכת נתוני האשראי של בנק ישראל — מידע נכלל בדוחות הנמסרים לנותני אשראי במשך כ-3 שנים ממועד הדיווח, ולאחר מכן נשמר במאגר לצרכי תיעוד בלבד (עד 10 שנים).' },
      { q: 'האם הוצאה לפועל משפיעה על דוח אשראי?', a: 'כן. תיקים פתוחים בהוצאה לפועל מדווחים ללשכות האשראי ופוגעים בדירוג האשראי, מה שמקשה על קבלת הלוואות, משכנתאות, וחכירות. סגירת התיק משפרת את הדירוג לאורך זמן.' },
      { q: 'מה קורה אם החייב נפטר?', a: 'החובות עוברים לעיזבון — לא ליורשים אישית. אם ערך העיזבון קטן מהחובות — הנושים מקבלים לפי סדר עדיפויות. היורשים לא נושאים בחוב מכיסם אלא אם חתמו כערבים. מומלץ להתייעץ עם עורך דין בעניין הירושה.' },
      { q: 'מה קורה אם הנושה נפטר?', a: 'כשנושה נפטר, זכויות הגבייה שלו עוברות לעיזבון ומשם ליורשיו. כלומר, החוב לא "נמחק" בשל פטירת הנושה. יורשי הנושה, או מנהל העיזבון, יכולים להמשיך בהליכי הגבייה. פנה ללשכה לברר מי הגורם שממשיך לנהל את התיק.' },
      { q: 'כמה זמן נשאר עיקול על נכס לאחר סגירת תיק?', a: 'לאחר סגירת התיק (בגין תשלום מלא, הסדר, או הפטר), הנושה מחויב לפנות ללשכת ההוצאה לפועל ולרשם המקרקעין/מרשם הרכבים לביטול העיקול. ביטול אוטומטי אינו מובטח — צריך לפעול. בדרך כלל עיקול נמחק מהרישומים תוך מספר שבועות לאחר הגשת הבקשה המתאימה.' },
      { q: 'האם פנסיית שארים מוגנת מעיקול?', a: 'כן. פנסיית שארים מביטוח לאומי (קצבת שאירים) מוגנת מעיקול כחלק מקצבאות ביטוח לאומי. לעומת זאת, פנסיית שארים מקרן פנסיה פרטית — ההגנה תלויה בסוג הקרן וסוג הקצבה: קצבה חודשית מוגנת בדרך כלל, חיסכון צבור לפני היוון עלול להיות חשוף. מומלץ להתייעץ עם עורך דין.' },
    ]
  },
  {
    id: 'practical',
    icon: '🛠️',
    title: 'שאלות מעשיות',
    questions: [
      { q: 'איפה מוגישים בקשה בהוצאה לפועל?', a: 'בלשכת ההוצאה לפועל הקרובה למקום מגוריך, או דרך המערכת המקוונת של רשות האכיפה והגבייה באתר gov.il.' },
      { q: 'כמה עולה להגיש בקשה לבד?', a: 'בקשות רוב — אגרות מינימליות של כמה עשרות שקלים. בקשות מסוימות (ערעור, איחוד תיקים) עלולות לדרוש אגרה גבוהה יותר.' },
      { q: 'מה מסמכים צריך להביא לחקירת יכולת?', a: 'תלושי משכורת 3 חודשים אחרונים, דפי חשבון בנק, קבלות הוצאות קבועות (שכר דירה, חשמל, תרופות), תעודת זהות.' },
      { q: 'האם אפשר להגיש בקשות אונליין?', a: 'כן. רשות האכיפה והגבייה מאפשרת הגשת מגוון בקשות דרך אתר gov.il. לחלק מהבקשות נדרשת הגשה פיזית.' },
      { q: 'מה עושים אם לא מבין את המכתב?', a: 'פנה לרשות האכיפה לבקשת הסבר, התייעץ עם עורך דין, או השתמש בצ\'אטבוט שלנו לקבלת מידע ראשוני.' },
      { q: 'האם אפשר לשלם חוב הוצאה לפועל בכרטיס אשראי?', a: 'כן. ניתן לשלם דרך מערכת הוצאה לפועל המקוונת, בדואר, או בלשכה — בכרטיס אשראי, העברה בנקאית, או מזומן.' },
      { q: 'כמה זמן נשאר הרישום בדוח האשראי?', a: 'לפי חוק נתוני אשראי, מידע נכלל בדוחות האשראי הנמסרים לנותני אשראי במשך כ-3 שנים ממועד הדיווח, ולאחר מכן נשמר במאגר בנק ישראל לצרכי תיעוד בלבד. גם מידע על הליך חדלות פירעון והפטר מדווח למערכת ומופיע בדוחות לתקופה דומה.' },
      { q: 'האם אפשר למכור רכב שיש עליו עיקול?', a: 'לא ניתן להעביר בעלות על רכב מעוקל ברשם הרכבים ללא ביטול העיקול קודם. מכירת רכב מעוקל מהווה הפרה של צו הרשם ועלולה להיות עבירה פלילית. לפני כל עסקת רכב — בדוק עיקולים ברשם הרכבים (שרות רישוי ישראל). כדי למכור — יש לשלם את החוב ולבטל את העיקול תחילה.' },
      { q: 'האם הוצאה לפועל יכולה לעקל את הביטוח הלאומי שלי?', a: 'לא. כלל קצבאות ביטוח לאומי — קצבת זקנה, נכות, ילדים, אבטלה, שאירים, דמי לידה, גמלת סיעוד — מוגנות לחלוטין מעיקול לפי חוק הביטוח הלאומי. אם הוצאה לפועל עיקלה סכומי ביטוח לאומי — ניתן לפנות לרשם מיידית ולבקש שחרור, עם הוכחה שמקור הכסף הוא ביטוח לאומי.' },
    ]
  },
];

// FAQPage schema — נבנית אוטומטית מכל השאלות שמוצגות בעמוד (מקור אמת אחד)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: categories.flatMap(cat =>
    cat.questions.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    }))
  ),
};
---

<BaseLayout
  title="100+ שאלות ותשובות על הוצאה לפועל (2026) — מדריך מלא לחייבים"
  description="100+ שאלות נפוצות על הוצאה לפועל בישראל 2026: עיקול ובדיקת תיק, ביטול עיקול, ערבות, חדלות פירעון, ריבית תיקון 9, זכויות חייבים — תשובות קצרות וברורות."
  schema={faqSchema}
>
  <Header />
  <main id="main-content" class="max-w-4xl mx-auto px-4 py-10">

    <Breadcrumb items={[{ label: 'שאלות נפוצות' }]} />

    <h1 class="text-3xl font-bold text-brand-dark mb-2">שאלות נפוצות</h1>
    <p class="text-gray-500 mb-6">
      {categories.reduce((sum, c) => sum + c.questions.length, 0)}+ תשובות לשאלות הנפוצות ביותר על הוצאה לפועל וחדלות פירעון
    </p>

    <!-- חיפוש -->
    <div class="mb-6">
      <label for="faq-search" class="sr-only">חיפוש בשאלות ותשובות</label>
      <input
        id="faq-search"
        type="search"
        inputmode="search"
        autocomplete="off"
        placeholder="🔍 חיפוש בשאלות ותשובות…"
        class="w-full border border-neutral-border rounded-xl px-4 py-3 text-base focus:ring-2 focus:ring-brand focus:outline-none"
      />
      <p id="faq-noresults" class="hidden mt-3 text-sm text-gray-500">
        לא נמצאו תוצאות. נסה מילה אחרת, או <a href="/tools/chatbot/" class="text-brand underline">שאל את הצ'אטבוט</a>.
      </p>
    </div>

    <!-- ניווט מהיר בין קטגוריות -->
    <div class="flex flex-wrap gap-2 mb-10">
      {categories.map(cat => (
        <a
          href={`#${cat.id}`}
          class="flex items-center gap-1.5 px-3 py-1.5 bg-white border border-neutral-border rounded-full text-sm text-gray-600 hover:border-brand hover:text-brand-dark transition-all"
        >
          <span>{cat.icon}</span>
          <span>{cat.title}</span>
        </a>
      ))}
    </div>

    <!-- קטגוריות ושאלות -->
    <div class="space-y-12">
      {categories.map(cat => (
        <section id={cat.id}>
          <h2 class="text-xl font-bold text-brand-dark mb-5 flex items-center gap-2">
            <span class="text-2xl">{cat.icon}</span>
            {cat.title}
          </h2>
          <div class="space-y-3">
            {cat.questions.map(faq => (
              <details class="border border-neutral-border rounded-xl group bg-white">
                <summary class="p-4 font-semibold text-gray-800 cursor-pointer hover:bg-gray-50 rounded-xl list-none flex justify-between items-center gap-4">
                  <span>{faq.q}</span>
                  <span class="text-neutral-muted shrink-0 group-open:rotate-180 transition-transform text-lg">▼</span>
                </summary>
                <div class="px-4 pb-4 pt-1 text-gray-600 leading-relaxed border-t border-neutral-border">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-14 bg-brand-dark text-white rounded-2xl p-8 text-center">
      <h2 class="text-xl font-bold mb-2">לא מצאת תשובה?</h2>
      <p class="text-brand-light mb-6">שאל את הצ'אטבוט שלנו — עונה 24/7 על שאלות על הוצאה לפועל</p>
      <a
        href="/tools/chatbot/"
        class="inline-block bg-white text-brand-dark font-bold px-6 py-3 rounded-lg hover:bg-brand-pale transition-colors"
      >
        לצ'אטבוט ←
      </a>
    </div>

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-xl p-4 text-sm text-gray-700">
      ⚠️ המידע כאן הוא כללי בלבד ואינו מהווה ייעוץ משפטי. לייעוץ אישי בתיק שלך — פנה לעורך דין.
    </div>

  </main>

  <script>
    const input = document.getElementById('faq-search');
    const noResults = document.getElementById('faq-noresults');
    const sections = Array.from(document.querySelectorAll('main section[id]'));
    const norm = (s) => (s || '').toLowerCase();
    input?.addEventListener('input', () => {
      const q = norm(input.value.trim());
      let anyVisible = false;
      sections.forEach(sec => {
        let secVisible = false;
        sec.querySelectorAll('details').forEach(d => {
          const match = !q || norm(d.textContent).includes(q);
          d.style.display = match ? '' : 'none';
          d.open = !!(q && match);
          if (match) secVisible = true;
        });
        sec.style.display = secVisible ? '' : 'none';
        if (secVisible) anyVisible = true;
      });
      if (noResults) noResults.classList.toggle('hidden', anyVisible || !q);
    });
  </script>

  <Footer />
</BaseLayout>
