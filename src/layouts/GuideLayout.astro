---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Disclaimer from '../components/Disclaimer.astro';
import CTAForm from '../components/CTAForm.astro';

export interface Props {
  title: string;
  description: string;
  breadcrumb: { label: string; href: string }[];
  publishDate?: string;
  updateDate?: string;
  schema?: object;
  readTime?: string;
}

const {
  title,
  description,
  breadcrumb,
  publishDate,
  updateDate,
  schema,
  readTime = '5 דקות',
} = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  inLanguage: 'he',
  author: { '@type': 'Organization', name: 'הוצאהלפועל.info' },
  publisher: {
    '@type': 'Organization',
    name: 'הוצאהלפועל.info',
    url: 'https://hotzaa-lapoal.info',
  },
  datePublished: publishDate,
  dateModified: updateDate ?? publishDate,
  ...schema,
};
---

<BaseLayout {title} {description} schema={articleSchema}>
  <Header />

  <main class="max-w-4xl mx-auto px-4 py-8">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-6 text-sm text-neutral-muted">
      <ol class="flex flex-wrap gap-1 items-center list-none">
        <li><a href="/" class="hover:text-brand-dark transition-colors">בית</a></li>
        {breadcrumb.map((crumb, i) => (
          <>
            <li class="text-neutral-border select-none">›</li>
            <li>
              {i === breadcrumb.length - 1
                ? <span class="text-gray-700">{crumb.label}</span>
                : <a href={crumb.href} class="hover:text-brand-dark transition-colors">{crumb.label}</a>
              }
            </li>
          </>
        ))}
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8 items-start">

      <!-- Main content -->
      <article class="prose prose-lg max-w-none rtl-prose">
        <header class="not-prose mb-8">
          <h1 class="text-3xl font-bold text-brand-dark leading-tight mb-3">{title}</h1>
          <div class="flex flex-wrap gap-4 text-sm text-neutral-muted">
            {updateDate && <span>עודכן: {updateDate}</span>}
            <span>זמן קריאה: {readTime}</span>
          </div>
          <p class="mt-4 text-lg text-gray-600 leading-relaxed">{description}</p>
        </header>

        <slot />

        <!-- What's next block -->
        <div class="not-prose mt-10 p-6 bg-brand-pale border border-brand-light rounded-xl">
          <h3 class="text-lg font-bold text-brand-dark mb-3">מה עכשיו?</h3>
          <slot name="next-steps" />
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="lg:sticky lg:top-24 space-y-6">
        <CTAForm compact />

        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-sm">
          <p class="font-semibold text-yellow-800 mb-1">⚠️ שים לב</p>
          <p class="text-yellow-700">המידע כאן הוא כללי בלבד. לייעוץ אישי בתיק שלך — פנה לעורך דין.</p>
        </div>
      </aside>

    </div>
  </main>

  <Disclaimer />
  <Footer />
</BaseLayout>
