---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Disclaimer from '../components/Disclaimer.astro';
import CTAForm from '../components/CTAForm.astro';

export interface Props {
  title: string;
  description: string;
  breadcrumb: { label: string; href: string }[];
  publishDate?: string;
  updateDate?: string;
  schema?: object | object[];
  readTime?: string;
  relatedGuides?: { title: string; href: string }[];
}

const defaultRelatedGuides = [
  { title: 'עיקול חשבון בנק', href: '/guides/ikul-heshbon/' },
  { title: 'ביטול עיקול', href: '/guides/bitul-ikul/' },
  { title: 'עיקול משכורת', href: '/guides/ikul-maskoret/' },
  { title: 'צו תשלומים', href: '/guides/tzav-tashlumim/' },
  { title: 'פשיטת רגל (חדלות פירעון)', href: '/guides/pshitat-regel/' },
];

const {
  title,
  description,
  breadcrumb,
  publishDate,
  updateDate,
  schema,
  readTime = '5 דקות',
  relatedGuides = defaultRelatedGuides,
} = Astro.props;

const siteUrl = 'https://hotzaa-lapoal.info';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  inLanguage: 'he',
  author: { '@type': 'Organization', name: 'הוצאהלפועל.info', url: 'https://hotzaa-lapoal.info/about/' },
  publisher: {
    '@type': 'Organization',
    name: 'הוצאהלפועל.info',
    url: siteUrl,
  },
  datePublished: publishDate,
  dateModified: updateDate ?? publishDate,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'בית', item: siteUrl },
    ...breadcrumb.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: crumb.label,
      item: `${siteUrl}${crumb.href}`,
    })),
  ],
};

const schemas = schema
  ? [articleSchema, ...(Array.isArray(schema) ? schema : [schema]), breadcrumbSchema]
  : [articleSchema, breadcrumbSchema];
---

<BaseLayout {title} {description} ogType="article" schema={schemas}>
  <Header />

  <main class="max-w-4xl mx-auto px-4 py-8">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-6 text-sm text-neutral-muted">
      <ol class="flex flex-wrap gap-1 items-center list-none">
        <li><a href="/" class="hover:text-brand-dark transition-colors">בית</a></li>
        {breadcrumb.map((crumb, i) => (
          <>
            <li class="text-neutral-border select-none">›</li>
            <li>
              {i === breadcrumb.length - 1
                ? <span class="text-gray-700">{crumb.label}</span>
                : <a href={crumb.href} class="hover:text-brand-dark transition-colors">{crumb.label}</a>
              }
            </li>
          </>
        ))}
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8 items-start">

      <!-- Main content -->
      <article class="prose prose-lg max-w-none rtl-prose">
        <header class="not-prose mb-8">
          <h1 class="text-3xl font-bold text-brand-dark leading-tight mb-3">{title}</h1>
          <div class="flex flex-wrap gap-4 text-sm text-neutral-muted">
            {updateDate && <span>עודכן: {updateDate}</span>}
            <span>זמן קריאה: {readTime}</span>
          </div>
          <div class="flex items-center gap-2 mt-2 text-xs text-gray-500">
            <span>✓</span>
            <span>המידע מבוסס על חוק ההוצאה לפועל תשכ"ז-1967 ועדכוני 2025–2026</span>
          </div>
          <p class="mt-4 text-lg text-gray-600 leading-relaxed">{description}</p>
        </header>

        <!-- Table of Contents (auto-populated by client JS) -->
        <nav id="toc" class="not-prose bg-brand-pale border border-brand-light rounded-xl p-5 mb-8 hidden" aria-label="תוכן עניינים">
          <p class="font-bold text-brand-dark text-sm mb-3">תוכן עניינים</p>
          <ol id="toc-list" class="space-y-1.5 text-sm list-decimal list-inside text-gray-700"></ol>
        </nav>

        <slot />

        <slot name="next-steps" />
      </article>

      <!-- Sidebar -->
      <aside class="lg:sticky lg:top-24 space-y-6">
        <CTAForm compact />

        <!-- Related guides box -->
        <div class="bg-white border border-neutral-border rounded-xl p-4 text-sm">
          <p class="font-semibold text-gray-800 mb-3">מדריכים קשורים</p>
          <ul class="space-y-2">
            {relatedGuides.map(g => (
              <li>
                <a href={g.href} class="text-brand hover:text-brand-dark transition-colors flex items-center gap-1.5">
                  <span class="text-xs">←</span>
                  {g.title}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 text-sm">
          <p class="font-semibold text-blue-800 mb-1">ℹ️ שים לב</p>
          <p class="text-gray-700">המידע כאן הוא כללי בלבד. לייעוץ אישי בתיק שלך — פנה לעורך דין.</p>
        </div>
      </aside>

    </div>
  </main>

  <!-- Related Guides -->
  <section class="bg-gray-50 border-t border-neutral-border py-10">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-xl font-bold text-gray-800 mb-5">מדריכים קשורים</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {[
          { title: 'עיקול חשבון בנק', href: '/guides/ikul-heshbon/', icon: '🏦' },
          { title: 'ביטול עיקול', href: '/guides/bitul-ikul/', icon: '✅' },
          { title: 'עיקול משכורת', href: '/guides/ikul-maskoret/', icon: '💼' },
          { title: 'צו תשלומים', href: '/guides/tzav-tashlumim/', icon: '📋' },
          { title: 'פשיטת רגל', href: '/guides/pshitat-regel/', icon: '⚖️' },
          { title: 'מזונות בהוצאה לפועל', href: '/guides/mazamot/', icon: '👨‍👧' },
          { title: 'עיכוב יציאה מהארץ', href: '/guides/ikul-yetzia/', icon: '✈️' },
          { title: 'איחוד תיקים', href: '/guides/ichud-tikim/', icon: '📂' },
          { title: 'עיקול רכב', href: '/guides/ikul-rechev/', icon: '🚗' },
          { title: 'כינוס נכסים', href: '/guides/kinnus-nechasim/', icon: '🏛️' },
          { title: 'ערב בהוצאה לפועל', href: '/guides/arev/', icon: '🤝' },
          { title: 'התיישנות חוב', href: '/guides/hitiyashnoot-chov/', icon: '⏰' },
          { title: 'סגירת תיק הוצאה לפועל', href: '/guides/sgor-tik/', icon: '🔒' },
          { title: 'עיקול פנסיה וקצבאות', href: '/guides/ikul-pensiya/', icon: '🏛️' },
          { title: 'עיקול דירה ומקרקעין', href: '/guides/ikul-dira/', icon: '🏠' },
          { title: 'הסדר חוב עם נושים', href: '/guides/hisdurim-chov/', icon: '🤝' },
          { title: 'בדיקת תיק הוצאה לפועל', href: '/guides/bdika-tik/', icon: '🔍' },
          { title: 'ריבית בהוצאה לפועל', href: '/guides/ribit-hotzaa/', icon: '📈' },
          { title: 'ביטול הגבלות', href: '/guides/bitul-hagbalot/', icon: '🔓' },
          { title: 'עיקול זמני', href: '/guides/ikul-zman/', icon: '⏱️' },
          { title: 'ערעור על הוצאה לפועל', href: '/guides/irur-hotzaa/', icon: '⚖️' },
          { title: 'לשכת הוצאה לפועל', href: '/guides/lishkat-hotzaa/', icon: '🏛️' },
          { title: 'פסק דין בהוצאה לפועל', href: '/guides/psak-din/', icon: '📄' },
          { title: 'עורך דין הוצאה לפועל', href: '/guides/orech-din/', icon: '👨‍⚖️' },
          { title: 'כל המדריכים', href: '/guides/', icon: '→' },
        ].map(g => (
          <a href={g.href} class="flex items-center gap-3 p-3 bg-white border border-neutral-border rounded-xl hover:border-brand hover:bg-brand-pale transition-all text-sm font-medium text-gray-700 hover:text-brand-dark">
            <span class="text-xl">{g.icon}</span>
            {g.title}
          </a>
        ))}
      </div>
    </div>
  </section>

  <Disclaimer />
  <Footer />

  <script>
    const article = document.querySelector('article');
    const toc = document.getElementById('toc');
    const tocList = document.getElementById('toc-list');
    if (article && toc && tocList) {
      const headings = article.querySelectorAll('h2');
      if (headings.length >= 3) {
        headings.forEach((h, i) => {
          const id = h.id || `section-${i + 1}`;
          h.id = id;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `#${id}`;
          a.textContent = h.textContent;
          a.className = 'hover:text-brand-dark transition-colors';
          li.appendChild(a);
          tocList.appendChild(li);
        });
        toc.classList.remove('hidden');
      }
    }
  </script>
</BaseLayout>
